{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "https://win11forge.local/schemas/download-sources.schema.json",
  "title": "Win11Forge Download Sources",
  "description": "Schema for Win11Forge external download sources and trusted domains configuration (Config/download-sources.json)",
  "type": "object",
  "required": ["prerequisites", "trustedDomains", "directDownloads", "packageManagers"],
  "additionalProperties": false,
  "properties": {
    "_meta": {
      "$ref": "#/$defs/Meta"
    },
    "prerequisites": {
      "type": "object",
      "description": "Prerequisite software required by the framework",
      "additionalProperties": {
        "$ref": "#/$defs/Prerequisite"
      }
    },
    "trustedDomains": {
      "type": "object",
      "description": "Whitelist of trusted domains for direct downloads",
      "required": ["domains"],
      "additionalProperties": false,
      "properties": {
        "description": {
          "type": "string"
        },
        "domains": {
          "type": "array",
          "description": "List of trusted domain names",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 253,
            "pattern": "^[a-zA-Z0-9][a-zA-Z0-9.-]*\\.[a-zA-Z]{2,}$"
          },
          "uniqueItems": true,
          "minItems": 1
        }
      }
    },
    "directDownloads": {
      "type": "object",
      "description": "Pre-configured direct download URLs for applications not available via package managers",
      "required": ["applications"],
      "additionalProperties": false,
      "properties": {
        "description": {
          "type": "string"
        },
        "applications": {
          "type": "object",
          "description": "Map of application name to download configuration",
          "additionalProperties": {
            "$ref": "#/$defs/DirectDownload"
          }
        }
      }
    },
    "packageManagers": {
      "type": "object",
      "description": "Package manager source configurations",
      "additionalProperties": {
        "$ref": "#/$defs/PackageManager"
      }
    },
    "apiEndpoints": {
      "type": "object",
      "description": "External API base URLs used by the framework",
      "properties": {
        "description": {
          "type": "string"
        }
      },
      "additionalProperties": {
        "oneOf": [
          { "$ref": "#/$defs/ApiEndpoint" },
          { "type": "string" }
        ]
      }
    },
    "cache": {
      "type": "object",
      "description": "Cache settings for package manager operations",
      "properties": {
        "description": {
          "type": "string"
        }
      },
      "additionalProperties": {
        "oneOf": [
          { "$ref": "#/$defs/CacheConfig" },
          { "type": "string" }
        ]
      }
    }
  },
  "$defs": {
    "Meta": {
      "type": "object",
      "description": "Metadata about the configuration file",
      "properties": {
        "description": { "type": "string" },
        "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
        "author": { "type": "string" },
        "lastUpdated": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
      }
    },
    "Prerequisite": {
      "type": "object",
      "description": "Prerequisite software definition",
      "required": ["description"],
      "properties": {
        "description": {
          "type": "string",
          "description": "Human-readable description of the prerequisite",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "description": "Version of the prerequisite"
        },
        "downloadUrl": {
          "type": "string",
          "description": "URL to download the prerequisite",
          "format": "uri"
        },
        "homepage": {
          "type": "string",
          "description": "Homepage URL of the prerequisite",
          "format": "uri"
        },
        "verifyUrl": {
          "type": "string",
          "description": "URL to verify the prerequisite source",
          "format": "uri"
        },
        "checksumUrl": {
          "type": "string",
          "description": "URL to download checksum file",
          "format": "uri"
        },
        "sha256": {
          "type": "string",
          "description": "SHA256 checksum of the download",
          "pattern": "^[A-Fa-f0-9]{64}$"
        },
        "wingetId": {
          "type": "string",
          "description": "Winget package identifier"
        },
        "notes": {
          "type": "string",
          "description": "Additional notes about the prerequisite"
        }
      }
    },
    "DirectDownload": {
      "type": "object",
      "description": "Direct download configuration for an application",
      "required": ["url"],
      "additionalProperties": false,
      "properties": {
        "url": {
          "type": "string",
          "description": "Download URL for the application installer",
          "format": "uri"
        },
        "silentArgs": {
          "type": "string",
          "description": "Command-line arguments for silent installation"
        },
        "pattern": {
          "type": "string",
          "description": "Filename pattern to match when URL points to a directory listing"
        },
        "sha256": {
          "type": "string",
          "description": "SHA256 checksum or SKIP_VALIDATION to bypass checksum verification"
        },
        "notes": {
          "type": "string",
          "description": "Additional notes about the download source"
        }
      }
    },
    "PackageManager": {
      "type": "object",
      "description": "Package manager source definition",
      "required": ["source"],
      "properties": {
        "source": {
          "type": "string",
          "description": "Package manager source identifier",
          "minLength": 1
        },
        "repositoryUrl": {
          "type": "string",
          "description": "URL of the package repository",
          "format": "uri"
        },
        "searchUrl": {
          "type": "string",
          "description": "URL for searching packages",
          "format": "uri"
        },
        "notes": {
          "type": "string",
          "description": "Additional notes about the package manager"
        }
      }
    },
    "ApiEndpoint": {
      "type": "object",
      "description": "External API endpoint configuration",
      "required": ["baseUrl"],
      "properties": {
        "baseUrl": {
          "type": "string",
          "description": "Base URL of the API",
          "format": "uri"
        },
        "description": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "CacheConfig": {
      "type": "object",
      "description": "Cache configuration for a package manager",
      "properties": {
        "listTTLMinutes": {
          "type": "integer",
          "description": "Time-to-live in minutes for list cache entries",
          "minimum": 1,
          "maximum": 1440
        },
        "searchTTLMinutes": {
          "type": "integer",
          "description": "Time-to-live in minutes for search cache entries",
          "minimum": 1,
          "maximum": 1440
        },
        "maxEntries": {
          "type": "integer",
          "description": "Maximum number of cache entries",
          "minimum": 1,
          "maximum": 10000
        },
        "enabled": {
          "type": "boolean",
          "description": "Whether caching is enabled"
        },
        "persistToDisk": {
          "type": "boolean",
          "description": "Whether to persist cache to disk"
        }
      }
    }
  }
}
