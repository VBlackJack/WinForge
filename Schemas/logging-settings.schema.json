{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "https://win11forge.local/schemas/logging-settings.schema.json",
  "title": "Win11Forge Logging Settings",
  "description": "Schema for Win11Forge logging system configuration (Config/logging-settings.json)",
  "type": "object",
  "required": ["textLogging", "jsonLogging", "piiRedaction", "categories", "levelColors"],
  "additionalProperties": false,
  "properties": {
    "_meta": {
      "$ref": "#/$defs/Meta"
    },
    "textLogging": {
      "type": "object",
      "description": "Plain text log file settings",
      "required": ["enabled", "retentionDays"],
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Whether text logging is enabled"
        },
        "retentionDays": {
          "type": "integer",
          "description": "Number of days to retain text log files",
          "minimum": 1,
          "maximum": 365
        }
      }
    },
    "jsonLogging": {
      "type": "object",
      "description": "JSON structured logging settings",
      "required": ["enabled", "retentionDays", "directory", "bufferSize", "prettyPrint"],
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Whether JSON structured logging is enabled"
        },
        "retentionDays": {
          "type": "integer",
          "description": "Number of days to retain JSON log files",
          "minimum": 1,
          "maximum": 365
        },
        "directory": {
          "type": "string",
          "description": "Directory path for JSON log files (supports environment variable expansion)",
          "minLength": 1,
          "maxLength": 260
        },
        "bufferSize": {
          "type": "integer",
          "description": "Number of log entries to buffer before flushing to disk",
          "minimum": 1,
          "maximum": 1000
        },
        "prettyPrint": {
          "type": "boolean",
          "description": "Whether to format JSON output with indentation"
        }
      }
    },
    "piiRedaction": {
      "type": "object",
      "description": "Personally identifiable information (PII) redaction settings",
      "required": ["enabled", "redactPatterns"],
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Whether PII redaction is enabled"
        },
        "notes": {
          "type": "string",
          "description": "Additional notes about the PII redaction policy"
        },
        "policy": {
          "type": "object",
          "description": "Human-readable redaction policy descriptions",
          "additionalProperties": {
            "type": "string"
          }
        },
        "redactPatterns": {
          "type": "array",
          "description": "List of regex patterns to detect and redact sensitive data",
          "items": {
            "$ref": "#/$defs/RedactPattern"
          },
          "minItems": 1
        },
        "excludeCategories": {
          "type": "array",
          "description": "Log categories excluded from PII redaction",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      }
    },
    "categories": {
      "type": "array",
      "description": "Available log categories",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 64
      },
      "uniqueItems": true,
      "minItems": 1
    },
    "levelColors": {
      "type": "object",
      "description": "Console color mapping for each log level",
      "required": ["Info", "Success", "Warning", "Error"],
      "additionalProperties": false,
      "properties": {
        "Info": {
          "$ref": "#/$defs/ConsoleColor"
        },
        "Success": {
          "$ref": "#/$defs/ConsoleColor"
        },
        "Warning": {
          "$ref": "#/$defs/ConsoleColor"
        },
        "Error": {
          "$ref": "#/$defs/ConsoleColor"
        },
        "Debug": {
          "$ref": "#/$defs/ConsoleColor"
        },
        "Verbose": {
          "$ref": "#/$defs/ConsoleColor"
        }
      }
    }
  },
  "$defs": {
    "Meta": {
      "type": "object",
      "description": "Metadata about the configuration file",
      "properties": {
        "description": { "type": "string" },
        "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
        "author": { "type": "string" },
        "lastUpdated": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
      }
    },
    "RedactPattern": {
      "type": "object",
      "description": "Pattern definition for PII redaction",
      "required": ["name", "pattern", "replacement"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Identifier for the redaction pattern",
          "minLength": 1,
          "maxLength": 64
        },
        "pattern": {
          "type": "string",
          "description": "Regular expression pattern to match sensitive data",
          "minLength": 1
        },
        "replacement": {
          "type": "string",
          "description": "Replacement string for matched sensitive data",
          "minLength": 1
        },
        "applyOnExport": {
          "type": "boolean",
          "description": "Whether this pattern is only applied on log export (not during live logging)"
        }
      }
    },
    "ConsoleColor": {
      "type": "string",
      "description": "PowerShell console color name",
      "enum": [
        "Black",
        "DarkBlue",
        "DarkGreen",
        "DarkCyan",
        "DarkRed",
        "DarkMagenta",
        "DarkYellow",
        "Gray",
        "DarkGray",
        "Blue",
        "Green",
        "Cyan",
        "Red",
        "Magenta",
        "Yellow",
        "White"
      ]
    }
  }
}
