{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "https://win11forge.local/schemas/api-settings.schema.json",
  "title": "Win11Forge API Settings",
  "description": "Schema for Win11Forge REST API server configuration",
  "type": "object",
  "required": ["port", "host"],
  "additionalProperties": true,
  "properties": {
    "_meta": {
      "type": "object",
      "description": "Metadata about the configuration file",
      "properties": {
        "description": { "type": "string" },
        "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
        "author": { "type": "string" },
        "lastUpdated": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
      }
    },
    "port": {
      "type": "integer",
      "description": "Port number for the API server",
      "minimum": 1,
      "maximum": 65535,
      "default": 5170
    },
    "host": {
      "type": "string",
      "description": "Host address for the API server",
      "default": "localhost",
      "minLength": 1,
      "maxLength": 255
    },
    "requestTimeoutMs": {
      "type": "integer",
      "description": "Request timeout in milliseconds",
      "minimum": 1000,
      "maximum": 600000,
      "default": 30000
    },
    "maxConcurrentRequests": {
      "type": "integer",
      "description": "Maximum number of concurrent requests",
      "minimum": 1,
      "maximum": 100,
      "default": 10
    },
    "enableCors": {
      "type": "boolean",
      "description": "Whether to enable CORS",
      "default": false
    },
    "logRequests": {
      "type": "boolean",
      "description": "Whether to log API requests",
      "default": true
    },
    "endpoints": {
      "type": "object",
      "description": "Endpoint configuration",
      "properties": {
        "enabled": {
          "type": "array",
          "description": "List of enabled API endpoints",
          "items": {
            "type": "string",
            "pattern": "^/api/.*$"
          },
          "uniqueItems": true
        }
      }
    },
    "security": {
      "type": "object",
      "description": "Security configuration",
      "properties": {
        "localhostOnly": {
          "type": "boolean",
          "description": "Restrict access to localhost only",
          "default": true
        },
        "requireAuthentication": {
          "type": "boolean",
          "description": "Require authentication for API access",
          "default": true
        },
        "authenticationMethod": {
          "type": "string",
          "description": "Authentication method",
          "enum": ["apiKey", "none"],
          "default": "apiKey"
        },
        "apiKeyHeader": {
          "type": "string",
          "description": "HTTP header name for API key",
          "default": "X-API-Key",
          "minLength": 1,
          "maxLength": 64
        },
        "csrf": {
          "type": "object",
          "description": "CSRF protection configuration",
          "properties": {
            "enabled": {
              "type": "boolean",
              "description": "Whether CSRF protection is enabled",
              "default": true
            },
            "tokenHeader": {
              "type": "string",
              "description": "HTTP header name for CSRF token",
              "default": "X-CSRF-Token",
              "minLength": 1,
              "maxLength": 64
            },
            "tokenTtlMinutes": {
              "type": "integer",
              "description": "CSRF token time-to-live in minutes",
              "minimum": 1,
              "maximum": 1440,
              "default": 60
            },
            "description": {
              "type": "string",
              "description": "Human-readable description of CSRF configuration"
            }
          }
        },
        "rateLimiting": {
          "type": "object",
          "description": "Rate limiting configuration",
          "properties": {
            "enabled": {
              "type": "boolean",
              "description": "Whether rate limiting is enabled",
              "default": true
            },
            "maxRequestsPerMinute": {
              "type": "integer",
              "description": "Maximum requests per minute",
              "minimum": 1,
              "maximum": 10000,
              "default": 60
            },
            "maxRequestsPerHour": {
              "type": "integer",
              "description": "Maximum requests per hour",
              "minimum": 1,
              "maximum": 100000,
              "default": 1000
            },
            "maxFailedAuthPerHour": {
              "type": "integer",
              "description": "Maximum failed authentication attempts per hour",
              "minimum": 1,
              "maximum": 100,
              "default": 10
            },
            "blockDurationMinutes": {
              "type": "integer",
              "description": "Duration to block after exceeding limits (minutes)",
              "minimum": 1,
              "maximum": 1440,
              "default": 60
            }
          }
        },
        "notes": {
          "type": "string",
          "description": "Additional security notes"
        }
      }
    },
    "apiKeys": {
      "type": "object",
      "description": "API key configuration",
      "properties": {
        "description": {
          "type": "string",
          "description": "Description of API key usage"
        },
        "securityWarning": {
          "type": "string",
          "description": "Security warning about API keys"
        },
        "keys": {
          "type": "array",
          "description": "List of API keys",
          "items": {
            "$ref": "#/$defs/ApiKey"
          }
        },
        "publicEndpoints": {
          "type": "array",
          "description": "Endpoints that don't require authentication",
          "items": {
            "type": "string",
            "pattern": "^/api/.*$"
          },
          "uniqueItems": true
        }
      }
    }
  },
  "$defs": {
    "ApiKey": {
      "type": "object",
      "description": "API key definition",
      "required": ["id", "key", "permissions", "enabled"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the key",
          "minLength": 1,
          "maxLength": 64
        },
        "key": {
          "type": "string",
          "description": "The API key value (must be 32+ characters for security)",
          "minLength": 32,
          "maxLength": 256
        },
        "description": {
          "type": "string",
          "description": "Description of the key's purpose",
          "maxLength": 256
        },
        "permissions": {
          "type": "array",
          "description": "Permissions granted to this key",
          "items": {
            "type": "string",
            "enum": ["read", "write", "admin"]
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "enabled": {
          "type": "boolean",
          "description": "Whether the key is active"
        },
        "createdAt": {
          "type": "string",
          "description": "Date the key was created",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "expiresAt": {
          "oneOf": [
            { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
            { "type": "null" }
          ],
          "description": "Expiration date (null for no expiration)"
        }
      }
    }
  }
}
