<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                    xmlns:po="http://schemas.microsoft.com/winfx/2006/xaml/presentation/options">

    <!-- High Contrast Color Palette (WCAG AAA compliant - 7:1 minimum contrast) -->
    <!-- All brushes are frozen for improved performance and thread safety -->

    <!-- Primary Colors - High contrast yellow on black -->
    <SolidColorBrush x:Key="HighContrastPrimaryBrush" Color="#FFFF00" po:Freeze="True"/>
    <SolidColorBrush x:Key="HighContrastPrimaryForegroundBrush" Color="#000000" po:Freeze="True"/>

    <!-- Secondary Colors - High contrast cyan -->
    <SolidColorBrush x:Key="HighContrastSecondaryBrush" Color="#00FFFF" po:Freeze="True"/>
    <SolidColorBrush x:Key="HighContrastSecondaryForegroundBrush" Color="#000000" po:Freeze="True"/>

    <!-- Background Colors -->
    <SolidColorBrush x:Key="HighContrastBackgroundBrush" Color="#000000" po:Freeze="True"/>
    <SolidColorBrush x:Key="HighContrastSurfaceBrush" Color="#1A1A1A" po:Freeze="True"/>
    <SolidColorBrush x:Key="HighContrastCardBrush" Color="#262626" po:Freeze="True"/>

    <!-- Text Colors -->
    <SolidColorBrush x:Key="HighContrastTextPrimaryBrush" Color="#FFFFFF" po:Freeze="True"/>
    <SolidColorBrush x:Key="HighContrastTextSecondaryBrush" Color="#E0E0E0" po:Freeze="True"/>
    <SolidColorBrush x:Key="HighContrastTextDisabledBrush" Color="#808080" po:Freeze="True"/>

    <!-- Status Colors - High visibility -->
    <SolidColorBrush x:Key="HighContrastSuccessBrush" Color="#00FF00" po:Freeze="True"/>
    <SolidColorBrush x:Key="HighContrastSuccessBackgroundBrush" Color="#003300" po:Freeze="True"/>
    <SolidColorBrush x:Key="HighContrastErrorBrush" Color="#FF0000" po:Freeze="True"/>
    <SolidColorBrush x:Key="HighContrastErrorBackgroundBrush" Color="#330000" po:Freeze="True"/>
    <SolidColorBrush x:Key="HighContrastWarningBrush" Color="#FFFF00" po:Freeze="True"/>
    <SolidColorBrush x:Key="HighContrastWarningBackgroundBrush" Color="#333300" po:Freeze="True"/>
    <SolidColorBrush x:Key="HighContrastInfoBrush" Color="#00FFFF" po:Freeze="True"/>
    <SolidColorBrush x:Key="HighContrastInfoBackgroundBrush" Color="#003333" po:Freeze="True"/>

    <!-- Border Colors -->
    <SolidColorBrush x:Key="HighContrastBorderBrush" Color="#FFFFFF" po:Freeze="True"/>
    <SolidColorBrush x:Key="HighContrastBorderLightBrush" Color="#666666" po:Freeze="True"/>
    <SolidColorBrush x:Key="HighContrastFocusBorderBrush" Color="#FFFF00" po:Freeze="True"/>

    <!-- Link Colors -->
    <SolidColorBrush x:Key="HighContrastLinkBrush" Color="#00FFFF" po:Freeze="True"/>
    <SolidColorBrush x:Key="HighContrastLinkHoverBrush" Color="#FFFFFF" po:Freeze="True"/>
    <SolidColorBrush x:Key="HighContrastLinkVisitedBrush" Color="#FF00FF" po:Freeze="True"/>

    <!-- Selection Colors -->
    <SolidColorBrush x:Key="HighContrastSelectionBrush" Color="#FFFF00" po:Freeze="True"/>
    <SolidColorBrush x:Key="HighContrastSelectionForegroundBrush" Color="#000000" po:Freeze="True"/>

    <!-- High Contrast Focus Visual Style (extra thick border) -->
    <Style x:Key="HighContrastFocusVisual">
        <Setter Property="Control.Template">
            <Setter.Value>
                <ControlTemplate>
                    <Border BorderBrush="{DynamicResource HighContrastFocusBorderBrush}"
                            BorderThickness="3"
                            CornerRadius="2"
                            Margin="-3"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- High Contrast Button Style -->
    <Style x:Key="HighContrastButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Background" Value="{DynamicResource HighContrastPrimaryBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource HighContrastPrimaryForegroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource HighContrastBorderBrush}"/>
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="FocusVisualStyle" Value="{StaticResource HighContrastFocusVisual}"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource HighContrastSecondaryBrush}"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Background" Value="{DynamicResource HighContrastBorderLightBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource HighContrastTextDisabledBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Bind high contrast styling to WPF-UI buttons while this dictionary is merged. -->
    <Style TargetType="{x:Type ui:Button}" BasedOn="{StaticResource HighContrastButtonStyle}"/>

    <!-- High Contrast Outlined Button Style -->
    <Style x:Key="HighContrastOutlinedButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Foreground" Value="{DynamicResource HighContrastPrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource HighContrastPrimaryBrush}"/>
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="FocusVisualStyle" Value="{StaticResource HighContrastFocusVisual}"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource HighContrastSurfaceBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- High Contrast TextBox Style -->
    <Style x:Key="HighContrastTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
        <Setter Property="Background" Value="{DynamicResource HighContrastSurfaceBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource HighContrastTextPrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource HighContrastBorderBrush}"/>
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="CaretBrush" Value="{DynamicResource HighContrastPrimaryBrush}"/>
        <Setter Property="FocusVisualStyle" Value="{StaticResource HighContrastFocusVisual}"/>
    </Style>

    <!-- High Contrast CheckBox Style -->
    <Style x:Key="HighContrastCheckBoxStyle" TargetType="CheckBox" BasedOn="{StaticResource {x:Type CheckBox}}">
        <Setter Property="Foreground" Value="{DynamicResource HighContrastTextPrimaryBrush}"/>
        <Setter Property="FocusVisualStyle" Value="{StaticResource HighContrastFocusVisual}"/>
        <Setter Property="FontWeight" Value="Medium"/>
    </Style>

    <!-- High Contrast ListBoxItem Style -->
    <Style x:Key="HighContrastListBoxItemStyle" TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
        <Setter Property="Foreground" Value="{DynamicResource HighContrastTextPrimaryBrush}"/>
        <Setter Property="FocusVisualStyle" Value="{StaticResource HighContrastFocusVisual}"/>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{DynamicResource HighContrastSelectionBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource HighContrastSelectionForegroundBrush}"/>
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource HighContrastSurfaceBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- High Contrast Card Style -->
    <Style x:Key="HighContrastCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource HighContrastCardBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource HighContrastBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <!-- High Contrast Progress Bar Style -->
    <Style x:Key="HighContrastProgressBarStyle" TargetType="ProgressBar" BasedOn="{StaticResource {x:Type ProgressBar}}">
        <Setter Property="Foreground" Value="{DynamicResource HighContrastPrimaryBrush}"/>
        <Setter Property="Background" Value="{DynamicResource HighContrastSurfaceBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource HighContrastBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <!-- High Contrast DataGrid Style -->
    <Style x:Key="HighContrastDataGridStyle" TargetType="DataGrid" BasedOn="{StaticResource {x:Type DataGrid}}">
        <Setter Property="Background" Value="{DynamicResource HighContrastBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource HighContrastTextPrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource HighContrastBorderBrush}"/>
        <Setter Property="GridLinesVisibility" Value="All"/>
        <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource HighContrastBorderLightBrush}"/>
        <Setter Property="VerticalGridLinesBrush" Value="{DynamicResource HighContrastBorderLightBrush}"/>
    </Style>

    <!-- High Contrast Severity Indicator Styles -->
    <Style x:Key="HighContrastSeverityCriticalStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource HighContrastErrorBackgroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource HighContrastErrorBrush}"/>
        <Setter Property="BorderThickness" Value="3"/>
    </Style>

    <Style x:Key="HighContrastSeverityWarningStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource HighContrastWarningBackgroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource HighContrastWarningBrush}"/>
        <Setter Property="BorderThickness" Value="2"/>
    </Style>

    <Style x:Key="HighContrastSeverityInfoStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource HighContrastInfoBackgroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource HighContrastInfoBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <Style x:Key="HighContrastSeveritySuccessStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource HighContrastSuccessBackgroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource HighContrastSuccessBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

</ResourceDictionary>
