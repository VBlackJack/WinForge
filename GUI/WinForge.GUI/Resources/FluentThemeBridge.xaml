<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- App-specific status color brushes -->
    <!-- These are custom application colors, not framework-dependent -->

    <!-- Status Colors (ThemeForge dark fallback) -->
    <SolidColorBrush x:Key="StatusPendingBrush" Color="#B3BBD6" Opacity="0.65"/>
    <SolidColorBrush x:Key="StatusInstallingBrush" Color="#8BE9FD"/>
    <SolidColorBrush x:Key="StatusInstalledBrush" Color="#50FA7B"/>
    <SolidColorBrush x:Key="StatusFailedBrush" Color="#FF5555"/>
    <SolidColorBrush x:Key="StatusSkippedBrush" Color="#FFB86C"/>
    <SolidColorBrush x:Key="StatusAlreadyInstalledBrush" Color="#50FA7B" Opacity="0.75"/>
    <SolidColorBrush x:Key="StatusUninstallingBrush" Color="#BD93F9"/>
    <SolidColorBrush x:Key="StatusUninstalledBrush" Color="#B3BBD6" Opacity="0.65"/>
    <SolidColorBrush x:Key="StatusSuccessBrush" Color="#50FA7B"/>

    <!-- Row Background Colors (semi-transparent for overlay on theme background) -->
    <SolidColorBrush x:Key="RowInstalledBackground" Color="#50FA7B" Opacity="0.12"/>
    <SolidColorBrush x:Key="RowFailedBackground" Color="#FF5555" Opacity="0.12"/>
    <SolidColorBrush x:Key="RowInstallingBackground" Color="#8BE9FD" Opacity="0.12"/>
    <SolidColorBrush x:Key="RowUninstalledBackground" Color="#B3BBD6" Opacity="0.12"/>
    <SolidColorBrush x:Key="RowUpdateAvailableBackground" Color="#FFB86C" Opacity="0.16"/>

    <!-- Primary/Secondary Hue Brushes (main accent colors, swapped by theme) -->
    <SolidColorBrush x:Key="PrimaryHueMidBrush" Color="#BD93F9"/>
    <SolidColorBrush x:Key="SecondaryHueMidBrush" Color="#8BE9FD"/>
    <SolidColorBrush x:Key="DataGridSelectedRowBackgroundBrush" Color="#40BD93F9"/>

    <!-- Accent Colors -->
    <SolidColorBrush x:Key="FavoriteActiveBrush" Color="#FFB86C"/>
    <SolidColorBrush x:Key="FavoriteInactiveBrush" Color="#B3BBD6" Opacity="0.65"/>
    <SolidColorBrush x:Key="FavoriteTextBrush" Color="#FFB86C"/>
    <SolidColorBrush x:Key="RequiredBrush" Color="#FFB86C"/>
    <SolidColorBrush x:Key="OptionalBrush" Color="#B3BBD6" Opacity="0.65"/>
    <SolidColorBrush x:Key="AccentGreenTextBrush" Color="#50FA7B"/>
    <SolidColorBrush x:Key="AccentOrangeTextBrush" Color="#FFB86C"/>
    <SolidColorBrush x:Key="ManualInstallBadgeBrush" Color="#FFB86C"/>

    <!-- Secondary/Muted Icon Colors -->
    <SolidColorBrush x:Key="IconSecondaryBrush" Color="#B3BBD6"/>
    <SolidColorBrush x:Key="IconHintBrush" Color="#B3BBD6" Opacity="0.65"/>
    <SolidColorBrush x:Key="IconDisabledBrush" Color="#B3BBD6" Opacity="0.65"/>
    <SolidColorBrush x:Key="SubtleDataGridLineBrush" Color="#44475A" Opacity="0.35"/>

    <!-- Error Display Colors -->
    <SolidColorBrush x:Key="ErrorBackgroundBrush" Color="#FF5555" Opacity="0.14"/>
    <SolidColorBrush x:Key="ErrorBorderBrush" Color="#FF5555"/>
    <SolidColorBrush x:Key="ErrorTextBrush" Color="#FF5555"/>
    <SolidColorBrush x:Key="ErrorIconBrush" Color="#FF5555"/>

    <!-- Validation Colors -->
    <SolidColorBrush x:Key="ValidationErrorBorderBrush" Color="#FF5555"/>
    <SolidColorBrush x:Key="ValidationSuccessBorderBrush" Color="#50FA7B"/>

    <!-- Warning Display Colors -->
    <SolidColorBrush x:Key="WarningBackgroundBrush" Color="#FFB86C" Opacity="0.16"/>
    <SolidColorBrush x:Key="WarningBorderBrush" Color="#FFB86C"/>
    <SolidColorBrush x:Key="WarningTextBrush" Color="#FFB86C"/>
    <SolidColorBrush x:Key="WarningIconBrush" Color="#FFB86C"/>

    <!-- Success Display Colors -->
    <SolidColorBrush x:Key="SuccessBackgroundBrush" Color="#50FA7B" Opacity="0.12"/>
    <SolidColorBrush x:Key="SuccessBorderBrush" Color="#50FA7B"/>
    <SolidColorBrush x:Key="SuccessTextBrush" Color="#50FA7B"/>
    <SolidColorBrush x:Key="SuccessIconBrush" Color="#50FA7B"/>

    <!-- Skeleton Loader Colors -->
    <SolidColorBrush x:Key="SkeletonBaseBrush" Color="#282A36"/>
    <SolidColorBrush x:Key="SkeletonHighlightBrush" Color="#44475A"/>

    <!-- Badge Foreground Brushes (for text on colored badge backgrounds) -->
    <!-- Overwritten by ThemeService at runtime for light/dark adaptation -->
    <SolidColorBrush x:Key="BadgePrimaryForegroundBrush" Color="#282A36"/>
    <SolidColorBrush x:Key="BadgeSecondaryForegroundBrush" Color="#282A36"/>

    <!-- Legacy light-theme semantic aliases (ThemeForge dark fallback values) -->
    <SolidColorBrush x:Key="ErrorTextLightBrush" Color="#FF5555"/>
    <SolidColorBrush x:Key="ErrorIconLightBrush" Color="#FF5555"/>
    <SolidColorBrush x:Key="ErrorBorderLightBrush" Color="#FF5555"/>
    <SolidColorBrush x:Key="ErrorBackgroundLightBrush" Color="#FF5555" Opacity="0.14"/>
    <SolidColorBrush x:Key="WarningTextLightBrush" Color="#FFB86C"/>
    <SolidColorBrush x:Key="WarningIconLightBrush" Color="#FFB86C"/>
    <SolidColorBrush x:Key="WarningBorderLightBrush" Color="#FFB86C"/>
    <SolidColorBrush x:Key="WarningBackgroundLightBrush" Color="#FFB86C" Opacity="0.16"/>
    <SolidColorBrush x:Key="SuccessTextLightBrush" Color="#50FA7B"/>
    <SolidColorBrush x:Key="SuccessIconLightBrush" Color="#50FA7B"/>
    <SolidColorBrush x:Key="SuccessBorderLightBrush" Color="#50FA7B"/>
    <SolidColorBrush x:Key="SuccessBackgroundLightBrush" Color="#50FA7B" Opacity="0.12"/>

    <!-- Legacy light-theme accent text aliases (ThemeForge dark fallback values) -->
    <SolidColorBrush x:Key="AccentGreenTextLightBrush" Color="#50FA7B"/>
    <SolidColorBrush x:Key="AccentOrangeTextLightBrush" Color="#FFB86C"/>

    <!-- Legacy light-theme hue aliases (ThemeForge dark fallback values) -->
    <SolidColorBrush x:Key="PrimaryHueMidLightBrush" Color="#BD93F9"/>
    <SolidColorBrush x:Key="SecondaryHueMidLightBrush" Color="#8BE9FD"/>

    <!-- Legacy light-theme accent aliases (ThemeForge dark fallback values) -->
    <SolidColorBrush x:Key="FavoriteActiveLightBrush" Color="#FFB86C"/>
    <SolidColorBrush x:Key="FavoriteTextLightBrush" Color="#FFB86C"/>
    <SolidColorBrush x:Key="RequiredLightBrush" Color="#FFB86C"/>
    <SolidColorBrush x:Key="ManualInstallBadgeLightBrush" Color="#FFB86C"/>
    <SolidColorBrush x:Key="SubtleDataGridLineLightBrush" Color="#44475A" Opacity="0.35"/>

    <!-- Legacy light-theme status aliases (ThemeForge dark fallback values) -->
    <SolidColorBrush x:Key="StatusInstalledLightBrush" Color="#50FA7B"/>
    <SolidColorBrush x:Key="StatusFailedLightBrush" Color="#FF5555"/>
    <SolidColorBrush x:Key="StatusInstallingLightBrush" Color="#8BE9FD"/>
    <SolidColorBrush x:Key="StatusSkippedLightBrush" Color="#FFB86C"/>
    <SolidColorBrush x:Key="StatusPendingLightBrush" Color="#B3BBD6" Opacity="0.65"/>

    <!-- Source Badge Colors (for package manager badges) -->
    <SolidColorBrush x:Key="PrimaryHueLightBrush" Color="#BD93F9"/>
    <SolidColorBrush x:Key="PrimaryHueLightForegroundBrush" Color="#282A36"/>
    <SolidColorBrush x:Key="SecondaryHueLightBrush" Color="#8BE9FD"/>
    <SolidColorBrush x:Key="SecondaryHueLightForegroundBrush" Color="#282A36"/>
    <SolidColorBrush x:Key="SourceWingetBadgeBackgroundBrush" Color="#263B82F6"/>
    <SolidColorBrush x:Key="SourceWingetBadgeBorderBrush" Color="#3B82F6"/>
    <SolidColorBrush x:Key="SourceWingetBadgeForegroundBrush" Color="#93C5FD"/>
    <SolidColorBrush x:Key="SourceChocolateyBadgeBackgroundBrush" Color="#2616A34A"/>
    <SolidColorBrush x:Key="SourceChocolateyBadgeBorderBrush" Color="#22C55E"/>
    <SolidColorBrush x:Key="SourceChocolateyBadgeForegroundBrush" Color="#86EFAC"/>
    <SolidColorBrush x:Key="SourceStoreBadgeBackgroundBrush" Color="#2614B8A6"/>
    <SolidColorBrush x:Key="SourceStoreBadgeBorderBrush" Color="#14B8A6"/>
    <SolidColorBrush x:Key="SourceStoreBadgeForegroundBrush" Color="#5EEAD4"/>
    <SolidColorBrush x:Key="SourceDirectBadgeBackgroundBrush" Color="#2AF97316"/>
    <SolidColorBrush x:Key="SourceDirectBadgeBorderBrush" Color="#F97316"/>
    <SolidColorBrush x:Key="SourceDirectBadgeForegroundBrush" Color="#FDBA74"/>

    <!-- Light Theme Source Badge variants -->
    <SolidColorBrush x:Key="SourceWingetBadgeBackgroundLightBrush" Color="#DBEAFE"/>
    <SolidColorBrush x:Key="SourceWingetBadgeBorderLightBrush" Color="#60A5FA"/>
    <SolidColorBrush x:Key="SourceWingetBadgeForegroundLightBrush" Color="#1D4ED8"/>
    <SolidColorBrush x:Key="SourceChocolateyBadgeBackgroundLightBrush" Color="#DCFCE7"/>
    <SolidColorBrush x:Key="SourceChocolateyBadgeBorderLightBrush" Color="#4ADE80"/>
    <SolidColorBrush x:Key="SourceChocolateyBadgeForegroundLightBrush" Color="#166534"/>
    <SolidColorBrush x:Key="SourceStoreBadgeBackgroundLightBrush" Color="#CCFBF1"/>
    <SolidColorBrush x:Key="SourceStoreBadgeBorderLightBrush" Color="#2DD4BF"/>
    <SolidColorBrush x:Key="SourceStoreBadgeForegroundLightBrush" Color="#0F766E"/>
    <SolidColorBrush x:Key="SourceDirectBadgeBackgroundLightBrush" Color="#FFEDD5"/>
    <SolidColorBrush x:Key="SourceDirectBadgeBorderLightBrush" Color="#FB923C"/>
    <SolidColorBrush x:Key="SourceDirectBadgeForegroundLightBrush" Color="#C2410C"/>

    <!-- Dialog Overlay Backdrop (semi-transparent, overwritten by ThemeService at runtime) -->
    <SolidColorBrush x:Key="DialogOverlayBackgroundBrush" Color="#80000000"/>

    <!-- Theme-Adaptive Accent Brush (overwritten by ThemeService at runtime) -->
    <SolidColorBrush x:Key="ThemeAdaptiveAccentBrush" Color="#BD93F9"/>

    <!-- Focus indicator fallback for WPF-UI Light and non-Dracula resources -->
    <SolidColorBrush x:Key="FocusIndicatorBrush" Color="#BD93F9"/>

</ResourceDictionary>
