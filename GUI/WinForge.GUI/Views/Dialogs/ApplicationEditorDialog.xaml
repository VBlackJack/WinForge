<Window x:Class="Win11Forge.GUI.Views.Dialogs.ApplicationEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:loc="clr-namespace:Win11Forge.GUI.Resources"
        xmlns:viewModels="clr-namespace:Win11Forge.GUI.ViewModels"
        xmlns:uc="clr-namespace:Win11Forge.GUI.UserControls"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=viewModels:ApplicationEditorViewModel}"
        Title="{Binding DialogTitle}"
        Height="560" Width="680"
        MinHeight="440" MinWidth="500"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="CanResize"
        Background="{DynamicResource ApplicationBackgroundBrush}"
        TextElement.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
        TextElement.FontWeight="Medium"
        TextElement.FontSize="{StaticResource FontSizeBody}">

    <Window.InputBindings>
        <KeyBinding Key="Escape" Command="{Binding CancelCommand}"/>
        <KeyBinding Key="S" Modifiers="Ctrl" Command="{Binding SaveCommand}"/>
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="{DynamicResource PrimaryHueMidBrush}"
                Padding="24,16">
            <StackPanel Orientation="Horizontal">
                <ui:SymbolIcon x:Name="HeaderIcon"
                               Width="28" Height="28"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource PrimaryHueMidForegroundBrush}"
                               Margin="0,0,16,0">
                    <ui:SymbolIcon.Style>
                        <Style TargetType="ui:SymbolIcon">
                            <Setter Property="Symbol" Value="Edit24"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsNewApplication}" Value="True">
                                    <Setter Property="Symbol" Value="Add24"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ui:SymbolIcon.Style>
                </ui:SymbolIcon>
                <TextBlock Text="{Binding DialogTitle}"
                           FontSize="{StaticResource FontSizeTitle}" FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryHueMidForegroundBrush}"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Tab Content -->
        <TabControl Grid.Row="1"
                    Margin="16">
            <!-- General Tab -->
            <TabItem Header="{loc:Loc AppEditor_Tab_General}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                    <StackPanel>
                        <!-- App ID -->
                        <ui:TextBox Text="{Binding Application.AppId, UpdateSourceTrigger=PropertyChanged}"
                                    PlaceholderText="{loc:Loc AppEditor_AppId}"
                                    IsEnabled="{Binding CanEditAppId}"
                                    Margin="0,0,0,16"
                                    AutomationProperties.Name="{loc:Loc AppEditor_AppId}"/>

                        <!-- Name -->
                        <ui:TextBox Text="{Binding Application.Name, UpdateSourceTrigger=PropertyChanged}"
                                    PlaceholderText="{loc:Loc AppEditor_Name}"
                                    Margin="0,0,0,16"
                                    AutomationProperties.Name="{loc:Loc AppEditor_Name}"/>

                        <!-- Category -->
                        <ComboBox ItemsSource="{Binding Categories}"
                                  SelectedItem="{Binding SelectedCategory}"
                                  IsEditable="False"
                                  Margin="0,0,0,16"
                                  AutomationProperties.Name="{loc:Loc Col_Category}"/>

                        <!-- Description -->
                        <ui:TextBox Text="{Binding Application.Description, UpdateSourceTrigger=PropertyChanged}"
                                    PlaceholderText="{loc:Loc AppEditor_Description}"
                                    AcceptsReturn="True"
                                    TextWrapping="Wrap"
                                    MinHeight="80"
                                    MaxHeight="150"
                                    VerticalScrollBarVisibility="Auto"
                                    Margin="0,0,0,16"
                                    AutomationProperties.Name="{loc:Loc AppEditor_Description}"/>

                        <!-- Homepage -->
                        <ui:TextBox Text="{Binding Application.Homepage, UpdateSourceTrigger=PropertyChanged}"
                                    PlaceholderText="{loc:Loc AppEditor_Homepage}"
                                    Margin="0,0,0,16"
                                    AutomationProperties.Name="{loc:Loc AppEditor_Homepage}"/>

                        <!-- Priority -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Slider Value="{Binding Application.DefaultPriority}"
                                    Minimum="1" Maximum="100"
                                    TickFrequency="10"
                                    IsSnapToTickEnabled="False"
                                    AutomationProperties.Name="{loc:Loc Col_Priority}"/>
                            <TextBlock Grid.Column="1"
                                       VerticalAlignment="Center"
                                       Margin="16,0,0,0"
                                       MinWidth="80"><Run Text="{loc:Loc AppEditor_PriorityLabel}"/><Run Text="{Binding Application.DefaultPriority, Mode=OneWay}"/></TextBlock>
                        </Grid>

                        <!-- Default Required -->
                        <CheckBox Content="{loc:Loc AppEditor_DefaultRequired}"
                                  IsChecked="{Binding Application.DefaultRequired}"
                                  Margin="0,0,0,16"
                                  AutomationProperties.Name="{loc:Loc AppEditor_DefaultRequired}"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Sources Tab -->
            <TabItem Header="{loc:Loc AppEditor_Tab_Sources}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                    <StackPanel>
                        <!-- Source Discovery -->
                        <Border CornerRadius="{StaticResource RadiusMedium}"
                                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                Padding="16"
                                Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="{loc:Loc AppEditor_SourceSearchTitle}"
                                           FontSize="{StaticResource FontSizeBodyLarge}"
                                           FontWeight="SemiBold"/>
                                <TextBlock Text="{loc:Loc AppEditor_SourceSearchDescription}"
                                           Margin="0,4,0,0"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>

                                <TabControl Margin="0,12,0,0">
                                    <TabItem Header="{loc:Loc Source_Winget}">
                                        <Grid Margin="0,8,0,0">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <Grid Grid.Row="0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <ui:TextBox Grid.Column="0"
                                                            Text="{Binding WingetSearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                                            PlaceholderText="{loc:Loc AppEditor_SearchPlaceholder}"
                                                            AutomationProperties.Name="{loc:Loc AppEditor_SearchPlaceholder}">
                                                    <ui:TextBox.InputBindings>
                                                        <KeyBinding Key="Enter" Command="{Binding SearchWingetPackagesCommand}"/>
                                                    </ui:TextBox.InputBindings>
                                                </ui:TextBox>

                                                <ui:Button Grid.Column="1"
                                                           Content="{loc:Loc AppEditor_SearchAction}"
                                                           Command="{Binding SearchWingetPackagesCommand}"
                                                           MinWidth="110"
                                                           Margin="8,0,0,0"
                                                           AutomationProperties.Name="{loc:Loc A11y_AppEditor_SearchWinget}"
                                                           Style="{StaticResource SecondaryButton}"/>
                                            </Grid>

                                            <TextBlock Grid.Row="1"
                                                       Text="{Binding WingetSearchStatus}"
                                                       Margin="0,8,0,8"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                       Visibility="{Binding WingetSearchStatus, Converter={StaticResource NullableToVisibilityConverter}}"/>

                                            <DataGrid Grid.Row="2"
                                                      ItemsSource="{Binding WingetSearchResults}"
                                                      SelectedItem="{Binding SelectedWingetSearchResult}"
                                                      AutoGenerateColumns="False"
                                                      CanUserAddRows="False"
                                                      CanUserDeleteRows="False"
                                                      IsReadOnly="True"
                                                      MinHeight="140"
                                                      MaxHeight="220"
                                                      Margin="0,0,0,8">
                                                <DataGrid.Columns>
                                                    <DataGridTextColumn Header="{loc:Loc AppEditor_SearchColumnName}"
                                                                        Binding="{Binding DisplayName}"
                                                                        Width="*"/>
                                                    <DataGridTextColumn Header="{loc:Loc AppEditor_SearchColumnId}"
                                                                        Binding="{Binding PackageId}"
                                                                        Width="2*"/>
                                                    <DataGridTextColumn Header="{loc:Loc AppEditor_SearchColumnVersion}"
                                                                        Binding="{Binding Version}"
                                                                        Width="120"/>
                                                </DataGrid.Columns>
                                            </DataGrid>

                                            <ui:Button Grid.Row="3"
                                                       Content="{loc:Loc AppEditor_ApplySelection}"
                                                       Command="{Binding ApplyWingetSearchResultCommand}"
                                                       IsEnabled="{Binding SelectedWingetSearchResult, Converter={StaticResource NullableToBooleanConverter}}"
                                                       AutomationProperties.Name="{loc:Loc A11y_AppEditor_ApplyWinget}"
                                                       Style="{StaticResource PrimaryButton}"
                                                       MinWidth="150"
                                                       HorizontalAlignment="Left"/>
                                        </Grid>
                                    </TabItem>

                                    <TabItem Header="{loc:Loc Source_Chocolatey}">
                                        <Grid Margin="0,8,0,0">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <Grid Grid.Row="0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <ui:TextBox Grid.Column="0"
                                                            Text="{Binding ChocolateySearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                                            PlaceholderText="{loc:Loc AppEditor_SearchPlaceholder}"
                                                            AutomationProperties.Name="{loc:Loc AppEditor_SearchPlaceholder}">
                                                    <ui:TextBox.InputBindings>
                                                        <KeyBinding Key="Enter" Command="{Binding SearchChocolateyPackagesCommand}"/>
                                                    </ui:TextBox.InputBindings>
                                                </ui:TextBox>

                                                <ui:Button Grid.Column="1"
                                                           Content="{loc:Loc AppEditor_SearchAction}"
                                                           Command="{Binding SearchChocolateyPackagesCommand}"
                                                           MinWidth="110"
                                                           Margin="8,0,0,0"
                                                           AutomationProperties.Name="{loc:Loc A11y_AppEditor_SearchChocolatey}"
                                                           Style="{StaticResource SecondaryButton}"/>
                                            </Grid>

                                            <TextBlock Grid.Row="1"
                                                       Text="{Binding ChocolateySearchStatus}"
                                                       Margin="0,8,0,8"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                       Visibility="{Binding ChocolateySearchStatus, Converter={StaticResource NullableToVisibilityConverter}}"/>

                                            <DataGrid Grid.Row="2"
                                                      ItemsSource="{Binding ChocolateySearchResults}"
                                                      SelectedItem="{Binding SelectedChocolateySearchResult}"
                                                      AutoGenerateColumns="False"
                                                      CanUserAddRows="False"
                                                      CanUserDeleteRows="False"
                                                      IsReadOnly="True"
                                                      MinHeight="140"
                                                      MaxHeight="220"
                                                      Margin="0,0,0,8">
                                                <DataGrid.Columns>
                                                    <DataGridTextColumn Header="{loc:Loc AppEditor_SearchColumnName}"
                                                                        Binding="{Binding DisplayName}"
                                                                        Width="*"/>
                                                    <DataGridTextColumn Header="{loc:Loc AppEditor_SearchColumnId}"
                                                                        Binding="{Binding PackageId}"
                                                                        Width="2*"/>
                                                    <DataGridTextColumn Header="{loc:Loc AppEditor_SearchColumnVersion}"
                                                                        Binding="{Binding Version}"
                                                                        Width="120"/>
                                                </DataGrid.Columns>
                                            </DataGrid>

                                            <ui:Button Grid.Row="3"
                                                       Content="{loc:Loc AppEditor_ApplySelection}"
                                                       Command="{Binding ApplyChocolateySearchResultCommand}"
                                                       IsEnabled="{Binding SelectedChocolateySearchResult, Converter={StaticResource NullableToBooleanConverter}}"
                                                       AutomationProperties.Name="{loc:Loc A11y_AppEditor_ApplyChocolatey}"
                                                       Style="{StaticResource PrimaryButton}"
                                                       MinWidth="150"
                                                       HorizontalAlignment="Left"/>
                                        </Grid>
                                    </TabItem>

                                    <TabItem Header="{loc:Loc Source_Store}">
                                        <Grid Margin="0,8,0,0">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <Grid Grid.Row="0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <ui:TextBox Grid.Column="0"
                                                            Text="{Binding StoreSearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                                            PlaceholderText="{loc:Loc AppEditor_SearchPlaceholder}"
                                                            AutomationProperties.Name="{loc:Loc AppEditor_SearchPlaceholder}">
                                                    <ui:TextBox.InputBindings>
                                                        <KeyBinding Key="Enter" Command="{Binding SearchStorePackagesCommand}"/>
                                                    </ui:TextBox.InputBindings>
                                                </ui:TextBox>

                                                <ui:Button Grid.Column="1"
                                                           Content="{loc:Loc AppEditor_SearchAction}"
                                                           Command="{Binding SearchStorePackagesCommand}"
                                                           MinWidth="110"
                                                           Margin="8,0,0,0"
                                                           AutomationProperties.Name="{loc:Loc A11y_AppEditor_SearchStore}"
                                                           Style="{StaticResource SecondaryButton}"/>
                                            </Grid>

                                            <TextBlock Grid.Row="1"
                                                       Text="{Binding StoreSearchStatus}"
                                                       Margin="0,8,0,8"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                       Visibility="{Binding StoreSearchStatus, Converter={StaticResource NullableToVisibilityConverter}}"/>

                                            <DataGrid Grid.Row="2"
                                                      ItemsSource="{Binding StoreSearchResults}"
                                                      SelectedItem="{Binding SelectedStoreSearchResult}"
                                                      AutoGenerateColumns="False"
                                                      CanUserAddRows="False"
                                                      CanUserDeleteRows="False"
                                                      IsReadOnly="True"
                                                      MinHeight="140"
                                                      MaxHeight="220"
                                                      Margin="0,0,0,8">
                                                <DataGrid.Columns>
                                                    <DataGridTextColumn Header="{loc:Loc AppEditor_SearchColumnName}"
                                                                        Binding="{Binding DisplayName}"
                                                                        Width="*"/>
                                                    <DataGridTextColumn Header="{loc:Loc AppEditor_SearchColumnId}"
                                                                        Binding="{Binding PackageId}"
                                                                        Width="2*"/>
                                                    <DataGridTextColumn Header="{loc:Loc AppEditor_SearchColumnVersion}"
                                                                        Binding="{Binding Version}"
                                                                        Width="120"/>
                                                </DataGrid.Columns>
                                            </DataGrid>

                                            <ui:Button Grid.Row="3"
                                                       Content="{loc:Loc AppEditor_ApplySelection}"
                                                       Command="{Binding ApplyStoreSearchResultCommand}"
                                                       IsEnabled="{Binding SelectedStoreSearchResult, Converter={StaticResource NullableToBooleanConverter}}"
                                                       AutomationProperties.Name="{loc:Loc A11y_AppEditor_ApplyStore}"
                                                       Style="{StaticResource PrimaryButton}"
                                                       MinWidth="150"
                                                       HorizontalAlignment="Left"/>
                                        </Grid>
                                    </TabItem>
                                </TabControl>
                            </StackPanel>
                        </Border>

                        <!-- Winget Source -->
                        <uc:WingetSourceEditor Margin="0,0,0,16"
                                                PackageId="{Binding Application.Sources.Winget, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                Version="{Binding Application.Sources.WingetConfig.Version, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                SourceRepository="{Binding Application.Sources.WingetConfig.Source, Mode=TwoWay}"
                                                IsSourceEnabled="{Binding WingetEnabled, Mode=TwoWay}"/>

                        <!-- Chocolatey Source -->
                        <uc:ChocolateySourceEditor Margin="0,0,0,16"
                                                    PackageName="{Binding Application.Sources.Chocolatey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                    Version="{Binding Application.Sources.ChocolateyConfig.Version, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                    IsSourceEnabled="{Binding ChocolateyEnabled, Mode=TwoWay}"/>

                        <!-- Store Source -->
                        <uc:StoreSourceEditor Margin="0,0,0,16"
                                               StoreId="{Binding Application.Sources.Store, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                               IsSourceEnabled="{Binding StoreEnabled, Mode=TwoWay}"/>

                        <!-- Direct Download Source -->
                        <uc:DirectDownloadSourceEditor Margin="0,0,0,16"
                                                        DownloadUrl="{Binding Application.Sources.DirectUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                        InstallerType="{Binding Application.Sources.DirectDownloadConfig.InstallerType, Mode=TwoWay}"
                                                        SilentArgs="{Binding Application.Sources.DirectDownloadConfig.SilentArgs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                        Checksum="{Binding Application.Sources.DirectDownloadConfig.Checksum, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                        ExpectedPublisher="{Binding Application.Sources.ExpectedPublisher, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                        IsSourceEnabled="{Binding DirectDownloadEnabled, Mode=TwoWay}"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Detection Tab -->
            <TabItem Header="{loc:Loc AppEditor_Tab_Detection}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                    <uc:DetectionEditor Method="{Binding Application.Detection.Method, Mode=TwoWay}"
                                         Path="{Binding Application.Detection.Path, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         VersionKey="{Binding Application.Detection.VersionKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         MinVersion="{Binding Application.Detection.MinVersion, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <!-- Validation Message -->
        <Border Grid.Row="2"
                Background="{DynamicResource SystemFillColorCriticalBrush}"
                Padding="16,8"
                Visibility="{Binding ValidationMessage, Converter={StaticResource NullableToVisibilityConverter}}">
            <StackPanel Orientation="Horizontal">
                <ui:SymbolIcon Symbol="ErrorCircle24"
                               Width="20" Height="20"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource BadgePrimaryForegroundBrush}"
                               Margin="0,0,12,0"/>
                <TextBlock Text="{Binding ValidationMessage}"
                           Foreground="{DynamicResource BadgePrimaryForegroundBrush}"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Actions -->
        <Border Grid.Row="3"
                Background="{DynamicResource SolidBackgroundFillColorSecondaryBrush}"
                Padding="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Verify button -->
                <ui:Button Grid.Column="0"
                           x:Name="VerifyButton"
                           Content="{loc:Loc AppCatalog_Verify}"
                           Style="{StaticResource PrimaryButton}"
                           Click="VerifyButton_Click"
                           MinWidth="80"
                           Margin="0,0,12,0"
                           AutomationProperties.Name="{loc:Loc AppCatalog_VerifySources}"/>

                <!-- Verify result -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <ui:SymbolIcon Symbol="CheckmarkCircle24"
                                   Width="20" Height="20"
                                   Foreground="{DynamicResource StatusInstalledBrush}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"
                                   Visibility="{Binding VerificationSuccess, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    <TextBlock Text="{Binding VerificationResult}"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                </StackPanel>

                <!-- Dirty indicator -->
                <TextBlock Grid.Column="2"
                           Text="{loc:Loc AppEditor_UnsavedChanges}"
                           Foreground="{DynamicResource SecondaryHueMidBrush}"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"
                           Visibility="{Binding IsDirty, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                <ui:Button Grid.Column="3"
                           Content="{loc:Loc AppEditor_Cancel}"
                           Style="{StaticResource SecondaryButton}"
                           Command="{Binding CancelCommand}"
                           IsCancel="True"
                           MinWidth="100"
                           Margin="0,0,12,0"
                           AutomationProperties.Name="{loc:Loc AppEditor_Cancel}"/>

                <ui:Button Grid.Column="4"
                           Style="{StaticResource PrimaryButton}"
                           Command="{Binding SaveCommand}"
                           IsDefault="True"
                           MinWidth="100"
                           AutomationProperties.Name="{loc:Loc AppEditor_Save}">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Save24"
                                       Width="18" Height="18"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"
                                       Visibility="{Binding IsSaving, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>
                        <ui:ProgressRing IsIndeterminate="True"
                                         Width="18" Height="18"
                                         Margin="0,0,8,0"
                                         Visibility="{Binding IsSaving, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        <TextBlock Text="{loc:Loc AppEditor_Save}" VerticalAlignment="Center"/>
                    </StackPanel>
                </ui:Button>
            </Grid>
        </Border>
    </Grid>
</Window>
