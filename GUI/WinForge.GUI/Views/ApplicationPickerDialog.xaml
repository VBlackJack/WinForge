<UserControl x:Class="WinForge.GUI.Views.ApplicationPickerDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:loc="clr-namespace:WinForge.GUI.Resources"
             mc:Ignorable="d"
             MinWidth="420" MinHeight="360"
             d:DesignHeight="500" d:DesignWidth="700">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="{DynamicResource PrimaryHueMidBrush}"
                Padding="16">
            <StackPanel Orientation="Horizontal">
                <ui:SymbolIcon Symbol="Box24"
                               Width="24"
                               Height="24"
                               VerticalAlignment="Center"
                               Margin="0,0,12,0"/>
                <TextBlock Text="{loc:Loc Dialog_SelectApp_Title}"
                           FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Search Bar -->
        <Grid Grid.Row="1" Margin="16,16,16,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <ui:TextBox Grid.Column="0"
                        x:Name="SearchTextBox"
                        Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                        PlaceholderText="{loc:Loc Apps_SearchHint}"
                        Icon="{ui:SymbolIcon Search24}"
                        AutomationProperties.Name="{loc:Loc A11y_AppPicker_Search}">
                <ui:TextBox.InputBindings>
                    <KeyBinding Key="Enter" Command="{Binding SearchCommand}"/>
                </ui:TextBox.InputBindings>
            </ui:TextBox>

            <ComboBox Grid.Column="1"
                      ItemsSource="{Binding Categories}"
                      SelectedItem="{Binding SelectedCategory}"
                      MinWidth="140"
                      MaxWidth="200"
                      Margin="8,0,0,0"
                      AutomationProperties.Name="{loc:Loc A11y_AppPicker_Category}"/>
        </Grid>

        <!-- Applications DataGrid -->
        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding FilteredApplications}"
                  SelectedItem="{Binding SelectedApplication}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  Margin="16,0,16,0"
                  VirtualizingStackPanel.IsVirtualizing="True"
                  VirtualizingStackPanel.VirtualizationMode="Recycling"
                  AutomationProperties.Name="{loc:Loc A11y_AppPicker_AppList}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="{loc:Loc Col_Application}"
                                    Binding="{Binding Name}"
                                    Width="*"/>
                <DataGridTextColumn Header="{loc:Loc Col_Category}"
                                    Binding="{Binding Category}"
                                    Width="100"/>
                <DataGridTextColumn Header="{loc:Loc Apps_Col_Id}"
                                    Binding="{Binding AppId}"
                                    Width="140"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Empty State -->
        <StackPanel Grid.Row="2"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Visibility="{Binding IsEmpty, Converter={StaticResource BooleanToVisibilityConverter}}">
            <ui:SymbolIcon Symbol="BoxDismiss24"
                           Width="48"
                           Height="48"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           HorizontalAlignment="Center"/>
            <TextBlock Text="{loc:Loc Dialog_NoAppsAvailable}"
                       FontSize="{StaticResource FontSizeCaption}"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,8,0,0"/>
        </StackPanel>

        <!-- Footer Buttons -->
        <Grid Grid.Row="3" Margin="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Selected Count -->
            <TextBlock Grid.Column="0"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                <Run Text="{Binding FilteredApplications.Count, Mode=OneWay}"/>
                <Run Text=" "/>
                <Run Text="{loc:Loc Dialog_AppsAvailable}"/>
            </TextBlock>

            <!-- Cancel Button -->
            <ui:Button Grid.Column="1"
                       Content="{loc:Loc Btn_Cancel}"
                       Command="{Binding CancelCommand}"
                       Style="{StaticResource SecondaryButton}"
                       Margin="0,0,12,0"
                       AutomationProperties.Name="{loc:Loc A11y_AppPicker_Cancel}"/>

            <!-- Add Button -->
            <ui:Button Grid.Column="2"
                       Content="{loc:Loc Dialog_SelectApp_Add}"
                       Command="{Binding ConfirmCommand}"
                       CommandParameter="{Binding SelectedApplication}"
                       IsEnabled="{Binding HasSelection}"
                       Style="{StaticResource PrimaryButton}"
                       AutomationProperties.Name="{loc:Loc A11y_AppPicker_Add}"/>
        </Grid>
    </Grid>
</UserControl>
