<UserControl x:Class="WinForge.GUI.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:loc="clr-namespace:WinForge.GUI.Resources"
             xmlns:viewModels="clr-namespace:WinForge.GUI.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=viewModels:SettingsViewModel}"
             d:DesignHeight="600" d:DesignWidth="800">

    <Grid Style="{StaticResource PageRootGridStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0"
                   Text="{loc:Loc Settings_Title}"
                   Style="{StaticResource PageTitleTextStyle}"
                   Margin="0,0,0,24"
                   AutomationProperties.AutomationId="PageSettings"/>

        <!-- Settings Content with Tabs -->
        <TabControl Grid.Row="1"
                    TabStripPlacement="Top">

            <!-- Appearance & Language Tab -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Color24" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="{loc:Loc Settings_Tab_Appearance}" FontSize="{StaticResource FontSizeBody}" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="16">
                    <StackPanel>
                        <!-- Theme Section -->
                        <Border Style="{StaticResource SectionCardStyle}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                    <TextBlock Text="{loc:Loc Settings_Section_Appearance}" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>

                                <!-- Theme Selector -->
                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{loc:Loc Settings_Theme}" FontSize="{StaticResource FontSizeBody}" FontWeight="Medium"/>
                                        <TextBlock Text="{loc:Loc Settings_Theme_Desc}" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <ComboBox ItemsSource="{Binding AvailableThemes}"
                                                  SelectedItem="{Binding SelectedTheme, Mode=TwoWay}"
                                                  MinWidth="180"
                                                  AutomationProperties.AutomationId="ThemePicker"
                                                  AutomationProperties.Name="{loc:Loc A11y_Settings_ThemePicker}">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding DisplayKey, Converter={StaticResource ResxKeyConverter}}"/>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                    </StackPanel>
                                </Grid>

                                <!-- Accent Tint Selector -->
                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{loc:Loc Settings_AccentTint}" FontSize="{StaticResource FontSizeBody}" FontWeight="Medium"/>
                                        <TextBlock Text="{loc:Loc Settings_AccentTint_Desc}" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <ComboBox ItemsSource="{Binding AvailableAccentTints}"
                                                  SelectedItem="{Binding SelectedAccentTint, Mode=TwoWay}"
                                                  MinWidth="180"
                                                  AutomationProperties.AutomationId="AccentTintPicker"
                                                  AutomationProperties.Name="{loc:Loc A11y_Settings_AccentTintPicker}">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding DisplayKey, Converter={StaticResource ResxKeyConverter}}"/>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                    </StackPanel>
                                </Grid>

                                <!-- Reduced Motion -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{loc:Loc Settings_ReducedMotion}" FontSize="{StaticResource FontSizeBody}" FontWeight="Medium"/>
                                        <TextBlock Text="{loc:Loc Settings_ReducedMotion_Desc}" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                    </StackPanel>

                                    <ui:ToggleSwitch Grid.Column="1"
                                                     IsChecked="{Binding ReducedMotion}"
                                                     AutomationProperties.Name="{loc:Loc A11y_Settings_ReducedMotion}"
                                                     AutomationProperties.HelpText="{loc:Loc Settings_ReducedMotion_Desc}"/>
                                </Grid>

                                <!-- High Contrast -->
                                <Grid Margin="0,16,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{loc:Loc Settings_HighContrast}" FontSize="{StaticResource FontSizeBody}" FontWeight="Medium"/>
                                        <TextBlock Text="{loc:Loc Settings_HighContrast_Desc}" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                    </StackPanel>

                                    <ui:ToggleSwitch Grid.Column="1"
                                                     IsChecked="{Binding IsHighContrastEnabled}"
                                                     AutomationProperties.Name="{loc:Loc A11y_Settings_HighContrast}"
                                                     AutomationProperties.HelpText="{loc:Loc Settings_HighContrast_Desc}"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Language Section -->
                        <Border Style="{StaticResource SectionCardStyle}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                    <TextBlock Text="{loc:Loc Settings_Section_Language}" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>

                                <!-- Language Selector -->
                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{loc:Loc Settings_Language}" FontSize="{StaticResource FontSizeBody}" FontWeight="Medium"/>
                                        <TextBlock Text="{loc:Loc Settings_Language_Desc}" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <ComboBox ItemsSource="{Binding AvailableLanguages}"
                                                  SelectedItem="{Binding SelectedLanguage}"
                                                  DisplayMemberPath="DisplayName"
                                                  MinWidth="140" MaxWidth="200" Margin="0,0,12,0"
                                                  AutomationProperties.Name="{loc:Loc A11y_Settings_Language}"/>
                                        <ui:Button Content="{loc:Loc Settings_Apply}"
                                                Command="{Binding ApplyLanguageCommand}"
                                                Style="{StaticResource PrimaryButton}"/>
                                    </StackPanel>
                                </Grid>

                                <!-- Restart Warning -->
                                <Border Background="{DynamicResource ControlFillColorDefaultBrush}"
                                        CornerRadius="{StaticResource RadiusSmall}" Padding="12"
                                        Visibility="{Binding RestartRequired, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                                            <ui:SymbolIcon Symbol="ErrorCircle24" Width="20" Height="20" VerticalAlignment="Center"
                                                                      Foreground="{DynamicResource SystemFillColorCriticalBrush}" Margin="0,0,8,0"/>
                                            <TextBlock Text="{loc:Loc Settings_RestartRequired}" FontSize="{StaticResource FontSizeCaption}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <ui:Button Grid.Column="1"
                                                Command="{Binding RestartApplicationCommand}"
                                                Style="{StaticResource PrimaryButton}"
                                                Margin="12,0,0,0"
                                                AutomationProperties.Name="{loc:Loc Settings_RestartNow}">
                                            <StackPanel Orientation="Horizontal">
                                                <ui:SymbolIcon Symbol="ArrowSync24" Width="16" Height="16" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                <TextBlock Text="{loc:Loc Settings_RestartNow}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </ui:Button>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Performance Tab -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Gauge24" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="{loc:Loc Settings_Tab_Performance}" FontSize="{StaticResource FontSizeBody}" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="16">
                    <Border Style="{StaticResource CardBorderStyle}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <TextBlock Text="{loc:Loc Settings_Section_Performance}" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                <ui:SymbolIcon Symbol="QuestionCircle24" Width="18" Height="18" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                          VerticalAlignment="Center" Margin="8,0,0,0" ToolTip="{loc:Loc Help_Performance}"/>
                            </StackPanel>

                            <!-- Parallel Installs Setting -->
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{loc:Loc Settings_ParallelInstalls}" FontSize="{StaticResource FontSizeBody}" FontWeight="Medium"/>
                                    <TextBlock Text="{loc:Loc Settings_ParallelInstalls_Desc}" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                </StackPanel>

                                <ComboBox Grid.Column="1"
                                          ItemsSource="{Binding ParallelInstallOptions}"
                                          SelectedItem="{Binding MaxParallelInstalls}"
                                          AutomationProperties.Name="{loc:Loc Settings_ParallelInstalls}"
                                          Width="80"/>
                            </Grid>

                            <!-- Parallel Scans Setting -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{loc:Loc Settings_ParallelScans}" FontSize="{StaticResource FontSizeBody}" FontWeight="Medium"/>
                                    <TextBlock Text="{loc:Loc Settings_ParallelScans_Desc}" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                </StackPanel>

                                <ComboBox Grid.Column="1"
                                          ItemsSource="{Binding ParallelScanOptions}"
                                          SelectedItem="{Binding MaxParallelScans}"
                                          AutomationProperties.Name="{loc:Loc Settings_ParallelScans}"
                                          Width="80"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </ScrollViewer>
            </TabItem>

            <!-- Data Tab -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Database24" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="{loc:Loc Settings_Tab_Data}" FontSize="{StaticResource FontSizeBody}" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="16">
                    <StackPanel>
                    <Border Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <!-- Section Header -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <TextBlock Text="{loc:Loc Settings_Section_Data}"
                                       FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Export/Import Settings -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{loc:Loc Settings_ExportImport}"
                                           FontSize="{StaticResource FontSizeBody}"
                                           FontWeight="Medium"/>
                                <TextBlock Text="{loc:Loc Settings_ExportImport_Desc}"
                                           FontSize="{StaticResource FontSizeCaption}"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <ui:Button Command="{Binding ExportSettingsCommand}"
                                        Style="{StaticResource SecondaryButton}"
                                        Margin="0,0,8,0">
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon Symbol="ArrowExportUp24" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock Text="{loc:Loc Settings_Export}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </ui:Button>
                                <ui:Button Command="{Binding ImportSettingsCommand}"
                                        Style="{StaticResource SecondaryButton}">
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon Symbol="ArrowImport24" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock Text="{loc:Loc Settings_Import}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </ui:Button>
                            </StackPanel>
                        </Grid>

                        <!-- Reset to Defaults -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{loc:Loc Settings_ResetDefaults}"
                                           FontSize="{StaticResource FontSizeBody}"
                                           FontWeight="Medium"/>
                                <TextBlock Text="{loc:Loc Settings_ResetDefaults_Desc}"
                                           FontSize="{StaticResource FontSizeCaption}"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>

                            <ui:Button Grid.Column="1"
                                    Command="{Binding ResetToDefaultsCommand}"
                                    Style="{StaticResource SecondaryButton}">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="ArrowReset24" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="{loc:Loc Settings_ResetBtn}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </ui:Button>
                        </Grid>

                        <!-- Clear History -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{loc:Loc Settings_ClearHistory}"
                                           FontSize="{StaticResource FontSizeBody}"
                                           FontWeight="Medium"/>
                                <TextBlock Text="{loc:Loc Settings_ClearHistory_Desc}"
                                           FontSize="{StaticResource FontSizeCaption}"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>

                            <ui:Button Grid.Column="1"
                                    Content="{loc:Loc Settings_ClearBtn}"
                                    Command="{Binding ClearHistoryCommand}"
                                    Style="{StaticResource DestructiveSolidButton}"/>
                        </Grid>

                        <!-- Open Log Folder -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{loc:Loc Settings_Btn_OpenLogs}"
                                           FontSize="{StaticResource FontSizeBody}"
                                           FontWeight="Medium"/>
                                <TextBlock Text="{loc:Loc Settings_OpenLogs_Desc}"
                                           FontSize="{StaticResource FontSizeCaption}"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>

                            <ui:Button Grid.Column="1"
                                    Command="{Binding OpenLogFolderCommand}"
                                    Style="{StaticResource SecondaryButton}">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="FolderOpen24" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="{loc:Loc Settings_Btn_OpenLogs}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </ui:Button>
                        </Grid>
                    </StackPanel>
                    </Border>

                    <!-- Error History Section -->
                    <Border Style="{StaticResource SectionCardStyle}" Margin="0,16,0,0">
                        <Expander IsExpanded="{Binding HasErrors}">
                            <Expander.Header>
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="ErrorCircle24"
                                                              Width="24" Height="24"
                                                              VerticalAlignment="Center"
                                                              Margin="0,0,12,0"/>
                                    <TextBlock Text="{loc:Loc Settings_ErrorHistory}"
                                               FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                    <Border Background="{DynamicResource ErrorBorderBrush}"
                                            CornerRadius="{StaticResource RadiusLarge}"
                                            Padding="8,2"
                                            Margin="12,0,0,0"
                                            Visibility="{Binding HasErrors, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <TextBlock Text="{Binding ErrorCount}"
                                                   Foreground="{DynamicResource BadgePrimaryForegroundBrush}"
                                                   FontWeight="Bold"
                                                   FontSize="{StaticResource FontSizeCaption}"/>
                                    </Border>
                                </StackPanel>
                            </Expander.Header>
                            <StackPanel Margin="0,12,0,0">
                                <!-- Clear Errors Button -->
                                <ui:Button Content="{loc:Loc Settings_ClearErrors}"
                                        Command="{Binding ClearErrorHistoryCommand}"
                                        Style="{StaticResource DestructiveSolidButton}"
                                        HorizontalAlignment="Right"
                                        Margin="0,0,0,12"
                                        Visibility="{Binding HasErrors, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                                <!-- Error List -->
                                <ItemsControl ItemsSource="{Binding RecentErrors}"
                                              VirtualizingPanel.IsVirtualizing="True"
                                              VirtualizingPanel.VirtualizationMode="Recycling"
                                              MaxHeight="300">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <VirtualizingStackPanel/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}"
                                                    BorderThickness="0,0,0,1"
                                                    Padding="0,8">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <ui:SymbolIcon Symbol="ErrorCircle24"
                                                                              Grid.Column="0"
                                                                              Width="20" Height="20"
                                                                              Foreground="{DynamicResource ErrorBorderBrush}"
                                                                              VerticalAlignment="Top"
                                                                              Margin="0,2,12,0"/>

                                                    <StackPanel Grid.Column="1">
                                                        <TextBlock Text="{Binding Message}"
                                                                   FontSize="{StaticResource FontSizeCaption}"
                                                                   TextWrapping="Wrap"/>
                                                        <TextBlock Text="{Binding Source}"
                                                                   FontSize="{StaticResource FontSizeCaption}"
                                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                                   Visibility="{Binding Source, Converter={StaticResource NullableToVisibilityConverter}}"
                                                                   Margin="0,4,0,0"/>
                                                    </StackPanel>

                                                    <TextBlock Grid.Column="2"
                                                               Text="{Binding FormattedTimestamp}"
                                                               FontSize="{StaticResource FontSizeCaption}"
                                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                               VerticalAlignment="Top"
                                                               Margin="12,2,0,0"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- Empty State -->
                                <TextBlock Text="{loc:Loc Settings_NoErrors}"
                                           FontSize="{StaticResource FontSizeCaption}"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           HorizontalAlignment="Center"
                                           Margin="0,16"
                                           Visibility="{Binding HasErrors, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>
                            </StackPanel>
                        </Expander>
                    </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Scheduled Deployments Tab -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="CalendarClock24" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="{loc:Loc Settings_Tab_Scheduled}" FontSize="{StaticResource FontSizeBody}" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="16">
                    <StackPanel>
                        <!-- Admin Required Warning -->
                        <Border Style="{StaticResource SectionCardStyle}"
                                              Visibility="{Binding IsScheduledDeploymentsAvailable, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="ErrorCircle24" Width="24" Height="24"
                                                          Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                                                          VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <TextBlock Text="{loc:Loc ScheduledDeployment_AdminRequired}"
                                           FontSize="{StaticResource FontSizeBody}"
                                           VerticalAlignment="Center"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <!-- Create New Scheduled Deployment -->
                        <Border Style="{StaticResource SectionCardStyle}"
                                              IsEnabled="{Binding IsScheduledDeploymentsAvailable}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                    <TextBlock Text="{loc:Loc ScheduledDeployment_CreateNew}"
                                               FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                </StackPanel>

                                <!-- Profile Selection -->
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="2*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Text="{loc:Loc ScheduledDeployment_Profile}"
                                               FontSize="{StaticResource FontSizeBody}"
                                               VerticalAlignment="Center"/>
                                    <ComboBox Grid.Column="1"
                                              ItemsSource="{Binding AvailableProfiles}"
                                              SelectedItem="{Binding NewScheduledProfile}"
                                              AutomationProperties.Name="{loc:Loc ScheduledDeployment_Profile}"/>
                                </Grid>

                                <!-- Trigger Type -->
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="2*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Text="{loc:Loc ScheduledDeployment_TriggerType}"
                                               FontSize="{StaticResource FontSizeBody}"
                                               VerticalAlignment="Center"/>
                                    <ComboBox Grid.Column="1"
                                              ItemsSource="{Binding AvailableTriggerTypes}"
                                              SelectedItem="{Binding NewScheduledTriggerType}"
                                              AutomationProperties.Name="{loc:Loc ScheduledDeployment_TriggerType}"/>
                                </Grid>

                                <!-- Schedule Time -->
                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Text="{loc:Loc ScheduledDeployment_DateTime}"
                                               FontSize="{StaticResource FontSizeBody}"
                                               VerticalAlignment="Center"/>
                                    <DatePicker Grid.Column="1"
                                                SelectedDate="{Binding NewScheduledTime}"
                                                AutomationProperties.Name="{loc:Loc ScheduledDeployment_Date}"
                                                Margin="0,0,8,0"/>
                                    <ui:TextBox Grid.Column="2"
                                                PlaceholderText="{loc:Loc Settings_TimePlaceholder}"
                                                AutomationProperties.Name="{loc:Loc ScheduledDeployment_Time}"
                                                AutomationProperties.HelpText="{loc:Loc Settings_TimePlaceholder}"
                                                Text="{Binding NewScheduledTimeText, UpdateSourceTrigger=PropertyChanged}"/>
                                </Grid>

                                <!-- Create Button -->
                                <ui:Button Command="{Binding CreateScheduledDeploymentCommand}"
                                        Style="{StaticResource PrimaryButton}"
                                        HorizontalAlignment="Right">
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon Symbol="CalendarAdd24" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBlock Text="{loc:Loc ScheduledDeployment_Create}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </ui:Button>
                            </StackPanel>
                        </Border>

                        <!-- Scheduled Deployments List -->
                        <Border Style="{StaticResource CardBorderStyle}"
                                              IsEnabled="{Binding IsScheduledDeploymentsAvailable}">
                            <StackPanel>
                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{loc:Loc ScheduledDeployment_List}"
                                                   FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <ui:Button Grid.Column="1"
                                            Command="{Binding LoadScheduledDeploymentsCommand}"
                                            Style="{StaticResource IconButton}"
                                            ToolTip="{loc:Loc ScheduledDeployment_Refresh}"
                                            AutomationProperties.Name="{loc:Loc ScheduledDeployment_Refresh}">
                                        <ui:SymbolIcon Symbol="ArrowSync24" Width="20" Height="20"/>
                                    </ui:Button>
                                </Grid>

                                <!-- Loading Indicator -->
                                <ProgressBar IsIndeterminate="True"
                                             Visibility="{Binding IsLoadingScheduledDeployments, Converter={StaticResource BooleanToVisibilityConverter}}"
                                             Margin="0,0,0,12"/>

                                <!-- Empty State -->
                                <TextBlock Text="{loc:Loc ScheduledDeployment_Empty}"
                                           FontSize="{StaticResource FontSizeCaption}"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           HorizontalAlignment="Center"
                                           Margin="0,16"
                                           Visibility="{Binding ScheduledDeployments.Count, Converter={StaticResource ZeroToVisibilityConverter}}"/>

                                <!-- Deployments DataGrid -->
                                <DataGrid ItemsSource="{Binding ScheduledDeployments}"
                                          SelectedItem="{Binding SelectedScheduledDeployment}"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          IsReadOnly="True"
                                          SelectionMode="Single"
                                          Visibility="{Binding ScheduledDeployments.Count, Converter={StaticResource NonZeroToVisibilityConverter}}"
                                          MaxHeight="300">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="{loc:Loc ScheduledDeployment_Col_Profile}"
                                                            Binding="{Binding ProfileName}"
                                                            Width="*"/>
                                        <DataGridTextColumn Header="{loc:Loc ScheduledDeployment_Col_Schedule}"
                                                            Binding="{Binding ScheduledTimeDisplay}"
                                                            Width="*"/>
                                        <DataGridTextColumn Header="{loc:Loc ScheduledDeployment_Col_Status}"
                                                            Binding="{Binding StatusDisplay}"
                                                            Width="Auto"/>
                                        <DataGridTextColumn Header="{loc:Loc ScheduledDeployment_Col_LastRun}"
                                                            Binding="{Binding LastRunResult}"
                                                            Width="Auto"/>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <!-- Action Buttons -->
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Right"
                                            Margin="0,16,0,0"
                                            Visibility="{Binding ScheduledDeployments.Count, Converter={StaticResource NonZeroToVisibilityConverter}}">
                                    <ui:Button Command="{Binding RunScheduledDeploymentNowCommand}"
                                            Style="{StaticResource SecondaryButton}"
                                            Margin="0,0,8,0"
                                            IsEnabled="{Binding SelectedScheduledDeployment, Converter={StaticResource NullableToBooleanConverter}}">
                                        <StackPanel Orientation="Horizontal">
                                            <ui:SymbolIcon Symbol="Play24" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Text="{loc:Loc ScheduledDeployment_RunNow}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </ui:Button>
                                    <ui:Button Command="{Binding RemoveScheduledDeploymentCommand}"
                                            Style="{StaticResource DestructiveSolidButton}"
                                            IsEnabled="{Binding SelectedScheduledDeployment, Converter={StaticResource NullableToBooleanConverter}}">
                                        <StackPanel Orientation="Horizontal">
                                            <ui:SymbolIcon Symbol="Delete24" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Text="{loc:Loc ScheduledDeployment_Remove}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </ui:Button>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- About Tab -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Info24" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="{loc:Loc Settings_Tab_About}" FontSize="{StaticResource FontSizeBody}" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="16">
                    <StackPanel>
                        <Border Style="{StaticResource CardBorderStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- App Info (Left) -->
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="{loc:Loc App_Name}"
                                               FontSize="{StaticResource FontSizeTitle}" FontWeight="SemiBold"
                                               Margin="0,0,0,16"/>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- Version -->
                                        <TextBlock Grid.Row="0" Grid.Column="0"
                                                   Text="{loc:Loc About_Version}"
                                                   FontSize="{StaticResource FontSizeBody}"
                                                   FontWeight="Medium"
                                                   Margin="0,0,24,8"/>
                                        <TextBlock Grid.Row="0" Grid.Column="1"
                                                   Text="{Binding AppVersion}"
                                                   FontSize="{StaticResource FontSizeBody}"
                                                   Margin="0,0,0,8"/>

                                        <!-- Author -->
                                        <TextBlock Grid.Row="1" Grid.Column="0"
                                                   Text="{loc:Loc About_Author}"
                                                   FontSize="{StaticResource FontSizeBody}"
                                                   FontWeight="Medium"
                                                   Margin="0,0,24,8"/>
                                        <TextBlock Grid.Row="1" Grid.Column="1"
                                                   Text="{loc:Loc About_AuthorName}"
                                                   FontSize="{StaticResource FontSizeBody}"
                                                   Margin="0,0,0,8"/>

                                        <!-- License -->
                                        <TextBlock Grid.Row="2" Grid.Column="0"
                                                   Text="{loc:Loc About_License}"
                                                   FontSize="{StaticResource FontSizeBody}"
                                                   FontWeight="Medium"
                                                   Margin="0,0,24,8"/>
                                        <TextBlock Grid.Row="2" Grid.Column="1"
                                                   Text="{loc:Loc About_LicenseValue}"
                                                   FontSize="{StaticResource FontSizeBody}"
                                                   Margin="0,0,0,8"/>

                                        <!-- GitHub -->
                                        <TextBlock Grid.Row="3" Grid.Column="0"
                                                   Text="{loc:Loc About_Repository}"
                                                   FontSize="{StaticResource FontSizeBody}"
                                                   FontWeight="Medium"
                                                   Margin="0,0,24,0"/>
                                        <ui:Button Grid.Row="3" Grid.Column="1"
                                                Content="{loc:Loc About_RepoUrl}"
                                                Command="{Binding OpenGitHubCommand}"
                                                Style="{StaticResource SecondaryButton}"
                                                HorizontalAlignment="Left"
                                                Padding="0"
                                                Margin="0"/>
                                    </Grid>
                                </StackPanel>

                                <!-- Logo (Right) -->
                                <Image Grid.Column="1"
                                       Source="/icon_cropped.png"
                                       Width="120" Height="120"
                                       RenderOptions.BitmapScalingMode="HighQuality"
                                       VerticalAlignment="Center"
                                       Margin="24,0,0,0"/>
                            </Grid>
                        </Border>

                        <!-- Status Message -->
                        <Border Padding="12" Margin="0,16,0,0"
                                              CornerRadius="{StaticResource RadiusMedium}" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                              Visibility="{Binding StatusMessage, Converter={StaticResource NullableToVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="CheckmarkCircle24"
                                                          Width="20" Height="20"
                                                          VerticalAlignment="Center"
                                                          Foreground="{DynamicResource SystemFillColorSuccessBrush}"
                                                          Margin="0,0,8,0"/>
                                <TextBlock Text="{Binding StatusMessage}"
                                           FontSize="{StaticResource FontSizeCaption}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
