<UserControl x:Class="Win11Forge.GUI.UserControls.DirectDownloadSourceEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:loc="clr-namespace:Win11Forge.GUI.Resources"
             mc:Ignorable="d"
             d:DesignHeight="330" d:DesignWidth="500">

    <Border CornerRadius="{StaticResource RadiusMedium}" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" Padding="16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header with enable toggle -->
            <Grid Grid.Row="0" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="ArrowDownload24"
                                   Width="24" Height="24"
                                   VerticalAlignment="Center"
                                   Margin="0,0,12,0"/>
                    <TextBlock Text="{loc:Loc AppEditor_DirectDownload}"
                               FontSize="{StaticResource FontSizeBodyLarge}" FontWeight="Medium"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <ui:ToggleSwitch Grid.Column="2"
                                 x:Name="EnableToggle"
                                 IsChecked="{Binding IsSourceEnabled, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                 ToolTip="{loc:Loc SourceEditor_EnableDisable}"
                                 AutomationProperties.Name="{loc:Loc SourceEditor_EnableDisable}"/>
            </Grid>

            <!-- Download URL -->
            <ui:TextBox Grid.Row="1"
                     Text="{Binding DownloadUrl, RelativeSource={RelativeSource AncestorType=UserControl}, UpdateSourceTrigger=PropertyChanged}"
                     PlaceholderText="{loc:Loc AppEditor_DirectUrl}"
                     IsEnabled="{Binding IsChecked, ElementName=EnableToggle}"
                     Margin="0,0,0,12"
                     AutomationProperties.Name="{loc:Loc AppEditor_DirectUrl}"/>

            <!-- Installer Type and Silent Args Row -->
            <Grid Grid.Row="2" Margin="0,0,0,12" IsEnabled="{Binding IsChecked, ElementName=EnableToggle}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Installer Type -->
                <ComboBox Grid.Column="0"
                          SelectedValue="{Binding InstallerType, RelativeSource={RelativeSource AncestorType=UserControl}}"
                          SelectedValuePath="Tag"
                          AutomationProperties.Name="{loc:Loc SourceEditor_InstallerType}">
                    <ComboBoxItem Content="exe" Tag="exe"/>
                    <ComboBoxItem Content="msi" Tag="msi"/>
                    <ComboBoxItem Content="msix" Tag="msix"/>
                    <ComboBoxItem Content="zip" Tag="zip"/>
                </ComboBox>

                <!-- Silent Args -->
                <ui:TextBox Grid.Column="2"
                         Text="{Binding SilentArgs, RelativeSource={RelativeSource AncestorType=UserControl}, UpdateSourceTrigger=PropertyChanged}"
                         PlaceholderText="{loc:Loc SourceEditor_SilentArgs}"
                         AutomationProperties.Name="{loc:Loc SourceEditor_SilentArgs}"/>
            </Grid>

            <!-- Checksum -->
            <ui:TextBox Grid.Row="3"
                     Text="{Binding Checksum, RelativeSource={RelativeSource AncestorType=UserControl}, UpdateSourceTrigger=PropertyChanged}"
                     PlaceholderText="{loc:Loc SourceEditor_Checksum}"
                     IsEnabled="{Binding IsChecked, ElementName=EnableToggle}"
                     Margin="0,0,0,8"
                     AutomationProperties.Name="{loc:Loc SourceEditor_Checksum}"/>

            <!-- Checksum hint -->
            <TextBlock Grid.Row="4"
                       Text="{loc:Loc SourceEditor_ChecksumHint}"
                       FontSize="{StaticResource FontSizeCaption}"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       IsEnabled="{Binding IsChecked, ElementName=EnableToggle}"
                       Margin="0,0,0,12"/>

            <!-- Expected Publisher -->
            <ui:TextBox Grid.Row="5"
                     Text="{Binding ExpectedPublisher, RelativeSource={RelativeSource AncestorType=UserControl}, UpdateSourceTrigger=PropertyChanged}"
                     PlaceholderText="{loc:Loc SourceEditor_ExpectedPublisher}"
                     IsEnabled="{Binding IsChecked, ElementName=EnableToggle}"
                     Margin="0,0,0,12"
                     AutomationProperties.Name="{loc:Loc SourceEditor_ExpectedPublisher}"/>

            <!-- Test URL Button and Status -->
            <Grid Grid.Row="6" IsEnabled="{Binding IsChecked, ElementName=EnableToggle}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <ui:Button Grid.Column="0"
                        Style="{StaticResource SecondaryButton}"
                        Command="{Binding TestCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                        ToolTip="{loc:Loc SourceEditor_TestUrlTooltip}"
                        MinWidth="120"
                        AutomationProperties.Name="{loc:Loc SourceEditor_TestUrl}">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Link24"
                                       Width="18" Height="18"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"
                                       Visibility="{Binding IsTesting, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>
                        <ProgressBar IsIndeterminate="True"
                                     Width="18" Height="18"
                                     Margin="0,0,8,0"
                                     Visibility="{Binding IsTesting, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        <TextBlock Text="{loc:Loc SourceEditor_TestUrl}" VerticalAlignment="Center"/>
                    </StackPanel>
                </ui:Button>

                <!-- Test Result -->
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            Margin="16,0,0,0"
                            VerticalAlignment="Center"
                            Visibility="{Binding TestResult, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource NullableToVisibilityConverter}}">
                    <ui:SymbolIcon x:Name="TestResultIcon"
                                   Width="20" Height="20"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                    <TextBlock Text="{Binding TestResult, RelativeSource={RelativeSource AncestorType=UserControl}}"
                               VerticalAlignment="Center"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</UserControl>
