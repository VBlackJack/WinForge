<UserControl x:Class="WinForge.GUI.Controls.EnhancedTooltip"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             x:Name="Root"
             MaxWidth="350">
    <Border Background="{DynamicResource SubtleFillColorSecondaryBrush}"
            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="{StaticResource RadiusSmall}"
            Padding="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title with Icon -->
            <StackPanel Grid.Row="0"
                        Orientation="Horizontal"
                        Margin="0,0,0,8"
                        Visibility="{Binding Title, ElementName=Root, Converter={StaticResource NullableToVisibilityConverter}}">
                <ui:SymbolIcon x:Name="TitleIcon"
                                          Symbol="{Binding IconKind, ElementName=Root}"
                                          Width="18" Height="18"
                                          VerticalAlignment="Center"
                                          Margin="0,0,8,0"
                                          Foreground="{DynamicResource SystemAccentColorPrimaryBrush}"
                                          Visibility="{Binding ShowIcon, ElementName=Root, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                <TextBlock Text="{Binding Title, ElementName=Root}"
                           FontSize="{StaticResource FontSizeBody}" FontWeight="Medium"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Description -->
            <TextBlock Grid.Row="1"
                       Text="{Binding Description, ElementName=Root}"
                       FontSize="{StaticResource FontSizeCaption}"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>

            <!-- Keyboard Shortcut (optional) -->
            <Border Grid.Row="2"
                    Margin="0,8,0,0"
                    Visibility="{Binding Shortcut, ElementName=Root, Converter={StaticResource NullableToVisibilityConverter}}">
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="Keyboard24"
                                              Width="14" Height="14"
                                              VerticalAlignment="Center"
                                              Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                              Margin="0,0,6,0"/>
                    <TextBlock Text="{Binding Shortcut, ElementName=Root}"
                               FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               FontFamily="Consolas"
                               VerticalAlignment="Center"
                               />
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</UserControl>
