<UserControl x:Class="Win11Forge.GUI.Views.ApplicationsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:loc="clr-namespace:Win11Forge.GUI.Resources"
             xmlns:viewModels="clr-namespace:Win11Forge.GUI.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=viewModels:ApplicationsViewModel}"
             d:DesignHeight="700" d:DesignWidth="1000"
             Loaded="UserControl_Loaded">

    <UserControl.InputBindings>
        <KeyBinding Key="N" Modifiers="Ctrl" Command="{Binding AddCommand}"/>
        <KeyBinding Key="E" Modifiers="Ctrl" Command="{Binding EditCommand}"/>
        <KeyBinding Key="Delete" Command="{Binding DeleteCommand}"/>
        <KeyBinding Key="F5" Command="{Binding RefreshCommand}"/>
        <KeyBinding Key="D" Modifiers="Ctrl" Command="{Binding DuplicateCommand}"/>
        <KeyBinding Key="Z" Modifiers="Ctrl" Command="{Binding UndoCommand}"/>
        <KeyBinding Key="Y" Modifiers="Ctrl" Command="{Binding RedoCommand}"/>
    </UserControl.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="{DynamicResource SolidBackgroundFillColorSecondaryBrush}"
                Padding="24,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="Database24"
                                   Width="32" Height="32"
                                   VerticalAlignment="Center"
                                   Margin="0,0,16,0"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{loc:Loc AppDb_Title}"
                                   FontSize="24" FontWeight="SemiBold"/>
                        <TextBlock Text="{loc:Loc AppDb_Subtitle}"
                                   FontSize="12"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </StackPanel>

                <!-- Actions -->
                <ScrollViewer Grid.Column="1"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled"
                              CanContentScroll="False">
                <StackPanel Orientation="Horizontal" Margin="16,0,0,0">
                    <!-- Undo/Redo buttons -->
                    <ui:Button Appearance="Transparent"
                               Command="{Binding UndoCommand}"
                               ToolTip="{Binding UndoButtonTooltip}"
                               AutomationProperties.Name="{loc:Loc A11y_Main_Undo}"
                               Style="{StaticResource TouchFriendlyIconButton}"
                               Margin="0,0,4,0"
                               Icon="{ui:SymbolIcon ArrowUndo24}"/>
                    <ui:Button Appearance="Transparent"
                               Command="{Binding RedoCommand}"
                               ToolTip="{Binding RedoButtonTooltip}"
                               AutomationProperties.Name="{loc:Loc A11y_Main_Redo}"
                               Style="{StaticResource TouchFriendlyIconButton}"
                               Margin="0,0,16,0"
                               Icon="{ui:SymbolIcon ArrowRedo24}"/>

                    <ui:Button Appearance="Primary"
                               Command="{Binding AddCommand}"
                               ToolTip="{loc:Loc AppDb_AddTooltip}"
                               AutomationProperties.Name="{loc:Loc AppDb_Add}"
                               Margin="0,0,8,0"
                               MinWidth="100">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Add24"
                                           Width="18" Height="18"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0"/>
                            <TextBlock Text="{loc:Loc AppDb_Add}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ui:Button>

                    <!-- Import/Export -->
                    <ui:Button Appearance="Secondary"
                               Command="{Binding ImportCommand}"
                               ToolTip="{loc:Loc AppDb_ImportTooltip}"
                               AutomationProperties.Name="{loc:Loc AppDb_Import}"
                               Margin="0,0,4,0"
                               MinWidth="80">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="ArrowImport24"
                                           Width="16" Height="16"
                                           VerticalAlignment="Center"
                                           Margin="0,0,6,0"/>
                            <TextBlock Text="{loc:Loc AppDb_Import}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ui:Button>
                    <ui:DropDownButton ToolTip="{loc:Loc AppDb_ExportTooltip}"
                                       Margin="0,0,8,0">
                        <ui:DropDownButton.Content>
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="ArrowExportLtr24"
                                               Width="16" Height="16"
                                               VerticalAlignment="Center"
                                               Margin="0,0,6,0"/>
                                <TextBlock Text="{loc:Loc AppDb_Export}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </ui:DropDownButton.Content>
                        <ui:DropDownButton.Flyout>
                            <ContextMenu>
                                <MenuItem Header="{loc:Loc AppDb_ExportSelected}"
                                          Command="{Binding ExportSelectedCommand}"/>
                                <MenuItem Header="{loc:Loc AppDb_ExportAll}"
                                          Command="{Binding ExportAllCommand}"/>
                            </ContextMenu>
                        </ui:DropDownButton.Flyout>
                    </ui:DropDownButton>

                    <!-- Verify All -->
                    <ui:Button Appearance="Secondary"
                               Command="{Binding VerifyAllSourcesCommand}"
                               ToolTip="{loc:Loc AppDb_VerifySources}"
                               AutomationProperties.Name="{loc:Loc AppDb_VerifySources}"
                               Margin="0,0,8,0"
                               MinWidth="80"
                               Visibility="{Binding IsVerifying, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="CheckmarkStarburst24"
                                           Width="16" Height="16"
                                           VerticalAlignment="Center"
                                           Margin="0,0,6,0"/>
                            <TextBlock Text="{loc:Loc AppDb_Verify}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ui:Button>
                    <ui:Button Appearance="Secondary"
                               Command="{Binding CancelVerificationCommand}"
                               ToolTip="{loc:Loc Btn_Cancel}"
                               AutomationProperties.Name="{loc:Loc Btn_Cancel}"
                               Margin="0,0,8,0"
                               MinWidth="80"
                               Visibility="{Binding IsVerifying, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <ui:ProgressRing IsIndeterminate="True"
                                             Width="16" Height="16"
                                             Margin="0,0,6,0"/>
                            <TextBlock Text="{loc:Loc Btn_Cancel}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ui:Button>

                    <ui:Button Appearance="Transparent"
                               Command="{Binding RefreshCommand}"
                               ToolTip="{loc:Loc AppDb_Refresh}"
                               AutomationProperties.Name="{loc:Loc AppDb_Refresh}"
                               Width="44" Height="44"
                               Icon="{ui:SymbolIcon ArrowSync24}"/>
                </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Toolbar / Filters -->
        <Border Grid.Row="1"
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}"
                BorderThickness="0,0,0,1"
                Padding="16,12">
            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled"
                          CanContentScroll="False">
                <Grid MinWidth="760">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" MinWidth="220"/>
                        <ColumnDefinition Width="Auto" MinWidth="160"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Search Box -->
                    <ui:TextBox Grid.Column="0"
                                Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                PlaceholderText="{loc:Loc AppDb_SearchHint}"
                                Icon="{ui:SymbolIcon Search24}"
                                Margin="0,0,16,0"
                                MinWidth="220"
                                MaxWidth="340"
                                VerticalAlignment="Center"
                                AutomationProperties.Name="{loc:Loc A11y_AppPicker_Search}">
                        <ui:TextBox.InputBindings>
                            <KeyBinding Key="Escape" Command="{Binding ClearFiltersCommand}"/>
                        </ui:TextBox.InputBindings>
                    </ui:TextBox>

                    <!-- Category Filter -->
                    <ComboBox Grid.Column="1"
                              ItemsSource="{Binding Categories}"
                              SelectedItem="{Binding SelectedCategory}"
                              MinWidth="160"
                              MaxWidth="220"
                              VerticalAlignment="Center"
                              Margin="0,0,16,0"
                              AutomationProperties.Name="{loc:Loc A11y_AppPicker_Category}"/>

                    <!-- Spacer -->
                    <Grid Grid.Column="2"/>

                    <!-- Selection Actions -->
                    <StackPanel Grid.Column="3" Orientation="Horizontal">
                        <ui:Button Appearance="Secondary"
                                   Command="{Binding EditCommand}"
                                   ToolTip="{loc:Loc AppDb_EditTooltip}"
                                   AutomationProperties.Name="{loc:Loc AppDb_Edit}"
                                   Margin="0,0,8,0"
                                   MinWidth="80">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Edit24"
                                               Width="16" Height="16"
                                               VerticalAlignment="Center"
                                               Margin="0,0,6,0"/>
                                <TextBlock Text="{loc:Loc AppDb_Edit}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </ui:Button>
                        <ui:Button Appearance="Secondary"
                                   Command="{Binding DuplicateCommand}"
                                   ToolTip="{loc:Loc AppDb_DuplicateTooltip}"
                                   AutomationProperties.Name="{loc:Loc AppDb_Duplicate}"
                                   Margin="0,0,8,0"
                                   MinWidth="80">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Copy24"
                                               Width="16" Height="16"
                                               VerticalAlignment="Center"
                                               Margin="0,0,6,0"/>
                                <TextBlock Text="{loc:Loc AppDb_Duplicate}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </ui:Button>
                        <ui:Button Appearance="Danger"
                                   Command="{Binding DeleteCommand}"
                                   ToolTip="{loc:Loc AppDb_DeleteTooltip}"
                                   AutomationProperties.Name="{loc:Loc AppDb_Delete}"
                                   MinWidth="80">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Delete24"
                                               Width="16" Height="16"
                                               VerticalAlignment="Center"
                                               Margin="0,0,6,0"/>
                                <TextBlock Text="{loc:Loc AppDb_Delete}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </ui:Button>
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </Border>

        <!-- Data Grid -->
        <Border Grid.Row="2" Padding="16">
            <Grid>
                <!-- Loading Indicator with message -->
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <ui:ProgressRing IsIndeterminate="True"
                                     HorizontalAlignment="Center"
                                     Width="48" Height="48"/>
                    <TextBlock Text="{loc:Loc Loading_Database}"
                               FontSize="12"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,16,0,0"/>
                </StackPanel>

                <!-- Applications DataGrid -->
                <DataGrid ItemsSource="{Binding ApplicationsView}"
                          SelectedItem="{Binding SelectedApplication}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          SelectionUnit="FullRow"
                          GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Auto"
                          MouseDoubleClick="DataGrid_MouseDoubleClick"
                          Visibility="{Binding IsLoading, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
                          AutomationProperties.Name="{loc:Loc A11y_Applications_DbGrid}"
                          RowStyle="{StaticResource EnhancedDataGridRowStyle}"
                          CellStyle="{StaticResource EnhancedDataGridCellStyle}">

                    <!-- Context Menu -->
                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="{loc:Loc AppDb_Add}"
                                      Command="{Binding AddCommand}"
                                      InputGestureText="Ctrl+N">
                                <MenuItem.Icon>
                                    <ui:SymbolIcon Symbol="Add24"/>
                                </MenuItem.Icon>
                            </MenuItem>
                            <Separator/>
                            <MenuItem Header="{loc:Loc AppDb_Edit}"
                                      Command="{Binding EditCommand}"
                                      InputGestureText="Ctrl+E">
                                <MenuItem.Icon>
                                    <ui:SymbolIcon Symbol="Edit24"/>
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="{loc:Loc AppDb_Duplicate}"
                                      Command="{Binding DuplicateCommand}"
                                      InputGestureText="Ctrl+D">
                                <MenuItem.Icon>
                                    <ui:SymbolIcon Symbol="Copy24"/>
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="{loc:Loc AppDb_Delete}"
                                      Command="{Binding DeleteCommand}"
                                      InputGestureText="Del">
                                <MenuItem.Icon>
                                    <ui:SymbolIcon Symbol="Delete24" Foreground="{DynamicResource SystemFillColorCriticalBrush}"/>
                                </MenuItem.Icon>
                            </MenuItem>
                            <Separator/>
                            <MenuItem Header="{loc:Loc AppDb_VerifySources}"
                                      Command="{Binding VerifySelectedCommand}">
                                <MenuItem.Icon>
                                    <ui:SymbolIcon Symbol="CheckmarkStarburst24"/>
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="{loc:Loc AppDb_ExportSelected}"
                                      Command="{Binding ExportSelectedCommand}">
                                <MenuItem.Icon>
                                    <ui:SymbolIcon Symbol="ArrowExportLtr24"/>
                                </MenuItem.Icon>
                            </MenuItem>
                            <Separator/>
                            <MenuItem Header="{loc:Loc AppDb_Refresh}"
                                      Command="{Binding RefreshCommand}"
                                      InputGestureText="F5">
                                <MenuItem.Icon>
                                    <ui:SymbolIcon Symbol="ArrowSync24"/>
                                </MenuItem.Icon>
                            </MenuItem>
                        </ContextMenu>
                    </DataGrid.ContextMenu>

                    <DataGrid.Columns>
                        <!-- App ID -->
                        <DataGridTextColumn Header="{loc:Loc AppDb_Col_Id}"
                                            Binding="{Binding AppId}"
                                            Width="*"
                                            MinWidth="140"
                                            SortDirection="Ascending"/>

                        <!-- Name -->
                        <DataGridTextColumn Header="{loc:Loc AppDb_Col_Name}"
                                            Binding="{Binding Name}"
                                            Width="*"
                                            MinWidth="180"/>

                        <!-- Category -->
                        <DataGridTextColumn Header="{loc:Loc AppDb_Col_Category}"
                                            Binding="{Binding Category}"
                                            Width="Auto"
                                            MinWidth="110"/>

                        <!-- Sources -->
                        <DataGridTemplateColumn Header="{loc:Loc AppDb_Col_Sources}" Width="*" MinWidth="180">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <!-- Winget -->
                                        <Border Background="{DynamicResource PrimaryHueLightBrush}"
                                                CornerRadius="4"
                                                Padding="6,2"
                                                Margin="0,0,4,0"
                                                Visibility="{Binding Sources.Winget, Converter={StaticResource NullableToVisibilityConverter}}">
                                            <TextBlock Text="{loc:Loc Source_Winget}" FontSize="11"
                                                       Foreground="{DynamicResource PrimaryHueLightForegroundBrush}"/>
                                        </Border>
                                        <!-- Chocolatey -->
                                        <Border Background="{DynamicResource SecondaryHueLightBrush}"
                                                CornerRadius="4"
                                                Padding="6,2"
                                                Margin="0,0,4,0"
                                                Visibility="{Binding Sources.Chocolatey, Converter={StaticResource NullableToVisibilityConverter}}">
                                            <TextBlock Text="{loc:Loc Source_Chocolatey}" FontSize="11"
                                                       Foreground="{DynamicResource SecondaryHueLightForegroundBrush}"/>
                                        </Border>
                                        <!-- Store -->
                                        <Border Background="{DynamicResource ControlFillColorDefaultBrush}"
                                                CornerRadius="4"
                                                Padding="6,2"
                                                Margin="0,0,4,0"
                                                Visibility="{Binding Sources.Store, Converter={StaticResource NullableToVisibilityConverter}}">
                                            <TextBlock Text="{loc:Loc Source_Store}" FontSize="11"/>
                                        </Border>
                                        <!-- Direct -->
                                        <Border Background="{DynamicResource ControlFillColorDefaultBrush}"
                                                CornerRadius="4"
                                                Padding="6,2"
                                                Visibility="{Binding Sources.DirectUrl, Converter={StaticResource NullableToVisibilityConverter}}">
                                            <TextBlock Text="{loc:Loc Source_Direct}" FontSize="11"/>
                                        </Border>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Priority -->
                        <DataGridTextColumn Header="{loc:Loc AppDb_Col_Priority}"
                                            Binding="{Binding DefaultPriority}"
                                            Width="80"/>

                        <!-- Verified -->
                        <DataGridTemplateColumn Header="{loc:Loc AppDb_Col_Verified}" Width="80">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <ui:SymbolIcon Symbol="{Binding Verified, Converter={StaticResource BoolToInstalledIconConverter}}"
                                                   Foreground="{Binding Verified, Converter={StaticResource BoolToInstalledColorConverter}}"
                                                   Width="20" Height="20"
                                                   HorizontalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Description (expandable) -->
                        <DataGridTextColumn Header="{loc:Loc AppDb_Col_Description}"
                                            Binding="{Binding Description}"
                                            Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Empty State -->
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Visibility="{Binding FilteredCount, Converter={StaticResource ZeroToVisibilityConverter}}">
                    <ui:SymbolIcon Symbol="DatabaseSearch24"
                                   Width="64" Height="64"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,16"
                                   AutomationProperties.Name="{loc:Loc A11y_NoDatabaseIcon}"/>
                    <TextBlock Text="{loc:Loc AppDb_NoResults}"
                               FontSize="20" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="{loc:Loc AppDb_NoResultsHint}"
                               FontSize="12"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,8,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Status Bar -->
        <Border Grid.Row="3"
                Background="{DynamicResource SolidBackgroundFillColorSecondaryBrush}"
                Padding="16,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="{Binding StatusMessage}"
                           FontSize="12"
                           VerticalAlignment="Center"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBlock VerticalAlignment="Center" Margin="0,0,16,0">
                        <Run Text="{loc:Loc AppDb_Showing}"/>
                        <Run Text="{Binding FilteredCount, Mode=OneWay}" FontWeight="SemiBold"/>
                        <Run Text="{loc:Loc AppDb_Of}"/>
                        <Run Text="{Binding TotalCount, Mode=OneWay}" FontWeight="SemiBold"/>
                        <Run Text="{loc:Loc AppDb_Applications}"/>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
