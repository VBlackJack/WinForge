<UserControl x:Class="Win11Forge.GUI.Views.ApplicationsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:loc="clr-namespace:Win11Forge.GUI.Resources"
             xmlns:viewModels="clr-namespace:Win11Forge.GUI.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=viewModels:ApplicationsViewModel}"
             d:DesignHeight="700" d:DesignWidth="1000"
             Loaded="UserControl_Loaded"
             Unloaded="UserControl_Unloaded">

    <UserControl.InputBindings>
        <KeyBinding Key="N" Modifiers="Ctrl" Command="{Binding AddCommand}"/>
        <KeyBinding Key="E" Modifiers="Ctrl" Command="{Binding EditCommand}"/>
        <KeyBinding Key="Delete" Command="{Binding DeleteCommand}"/>
        <KeyBinding Key="F5" Command="{Binding RefreshCommand}"/>
        <KeyBinding Key="D" Modifiers="Ctrl" Command="{Binding DuplicateCommand}"/>
        <KeyBinding Key="Z" Modifiers="Ctrl" Command="{Binding UndoCommand}"/>
        <KeyBinding Key="Y" Modifiers="Ctrl" Command="{Binding RedoCommand}"/>
    </UserControl.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="{DynamicResource MaterialDesignToolBarBackground}"
                Padding="24,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Database"
                                              Width="32" Height="32"
                                              VerticalAlignment="Center"
                                              Margin="0,0,16,0"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{loc:Loc AppDb_Title}"
                                   Style="{StaticResource MaterialDesignHeadline5TextBlock}"/>
                        <TextBlock Text="{loc:Loc AppDb_Subtitle}"
                                   Style="{StaticResource MaterialDesignBody2TextBlock}"
                                   Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                    </StackPanel>
                </StackPanel>

                <!-- Actions -->
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <!-- Undo/Redo buttons -->
                    <Button Style="{StaticResource MaterialDesignIconButton}"
                            Command="{Binding UndoCommand}"
                            ToolTip="{Binding NextUndoDescription, StringFormat='{}{0} (Ctrl+Z)', FallbackValue='Undo (Ctrl+Z)'}"
                            AutomationProperties.Name="Undo last action"
                            Width="44" Height="44"
                            Margin="0,0,4,0">
                        <materialDesign:PackIcon Kind="Undo" Width="24" Height="24"/>
                    </Button>
                    <Button Style="{StaticResource MaterialDesignIconButton}"
                            Command="{Binding RedoCommand}"
                            ToolTip="{Binding NextRedoDescription, StringFormat='{}{0} (Ctrl+Y)', FallbackValue='Redo (Ctrl+Y)'}"
                            AutomationProperties.Name="Redo last action"
                            Width="44" Height="44"
                            Margin="0,0,16,0">
                        <materialDesign:PackIcon Kind="Redo" Width="24" Height="24"/>
                    </Button>

                    <Button Style="{StaticResource MaterialDesignRaisedButton}"
                            Command="{Binding AddCommand}"
                            ToolTip="{loc:Loc AppDb_AddTooltip}"
                            AutomationProperties.Name="Add new application"
                            Margin="0,0,8,0"
                            MinWidth="100">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Plus"
                                                      Width="18" Height="18"
                                                      VerticalAlignment="Center"
                                                      Margin="0,0,8,0"/>
                            <TextBlock Text="{loc:Loc AppDb_Add}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Import/Export -->
                    <Button Style="{StaticResource ThemeAdaptiveOutlinedButton}"
                            Command="{Binding ImportCommand}"
                            ToolTip="{loc:Loc AppDb_ImportTooltip}"
                            AutomationProperties.Name="Import applications"
                            Margin="0,0,4,0"
                            MinWidth="80">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Import"
                                                      Width="16" Height="16"
                                                      VerticalAlignment="Center"
                                                      Margin="0,0,6,0"/>
                            <TextBlock Text="{loc:Loc AppDb_Import}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <materialDesign:PopupBox PlacementMode="BottomAndAlignRightEdges"
                                              ToolTip="{loc:Loc AppDb_ExportTooltip}"
                                              Margin="0,0,8,0">
                        <materialDesign:PopupBox.ToggleContent>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Export"
                                                          Width="16" Height="16"
                                                          VerticalAlignment="Center"
                                                          Margin="0,0,6,0"/>
                                <TextBlock Text="{loc:Loc AppDb_Export}" VerticalAlignment="Center"/>
                                <materialDesign:PackIcon Kind="ChevronDown"
                                                          Width="16" Height="16"
                                                          VerticalAlignment="Center"
                                                          Margin="4,0,0,0"/>
                            </StackPanel>
                        </materialDesign:PopupBox.ToggleContent>
                        <StackPanel MinWidth="150">
                            <Button Content="{loc:Loc AppDb_ExportSelected}"
                                    Command="{Binding ExportSelectedCommand}"
                                    Style="{StaticResource MaterialDesignFlatButton}"
                                    HorizontalContentAlignment="Left"
                                    Padding="16,8"/>
                            <Button Content="{loc:Loc AppDb_ExportAll}"
                                    Command="{Binding ExportAllCommand}"
                                    Style="{StaticResource MaterialDesignFlatButton}"
                                    HorizontalContentAlignment="Left"
                                    Padding="16,8"/>
                        </StackPanel>
                    </materialDesign:PopupBox>

                    <!-- Verify All -->
                    <Button Style="{StaticResource ThemeAdaptiveOutlinedButton}"
                            Command="{Binding VerifyAllSourcesCommand}"
                            ToolTip="{loc:Loc AppDb_VerifySources}"
                            AutomationProperties.Name="Verify all sources"
                            Margin="0,0,8,0"
                            MinWidth="80"
                            Visibility="{Binding IsVerifying, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="CheckAll"
                                                      Width="16" Height="16"
                                                      VerticalAlignment="Center"
                                                      Margin="0,0,6,0"/>
                            <TextBlock Text="{loc:Loc AppDb_Verify}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource ThemeAdaptiveOutlinedButton}"
                            Command="{Binding CancelVerificationCommand}"
                            ToolTip="{loc:Loc Btn_Cancel}"
                            AutomationProperties.Name="Cancel verification"
                            Margin="0,0,8,0"
                            MinWidth="80"
                            Visibility="{Binding IsVerifying, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                                         Value="{Binding VerificationProgress}"
                                         IsIndeterminate="True"
                                         Width="16" Height="16"
                                         Margin="0,0,6,0"/>
                            <TextBlock Text="{loc:Loc Btn_Cancel}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource MaterialDesignIconButton}"
                            Command="{Binding RefreshCommand}"
                            ToolTip="{loc:Loc AppDb_Refresh}"
                            AutomationProperties.Name="Refresh applications list"
                            Width="44" Height="44">
                        <materialDesign:PackIcon Kind="Refresh" Width="24" Height="24"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Toolbar / Filters -->
        <Border Grid.Row="1"
                Background="{DynamicResource MaterialDesignCardBackground}"
                BorderBrush="{DynamicResource MaterialDesignDivider}"
                BorderThickness="0,0,0,1"
                Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="300"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Search Box -->
                <TextBox Grid.Column="0"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         materialDesign:HintAssist.Hint="{loc:Loc AppDb_SearchHint}"
                         materialDesign:TextFieldAssist.HasClearButton="True"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Margin="0,0,16,0"
                         VerticalAlignment="Center"
                         AutomationProperties.Name="Search applications">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Escape" Command="{Binding ClearFiltersCommand}"/>
                    </TextBox.InputBindings>
                </TextBox>

                <!-- Category Filter -->
                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding Categories}"
                          SelectedItem="{Binding SelectedCategory}"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          materialDesign:HintAssist.Hint="{loc:Loc AppDb_CategoryFilter}"
                          VerticalAlignment="Center"
                          Margin="0,0,16,0"
                          AutomationProperties.Name="Filter by category"/>

                <!-- Spacer -->
                <Grid Grid.Column="2"/>

                <!-- Selection Actions -->
                <StackPanel Grid.Column="3" Orientation="Horizontal">
                    <Button Style="{StaticResource ThemeAdaptiveOutlinedButton}"
                            Command="{Binding EditCommand}"
                            ToolTip="{loc:Loc AppDb_EditTooltip}"
                            AutomationProperties.Name="Edit selected application"
                            Margin="0,0,8,0"
                            MinWidth="80">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Pencil"
                                                      Width="16" Height="16"
                                                      VerticalAlignment="Center"
                                                      Margin="0,0,6,0"/>
                            <TextBlock Text="{loc:Loc AppDb_Edit}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource ThemeAdaptiveOutlinedButton}"
                            Command="{Binding DuplicateCommand}"
                            ToolTip="{loc:Loc AppDb_DuplicateTooltip}"
                            AutomationProperties.Name="Duplicate selected application"
                            Margin="0,0,8,0"
                            MinWidth="80">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ContentCopy"
                                                      Width="16" Height="16"
                                                      VerticalAlignment="Center"
                                                      Margin="0,0,6,0"/>
                            <TextBlock Text="{loc:Loc AppDb_Duplicate}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource DestructiveOutlinedButton}"
                            Command="{Binding DeleteCommand}"
                            ToolTip="{loc:Loc AppDb_DeleteTooltip}"
                            AutomationProperties.Name="Delete selected application"
                            MinWidth="80">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Delete"
                                                      Width="16" Height="16"
                                                      VerticalAlignment="Center"
                                                      Margin="0,0,6,0"/>
                            <TextBlock Text="{loc:Loc AppDb_Delete}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Data Grid -->
        <Border Grid.Row="2" Padding="16">
            <Grid>
                <!-- Loading Indicator with message -->
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                                 IsIndeterminate="True"
                                 HorizontalAlignment="Center"
                                 Width="48" Height="48"/>
                    <TextBlock Text="{loc:Loc Loading_Database}"
                               Style="{StaticResource MaterialDesignBody2TextBlock}"
                               Foreground="{DynamicResource MaterialDesignBodyLight}"
                               HorizontalAlignment="Center"
                               Margin="0,16,0,0"/>
                </StackPanel>

                <!-- Applications DataGrid -->
                <DataGrid ItemsSource="{Binding ApplicationsView}"
                          SelectedItem="{Binding SelectedApplication}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          SelectionUnit="FullRow"
                          GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Auto"
                          MouseDoubleClick="DataGrid_MouseDoubleClick"
                          Visibility="{Binding IsLoading, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
                          AutomationProperties.Name="Applications database grid"
                          RowStyle="{StaticResource EnhancedDataGridRowStyle}"
                          CellStyle="{StaticResource EnhancedDataGridCellStyle}">

                    <!-- Context Menu -->
                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="{loc:Loc AppDb_Add}"
                                      Command="{Binding AddCommand}"
                                      InputGestureText="Ctrl+N">
                                <MenuItem.Icon>
                                    <materialDesign:PackIcon Kind="Plus"/>
                                </MenuItem.Icon>
                            </MenuItem>
                            <Separator/>
                            <MenuItem Header="{loc:Loc AppDb_Edit}"
                                      Command="{Binding EditCommand}"
                                      InputGestureText="Ctrl+E">
                                <MenuItem.Icon>
                                    <materialDesign:PackIcon Kind="Pencil"/>
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="{loc:Loc AppDb_Duplicate}"
                                      Command="{Binding DuplicateCommand}"
                                      InputGestureText="Ctrl+D">
                                <MenuItem.Icon>
                                    <materialDesign:PackIcon Kind="ContentCopy"/>
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="{loc:Loc AppDb_Delete}"
                                      Command="{Binding DeleteCommand}"
                                      InputGestureText="Del">
                                <MenuItem.Icon>
                                    <materialDesign:PackIcon Kind="Delete" Foreground="{DynamicResource MaterialDesignValidationErrorBrush}"/>
                                </MenuItem.Icon>
                            </MenuItem>
                            <Separator/>
                            <MenuItem Header="{loc:Loc AppDb_VerifySources}"
                                      Command="{Binding VerifySelectedCommand}">
                                <MenuItem.Icon>
                                    <materialDesign:PackIcon Kind="CheckDecagram"/>
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="{loc:Loc AppDb_ExportSelected}"
                                      Command="{Binding ExportSelectedCommand}">
                                <MenuItem.Icon>
                                    <materialDesign:PackIcon Kind="Export"/>
                                </MenuItem.Icon>
                            </MenuItem>
                            <Separator/>
                            <MenuItem Header="{loc:Loc AppDb_Refresh}"
                                      Command="{Binding RefreshCommand}"
                                      InputGestureText="F5">
                                <MenuItem.Icon>
                                    <materialDesign:PackIcon Kind="Refresh"/>
                                </MenuItem.Icon>
                            </MenuItem>
                        </ContextMenu>
                    </DataGrid.ContextMenu>

                    <DataGrid.Columns>
                        <!-- App ID -->
                        <DataGridTextColumn Header="{loc:Loc AppDb_Col_Id}"
                                            Binding="{Binding AppId}"
                                            Width="180"
                                            SortDirection="Ascending"/>

                        <!-- Name -->
                        <DataGridTextColumn Header="{loc:Loc AppDb_Col_Name}"
                                            Binding="{Binding Name}"
                                            Width="200"/>

                        <!-- Category -->
                        <DataGridTextColumn Header="{loc:Loc AppDb_Col_Category}"
                                            Binding="{Binding Category}"
                                            Width="120"/>

                        <!-- Sources -->
                        <DataGridTemplateColumn Header="{loc:Loc AppDb_Col_Sources}" Width="200">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <!-- Winget -->
                                        <Border Background="{DynamicResource PrimaryHueLightBrush}"
                                                CornerRadius="4"
                                                Padding="6,2"
                                                Margin="0,0,4,0"
                                                Visibility="{Binding Sources.Winget, Converter={StaticResource NullableToVisibilityConverter}}">
                                            <TextBlock Text="{loc:Loc Source_Winget}" FontSize="11"
                                                       Foreground="{DynamicResource PrimaryHueLightForegroundBrush}"/>
                                        </Border>
                                        <!-- Chocolatey -->
                                        <Border Background="{DynamicResource SecondaryHueLightBrush}"
                                                CornerRadius="4"
                                                Padding="6,2"
                                                Margin="0,0,4,0"
                                                Visibility="{Binding Sources.Chocolatey, Converter={StaticResource NullableToVisibilityConverter}}">
                                            <TextBlock Text="{loc:Loc Source_Chocolatey}" FontSize="11"
                                                       Foreground="{DynamicResource SecondaryHueLightForegroundBrush}"/>
                                        </Border>
                                        <!-- Store -->
                                        <Border Background="{DynamicResource MaterialDesignChipBackground}"
                                                CornerRadius="4"
                                                Padding="6,2"
                                                Margin="0,0,4,0"
                                                Visibility="{Binding Sources.Store, Converter={StaticResource NullableToVisibilityConverter}}">
                                            <TextBlock Text="{loc:Loc Source_Store}" FontSize="11"/>
                                        </Border>
                                        <!-- Direct -->
                                        <Border Background="{DynamicResource MaterialDesignChipBackground}"
                                                CornerRadius="4"
                                                Padding="6,2"
                                                Visibility="{Binding Sources.DirectUrl, Converter={StaticResource NullableToVisibilityConverter}}">
                                            <TextBlock Text="{loc:Loc Source_Direct}" FontSize="11"/>
                                        </Border>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Priority -->
                        <DataGridTextColumn Header="{loc:Loc AppDb_Col_Priority}"
                                            Binding="{Binding DefaultPriority}"
                                            Width="80"/>

                        <!-- Verified -->
                        <DataGridTemplateColumn Header="{loc:Loc AppDb_Col_Verified}" Width="80">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <materialDesign:PackIcon Kind="{Binding Verified, Converter={StaticResource BoolToInstalledIconConverter}}"
                                                              Foreground="{Binding Verified, Converter={StaticResource BoolToInstalledColorConverter}}"
                                                              Width="20" Height="20"
                                                              HorizontalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Description (expandable) -->
                        <DataGridTextColumn Header="{loc:Loc AppDb_Col_Description}"
                                            Binding="{Binding Description}"
                                            Width="*"
                                            ElementStyle="{StaticResource MaterialDesignDataGridTextColumnStyle}"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Empty State -->
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Visibility="{Binding FilteredCount, Converter={StaticResource ZeroToVisibilityConverter}}">
                    <materialDesign:PackIcon Kind="DatabaseOff"
                                              Width="64" Height="64"
                                              Foreground="{DynamicResource MaterialDesignBodyLight}"
                                              HorizontalAlignment="Center"
                                              Margin="0,0,0,16"
                                              AutomationProperties.Name="{loc:Loc A11y_NoDatabaseIcon}"/>
                    <TextBlock Text="{loc:Loc AppDb_NoResults}"
                               Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                               Foreground="{DynamicResource MaterialDesignBodyLight}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="{loc:Loc AppDb_NoResultsHint}"
                               Style="{StaticResource MaterialDesignBody2TextBlock}"
                               Foreground="{DynamicResource MaterialDesignBodyLight}"
                               HorizontalAlignment="Center"
                               Margin="0,8,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Status Bar -->
        <Border Grid.Row="3"
                Background="{DynamicResource MaterialDesignToolBarBackground}"
                Padding="16,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="{Binding StatusMessage}"
                           Style="{StaticResource MaterialDesignBody2TextBlock}"
                           VerticalAlignment="Center"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBlock VerticalAlignment="Center" Margin="0,0,16,0">
                        <Run Text="{loc:Loc AppDb_Showing}"/>
                        <Run Text="{Binding FilteredCount, Mode=OneWay}" FontWeight="SemiBold"/>
                        <Run Text="{loc:Loc AppDb_Of}"/>
                        <Run Text="{Binding TotalCount, Mode=OneWay}" FontWeight="SemiBold"/>
                        <Run Text="{loc:Loc AppDb_Applications}"/>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
