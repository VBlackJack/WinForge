<UserControl x:Class="Win11Forge.GUI.Views.AppsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:loc="clr-namespace:Win11Forge.GUI.Resources"
             xmlns:viewModels="clr-namespace:Win11Forge.GUI.ViewModels"
             xmlns:models="clr-namespace:Win11Forge.GUI.Models"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=viewModels:AppsViewModel}"
             d:DesignHeight="700" d:DesignWidth="1000">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0"
                   Text="{loc:Loc Apps_Title}"
                   Style="{StaticResource MaterialDesignHeadline4TextBlock}"
                   Margin="0,0,0,24"/>

        <!-- Filter Bar Card -->
        <materialDesign:Card Grid.Row="1"
                              Padding="16"
                              Margin="0,0,0,16"
                              materialDesign:ElevationAssist.Elevation="Dp2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MaxWidth="400"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Search TextBox -->
                <TextBox Grid.Column="0"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         materialDesign:HintAssist.Hint="{loc:Loc Apps_SearchHint}"
                         materialDesign:TextFieldAssist.HasClearButton="True"
                         materialDesign:TextFieldAssist.HasLeadingIcon="True"
                         materialDesign:TextFieldAssist.LeadingIcon="Magnify"/>

                <!-- Category ComboBox -->
                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding Categories}"
                          SelectedItem="{Binding SelectedCategory}"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          Width="180"
                          Margin="16,0,0,0"/>

                <!-- Clear Filters Button -->
                <Button Grid.Column="2"
                        Command="{Binding ClearFiltersCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        ToolTip="Clear filters"
                        Margin="8,0,0,0">
                    <materialDesign:PackIcon Kind="FilterRemove"/>
                </Button>

                <!-- Stats Display -->
                <StackPanel Grid.Column="4"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <!-- Normal stats -->
                    <TextBlock Style="{StaticResource MaterialDesignBody2TextBlock}"
                               VerticalAlignment="Center"
                               Visibility="{Binding IsScanning, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                        <Run Text="{Binding FilteredCount, Mode=OneWay}"/>
                        <Run Text="/"/>
                        <Run Text="{Binding TotalApplicationsCount, Mode=OneWay}"/>
                        <Run Text=" | "/>
                        <Run Text="{Binding InstalledCount, Mode=OneWay}" Foreground="{DynamicResource SecondaryHueMidBrush}"/>
                        <Run Text=" installed"/>
                    </TextBlock>
                    <!-- Scan progress -->
                    <StackPanel Orientation="Horizontal"
                                Visibility="{Binding IsScanning, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                                     Value="0"
                                     IsIndeterminate="True"
                                     Width="20"
                                     Height="20"
                                     Margin="0,0,8,0"/>
                        <TextBlock Style="{StaticResource MaterialDesignBody2TextBlock}"
                                   VerticalAlignment="Center">
                            <Run Text="{Binding ScannedCount, Mode=OneWay}"/>
                            <Run Text="/"/>
                            <Run Text="{Binding TotalApplicationsCount, Mode=OneWay}"/>
                        </TextBlock>
                    </StackPanel>
                </StackPanel>

                <!-- Scan/Cancel Button -->
                <Button Grid.Column="5"
                        Command="{Binding ScanCommand}"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Content="{loc:Loc Btn_Scan}"
                        Margin="16,0,0,0"
                        Visibility="{Binding IsScanning, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>
                <Button Grid.Column="5"
                        Command="{Binding CancelScanCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Content="{loc:Loc Btn_Cancel}"
                        Margin="16,0,0,0"
                        Visibility="{Binding IsScanning, Converter={StaticResource BooleanToVisibilityConverter}}"/>
            </Grid>
        </materialDesign:Card>

        <!-- Applications DataGrid -->
        <materialDesign:Card Grid.Row="2"
                              Padding="0"
                              materialDesign:ElevationAssist.Elevation="Dp2">
            <Grid>
                <!-- Loading Indicator -->
                <StackPanel Orientation="Vertical"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                                 Value="0"
                                 IsIndeterminate="True"
                                 Width="48"
                                 Height="48"/>
                    <TextBlock Text="{loc:Loc Common_Loading}"
                               Style="{StaticResource MaterialDesignBody1TextBlock}"
                               HorizontalAlignment="Center"
                               Margin="0,16,0,0"/>
                </StackPanel>

                <!-- DataGrid -->
                <DataGrid ItemsSource="{Binding FilteredApplications}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          CanUserReorderColumns="True"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          SelectionUnit="FullRow"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          BorderThickness="0"
                          materialDesign:DataGridAssist.CellPadding="16 8"
                          materialDesign:DataGridAssist.ColumnHeaderPadding="16 8"
                          Visibility="{Binding IsLoading, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                    <DataGrid.Columns>
                        <!-- Application Name Column -->
                        <DataGridTemplateColumn Width="*" MinWidth="200">
                            <DataGridTemplateColumn.Header>
                                <TextBlock Text="{loc:Loc Col_Application}"/>
                            </DataGridTemplateColumn.Header>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate DataType="{x:Type models:ApplicationModel}">
                                    <StackPanel Orientation="Vertical">
                                        <TextBlock Text="{Binding Name}"
                                                   Style="{StaticResource MaterialDesignBody1TextBlock}"
                                                   FontWeight="Medium"/>
                                        <TextBlock Text="{Binding Description}"
                                                   Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                                   Opacity="0.7"
                                                   TextTrimming="CharacterEllipsis"
                                                   MaxWidth="350"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Category Column -->
                        <DataGridTemplateColumn Width="130">
                            <DataGridTemplateColumn.Header>
                                <TextBlock Text="{loc:Loc Col_Category}"/>
                            </DataGridTemplateColumn.Header>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate DataType="{x:Type models:ApplicationModel}">
                                    <materialDesign:Chip Content="{Binding Category}"
                                                          IconBackground="{DynamicResource PrimaryHueLightBrush}"
                                                          IconForeground="{DynamicResource PrimaryHueLightForegroundBrush}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Sources Column -->
                        <DataGridTemplateColumn Width="150">
                            <DataGridTemplateColumn.Header>
                                <TextBlock Text="{loc:Loc Apps_Col_Sources}"/>
                            </DataGridTemplateColumn.Header>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate DataType="{x:Type models:ApplicationModel}">
                                    <TextBlock Text="{Binding Sources}"
                                               Style="{StaticResource MaterialDesignBody2TextBlock}"
                                               Foreground="{DynamicResource SecondaryHueMidBrush}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- App ID Column -->
                        <DataGridTemplateColumn Width="180">
                            <DataGridTemplateColumn.Header>
                                <TextBlock Text="{loc:Loc Apps_Col_Id}"/>
                            </DataGridTemplateColumn.Header>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate DataType="{x:Type models:ApplicationModel}">
                                    <TextBlock Text="{Binding AppId}"
                                               Style="{StaticResource MaterialDesignBody2TextBlock}"
                                               FontFamily="Consolas"
                                               Opacity="0.8"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Priority Column -->
                        <DataGridTemplateColumn Width="80">
                            <DataGridTemplateColumn.Header>
                                <TextBlock Text="{loc:Loc Col_Priority}"/>
                            </DataGridTemplateColumn.Header>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate DataType="{x:Type models:ApplicationModel}">
                                    <TextBlock Text="{Binding Priority}"
                                               HorizontalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Status Column -->
                        <DataGridTemplateColumn Width="120">
                            <DataGridTemplateColumn.Header>
                                <TextBlock Text="{loc:Loc Col_Status}"/>
                            </DataGridTemplateColumn.Header>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate DataType="{x:Type models:ApplicationModel}">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="{Binding Status, Converter={StaticResource StatusToIconConverter}}"
                                                                  Width="18"
                                                                  Height="18"
                                                                  Foreground="{Binding Status, Converter={StaticResource StatusToColorConverter}}"
                                                                  VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding StatusMessage}"
                                                   Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                                   VerticalAlignment="Center"
                                                   Margin="6,0,0,0"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Actions Column -->
                        <DataGridTemplateColumn Width="100">
                            <DataGridTemplateColumn.Header>
                                <TextBlock Text="{loc:Loc Col_Actions}"/>
                            </DataGridTemplateColumn.Header>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate DataType="{x:Type models:ApplicationModel}">
                                    <Button Content="{loc:Loc Btn_Install}"
                                            Command="{Binding DataContext.InstallAppCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            Padding="8,4">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignFlatButton}">
                                                <Setter Property="Foreground" Value="{DynamicResource SecondaryHueMidBrush}"/>
                                                <Style.Triggers>
                                                    <!-- Hide if Installed -->
                                                    <DataTrigger Binding="{Binding Status}" Value="{x:Static models:ApplicationStatus.Installed}">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                    <!-- Hide if AlreadyInstalled -->
                                                    <DataTrigger Binding="{Binding Status}" Value="{x:Static models:ApplicationStatus.AlreadyInstalled}">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                    <!-- Hide if Installing -->
                                                    <DataTrigger Binding="{Binding Status}" Value="{x:Static models:ApplicationStatus.Installing}">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </materialDesign:Card>

        <!-- Error Message -->
        <TextBlock Grid.Row="2"
                   Text="{Binding ErrorMessage}"
                   Foreground="{DynamicResource MaterialDesignValidationErrorBrush}"
                   Style="{StaticResource MaterialDesignBody1TextBlock}"
                   Visibility="{Binding ErrorMessage, Converter={StaticResource NullableToVisibilityConverter}}"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"/>
    </Grid>
</UserControl>
