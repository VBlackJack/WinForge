<UserControl x:Class="Win11Forge.GUI.Views.AppsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:loc="clr-namespace:Win11Forge.GUI.Resources"
             xmlns:viewModels="clr-namespace:Win11Forge.GUI.ViewModels"
             xmlns:models="clr-namespace:Win11Forge.GUI.Models"
             xmlns:controls="clr-namespace:Win11Forge.GUI.Controls"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=viewModels:AppsViewModel}"
             d:DesignHeight="700" d:DesignWidth="1000">

    <!-- Single unified DialogHost to avoid nesting issues -->
    <materialDesign:DialogHost Identifier="AppsDialogHost"
                                IsOpen="{Binding IsDialogOpen, Mode=OneWay}"
                                CloseOnClickAway="True"
                                DialogClosing="DialogHost_DialogClosing">
        <materialDesign:DialogHost.DialogContent>
            <Grid>
                <!-- Log Viewer Dialog -->
                <Border MinWidth="600" MaxWidth="900" MaxHeight="500" Padding="24"
                        Visibility="{Binding IsLogViewerOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Dialog Header -->
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                            <materialDesign:PackIcon Kind="FileDocumentOutline"
                                                      Width="24" Height="24"
                                                      VerticalAlignment="Center"
                                                      Margin="0,0,12,0"/>
                            <TextBlock Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                                       VerticalAlignment="Center">
                                <Run Text="{loc:Loc LogViewer_Title}"/>
                                <Run Text=" - "/>
                                <Run Text="{Binding LogViewerApplication.Name, FallbackValue=''}"/>
                            </TextBlock>
                        </StackPanel>

                        <!-- Log Content -->
                        <Border Grid.Row="1"
                                Background="{DynamicResource MaterialDesignCardBackground}"
                                BorderBrush="{DynamicResource MaterialDesignDivider}"
                                BorderThickness="1"
                                CornerRadius="4">
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Auto">
                                <TextBox Text="{Binding LogViewerApplication.LogOutput, Mode=OneWay}"
                                         IsReadOnly="True"
                                         TextWrapping="NoWrap"
                                         FontFamily="Consolas"
                                         FontSize="12"
                                         BorderThickness="0"
                                         Padding="12"
                                         Background="Transparent"
                                         VerticalScrollBarVisibility="Disabled"
                                         HorizontalScrollBarVisibility="Disabled"/>
                            </ScrollViewer>
                        </Border>

                        <!-- No logs message -->
                        <TextBlock Grid.Row="1"
                                   Text="{loc:Loc LogViewer_NoLogs}"
                                   Style="{StaticResource MaterialDesignBody2TextBlock}"
                                   Foreground="{DynamicResource MaterialDesignBodyLight}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Visibility="{Binding LogViewerApplication.LogOutput, Converter={StaticResource InverseNullableToVisibilityConverter}}"/>

                        <!-- Dialog Actions -->
                        <StackPanel Grid.Row="2"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    Margin="0,16,0,0">
                            <Button Content="{loc:Loc LogViewer_Copy}"
                                    Style="{StaticResource ThemeAdaptiveOutlinedButton}"
                                    Click="CopyLogsToClipboard_Click"
                                    Margin="0,0,12,0"/>
                            <Button Content="{loc:Loc LogViewer_Close}"
                                    Style="{StaticResource MaterialDesignRaisedButton}"
                                    Command="{Binding CloseLogViewerCommand}"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Summary Dialog -->
                <Border MinWidth="400" MaxWidth="500" Padding="24"
                        Visibility="{Binding IsSummaryDialogOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Dialog Header -->
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                            <materialDesign:PackIcon Kind="{Binding LastDeploymentResult, Converter={StaticResource StatusToIconConverter}}"
                                                      Foreground="{Binding LastDeploymentResult, Converter={StaticResource StatusToColorConverter}}"
                                                      Width="28" Height="28"
                                                      VerticalAlignment="Center"
                                                      Margin="0,0,12,0"/>
                            <TextBlock Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                                       Text="{loc:Loc Summary_Title}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Summary Content -->
                        <StackPanel Grid.Row="1" Margin="0,0,0,24">
                            <!-- Result Message -->
                            <TextBlock Text="{Binding LastDeploymentResult, Converter={StaticResource DeploymentResultToStringConverter}}"
                                       Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                                       Margin="0,0,0,16"/>

                            <!-- Stats Grid -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Success Count -->
                                <TextBlock Grid.Row="0" Grid.Column="0"
                                           Text="{loc:Loc Summary_Successful}"
                                           Style="{StaticResource MaterialDesignBody1TextBlock}"
                                           Margin="0,0,16,8"/>
                                <TextBlock Grid.Row="0" Grid.Column="1"
                                           Text="{Binding SuccessCount}"
                                           Style="{StaticResource MaterialDesignBody1TextBlock}"
                                           Foreground="{DynamicResource AccentGreenTextBrush}"
                                           FontWeight="Bold"
                                           Margin="0,0,0,8"/>

                                <!-- Failed Count -->
                                <TextBlock Grid.Row="1" Grid.Column="0"
                                           Text="{loc:Loc Summary_FailedCount}"
                                           Style="{StaticResource MaterialDesignBody1TextBlock}"
                                           Margin="0,0,16,8"/>
                                <TextBlock Grid.Row="1" Grid.Column="1"
                                           Text="{Binding FailedCount}"
                                           Style="{StaticResource MaterialDesignBody1TextBlock}"
                                           Foreground="{DynamicResource MaterialDesignValidationErrorBrush}"
                                           FontWeight="Bold"
                                           Margin="0,0,0,8"/>

                                <!-- Skipped Count -->
                                <TextBlock Grid.Row="2" Grid.Column="0"
                                           Text="{loc:Loc Summary_SkippedCount}"
                                           Style="{StaticResource MaterialDesignBody1TextBlock}"
                                           Margin="0,0,16,0"/>
                                <TextBlock Grid.Row="2" Grid.Column="1"
                                           Text="{Binding SkippedCount}"
                                           Style="{StaticResource MaterialDesignBody1TextBlock}"
                                           Foreground="{DynamicResource MaterialDesignBodyLight}"
                                           FontWeight="Bold"/>
                            </Grid>
                        </StackPanel>

                        <!-- Dialog Actions -->
                        <Button Grid.Row="2"
                                Content="{loc:Loc Summary_Close}"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                Command="{Binding CloseSummaryDialogCommand}"
                                HorizontalAlignment="Right"/>
                    </Grid>
                </Border>
            </Grid>
        </materialDesign:DialogHost.DialogContent>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0"
                   Text="{loc:Loc Apps_Title}"
                   Style="{StaticResource MaterialDesignHeadline4TextBlock}"
                   Margin="0,0,0,16"/>

        <!-- Profile Selector Card -->
        <materialDesign:Card Grid.Row="1"
                              Padding="{StaticResource CardPadding}"
                              Margin="{StaticResource MarginNormalBottom}"
                              materialDesign:ElevationAssist.Elevation="Dp2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Profile Icon and Label with Help -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="FolderAccount"
                                              Width="24" Height="24"
                                              VerticalAlignment="Center"
                                              Foreground="{DynamicResource PrimaryHueMidBrush}"
                                              Margin="0,0,12,0"/>
                    <TextBlock Text="{loc:Loc Apps_ProfileLabel}"
                               Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                               VerticalAlignment="Center"/>
                    <materialDesign:PackIcon Kind="HelpCircleOutline"
                                              Width="18" Height="18"
                                              VerticalAlignment="Center"
                                              Foreground="{DynamicResource MaterialDesignBodyLight}"
                                              Margin="6,0,0,0"
                                              ToolTip="{loc:Loc Apps_ProfileHelpTooltip}"
                                              Cursor="Help"/>
                </StackPanel>

                <!-- Profile ComboBox (visible when profiles exist) -->
                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding AvailableProfiles}"
                          SelectedItem="{Binding SelectedProfile}"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          materialDesign:HintAssist.Hint="{loc:Loc Apps_SelectProfile}"
                          MinWidth="180"
                          Margin="16,0,0,0"
                          ToolTip="{loc:Loc Apps_ProfileHelpTooltip}"
                          Visibility="{Binding HasProfiles, Converter={StaticResource BooleanToVisibilityConverter}}"
                          AutomationProperties.Name="Select deployment profile"
                          AutomationProperties.HelpText="Choose a profile to auto-select its applications"/>

                <!-- No Profiles Message (visible when no profiles exist) -->
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            Margin="16,0,0,0"
                            VerticalAlignment="Center"
                            Visibility="{Binding HasProfiles, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                    <materialDesign:PackIcon Kind="InformationOutline"
                                              Width="18" Height="18"
                                              Foreground="{DynamicResource MaterialDesignBodyLight}"
                                              VerticalAlignment="Center"
                                              Margin="0,0,8,0"/>
                    <TextBlock Text="{loc:Loc Apps_NoProfilesAvailable}"
                               Style="{StaticResource MaterialDesignBody2TextBlock}"
                               Foreground="{DynamicResource MaterialDesignBodyLight}"
                               VerticalAlignment="Center"
                               ToolTip="{loc:Loc Apps_NoProfilesHint}"/>
                </StackPanel>

                <!-- Clear Profile Button -->
                <Button Grid.Column="2"
                        Command="{Binding ClearProfileCommand}"
                        Style="{StaticResource ThemeAdaptiveOutlinedButton}"
                        ToolTip="{loc:Loc Apps_ClearProfile}"
                        Margin="8,0,0,0"
                        Visibility="{Binding HasProfileApplied, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <materialDesign:PackIcon Kind="Close"/>
                </Button>

                <!-- Save Profile Button -->
                <Button Grid.Column="3"
                        Command="{Binding ShowSaveProfileDialogCommand}"
                        Style="{StaticResource ThemeAdaptiveOutlinedButton}"
                        ToolTip="{loc:Loc Apps_SaveProfile}"
                        Margin="8,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="ContentSave" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="{loc:Loc Apps_SaveProfile}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Profile Info Badge -->
                <Border Grid.Column="4"
                        Background="{DynamicResource PrimaryHueMidBrush}"
                        CornerRadius="4"
                        Padding="12,6"
                        Margin="16,0,0,0"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Left"
                        Visibility="{Binding HasProfileApplied, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="CheckCircle" Width="16" Height="16" VerticalAlignment="Center" Margin="0,0,8,0"
                                                  Foreground="White"/>
                        <TextBlock Style="{StaticResource MaterialDesignCaptionTextBlock}" VerticalAlignment="Center"
                                   Foreground="White">
                            <Run Text="{Binding SelectedCount}"/>
                            <Run Text="{loc:Loc Apps_AppsSelected}"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Install Selected Button (prominent) -->
                <Button Grid.Column="5"
                        Command="{Binding InstallSelectedCommand}"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        ToolTip="{loc:Loc Apps_InstallSelected}"
                        Visibility="{Binding HasSelectedApps, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Download" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="{loc:Loc Apps_InstallSelected}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </materialDesign:Card>

        <!-- Filter Bar Card -->
        <materialDesign:Card Grid.Row="2"
                              Padding="{StaticResource CardPadding}"
                              Margin="{StaticResource MarginNormalBottom}"
                              materialDesign:ElevationAssist.Elevation="Dp2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <!-- Filters Section -->
                    <ColumnDefinition Width="Auto" MinWidth="220"/> <!-- 0: Search -->
                    <ColumnDefinition Width="Auto"/>                <!-- 1: Category -->
                    <ColumnDefinition Width="Auto"/>                <!-- 2: Status -->
                    <ColumnDefinition Width="Auto"/>                <!-- 3: Clear Filters -->
                    <!-- Separator -->
                    <ColumnDefinition Width="Auto"/>                <!-- 4: Separator -->
                    <!-- View Options Section -->
                    <ColumnDefinition Width="Auto"/>                <!-- 5: Column Visibility -->
                    <ColumnDefinition Width="Auto"/>                <!-- 6: Active Filter Badges -->
                    <ColumnDefinition Width="*"/>                   <!-- 7: Stats (flexible) -->
                    <!-- Actions Section -->
                    <ColumnDefinition Width="Auto"/>                <!-- 8: Scan -->
                    <ColumnDefinition Width="Auto"/>                <!-- 9: Scan Updates -->
                </Grid.ColumnDefinitions>

                <!-- FILTERS SECTION -->

                <!-- Search Box with Auto-complete -->
                <controls:SearchBox Grid.Column="0"
                                     Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     SuggestionsSource="{Binding ApplicationNames}"
                                     Width="220"
                                     Margin="0,0,16,0"/>

                <!-- Category ComboBox -->
                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding Categories}"
                          SelectedItem="{Binding SelectedCategory}"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          MinWidth="140"
                          MaxWidth="200"
                          Margin="0,0,0,0"
                          AutomationProperties.Name="Filter by category"
                          AutomationProperties.HelpText="Select a category to filter applications"/>

                <!-- Status Filter ComboBox -->
                <ComboBox Grid.Column="2"
                          ItemsSource="{Binding StatusFilters}"
                          SelectedItem="{Binding SelectedStatusFilter}"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          MinWidth="120"
                          MaxWidth="180"
                          Margin="8,0,0,0"
                          AutomationProperties.Name="Filter by status"
                          AutomationProperties.HelpText="Select a status to filter applications">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Converter={StaticResource StatusFilterToStringConverter}}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <!-- Clear Filters Button -->
                <Button Grid.Column="3"
                        Command="{Binding ClearFiltersCommand}"
                        Style="{StaticResource ThemeAdaptiveOutlinedButton}"
                        ToolTip="{loc:Loc Apps_ClearFilters}"
                        Margin="8,0,0,0"
                        AutomationProperties.Name="Clear all filters"
                        AutomationProperties.HelpText="Reset search text, category, and status filters">
                    <materialDesign:PackIcon Kind="FilterRemove"/>
                </Button>

                <!-- VIEW OPTIONS SECTION -->

                <!-- Separator between Filters and View Options -->
                <Border Grid.Column="4"
                        Width="1"
                        Background="{DynamicResource MaterialDesignDivider}"
                        Margin="16,4"
                        VerticalAlignment="Stretch"/>

                <!-- Column Visibility Toggle Button with Popup -->
                <materialDesign:PopupBox Grid.Column="5"
                                          PlacementMode="BottomAndAlignRightEdges"
                                          ToolTip="{loc:Loc Apps_ColumnVisibility}"
                                          Margin="8,0,0,0"
                                          StaysOpen="True"
                                          AutomationProperties.Name="Toggle column visibility"
                                          AutomationProperties.HelpText="Show or hide table columns">
                    <materialDesign:PopupBox.ToggleContent>
                        <materialDesign:PackIcon Kind="TableColumn" Width="24" Height="24"/>
                    </materialDesign:PopupBox.ToggleContent>
                    <StackPanel Orientation="Vertical" MinWidth="180" Margin="8">
                        <TextBlock Text="{loc:Loc Apps_ColumnVisibility}"
                                   Style="{StaticResource MaterialDesignSubtitle2TextBlock}"
                                   Margin="8,4,8,12"/>
                        <CheckBox Content="{loc:Loc Col_Favorites}"
                                  IsChecked="{Binding ShowFavoritesColumn, Mode=TwoWay}"
                                  Style="{StaticResource MaterialDesignCheckBox}"
                                  Margin="8,4"/>
                        <CheckBox Content="{loc:Loc Col_Version}"
                                  IsChecked="{Binding ShowVersionColumn, Mode=TwoWay}"
                                  Style="{StaticResource MaterialDesignCheckBox}"
                                  Margin="8,4"/>
                        <CheckBox Content="{loc:Loc Col_Status}"
                                  IsChecked="{Binding ShowStatusColumn, Mode=TwoWay}"
                                  Style="{StaticResource MaterialDesignCheckBox}"
                                  Margin="8,4"/>
                        <CheckBox Content="{loc:Loc Col_Category}"
                                  IsChecked="{Binding ShowCategoryColumn, Mode=TwoWay}"
                                  Style="{StaticResource MaterialDesignCheckBox}"
                                  Margin="8,4"/>
                        <CheckBox Content="{loc:Loc Apps_Col_Sources}"
                                  IsChecked="{Binding ShowSourcesColumn, Mode=TwoWay}"
                                  Style="{StaticResource MaterialDesignCheckBox}"
                                  Margin="8,4"/>
                        <CheckBox Content="{loc:Loc Col_Logs}"
                                  IsChecked="{Binding ShowLogsColumn, Mode=TwoWay}"
                                  Style="{StaticResource MaterialDesignCheckBox}"
                                  Margin="8,4"/>
                        <Separator Margin="8,8"/>
                        <Button Content="{loc:Loc Apps_ResetColumns}"
                                Command="{Binding ResetColumnsToDefaultsCommand}"
                                Style="{StaticResource MaterialDesignFlatButton}"
                                HorizontalAlignment="Stretch"
                                Margin="4,0"/>
                    </StackPanel>
                </materialDesign:PopupBox>

                <!-- Active Filter Indicators (moved after separator) -->
                <StackPanel Grid.Column="6"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="8,0,0,0">
                    <!-- Search Filter Badge -->
                    <Border Style="{StaticResource HoverBadgeStyle}"
                            Background="{DynamicResource PrimaryHueMidBrush}"
                            CornerRadius="12"
                            Padding="8,4"
                            Margin="0,0,8,0"
                            Cursor="Hand"
                            Visibility="{Binding HasSearchFilter, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Magnify" Width="14" Height="14" VerticalAlignment="Center"
                                                      Foreground="White"/>
                            <TextBlock Text="{Binding SearchText}"
                                       Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                       MaxWidth="80"
                                       TextTrimming="CharacterEllipsis"
                                       VerticalAlignment="Center"
                                       Margin="4,0,0,0"
                                       Foreground="White"/>
                        </StackPanel>
                    </Border>
                    <!-- Category Filter Badge -->
                    <Border Style="{StaticResource HoverBadgeStyle}"
                            Background="{DynamicResource SecondaryHueMidBrush}"
                            CornerRadius="12"
                            Padding="8,4"
                            Margin="0,0,8,0"
                            Cursor="Hand"
                            Visibility="{Binding HasCategoryFilter, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="FolderOutline" Width="14" Height="14" VerticalAlignment="Center"
                                                      Foreground="Black"/>
                            <TextBlock Text="{Binding SelectedCategory}"
                                       Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                       VerticalAlignment="Center"
                                       Margin="4,0,0,0"
                                       Foreground="Black"/>
                        </StackPanel>
                    </Border>
                    <!-- Status Filter Badge -->
                    <Border Style="{StaticResource HoverBadgeStyle}"
                            Background="{DynamicResource MaterialDesignChipBackground}"
                            CornerRadius="12"
                            Padding="8,4"
                            Cursor="Hand"
                            Visibility="{Binding HasStatusFilter, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="FilterOutline" Width="14" Height="14" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding SelectedStatusFilter, Converter={StaticResource StatusFilterToStringConverter}}"
                                       Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                       VerticalAlignment="Center"
                                       Margin="4,0,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Stats Display -->
                <StackPanel Grid.Column="7"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <!-- Normal stats -->
                    <TextBlock Style="{StaticResource MaterialDesignBody2TextBlock}"
                               VerticalAlignment="Center"
                               Visibility="{Binding IsScanning, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                        <Run Text="{Binding FilteredCount, Mode=OneWay}"/>
                        <Run Text="/"/>
                        <Run Text="{Binding TotalApplicationsCount, Mode=OneWay}"/>
                        <Run Text=" | "/>
                        <Run Text="{Binding InstalledCount, Mode=OneWay}" Foreground="{DynamicResource AccentGreenTextBrush}"/>
                        <Run Text=" "/><Run Text="{loc:Loc Apps_Installed}"/>
                        <Run Text=" | "/>
                        <Run Text="{Binding SelectedCount, Mode=OneWay}" Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                        <Run Text=" "/><Run Text="{loc:Loc Apps_Selected}"/>
                        <Run Text=" | "/>
                        <Run Text="{Binding FavoritesCount, Mode=OneWay}" Foreground="{DynamicResource FavoriteTextBrush}"/>
                        <Run Text=" "/><Run Text="{loc:Loc Apps_Favorites}"/>
                    </TextBlock>
                    <!-- Scan progress -->
                    <StackPanel Orientation="Horizontal"
                                Visibility="{Binding IsScanning, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                                     Value="0"
                                     IsIndeterminate="True"
                                     Width="20"
                                     Height="20"
                                     Margin="0,0,8,0"/>
                        <TextBlock Style="{StaticResource MaterialDesignBody2TextBlock}"
                                   VerticalAlignment="Center">
                            <Run Text="{Binding ScannedCount, Mode=OneWay}"/>
                            <Run Text="/"/>
                            <Run Text="{Binding ScanTotalCount, Mode=OneWay}"/>
                        </TextBlock>
                    </StackPanel>
                </StackPanel>

                <!-- Scan/Cancel Button -->
                <Button Grid.Column="8"
                        Command="{Binding ScanCommand}"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Content="{loc:Loc Btn_Scan}"
                        ToolTip="{loc:Loc Help_Tooltip_Scan}"
                        Margin="16,0,0,0"
                        Visibility="{Binding IsScanning, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
                        AutomationProperties.Name="Scan for installed applications"
                        AutomationProperties.HelpText="Check which applications are already installed on this system"/>
                <Button Grid.Column="8"
                        Command="{Binding CancelScanCommand}"
                        Style="{StaticResource ThemeAdaptiveOutlinedButton}"
                        Content="{loc:Loc Btn_Cancel}"
                        Margin="16,0,0,0"
                        Visibility="{Binding IsScanning, Converter={StaticResource BooleanToVisibilityConverter}}"
                        AutomationProperties.Name="Cancel scan"
                        AutomationProperties.HelpText="Stop the current scan operation"/>

                <!-- Scan Updates Button -->
                <Button Grid.Column="9"
                        Command="{Binding ScanUpdatesCommand}"
                        Style="{StaticResource ThemeAdaptiveOutlinedButton}"
                        Margin="8,0,0,0"
                        Visibility="{Binding IsScanningUpdates, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
                        AutomationProperties.Name="Scan for updates"
                        AutomationProperties.HelpText="Check for available updates for installed applications">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Update" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="{loc:Loc Btn_ScanUpdates}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <StackPanel Grid.Column="9"
                            Orientation="Horizontal"
                            Margin="8,0,0,0"
                            Visibility="{Binding IsScanningUpdates, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                                 Value="0"
                                 IsIndeterminate="True"
                                 Width="20"
                                 Height="20"
                                 Margin="0,0,8,0"/>
                    <TextBlock Text="{loc:Loc Common_Loading}"
                               Style="{StaticResource MaterialDesignBody2TextBlock}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </materialDesign:Card>

        <!-- Selection Action Bar -->
        <materialDesign:Card Grid.Row="3"
                              Padding="{StaticResource MarginMedium}"
                              Margin="{StaticResource MarginSmallBottom}"
                              materialDesign:ElevationAssist.Elevation="Dp1"
                              Visibility="{Binding IsLoading, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Selection Help Icon -->
                <materialDesign:PackIcon Grid.Column="0"
                                          Kind="HelpCircleOutline"
                                          Width="18" Height="18"
                                          VerticalAlignment="Center"
                                          Foreground="{DynamicResource MaterialDesignBodyLight}"
                                          Margin="0,0,12,0"
                                          ToolTip="{loc:Loc Apps_SelectionHelpTooltip}"
                                          Cursor="Help"/>
                <!-- Select All/None/Not Installed Buttons -->
                <Button Grid.Column="1"
                        Content="{loc:Loc Apps_SelectAll}"
                        Command="{Binding SelectAllCommand}"
                        Style="{StaticResource ThemeAdaptiveOutlinedButton}"
                        Padding="12,4"
                        Margin="0,0,8,0"
                        AutomationProperties.Name="Select all applications"
                        AutomationProperties.HelpText="Select all applications in the filtered list"/>
                <Button Grid.Column="2"
                        Content="{loc:Loc Apps_SelectNone}"
                        Command="{Binding SelectNoneCommand}"
                        Style="{StaticResource ThemeAdaptiveOutlinedButton}"
                        Padding="12,4"
                        Margin="0,0,8,0"
                        AutomationProperties.Name="Select none"
                        AutomationProperties.HelpText="Deselect all applications"/>
                <Button Grid.Column="3"
                        Content="{loc:Loc Apps_SelectNotInstalled}"
                        Command="{Binding SelectNotInstalledCommand}"
                        Style="{StaticResource ThemeAdaptiveOutlinedButton}"
                        Padding="12,4"
                        AutomationProperties.Name="Select not installed"
                        AutomationProperties.HelpText="Select only applications that are not yet installed"/>

                <!-- Install Selected Button (hidden during batch ops) -->
                <StackPanel Grid.Column="5" Orientation="Horizontal"
                            Visibility="{Binding IsInstalling, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                    <!-- Select Favorites Button -->
                    <Button Content="{loc:Loc Apps_SelectFavorites}"
                            Command="{Binding SelectFavoritesCommand}"
                            Style="{StaticResource ThemeAdaptiveOutlinedButton}"
                            Padding="12,4"
                            Margin="0,0,8,0"
                            Visibility="{Binding IsUninstalling, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
                            AutomationProperties.Name="Select favorites"
                            AutomationProperties.HelpText="Select only applications marked as favorites"/>
                    <!-- Uninstall Selected Button -->
                    <Button Command="{Binding UninstallSelectedCommand}"
                            Style="{StaticResource ThemeAdaptiveOutlinedButton}"
                            Margin="0,0,8,0"
                            Visibility="{Binding IsUninstalling, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
                            AutomationProperties.Name="Uninstall selected applications"
                            AutomationProperties.HelpText="Remove the selected applications from this system">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Delete" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="{loc:Loc Apps_UninstallSelected}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <!-- Install Selected Button -->
                    <Button Command="{Binding InstallSelectedCommand}"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Visibility="{Binding IsUninstalling, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
                            AutomationProperties.Name="Install selected applications"
                            AutomationProperties.HelpText="Download and install the selected applications">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Download" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="{loc:Loc Apps_InstallSelected}" VerticalAlignment="Center"/>
                            <TextBlock VerticalAlignment="Center" Margin="8,0,0,0">
                                <Run Text="("/>
                                <Run Text="{Binding SelectedCount, Mode=OneWay}"/>
                                <Run Text=")"/>
                            </TextBlock>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Batch Progress Panel (visible during batch ops) -->
                <StackPanel Grid.Column="5" Orientation="Horizontal" VerticalAlignment="Center">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsInstalling}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsUninstalling}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <!-- Operation Type Icon and Label -->
                    <materialDesign:PackIcon Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,6,0">
                        <materialDesign:PackIcon.Style>
                            <Style TargetType="materialDesign:PackIcon">
                                <Setter Property="Kind" Value="Download"/>
                                <Setter Property="Foreground" Value="{DynamicResource PrimaryHueMidBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsUninstalling}" Value="True">
                                        <Setter Property="Kind" Value="Delete"/>
                                        <Setter Property="Foreground" Value="{DynamicResource MaterialDesignValidationErrorBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </materialDesign:PackIcon.Style>
                    </materialDesign:PackIcon>
                    <TextBlock VerticalAlignment="Center" Margin="0,0,8,0" FontWeight="Medium">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource MaterialDesignBody2TextBlock}">
                                <Setter Property="Text" Value="{loc:Loc Progress_Installing}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsUninstalling}" Value="True">
                                        <Setter Property="Text" Value="{loc:Loc Status_Uninstalling}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <!-- Progress Text -->
                    <TextBlock VerticalAlignment="Center" Margin="0,0,8,0">
                        <Run Text="{Binding BatchProgressCurrent, Mode=OneWay}"/>
                        <Run Text="/"/>
                        <Run Text="{Binding BatchProgressTotal, Mode=OneWay}"/>
                    </TextBlock>
                    <!-- Current App Name -->
                    <TextBlock Text="{Binding CurrentBatchAppName}"
                               Style="{StaticResource MaterialDesignCaptionTextBlock}"
                               Foreground="{DynamicResource PrimaryHueMidBrush}"
                               FontWeight="Medium"
                               VerticalAlignment="Center"
                               MaxWidth="200"
                               TextTrimming="CharacterEllipsis"
                               ToolTip="{Binding CurrentBatchAppName}"
                               Margin="0,0,12,0"
                               Visibility="{Binding CurrentBatchAppName, Converter={StaticResource NullableToVisibilityConverter}}"/>
                    <!-- Progress Bar -->
                    <ProgressBar Value="{Binding BatchProgressPercent}"
                                 Width="150"
                                 Height="8"
                                 VerticalAlignment="Center"
                                 Margin="0,0,8,0"/>
                    <!-- Estimated Time Remaining -->
                    <TextBlock Text="{Binding EstimatedTimeRemaining}"
                               Style="{StaticResource MaterialDesignCaptionTextBlock}"
                               Foreground="{DynamicResource MaterialDesignBodyLight}"
                               VerticalAlignment="Center"
                               Margin="0,0,12,0"
                               Visibility="{Binding EstimatedTimeRemaining, Converter={StaticResource NullableToVisibilityConverter}}"/>
                    <!-- Pause Button -->
                    <Button Command="{Binding PauseCommand}"
                            Style="{StaticResource MaterialDesignIconButton}"
                            Width="44" Height="44"
                            ToolTip="{loc:Loc Btn_Pause}"
                            Visibility="{Binding IsPaused, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
                            AutomationProperties.Name="Pause"
                            AutomationProperties.HelpText="Pause the current batch operation">
                        <materialDesign:PackIcon Kind="Pause"/>
                    </Button>
                    <!-- Resume Button -->
                    <Button Command="{Binding ResumeCommand}"
                            Style="{StaticResource MaterialDesignIconButton}"
                            Width="44" Height="44"
                            ToolTip="{loc:Loc Btn_Resume}"
                            Visibility="{Binding IsPaused, Converter={StaticResource BooleanToVisibilityConverter}}"
                            AutomationProperties.Name="Resume"
                            AutomationProperties.HelpText="Resume the paused batch operation">
                        <materialDesign:PackIcon Kind="Play"/>
                    </Button>
                    <!-- Cancel Button -->
                    <Button Command="{Binding CancelBatchCommand}"
                            Style="{StaticResource MaterialDesignIconButton}"
                            Width="44" Height="44"
                            ToolTip="{loc:Loc Btn_Cancel}"
                            Foreground="{DynamicResource MaterialDesignValidationErrorBrush}"
                            AutomationProperties.Name="Cancel"
                            AutomationProperties.HelpText="Cancel the current batch operation">
                        <materialDesign:PackIcon Kind="Close"/>
                    </Button>
                </StackPanel>
            </Grid>
        </materialDesign:Card>

        <!-- Applications DataGrid -->
        <materialDesign:Card Grid.Row="4"
                              Padding="0"
                              materialDesign:ElevationAssist.Elevation="Dp2">
            <Grid>
                <!-- Loading Indicator -->
                <StackPanel Orientation="Vertical"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                                 Value="0"
                                 IsIndeterminate="True"
                                 Width="48"
                                 Height="48"/>
                    <TextBlock Text="{loc:Loc Common_Loading}"
                               Style="{StaticResource MaterialDesignBody1TextBlock}"
                               HorizontalAlignment="Center"
                               Margin="0,16,0,0"/>
                </StackPanel>

                <!-- Empty Filter Results State -->
                <StackPanel Orientation="Vertical"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Visibility="{Binding IsEmptyFilterResults, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <materialDesign:PackIcon Kind="FilterOff"
                                              Width="64" Height="64"
                                              Foreground="{DynamicResource MaterialDesignBodyLight}"
                                              HorizontalAlignment="Center"
                                              Margin="0,0,0,16"/>
                    <TextBlock Text="{loc:Loc Apps_EmptyFilterResults}"
                               Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                               Foreground="{DynamicResource MaterialDesignBodyLight}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,8"/>
                    <TextBlock Text="{loc:Loc Apps_EmptyFilterResultsHint}"
                               Style="{StaticResource MaterialDesignBody2TextBlock}"
                               Foreground="{DynamicResource MaterialDesignBodyLight}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,16"/>
                    <Button Content="{loc:Loc Apps_ClearFilters}"
                            Command="{Binding ClearFiltersCommand}"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            HorizontalAlignment="Center"
                            AutomationProperties.Name="Clear all filters to show applications"/>
                </StackPanel>

                <!-- DataGrid with UI Virtualization for performance -->
                <DataGrid x:Name="ApplicationsDataGrid"
                          ItemsSource="{Binding FilteredApplications, ValidatesOnDataErrors=False, ValidatesOnNotifyDataErrors=False}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          CanUserReorderColumns="True"
                          CanUserSortColumns="True"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          SelectionUnit="FullRow"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          BorderThickness="0"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.VirtualizationMode="Recycling"
                          VirtualizingPanel.ScrollUnit="Item"
                          EnableRowVirtualization="True"
                          EnableColumnVirtualization="False"
                          ScrollViewer.IsDeferredScrollingEnabled="False"
                          materialDesign:DataGridAssist.CellPadding="16 8"
                          materialDesign:DataGridAssist.ColumnHeaderPadding="16 8"
                          RowValidationErrorTemplate="{x:Null}"
                          RowHeaderWidth="0"
                          Visibility="{Binding IsLoading, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
                          PreviewKeyDown="ApplicationsDataGrid_PreviewKeyDown"
                          AutomationProperties.Name="Applications list"
                          AutomationProperties.HelpText="List of available applications. Use arrow keys to navigate, Space to toggle selection.">
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow" BasedOn="{StaticResource MaterialDesignDataGridRow}">
                            <Setter Property="Background" Value="{Binding Status, Converter={StaticResource StatusToRowBackgroundConverter}}"/>
                            <Setter Property="MinHeight" Value="56"/>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem x:Name="MenuLaunch"
                                      Header="{loc:Loc Menu_Launch}"
                                      Click="ContextMenu_Launch_Click">
                                <MenuItem.Icon>
                                    <materialDesign:PackIcon Kind="Play"/>
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem x:Name="MenuOpenHomepage"
                                      Header="{loc:Loc Menu_OpenHomepage}"
                                      Click="ContextMenu_OpenHomepage_Click">
                                <MenuItem.Icon>
                                    <materialDesign:PackIcon Kind="Web"/>
                                </MenuItem.Icon>
                            </MenuItem>
                            <Separator/>
                            <MenuItem x:Name="MenuInstall"
                                      Header="{loc:Loc Menu_Install}"
                                      Click="ContextMenu_Install_Click">
                                <MenuItem.Icon>
                                    <materialDesign:PackIcon Kind="Download"/>
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem x:Name="MenuUninstall"
                                      Header="{loc:Loc Menu_Uninstall}"
                                      Click="ContextMenu_Uninstall_Click">
                                <MenuItem.Icon>
                                    <materialDesign:PackIcon Kind="Delete"/>
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem x:Name="MenuUpdate"
                                      Header="{loc:Loc Menu_Update}"
                                      Click="ContextMenu_Update_Click">
                                <MenuItem.Icon>
                                    <materialDesign:PackIcon Kind="Update"/>
                                </MenuItem.Icon>
                            </MenuItem>
                            <Separator/>
                            <MenuItem x:Name="MenuScan"
                                      Header="{loc:Loc Menu_Scan}"
                                      Click="ContextMenu_Scan_Click">
                                <MenuItem.Icon>
                                    <materialDesign:PackIcon Kind="Magnify"/>
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem x:Name="MenuScanSelected"
                                      Header="{loc:Loc Menu_ScanSelected}"
                                      Click="ContextMenu_ScanSelected_Click">
                                <MenuItem.Icon>
                                    <materialDesign:PackIcon Kind="MagnifyPlus"/>
                                </MenuItem.Icon>
                            </MenuItem>
                            <Separator/>
                            <MenuItem Header="{loc:Loc Menu_ToggleSelection}"
                                      Click="ContextMenu_ToggleSelection_Click">
                                <MenuItem.Icon>
                                    <materialDesign:PackIcon Kind="CheckboxMarked"/>
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="{loc:Loc Menu_ToggleFavorite}"
                                      Click="ContextMenu_ToggleFavorite_Click">
                                <MenuItem.Icon>
                                    <materialDesign:PackIcon Kind="Star"/>
                                </MenuItem.Icon>
                            </MenuItem>
                            <Separator/>
                            <MenuItem x:Name="MenuViewLogs"
                                      Header="{loc:Loc Menu_ViewLogs}"
                                      Click="ContextMenu_ViewLogs_Click">
                                <MenuItem.Icon>
                                    <materialDesign:PackIcon Kind="FileDocument"/>
                                </MenuItem.Icon>
                            </MenuItem>
                            <Separator/>
                            <MenuItem Header="{loc:Loc Menu_CopyAppId}"
                                      Click="ContextMenu_CopyAppId_Click">
                                <MenuItem.Icon>
                                    <materialDesign:PackIcon Kind="ContentCopy"/>
                                </MenuItem.Icon>
                            </MenuItem>
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                    <DataGrid.Columns>
                        <!-- Selection Checkbox Column -->
                        <DataGridTemplateColumn Width="Auto" MinWidth="50" SortMemberPath="IsSelected">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate DataType="{x:Type models:ApplicationModel}">
                                    <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                              Style="{StaticResource AnimatedSelectionCheckBox}"
                                              HorizontalAlignment="Center"
                                              Checked="SelectionCheckBox_Changed"
                                              Unchecked="SelectionCheckBox_Changed"
                                              AutomationProperties.Name="{Binding Name, StringFormat='Select {0}'}"
                                              AutomationProperties.HelpText="Toggle selection for this application"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Favorites Column -->
                        <DataGridTemplateColumn Width="Auto" MinWidth="40" SortMemberPath="IsFavorite"
                                                Visibility="{Binding DataContext.ShowFavoritesColumn, RelativeSource={RelativeSource AncestorType=DataGrid}, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate DataType="{x:Type models:ApplicationModel}">
                                    <Button Style="{StaticResource AnimatedFavoriteButton}"
                                            Command="{Binding DataContext.ToggleFavoriteCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            ToolTip="{loc:Loc Menu_ToggleFavorite}"
                                            AutomationProperties.Name="{Binding Name, StringFormat='Toggle favorite for {0}'}"
                                            AutomationProperties.HelpText="Add or remove from favorites">
                                        <materialDesign:PackIcon Kind="{Binding IsFavorite, Converter={StaticResource BoolToFavoriteIconConverter}}"
                                                                  Foreground="{Binding IsFavorite, Converter={StaticResource BoolToFavoriteColorConverter}}"
                                                                  Width="20" Height="20"/>
                                    </Button>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Application Name Column -->
                        <DataGridTemplateColumn Width="*" MinWidth="180" SortMemberPath="Name">
                            <DataGridTemplateColumn.Header>
                                <TextBlock Text="{loc:Loc Col_Application}"/>
                            </DataGridTemplateColumn.Header>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate DataType="{x:Type models:ApplicationModel}">
                                    <StackPanel Orientation="Vertical">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Name}"
                                                       Style="{StaticResource MaterialDesignBody1TextBlock}"
                                                       FontWeight="Medium"/>
                                            <!-- Profile Tier Badge -->
                                            <Border Background="{DynamicResource SecondaryHueMidBrush}"
                                                    CornerRadius="4"
                                                    Padding="6,2"
                                                    Margin="8,0,0,0"
                                                    VerticalAlignment="Center"
                                                    Visibility="{Binding ProfileTier, Converter={StaticResource NullableToVisibilityConverter}}">
                                                <TextBlock Text="{Binding ProfileTier}"
                                                           FontSize="10"
                                                           FontWeight="Bold"
                                                           Foreground="White"/>
                                            </Border>
                                            <!-- Manual Install Badge -->
                                            <Border Background="{DynamicResource ManualInstallBadgeBrush}"
                                                    CornerRadius="4"
                                                    Padding="6,2"
                                                    Margin="8,0,0,0"
                                                    VerticalAlignment="Center"
                                                    ToolTip="{loc:Loc Apps_ManualInstallTooltip}"
                                                    Visibility="{Binding ManualInstallOnly, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <TextBlock Text="{loc:Loc Apps_ManualInstall}"
                                                           FontSize="10"
                                                           FontWeight="Bold"
                                                           Foreground="White"/>
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Text="{Binding Description}"
                                                   Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                                   Foreground="{DynamicResource MaterialDesignBodyLight}"
                                                   TextTrimming="CharacterEllipsis"
                                                   MaxWidth="350"/>
                                        <!-- Install Notes -->
                                        <TextBlock Text="{Binding InstallNotes}"
                                                   Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                                   Foreground="{DynamicResource MaterialDesignValidationErrorBrush}"
                                                   TextWrapping="Wrap"
                                                   MaxWidth="350"
                                                   Margin="0,2,0,0"
                                                   Visibility="{Binding InstallNotes, Converter={StaticResource NullableToVisibilityConverter}}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Version Column (combined current + available) -->
                        <DataGridTemplateColumn Width="Auto" MinWidth="120" SortMemberPath="CurrentVersion"
                                                Visibility="{Binding DataContext.ShowVersionColumn, RelativeSource={RelativeSource AncestorType=DataGrid}, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <DataGridTemplateColumn.Header>
                                <TextBlock Text="{loc:Loc Col_Version}"/>
                            </DataGridTemplateColumn.Header>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate DataType="{x:Type models:ApplicationModel}">
                                    <StackPanel Orientation="Horizontal"
                                                Visibility="{Binding CurrentVersion, Converter={StaticResource NullableToVisibilityConverter}}">
                                        <!-- Current Version -->
                                        <TextBlock Text="{Binding CurrentVersion}"
                                                   Style="{StaticResource MaterialDesignBody2TextBlock}"
                                                   FontFamily="Consolas"
                                                   VerticalAlignment="Center"/>
                                        <!-- Arrow and New Version (only if update available) -->
                                        <StackPanel Orientation="Horizontal"
                                                    Visibility="{Binding AvailableVersion, Converter={StaticResource NullableToVisibilityConverter}}">
                                            <materialDesign:PackIcon Kind="ArrowRight"
                                                                      Width="16"
                                                                      Height="16"
                                                                      Foreground="{DynamicResource AccentGreenTextBrush}"
                                                                      VerticalAlignment="Center"
                                                                      Margin="6,0,6,0"/>
                                            <TextBlock Text="{Binding AvailableVersion}"
                                                       Style="{StaticResource MaterialDesignBody2TextBlock}"
                                                       FontFamily="Consolas"
                                                       Foreground="{DynamicResource AccentGreenTextBrush}"
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Status Column -->
                        <DataGridTemplateColumn Width="Auto" MinWidth="100" SortMemberPath="Status"
                                                Visibility="{Binding DataContext.ShowStatusColumn, RelativeSource={RelativeSource AncestorType=DataGrid}, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <DataGridTemplateColumn.Header>
                                <TextBlock Text="{loc:Loc Col_Status}"/>
                            </DataGridTemplateColumn.Header>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate DataType="{x:Type models:ApplicationModel}">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="{Binding Status, Converter={StaticResource StatusToIconConverter}}"
                                                                  Width="18"
                                                                  Height="18"
                                                                  Foreground="{Binding Status, Converter={StaticResource StatusToColorConverter}}"
                                                                  VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding StatusMessage}"
                                                   Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                                   VerticalAlignment="Center"
                                                   Margin="6,0,0,0"
                                                   TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding StatusMessage}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Category Column -->
                        <DataGridTemplateColumn Width="Auto" MinWidth="100" SortMemberPath="Category"
                                                Visibility="{Binding DataContext.ShowCategoryColumn, RelativeSource={RelativeSource AncestorType=DataGrid}, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <DataGridTemplateColumn.Header>
                                <TextBlock Text="{loc:Loc Col_Category}"/>
                            </DataGridTemplateColumn.Header>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate DataType="{x:Type models:ApplicationModel}">
                                    <Border Background="{DynamicResource MaterialDesignChipBackground}"
                                            CornerRadius="12"
                                            Padding="10,4"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Category}"
                                                   Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Center"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Sources Column -->
                        <DataGridTemplateColumn Width="Auto" MinWidth="100" SortMemberPath="Sources"
                                                Visibility="{Binding DataContext.ShowSourcesColumn, RelativeSource={RelativeSource AncestorType=DataGrid}, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <DataGridTemplateColumn.Header>
                                <TextBlock Text="{loc:Loc Apps_Col_Sources}"/>
                            </DataGridTemplateColumn.Header>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate DataType="{x:Type models:ApplicationModel}">
                                    <TextBlock Text="{Binding Sources}"
                                               Style="{StaticResource MaterialDesignBody2TextBlock}"
                                               Foreground="{DynamicResource AccentGreenTextBrush}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Logs Column -->
                        <DataGridTemplateColumn Width="60" MinWidth="60" SortMemberPath="LogOutput"
                                                Visibility="{Binding DataContext.ShowLogsColumn, RelativeSource={RelativeSource AncestorType=DataGrid}, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <DataGridTemplateColumn.Header>
                                <TextBlock Text="{loc:Loc Col_Logs}" HorizontalAlignment="Center"/>
                            </DataGridTemplateColumn.Header>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate DataType="{x:Type models:ApplicationModel}">
                                    <Button Style="{StaticResource HoverScaleIconButton}"
                                            Width="44" Height="44"
                                            HorizontalAlignment="Center"
                                            ToolTip="{loc:Loc Btn_ViewLogs}"
                                            Command="{Binding DataContext.ViewLogsCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            Visibility="{Binding LogOutput, Converter={StaticResource NullableToVisibilityConverter}}"
                                            AutomationProperties.Name="{Binding Name, StringFormat='View logs for {0}'}"
                                            AutomationProperties.HelpText="Opens the installation logs for this application">
                                        <materialDesign:PackIcon Kind="FileDocumentOutline" Width="20" Height="20"/>
                                    </Button>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </materialDesign:Card>

        <!-- Error Message with Recovery Options -->
        <Border Grid.Row="4"
                Background="{DynamicResource ErrorBackgroundBrush}"
                BorderBrush="{DynamicResource ErrorBorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16"
                Margin="24"
                Visibility="{Binding ErrorMessage, Converter={StaticResource NullableToVisibilityConverter}}"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                MaxWidth="500">
            <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,12">
                    <materialDesign:PackIcon Kind="AlertCircle"
                                              Width="24" Height="24"
                                              Foreground="{DynamicResource MaterialDesignValidationErrorBrush}"
                                              VerticalAlignment="Center"
                                              Margin="0,0,12,0"/>
                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="{DynamicResource MaterialDesignValidationErrorBrush}"
                               Style="{StaticResource MaterialDesignBody1TextBlock}"
                               TextWrapping="Wrap"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Content="{loc:Loc Common_TryAgain}"
                            Command="{Binding RetryLastOperationCommand}"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Margin="0,0,8,0"
                            MinWidth="100"
                            AutomationProperties.Name="Retry the failed operation"/>
                    <Button Content="{loc:Loc Common_Dismiss}"
                            Command="{Binding DismissErrorCommand}"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            MinWidth="100"
                            AutomationProperties.Name="Dismiss error message"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
    </materialDesign:DialogHost>
</UserControl>
