<UserControl x:Class="Win11Forge.GUI.Views.ApplicationPickerDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:loc="clr-namespace:Win11Forge.GUI.Resources"
             mc:Ignorable="d"
             Width="700" Height="500"
             d:DesignHeight="500" d:DesignWidth="700">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <materialDesign:ColorZone Grid.Row="0"
                                   Mode="PrimaryMid"
                                   Padding="16"
                                   materialDesign:ElevationAssist.Elevation="Dp2">
            <StackPanel Orientation="Horizontal">
                <materialDesign:PackIcon Kind="PackageVariantPlus"
                                          Width="24"
                                          Height="24"
                                          VerticalAlignment="Center"
                                          Margin="0,0,12,0"/>
                <TextBlock Text="{loc:Loc Dialog_SelectApp_Title}"
                           Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </materialDesign:ColorZone>

        <!-- Search Bar -->
        <Grid Grid.Row="1" Margin="16,16,16,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox Grid.Column="0"
                     x:Name="SearchTextBox"
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                     materialDesign:HintAssist.Hint="{loc:Loc Apps_SearchHint}"
                     materialDesign:TextFieldAssist.HasClearButton="True">
                <TextBox.InputBindings>
                    <KeyBinding Key="Enter" Command="{Binding SearchCommand}"/>
                </TextBox.InputBindings>
            </TextBox>

            <ComboBox Grid.Column="1"
                      ItemsSource="{Binding Categories}"
                      SelectedItem="{Binding SelectedCategory}"
                      Style="{StaticResource MaterialDesignOutlinedComboBox}"
                      Width="180"
                      Margin="8,0,0,0"/>
        </Grid>

        <!-- Applications DataGrid -->
        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding FilteredApplications}"
                  SelectedItem="{Binding SelectedApplication}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  Style="{StaticResource MaterialDesignDataGrid}"
                  Margin="16,0,16,0"
                  VirtualizingStackPanel.IsVirtualizing="True"
                  VirtualizingStackPanel.VirtualizationMode="Recycling">
            <DataGrid.Columns>
                <DataGridTextColumn Header="{loc:Loc Col_Application}"
                                    Binding="{Binding Name}"
                                    Width="*"/>
                <DataGridTextColumn Header="{loc:Loc Col_Category}"
                                    Binding="{Binding Category}"
                                    Width="120"/>
                <DataGridTextColumn Header="{loc:Loc Apps_Col_Id}"
                                    Binding="{Binding AppId}"
                                    Width="180"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Empty State -->
        <StackPanel Grid.Row="2"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Visibility="{Binding IsEmpty, Converter={StaticResource BooleanToVisibilityConverter}}">
            <materialDesign:PackIcon Kind="PackageVariantRemove"
                                      Width="48"
                                      Height="48"
                                      Opacity="0.3"
                                      HorizontalAlignment="Center"/>
            <TextBlock Text="{loc:Loc Dialog_NoAppsAvailable}"
                       Style="{StaticResource MaterialDesignBody2TextBlock}"
                       Opacity="0.5"
                       HorizontalAlignment="Center"
                       Margin="0,8,0,0"/>
        </StackPanel>

        <!-- Footer Buttons -->
        <Grid Grid.Row="3" Margin="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Selected Count -->
            <TextBlock Grid.Column="0"
                       VerticalAlignment="Center"
                       Opacity="0.7">
                <Run Text="{Binding FilteredApplications.Count, Mode=OneWay}"/>
                <Run Text=" "/>
                <Run Text="{loc:Loc Dialog_AppsAvailable}"/>
            </TextBlock>

            <!-- Cancel Button -->
            <Button Grid.Column="1"
                    Content="{loc:Loc Btn_Cancel}"
                    Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}"
                    CommandParameter="{x:Null}"
                    Style="{StaticResource MaterialDesignFlatSecondaryButton}"
                    Margin="0,0,12,0"/>

            <!-- Add Button -->
            <Button Grid.Column="2"
                    Content="{loc:Loc Dialog_SelectApp_Add}"
                    Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}"
                    CommandParameter="{Binding SelectedApplication}"
                    IsEnabled="{Binding HasSelection}"
                    Style="{StaticResource MaterialDesignRaisedButton}"/>
        </Grid>
    </Grid>
</UserControl>
