<UserControl x:Class="Win11Forge.GUI.Views.LogsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:loc="clr-namespace:Win11Forge.GUI.Resources"
             xmlns:viewModels="clr-namespace:Win11Forge.GUI.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=viewModels:LogsViewModel}"
             d:DesignHeight="600" d:DesignWidth="900">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="{loc:Loc Logs_Title}"
                           Style="{StaticResource PageTitleTextStyle}"
                           AutomationProperties.AutomationId="PageLogs"/>
                <TextBlock Text="{loc:Loc Logs_Subtitle}"
                           Style="{StaticResource PageSubtitleTextStyle}"/>
            </StackPanel>

            <!-- Actions -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <ui:Button Command="{Binding RefreshCommand}"
                           Appearance="Secondary"
                           Margin="0,0,8,0"
                           ToolTip="{loc:Loc Logs_Refresh}">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="ArrowSync24" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="{loc:Loc Logs_Refresh}" VerticalAlignment="Center"/>
                    </StackPanel>
                </ui:Button>
                <ui:Button Command="{Binding OpenLogFolderCommand}"
                           Appearance="Secondary"
                           Margin="0,0,8,0"
                           ToolTip="{loc:Loc Logs_OpenFolder}">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="FolderOpen24" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="{loc:Loc Logs_OpenFolder}" VerticalAlignment="Center"/>
                    </StackPanel>
                </ui:Button>
                <ui:Button Command="{Binding ExportLogsCommand}"
                           Appearance="Secondary"
                           ToolTip="{loc:Loc Logs_Export}">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="ArrowExportLtr24" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="{loc:Loc Logs_Export}" VerticalAlignment="Center"/>
                    </StackPanel>
                </ui:Button>
            </StackPanel>
        </Grid>

        <!-- Filters -->
        <Border Grid.Row="1" Padding="16" Margin="0,0,0,16"
                CornerRadius="8"
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled"
                          CanContentScroll="False">
            <Grid MinWidth="620">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Search -->
                <ui:TextBox Grid.Column="0"
                            Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                            PlaceholderText="{loc:Loc Logs_SearchPlaceholder}"
                            AutomationProperties.Name="{loc:Loc A11y_Logs_Search}"
                            Margin="0,0,16,0">
                    <ui:TextBox.InputBindings>
                        <KeyBinding Key="Enter" Command="{Binding SearchCommand}"/>
                    </ui:TextBox.InputBindings>
                </ui:TextBox>

                <!-- Log Level Filter -->
                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding LogLevels}"
                          SelectedItem="{Binding SelectedLogLevel}"
                          AutomationProperties.Name="{loc:Loc A11y_Logs_LevelFilter}"
                          MinWidth="120"
                          Margin="0,0,8,0"/>

                <!-- Date Filter -->
                <DatePicker Grid.Column="2"
                            SelectedDate="{Binding FilterDate}"
                            AutomationProperties.Name="{loc:Loc A11y_Logs_DateFilter}"
                            MinWidth="140"
                            Margin="0,0,8,0"/>

                <!-- Clear Filters -->
                <ui:Button Grid.Column="3"
                           Command="{Binding ClearFiltersCommand}"
                           Appearance="Transparent"
                           Style="{StaticResource TouchFriendlyIconButton}"
                           ToolTip="{loc:Loc Logs_ClearFilters}"
                           AutomationProperties.Name="{loc:Loc A11y_Logs_ClearFilters}">
                    <ui:SymbolIcon Symbol="FilterDismiss24" Width="20" Height="20"/>
                </ui:Button>

                <!-- Clear Old Logs -->
                <ui:Button Grid.Column="4"
                           Command="{Binding ClearOldLogsCommand}"
                           Appearance="Transparent"
                           Style="{StaticResource TouchFriendlyIconButton}"
                           ToolTip="{loc:Loc Logs_ClearOld}"
                           AutomationProperties.Name="{loc:Loc A11y_Logs_ClearOld}"
                           Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                           Margin="8,0,0,0">
                    <ui:SymbolIcon Symbol="DeleteDismiss24" Width="20" Height="20"/>
                </ui:Button>
            </Grid>
            </ScrollViewer>
        </Border>

        <!-- Log Files List -->
        <Border Grid.Row="2" Padding="0"
                CornerRadius="8"
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Log Files Header -->
                <Border Grid.Row="0" Background="{DynamicResource SubtleFillColorSecondaryBrush}" Padding="16,12"
                        CornerRadius="8,8,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="{loc:Loc Logs_Files}"
                                   FontSize="16" FontWeight="Medium"/>
                        <TextBlock Grid.Column="1"
                                   FontSize="12"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                            <Run Text="{Binding FilteredLogFiles.Count, Mode=OneWay}"/>
                            <Run Text="{loc:Loc Logs_FilesCount}"/>
                        </TextBlock>
                    </Grid>
                </Border>

                <!-- Log Files DataGrid -->
                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding FilteredLogFiles}"
                          SelectedItem="{Binding SelectedLogFile}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          SelectionMode="Single"
                          SelectionUnit="FullRow"
                          GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column"
                          VerticalScrollBarVisibility="Auto"
                          MouseDoubleClick="DataGrid_MouseDoubleClick">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="" Width="Auto">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <ui:SymbolIcon Symbol="{Binding Icon}"
                                                   Width="20" Height="20"
                                                   Foreground="{Binding IconColor}"
                                                   VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="{loc:Loc Logs_FileName}"
                                            Binding="{Binding FileName}"
                                            Width="*"/>
                        <DataGridTextColumn Header="{loc:Loc Logs_Size}"
                                            Binding="{Binding SizeFormatted}"
                                            Width="100"/>
                        <DataGridTextColumn Header="{loc:Loc Logs_Date}"
                                            Binding="{Binding LastModified, StringFormat={}{0:g}}"
                                            Width="150"/>
                        <DataGridTemplateColumn Header="{loc:Loc Col_Actions}" Width="Auto">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <ui:Button Command="{Binding DataContext.ViewLogCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                   CommandParameter="{Binding}"
                                                   Appearance="Transparent"
                                                   Width="44" Height="44"
                                                   Padding="8"
                                                   ToolTip="{loc:Loc Logs_View}"
                                                   AutomationProperties.Name="{loc:Loc A11y_Logs_ViewLog}">
                                            <ui:SymbolIcon Symbol="Eye24" Width="18" Height="18"/>
                                        </ui:Button>
                                        <ui:Button Command="{Binding DataContext.CopyLogPathCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                   CommandParameter="{Binding}"
                                                   Appearance="Transparent"
                                                   Width="44" Height="44"
                                                   Padding="8"
                                                   ToolTip="{loc:Loc Logs_CopyPath}"
                                                   AutomationProperties.Name="{loc:Loc A11y_Logs_CopyPath}">
                                            <ui:SymbolIcon Symbol="Copy24" Width="18" Height="18"/>
                                        </ui:Button>
                                        <ui:Button Command="{Binding DataContext.DeleteLogCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                   CommandParameter="{Binding}"
                                                   Appearance="Transparent"
                                                   Width="44" Height="44"
                                                   Padding="8"
                                                   Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                                                   ToolTip="{loc:Loc Logs_Delete}"
                                                   AutomationProperties.Name="{loc:Loc A11y_Logs_DeleteLog}">
                                            <ui:SymbolIcon Symbol="Delete24" Width="18" Height="18"/>
                                        </ui:Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Empty State -->
                <StackPanel Grid.Row="1"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            Visibility="{Binding HasNoLogs, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <ui:SymbolIcon Symbol="DocumentError24"
                                   Width="64" Height="64"
                                   FontSize="48"
                                   HorizontalAlignment="Center"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    <TextBlock Text="{loc:Loc Logs_NoLogs}"
                               FontSize="20" FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Margin="0,16,0,0"/>
                    <TextBlock Text="{loc:Loc Logs_NoLogs_Hint}"
                               FontSize="12"
                               HorizontalAlignment="Center"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Margin="0,8,0,0"/>
                </StackPanel>

                <!-- Loading -->
                <ProgressBar Grid.Row="1"
                             IsIndeterminate="True"
                             VerticalAlignment="Top"
                             Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"/>
            </Grid>
        </Border>

        <!-- Status Bar -->
        <Border Grid.Row="3" Margin="0,16,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{Binding StatusMessage}"
                           FontSize="12"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           VerticalAlignment="Center"/>

                <TextBlock Grid.Column="1"
                           FontSize="12"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           VerticalAlignment="Center">
                    <Run Text="{loc:Loc Logs_TotalSize}"/>
                    <Run Text="{Binding TotalSizeFormatted, Mode=OneWay}"/>
                </TextBlock>
            </Grid>
        </Border>
    </Grid>
</UserControl>
