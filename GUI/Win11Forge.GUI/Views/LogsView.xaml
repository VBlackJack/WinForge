<UserControl x:Class="Win11Forge.GUI.Views.LogsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:loc="clr-namespace:Win11Forge.GUI.Resources"
             xmlns:viewModels="clr-namespace:Win11Forge.GUI.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=viewModels:LogsViewModel}"
             d:DesignHeight="600" d:DesignWidth="900">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="{loc:Loc Logs_Title}"
                           Style="{StaticResource MaterialDesignHeadline4TextBlock}"/>
                <TextBlock Text="{loc:Loc Logs_Subtitle}"
                           Style="{StaticResource MaterialDesignBody2TextBlock}"
                           Opacity="0.7"
                           Margin="0,4,0,0"/>
            </StackPanel>

            <!-- Actions -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Command="{Binding RefreshCommand}"
                        Style="{StaticResource ThemeAdaptiveOutlinedButton}"
                        Margin="0,0,8,0"
                        ToolTip="{loc:Loc Logs_Refresh}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Refresh" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="{loc:Loc Logs_Refresh}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding OpenLogFolderCommand}"
                        Style="{StaticResource ThemeAdaptiveOutlinedButton}"
                        Margin="0,0,8,0"
                        ToolTip="{loc:Loc Logs_OpenFolder}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="FolderOpen" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="{loc:Loc Logs_OpenFolder}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding ExportLogsCommand}"
                        Style="{StaticResource ThemeAdaptiveOutlinedButton}"
                        ToolTip="{loc:Loc Logs_Export}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Export" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="{loc:Loc Logs_Export}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Filters -->
        <materialDesign:Card Grid.Row="1" Padding="16" Margin="0,0,0,16" materialDesign:ElevationAssist.Elevation="Dp2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Search -->
                <TextBox Grid.Column="0"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         materialDesign:HintAssist.Hint="{loc:Loc Logs_SearchPlaceholder}"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Margin="0,0,16,0">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Enter" Command="{Binding SearchCommand}"/>
                    </TextBox.InputBindings>
                </TextBox>

                <!-- Log Level Filter -->
                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding LogLevels}"
                          SelectedItem="{Binding SelectedLogLevel}"
                          materialDesign:HintAssist.Hint="{loc:Loc Logs_Level}"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          Width="120"
                          Margin="0,0,8,0"/>

                <!-- Date Filter -->
                <DatePicker Grid.Column="2"
                            SelectedDate="{Binding FilterDate}"
                            materialDesign:HintAssist.Hint="{loc:Loc Logs_Date}"
                            Style="{StaticResource MaterialDesignOutlinedDatePicker}"
                            Width="150"
                            Margin="0,0,8,0"/>

                <!-- Clear Filters -->
                <Button Grid.Column="3"
                        Command="{Binding ClearFiltersCommand}"
                        Style="{StaticResource ThemeAdaptiveOutlinedButton}"
                        ToolTip="{loc:Loc Logs_ClearFilters}">
                    <materialDesign:PackIcon Kind="FilterRemove" Width="20" Height="20"/>
                </Button>

                <!-- Clear Old Logs -->
                <Button Grid.Column="4"
                        Command="{Binding ClearOldLogsCommand}"
                        Style="{StaticResource ThemeAdaptiveOutlinedButton}"
                        Foreground="{DynamicResource MaterialDesignValidationErrorBrush}"
                        ToolTip="{loc:Loc Logs_ClearOld}"
                        Margin="8,0,0,0">
                    <materialDesign:PackIcon Kind="DeleteClock" Width="20" Height="20"/>
                </Button>
            </Grid>
        </materialDesign:Card>

        <!-- Log Files List -->
        <materialDesign:Card Grid.Row="2" Padding="0" materialDesign:ElevationAssist.Elevation="Dp2">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Log Files Header -->
                <Border Grid.Row="0" Background="{DynamicResource MaterialDesignToolBarBackground}" Padding="16,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="{loc:Loc Logs_Files}"
                                   Style="{StaticResource MaterialDesignSubtitle1TextBlock}"/>
                        <TextBlock Grid.Column="1"
                                   Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                   Opacity="0.7">
                            <Run Text="{Binding FilteredLogFiles.Count, Mode=OneWay}"/>
                            <Run Text="{loc:Loc Logs_FilesCount}"/>
                        </TextBlock>
                    </Grid>
                </Border>

                <!-- Log Files DataGrid -->
                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding FilteredLogFiles}"
                          SelectedItem="{Binding SelectedLogFile}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          SelectionMode="Single"
                          SelectionUnit="FullRow"
                          GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column"
                          materialDesign:DataGridAssist.CellPadding="12 8"
                          materialDesign:DataGridAssist.ColumnHeaderPadding="12 8"
                          VerticalScrollBarVisibility="Auto"
                          MouseDoubleClick="DataGrid_MouseDoubleClick">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="" Width="Auto">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <materialDesign:PackIcon Kind="{Binding Icon}"
                                                              Width="20" Height="20"
                                                              Foreground="{Binding IconColor}"
                                                              VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="{loc:Loc Logs_FileName}"
                                            Binding="{Binding FileName}"
                                            Width="*"/>
                        <DataGridTextColumn Header="{loc:Loc Logs_Size}"
                                            Binding="{Binding SizeFormatted}"
                                            Width="100"/>
                        <DataGridTextColumn Header="{loc:Loc Logs_Date}"
                                            Binding="{Binding LastModified, StringFormat={}{0:g}}"
                                            Width="150"/>
                        <DataGridTemplateColumn Header="{loc:Loc Col_Actions}" Width="Auto">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Command="{Binding DataContext.ViewLogCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource MaterialDesignIconButton}"
                                                Width="32" Height="32"
                                                ToolTip="{loc:Loc Logs_View}">
                                            <materialDesign:PackIcon Kind="Eye" Width="18" Height="18"/>
                                        </Button>
                                        <Button Command="{Binding DataContext.CopyLogPathCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource MaterialDesignIconButton}"
                                                Width="32" Height="32"
                                                ToolTip="{loc:Loc Logs_CopyPath}">
                                            <materialDesign:PackIcon Kind="ContentCopy" Width="18" Height="18"/>
                                        </Button>
                                        <Button Command="{Binding DataContext.DeleteLogCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource MaterialDesignIconButton}"
                                                Width="32" Height="32"
                                                Foreground="{DynamicResource MaterialDesignValidationErrorBrush}"
                                                ToolTip="{loc:Loc Logs_Delete}">
                                            <materialDesign:PackIcon Kind="Delete" Width="18" Height="18"/>
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Empty State -->
                <StackPanel Grid.Row="1"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            Visibility="{Binding HasNoLogs, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <materialDesign:PackIcon Kind="FileDocumentAlertOutline"
                                              Width="64" Height="64"
                                              HorizontalAlignment="Center"
                                              Opacity="0.5"/>
                    <TextBlock Text="{loc:Loc Logs_NoLogs}"
                               Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                               HorizontalAlignment="Center"
                               Opacity="0.7"
                               Margin="0,16,0,0"/>
                    <TextBlock Text="{loc:Loc Logs_NoLogs_Hint}"
                               Style="{StaticResource MaterialDesignBody2TextBlock}"
                               HorizontalAlignment="Center"
                               Opacity="0.5"
                               Margin="0,8,0,0"/>
                </StackPanel>

                <!-- Loading -->
                <ProgressBar Grid.Row="1"
                             IsIndeterminate="True"
                             VerticalAlignment="Top"
                             Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"/>
            </Grid>
        </materialDesign:Card>

        <!-- Status Bar -->
        <Border Grid.Row="3" Margin="0,16,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{Binding StatusMessage}"
                           Style="{StaticResource MaterialDesignCaptionTextBlock}"
                           Opacity="0.7"
                           VerticalAlignment="Center"/>

                <TextBlock Grid.Column="1"
                           Style="{StaticResource MaterialDesignCaptionTextBlock}"
                           Opacity="0.7"
                           VerticalAlignment="Center">
                    <Run Text="{loc:Loc Logs_TotalSize}"/>
                    <Run Text="{Binding TotalSizeFormatted, Mode=OneWay}"/>
                </TextBlock>
            </Grid>
        </Border>
    </Grid>
</UserControl>
