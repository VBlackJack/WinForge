<Window x:Class="Win11Forge.GUI.Views.SplashScreen"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Win11Forge"
        Width="400"
        Height="300"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Topmost="True"
        ShowInTaskbar="False">

    <Border Background="{DynamicResource ApplicationBackgroundBrush}"
            CornerRadius="16"
            BorderBrush="{DynamicResource SystemAccentColorPrimaryBrush}"
            BorderThickness="2">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20"
                              ShadowDepth="0"
                              Opacity="0.4"
                              Color="Black"/>
        </Border.Effect>

        <Grid Margin="32">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Application Icon -->
            <ui:SymbolIcon Grid.Row="0"
                           Symbol="Settings24"
                           Width="64"
                           Height="64"
                           FontSize="{StaticResource FontSizeHero}"
                           HorizontalAlignment="Center"
                           Foreground="{DynamicResource SystemAccentColorPrimaryBrush}"
                           RenderTransformOrigin="0.5,0.5">
                <ui:SymbolIcon.RenderTransform>
                    <RotateTransform x:Name="IconRotateTransform"/>
                </ui:SymbolIcon.RenderTransform>
            </ui:SymbolIcon>

            <!-- Application Name -->
            <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Win11Forge"
                           FontSize="{StaticResource FontSizeDisplay}"
                           FontWeight="Bold"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                           HorizontalAlignment="Center"/>
                <TextBlock x:Name="VersionText"
                           FontSize="{StaticResource FontSizeBody}"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,4,0,0"/>
            </StackPanel>

            <!-- Loading Progress -->
            <ProgressBar Grid.Row="2"
                         IsIndeterminate="True"
                         Height="4"
                         Margin="0,16,0,0"/>

            <!-- Status Message -->
            <TextBlock x:Name="StatusText"
                       Grid.Row="3"
                       FontSize="{StaticResource FontSizeCaption}"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,12,0,0"/>
        </Grid>
    </Border>
</Window>
