<UserControl x:Class="Win11Forge.GUI.Views.DeploymentView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:loc="clr-namespace:Win11Forge.GUI.Resources"
             xmlns:viewModels="clr-namespace:Win11Forge.GUI.ViewModels"
             xmlns:models="clr-namespace:Win11Forge.GUI.Models"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=viewModels:DeploymentViewModel}"
             d:DesignHeight="700" d:DesignWidth="1000">

    <materialDesign:DialogHost IsOpen="{Binding IsLogViewerOpen}"
                                CloseOnClickAway="True"
                                DialogClosing="DialogHost_DialogClosing">
        <materialDesign:DialogHost.DialogContent>
            <!-- Log Viewer Dialog -->
            <Border MinWidth="600" MaxWidth="900" MaxHeight="500" Padding="24">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Dialog Header -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,16">
                        <TextBlock Text="{loc:Loc LogViewer_Title}"
                                   Style="{StaticResource MaterialDesignHeadline6TextBlock}"/>
                        <TextBlock Text="{Binding LogViewerApplication.Name}"
                                   Style="{StaticResource MaterialDesignBody1TextBlock}"
                                   Foreground="{DynamicResource MaterialDesignBodyLight}"
                                   Margin="0,4,0,0"/>
                        <!-- Error message if present -->
                        <Border Background="{DynamicResource ErrorBackgroundBrush}"
                                BorderBrush="{DynamicResource ErrorBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="12,8"
                                Margin="0,12,0,0"
                                Visibility="{Binding LogViewerApplication.ErrorMessage, Converter={StaticResource NullableToVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="AlertCircle"
                                                          Foreground="{DynamicResource ErrorIconBrush}"
                                                          Width="20" Height="20"
                                                          VerticalAlignment="Center"
                                                          Margin="0,0,8,0"/>
                                <TextBlock Text="{Binding LogViewerApplication.ErrorMessage}"
                                           Foreground="{DynamicResource ErrorTextBrush}"
                                           TextWrapping="Wrap"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Log Content -->
                    <Border Grid.Row="1"
                            Background="{DynamicResource MaterialDesignCardBackground}"
                            BorderBrush="{DynamicResource MaterialDesignDivider}"
                            BorderThickness="1"
                            CornerRadius="4">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Auto">
                            <TextBox Text="{Binding LogViewerApplication.LogOutput, Mode=OneWay}"
                                     IsReadOnly="True"
                                     TextWrapping="NoWrap"
                                     FontFamily="Consolas"
                                     FontSize="12"
                                     BorderThickness="0"
                                     Padding="12"
                                     Background="Transparent"
                                     VerticalScrollBarVisibility="Disabled"
                                     HorizontalScrollBarVisibility="Disabled"/>
                        </ScrollViewer>
                    </Border>

                    <!-- No logs message -->
                    <TextBlock Grid.Row="1"
                               Text="{loc:Loc LogViewer_NoLogs}"
                               Style="{StaticResource MaterialDesignBody2TextBlock}"
                               Foreground="{DynamicResource MaterialDesignBodyLight}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Visibility="{Binding LogViewerApplication.LogOutput, Converter={StaticResource InverseNullableToVisibilityConverter}}"/>

                    <!-- Dialog Actions -->
                    <StackPanel Grid.Row="2"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Margin="0,16,0,0">
                        <Button Content="{loc:Loc LogViewer_Copy}"
                                Style="{StaticResource ThemeAdaptiveOutlinedButton}"
                                Click="CopyLogsToClipboard_Click"
                                Margin="0,0,12,0"/>
                        <Button Content="{loc:Loc LogViewer_Close}"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                Command="{Binding CloseLogViewerCommand}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </materialDesign:DialogHost.DialogContent>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="{loc:Loc Monitoring_Title}"
                       Style="{StaticResource MaterialDesignHeadline4TextBlock}"/>
            <TextBlock Text="{loc:Loc Monitoring_Subtitle}"
                       Style="{StaticResource MaterialDesignBody2TextBlock}"
                       Foreground="{DynamicResource MaterialDesignBodyLight}"
                       Margin="0,8,0,0"/>
        </StackPanel>

        <!-- Deployment Progress Card -->
        <materialDesign:Card Grid.Row="1"
                              Padding="24"
                              Margin="0,0,0,16"
                              materialDesign:ElevationAssist.Elevation="Dp2"
                              Visibility="{Binding IsDeploying, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Status Header -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="{Binding IsPaused, Converter={StaticResource BoolToPauseIconConverter}}"
                                                  Width="28" Height="28"
                                                  Foreground="{DynamicResource PrimaryHueMidBrush}"
                                                  VerticalAlignment="Center"
                                                  Margin="0,0,12,0"/>
                        <StackPanel>
                            <TextBlock Text="{Binding DeploymentStatusMessage}"
                                       Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                                       TextTrimming="CharacterEllipsis"
                                       MaxWidth="400"/>
                            <TextBlock Text="{Binding CurrentAppName}"
                                       Style="{StaticResource MaterialDesignBody2TextBlock}"
                                       Foreground="{DynamicResource MaterialDesignBodyLight}"
                                       TextTrimming="CharacterEllipsis"
                                       MaxWidth="400"
                                       ToolTip="{Binding CurrentAppName}"
                                       Visibility="{Binding CurrentAppName, Converter={StaticResource NullableToVisibilityConverter}}"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Counter Badge -->
                    <Border Grid.Column="1"
                            Background="{DynamicResource PrimaryHueLightBrush}"
                            CornerRadius="16"
                            Padding="16,8">
                        <TextBlock Foreground="{DynamicResource PrimaryHueLightForegroundBrush}"
                                   FontWeight="Bold"
                                   FontSize="16">
                            <Run Text="{Binding CompletedCount, Mode=OneWay}"/>
                            <Run Text="/"/>
                            <Run Text="{Binding TotalToInstall, Mode=OneWay}"/>
                        </TextBlock>
                    </Border>
                </Grid>

                <!-- Progress Bar -->
                <ProgressBar Grid.Row="1"
                             Value="{Binding ProgressPercentage, Mode=OneWay}"
                             Minimum="0"
                             Maximum="100"
                             Height="8"
                             Margin="0,20,0,8"
                             Style="{StaticResource MaterialDesignLinearProgressBar}"/>

                <!-- Time Info -->
                <StackPanel Grid.Row="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,16">
                    <materialDesign:PackIcon Kind="ClockOutline"
                                              Width="16" Height="16"
                                              VerticalAlignment="Center"
                                              Foreground="{DynamicResource MaterialDesignBodyLight}"
                                              Margin="0,0,6,0"/>
                    <TextBlock Style="{StaticResource MaterialDesignBody2TextBlock}"
                               Foreground="{DynamicResource MaterialDesignBodyLight}"
                               VerticalAlignment="Center">
                        <Run Text="{Binding ElapsedTime, Mode=OneWay}"/>
                        <Run Text=" / ~"/>
                        <Run Text="{Binding EstimatedTimeRemaining, Mode=OneWay}"/>
                    </TextBlock>
                    <TextBlock Text=" - "
                               Style="{StaticResource MaterialDesignBody2TextBlock}"
                               Foreground="{DynamicResource MaterialDesignBodyLight}"
                               Margin="8,0"/>
                    <TextBlock Style="{StaticResource MaterialDesignBody2TextBlock}"
                               FontWeight="Bold">
                        <Run Text="{Binding ProgressPercentage, Mode=OneWay, StringFormat={}{0:F0}}"/>
                        <Run Text="%"/>
                    </TextBlock>
                </StackPanel>

                <!-- Control Buttons -->
                <StackPanel Grid.Row="3"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center">
                    <!-- Pause Button -->
                    <Button Content="{loc:Loc Btn_Pause}"
                            Style="{StaticResource ThemeAdaptiveOutlinedButton}"
                            Command="{Binding PauseDeploymentCommand}"
                            Visibility="{Binding CanPauseDeployment, Converter={StaticResource BooleanToVisibilityConverter}}"
                            Margin="0,0,12,0">
                        <Button.ContentTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Pause" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="{loc:Loc Btn_Pause}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </Button.ContentTemplate>
                    </Button>

                    <!-- Resume Button -->
                    <Button Style="{StaticResource MaterialDesignRaisedButton}"
                            Command="{Binding ResumeDeploymentCommand}"
                            Visibility="{Binding CanResumeDeployment, Converter={StaticResource BooleanToVisibilityConverter}}"
                            Margin="0,0,12,0">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Play" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="{loc:Loc Btn_Resume}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Cancel Button -->
                    <Button Style="{StaticResource MaterialDesignOutlinedSecondaryButton}"
                            Command="{Binding CancelDeploymentCommand}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Close" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="{loc:Loc Btn_Cancel}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </materialDesign:Card>

        <!-- Empty State (no deployment in progress) -->
        <materialDesign:Card Grid.Row="1"
                              Padding="48"
                              Margin="0,0,0,16"
                              materialDesign:ElevationAssist.Elevation="Dp2"
                              Visibility="{Binding IsDeploying, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
            <StackPanel HorizontalAlignment="Center">
                <materialDesign:PackIcon Kind="MonitorDashboard"
                                          Width="64" Height="64"
                                          HorizontalAlignment="Center"
                                          Foreground="{DynamicResource MaterialDesignBodyLight}"
                                          AutomationProperties.Name="{loc:Loc A11y_NoDeploymentIcon}"/>
                <TextBlock Text="{loc:Loc Monitoring_NoDeployment}"
                           Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                           HorizontalAlignment="Center"
                           Margin="0,16,0,8"/>
                <TextBlock Text="{loc:Loc Monitoring_NoDeploymentHint}"
                           Style="{StaticResource MaterialDesignBody2TextBlock}"
                           Foreground="{DynamicResource MaterialDesignBodyLight}"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </materialDesign:Card>

        <!-- Deployment Result Banner -->
        <Border Grid.Row="2"
                Margin="0,0,0,16"
                Padding="16"
                CornerRadius="8"
                Visibility="{Binding IsDeploymentComplete, Converter={StaticResource BooleanToVisibilityConverter}}"
                AutomationProperties.LiveSetting="Polite">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="{DynamicResource SuccessBackgroundBrush}"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding DeploymentResult}" Value="Success">
                            <Setter Property="Background" Value="{DynamicResource SuccessBackgroundBrush}"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding DeploymentResult}" Value="Partial">
                            <Setter Property="Background" Value="{DynamicResource WarningBackgroundBrush}"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding DeploymentResult}" Value="Failed">
                            <Setter Property="Background" Value="{DynamicResource ErrorBackgroundBrush}"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding DeploymentResult}" Value="Cancelled">
                            <Setter Property="Background" Value="{DynamicResource MaterialDesignToolBarBackground}"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <!-- Result Icon -->
                <materialDesign:PackIcon Grid.Column="0"
                                          Width="32" Height="32"
                                          VerticalAlignment="Center"
                                          Margin="0,0,16,0">
                    <materialDesign:PackIcon.Style>
                        <Style TargetType="materialDesign:PackIcon">
                            <Setter Property="Kind" Value="CheckCircle"/>
                            <Setter Property="Foreground" Value="{DynamicResource SuccessIconBrush}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding DeploymentResult}" Value="Partial">
                                    <Setter Property="Kind" Value="AlertCircle"/>
                                    <Setter Property="Foreground" Value="{DynamicResource WarningIconBrush}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding DeploymentResult}" Value="Failed">
                                    <Setter Property="Kind" Value="CloseCircle"/>
                                    <Setter Property="Foreground" Value="{DynamicResource ErrorIconBrush}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding DeploymentResult}" Value="Cancelled">
                                    <Setter Property="Kind" Value="Cancel"/>
                                    <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBody}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </materialDesign:PackIcon.Style>
                </materialDesign:PackIcon>
                <!-- Result Text -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock>
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource MaterialDesignHeadline6TextBlock}">
                                <Setter Property="Text" Value="{loc:Loc Deployment_Result_Success}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DeploymentResult}" Value="Partial">
                                        <Setter Property="Text" Value="{loc:Loc Deployment_Result_Partial}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding DeploymentResult}" Value="Failed">
                                        <Setter Property="Text" Value="{loc:Loc Deployment_Result_Failed}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding DeploymentResult}" Value="Cancelled">
                                        <Setter Property="Text" Value="{loc:Loc Deployment_Result_Cancelled}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Style="{StaticResource MaterialDesignBody2TextBlock}"
                               Foreground="{DynamicResource MaterialDesignBodyLight}"
                               Margin="0,4,0,0">
                        <Run Text="{Binding SuccessCount, Mode=OneWay}"/>
                        <Run Text="{loc:Loc Deployment_Summary_Installed}"/>
                        <Run Text="{Binding FailureCount, Mode=OneWay}"/>
                        <Run Text="{loc:Loc Deployment_Summary_Failed}"/>
                        <Run Text="{Binding SkippedCount, Mode=OneWay}"/>
                        <Run Text="{loc:Loc Deployment_Summary_Skipped}"/>
                    </TextBlock>
                </StackPanel>
                <!-- Elapsed Time -->
                <TextBlock Grid.Column="2"
                           Style="{StaticResource MaterialDesignBody2TextBlock}"
                           Foreground="{DynamicResource MaterialDesignBodyLight}"
                           VerticalAlignment="Center">
                    <Run Text="{Binding ElapsedTime, Mode=OneWay}"/>
                </TextBlock>
            </Grid>
        </Border>

        <!-- Applications List (status only) - visible during deployment and after completion -->
        <materialDesign:Card Grid.Row="2"
                              Padding="0"
                              materialDesign:ElevationAssist.Elevation="Dp2">
            <materialDesign:Card.Style>
                <Style TargetType="materialDesign:Card" BasedOn="{StaticResource {x:Type materialDesign:Card}}">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Setter Property="Margin" Value="0"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsDeploying}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsDeploymentComplete}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Setter Property="Margin" Value="0,80,0,0"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </materialDesign:Card.Style>
            <DataGrid ItemsSource="{Binding DeploymentApplications}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      CanUserReorderColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      SelectionUnit="FullRow"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      BorderThickness="0"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.VirtualizationMode="Recycling"
                      VirtualizingPanel.ScrollUnit="Pixel"
                      EnableRowVirtualization="True"
                      materialDesign:DataGridAssist.CellPadding="12 8"
                      materialDesign:DataGridAssist.ColumnHeaderPadding="12 10"
                      RowStyle="{StaticResource EnhancedDataGridRowStyle}"
                      CellStyle="{StaticResource EnhancedDataGridCellStyle}"
                      AutomationProperties.Name="Deployment applications list">
                <DataGrid.Columns>
                    <!-- Status Icon -->
                    <DataGridTemplateColumn Width="50">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type models:ApplicationModel}">
                                <materialDesign:PackIcon Kind="{Binding Status, Converter={StaticResource StatusToIconConverter}}"
                                                          Width="20" Height="20"
                                                          HorizontalAlignment="Center"
                                                          Foreground="{Binding Status, Converter={StaticResource StatusToColorConverter}}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Application Name -->
                    <DataGridTemplateColumn Width="*" MinWidth="250">
                        <DataGridTemplateColumn.Header>
                            <TextBlock Text="{loc:Loc Col_Application}"/>
                        </DataGridTemplateColumn.Header>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type models:ApplicationModel}">
                                <TextBlock Text="{Binding Name}"
                                           Style="{StaticResource MaterialDesignBody1TextBlock}"
                                           VerticalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Status Message -->
                    <DataGridTemplateColumn Width="200">
                        <DataGridTemplateColumn.Header>
                            <TextBlock Text="{loc:Loc Col_Status}"/>
                        </DataGridTemplateColumn.Header>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type models:ApplicationModel}">
                                <TextBlock Text="{Binding StatusMessage}"
                                           Style="{StaticResource MaterialDesignBody2TextBlock}"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTip="{Binding StatusMessage}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Logs Button -->
                    <DataGridTemplateColumn Width="50">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type models:ApplicationModel}">
                                <!-- WCAG 2.5.5: 44x44px minimum touch target -->
                                <Button Style="{StaticResource MaterialDesignIconButton}"
                                        Width="44" Height="44"
                                        ToolTip="{loc:Loc Btn_ViewLogs}"
                                        Command="{Binding DataContext.ViewLogsCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"
                                        Visibility="{Binding LogOutput, Converter={StaticResource NullableToVisibilityConverter}}">
                                    <materialDesign:PackIcon Kind="FileDocumentOutline" Width="20" Height="20"/>
                                </Button>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </materialDesign:Card>

        <!-- Error Message -->
        <TextBlock Grid.Row="2"
                   Text="{Binding ErrorMessage}"
                   Foreground="{DynamicResource MaterialDesignValidationErrorBrush}"
                   Style="{StaticResource MaterialDesignBody1TextBlock}"
                   Visibility="{Binding ErrorMessage, Converter={StaticResource NullableToVisibilityConverter}}"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Top"
                   Margin="0,16,0,0"/>
    </Grid>
    </materialDesign:DialogHost>
</UserControl>
