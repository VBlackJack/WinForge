<UserControl x:Class="Win11Forge.GUI.Views.DeploymentView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:loc="clr-namespace:Win11Forge.GUI.Resources"
             xmlns:viewModels="clr-namespace:Win11Forge.GUI.ViewModels"
             xmlns:models="clr-namespace:Win11Forge.GUI.Models"
             xmlns:controls="clr-namespace:Win11Forge.GUI.Controls"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=viewModels:DeploymentViewModel}"
             d:DesignHeight="700" d:DesignWidth="1000">

    <materialDesign:DialogHost IsOpen="{Binding IsLogViewerOpen}"
                                CloseOnClickAway="True"
                                DialogClosing="DialogHost_DialogClosing">
        <materialDesign:DialogHost.DialogContent>
            <!-- Log Viewer Dialog -->
            <Border MinWidth="600" MaxWidth="900" MaxHeight="500" Padding="24">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Dialog Header -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,16">
                        <TextBlock Text="{loc:Loc LogViewer_Title}"
                                   Style="{StaticResource MaterialDesignHeadline6TextBlock}"/>
                        <TextBlock Text="{Binding LogViewerApplication.Name}"
                                   Style="{StaticResource MaterialDesignBody1TextBlock}"
                                   Opacity="0.7"
                                   Margin="0,4,0,0"/>
                        <!-- Error message if present -->
                        <Border Background="{DynamicResource ErrorBackgroundBrush}"
                                BorderBrush="{DynamicResource ErrorBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="12,8"
                                Margin="0,12,0,0"
                                Visibility="{Binding LogViewerApplication.ErrorMessage, Converter={StaticResource NullableToVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="AlertCircle"
                                                          Foreground="{DynamicResource ErrorIconBrush}"
                                                          Width="20" Height="20"
                                                          VerticalAlignment="Center"
                                                          Margin="0,0,8,0"/>
                                <TextBlock Text="{Binding LogViewerApplication.ErrorMessage}"
                                           Foreground="{DynamicResource ErrorTextBrush}"
                                           TextWrapping="Wrap"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Log Content -->
                    <Border Grid.Row="1"
                            Background="{DynamicResource MaterialDesignCardBackground}"
                            BorderBrush="{DynamicResource MaterialDesignDivider}"
                            BorderThickness="1"
                            CornerRadius="4">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Auto">
                            <TextBox Text="{Binding LogViewerApplication.LogOutput, Mode=OneWay}"
                                     IsReadOnly="True"
                                     TextWrapping="NoWrap"
                                     FontFamily="Consolas"
                                     FontSize="12"
                                     BorderThickness="0"
                                     Padding="12"
                                     Background="Transparent"
                                     VerticalScrollBarVisibility="Disabled"
                                     HorizontalScrollBarVisibility="Disabled"/>
                        </ScrollViewer>
                    </Border>

                    <!-- No logs message -->
                    <TextBlock Grid.Row="1"
                               Text="{loc:Loc LogViewer_NoLogs}"
                               Style="{StaticResource MaterialDesignBody2TextBlock}"
                               Opacity="0.5"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Visibility="{Binding LogViewerApplication.LogOutput, Converter={StaticResource InverseNullableToVisibilityConverter}}"/>

                    <!-- Dialog Actions -->
                    <StackPanel Grid.Row="2"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Margin="0,16,0,0">
                        <Button Content="{loc:Loc LogViewer_Copy}"
                                Style="{StaticResource MaterialDesignFlatSecondaryButton}"
                                Click="CopyLogsToClipboard_Click"
                                Margin="0,0,12,0"/>
                        <Button Content="{loc:Loc LogViewer_Close}"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                Command="{Binding CloseLogViewerCommand}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </materialDesign:DialogHost.DialogContent>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="{loc:Loc Deploy_Title}"
                       Style="{StaticResource MaterialDesignHeadline4TextBlock}"
                       Margin="0,0,0,12"/>
            <!-- Breadcrumb Navigation -->
            <controls:Breadcrumb x:Name="DeploymentBreadcrumb"
                                 AutomationProperties.Name="Deployment progress steps"/>
        </StackPanel>

        <!-- Dry Run Warning Banner (prominent position at top) -->
        <Border Grid.Row="1"
                Background="{DynamicResource WarningBackgroundBrush}"
                BorderBrush="{DynamicResource WarningBorderBrush}"
                BorderThickness="2"
                CornerRadius="4"
                Padding="16,12"
                Margin="0,0,0,16"
                Visibility="{Binding IsDryRun, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <materialDesign:PackIcon Kind="AlertCircleOutline"
                                          Width="24"
                                          Height="24"
                                          Foreground="{DynamicResource WarningIconBrush}"
                                          VerticalAlignment="Center"
                                          Margin="0,0,12,0"/>
                <TextBlock Text="{loc:Loc Deploy_DryRunBanner}"
                           Style="{StaticResource MaterialDesignBody1TextBlock}"
                           FontWeight="Bold"
                           Foreground="{DynamicResource WarningTextBrush}"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Profile Selection Card -->
        <materialDesign:Card Grid.Row="2"
                              Padding="16"
                              Margin="0,0,0,16"
                              materialDesign:ElevationAssist.Elevation="Dp2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="250"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Profile Label with Help -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
                    <TextBlock Text="{loc:Loc Deploy_SelectProfile}"
                               Style="{StaticResource MaterialDesignBody1TextBlock}"
                               VerticalAlignment="Center"/>
                    <materialDesign:PackIcon Kind="HelpCircleOutline"
                                              Width="16" Height="16"
                                              Opacity="0.6"
                                              VerticalAlignment="Center"
                                              Margin="8,0,0,0"
                                              ToolTip="{loc:Loc Help_SelectProfile}"/>
                </StackPanel>

                <!-- Profile ComboBox -->
                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding AvailableProfiles}"
                          SelectedItem="{Binding SelectedProfile}"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBoolConverter}}"
                          AutomationProperties.Name="Select deployment profile"
                          AutomationProperties.HelpText="Choose a predefined set of applications to deploy"/>

                <!-- Loading Indicator -->
                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Visibility="{Binding IsLoadingProfile, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                                 Value="0"
                                 IsIndeterminate="True"
                                 Width="20"
                                 Height="20"
                                 Margin="0,0,8,0"/>
                    <TextBlock Text="{loc:Loc Common_Loading}"
                               VerticalAlignment="Center"
                               Style="{StaticResource MaterialDesignBody2TextBlock}"/>
                </StackPanel>
            </Grid>
        </materialDesign:Card>

        <!-- Profile Summary Card -->
        <materialDesign:Card Grid.Row="3"
                              Padding="16"
                              Margin="0,0,0,16"
                              materialDesign:ElevationAssist.Elevation="Dp2"
                              Visibility="{Binding CurrentProfile, Converter={StaticResource NullableToVisibilityConverter}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Summary Title -->
                <TextBlock Grid.Row="0"
                           Text="{loc:Loc Deploy_ProfileSummary}"
                           Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                           Margin="0,0,0,12"/>

                <!-- Summary Content -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Total -->
                    <TextBlock Grid.Column="0"
                               Text="{loc:Loc Deploy_TotalApps}"
                               Style="{StaticResource MaterialDesignBody2TextBlock}"
                               VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1"
                               Text="{Binding CurrentProfile.TotalApplications}"
                               Style="{StaticResource MaterialDesignBody1TextBlock}"
                               FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryHueMidBrush}"
                               VerticalAlignment="Center"/>

                    <!-- Required -->
                    <TextBlock Grid.Column="2"
                               Text="{loc:Loc Deploy_RequiredApps}"
                               Style="{StaticResource MaterialDesignBody2TextBlock}"
                               VerticalAlignment="Center"
                               Margin="24,0,0,0"/>
                    <TextBlock Grid.Column="3"
                               Text="{Binding CurrentProfile.RequiredApplications}"
                               Style="{StaticResource MaterialDesignBody1TextBlock}"
                               FontWeight="Bold"
                               Foreground="{DynamicResource SecondaryHueMidBrush}"
                               VerticalAlignment="Center"/>

                    <!-- Selected -->
                    <TextBlock Grid.Column="4"
                               Text="{loc:Loc Deploy_Selected}"
                               Style="{StaticResource MaterialDesignBody2TextBlock}"
                               VerticalAlignment="Center"
                               Margin="24,0,0,0"/>
                    <TextBlock Grid.Column="5"
                               Text="{Binding SelectedApplicationsCount}"
                               Style="{StaticResource MaterialDesignBody1TextBlock}"
                               FontWeight="Bold"
                               VerticalAlignment="Center"/>

                    <!-- Action Buttons -->
                    <Button Grid.Column="6"
                            Content="{loc:Loc Deploy_SelectAll}"
                            Style="{StaticResource MaterialDesignFlatSecondaryButton}"
                            Command="{Binding SelectAllCommand}"
                            Margin="16,0,8,0"
                            AutomationProperties.Name="Select all applications"
                            AutomationProperties.HelpText="Select all optional applications for deployment"/>
                    <Button Grid.Column="7"
                            Content="{loc:Loc Deploy_SelectNone}"
                            Style="{StaticResource MaterialDesignFlatSecondaryButton}"
                            Command="{Binding SelectNoneCommand}"
                            AutomationProperties.Name="Select none"
                            AutomationProperties.HelpText="Deselect all optional applications"/>
                </Grid>
            </Grid>
        </materialDesign:Card>

        <!-- Deployment Controls Card -->
        <materialDesign:Card Grid.Row="4"
                              Padding="16"
                              Margin="0,0,0,16"
                              materialDesign:ElevationAssist.Elevation="Dp2"
                              Visibility="{Binding CurrentProfile, Converter={StaticResource NullableToVisibilityConverter}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Dry Run Toggle -->
                <ToggleButton Grid.Column="0"
                              IsChecked="{Binding IsDryRun}"
                              Style="{StaticResource MaterialDesignSwitchToggleButton}"
                              IsEnabled="{Binding IsDeploying, Converter={StaticResource InverseBoolConverter}}"
                              AutomationProperties.Name="Dry Run mode"
                              AutomationProperties.HelpText="When enabled, simulates the deployment without making actual changes"/>
                <StackPanel Grid.Column="1"
                            Orientation="Vertical"
                            Margin="12,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{loc:Loc Lbl_DryRun}"
                                   Style="{StaticResource MaterialDesignBody1TextBlock}"/>
                        <materialDesign:PackIcon Kind="HelpCircleOutline"
                                                  Width="14" Height="14"
                                                  Opacity="0.6"
                                                  VerticalAlignment="Center"
                                                  Margin="6,0,0,0"
                                                  ToolTip="{loc:Loc Help_DryRun}"/>
                    </StackPanel>
                    <TextBlock Text="{loc:Loc Lbl_DryRun_Hint}"
                               Style="{StaticResource MaterialDesignCaptionTextBlock}"
                               Opacity="0.7"/>
                </StackPanel>

                <!-- Progress/Status Display -->
                <Grid Grid.Column="2"
                      Margin="24,0"
                      Visibility="{Binding IsDeploying, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Status Icon -->
                    <materialDesign:PackIcon Grid.Row="0" Grid.Column="0"
                                              Kind="{Binding IsPaused, Converter={StaticResource BoolToPauseIconConverter}}"
                                              Width="20" Height="20"
                                              VerticalAlignment="Center"
                                              Margin="0,0,8,0"
                                              Foreground="{DynamicResource PrimaryHueMidBrush}"/>

                    <!-- Status Text -->
                    <TextBlock Grid.Row="0" Grid.Column="1"
                               Text="{Binding DeploymentStatusMessage}"
                               Style="{StaticResource MaterialDesignBody2TextBlock}"
                               VerticalAlignment="Center"/>

                    <!-- Counter -->
                    <TextBlock Grid.Row="0" Grid.Column="2"
                               VerticalAlignment="Center"
                               Margin="12,0,0,0">
                        <Run Text="{Binding CompletedCount, Mode=OneWay}"/>
                        <Run Text="/"/>
                        <Run Text="{Binding TotalToInstall, Mode=OneWay}"/>
                    </TextBlock>

                    <!-- Progress Bar -->
                    <ProgressBar Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                                 Value="{Binding ProgressPercentage, Mode=OneWay}"
                                 Minimum="0"
                                 Maximum="100"
                                 Height="6"
                                 Margin="0,8,0,0"
                                 Style="{StaticResource MaterialDesignLinearProgressBar}"/>
                </Grid>

                <!-- Deploy Button -->
                <Button Grid.Column="3"
                        Content="{loc:Loc Btn_Deploy}"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Command="{Binding DeployCommand}"
                        Margin="0,0,12,0"
                        AutomationProperties.Name="Start deployment"
                        AutomationProperties.HelpText="Begin installing the selected applications"/>

                <!-- Pause Button -->
                <Button Grid.Column="4"
                        Content="{loc:Loc Btn_Pause}"
                        Style="{StaticResource MaterialDesignFlatSecondaryButton}"
                        Command="{Binding PauseDeploymentCommand}"
                        Visibility="{Binding CanPauseDeployment, Converter={StaticResource BooleanToVisibilityConverter}}"
                        Margin="0,0,8,0"
                        AutomationProperties.Name="Pause deployment"
                        AutomationProperties.HelpText="Pause the current deployment after the current application completes"/>

                <!-- Resume Button -->
                <Button Grid.Column="5"
                        Content="{loc:Loc Btn_Resume}"
                        Style="{StaticResource MaterialDesignRaisedSecondaryButton}"
                        Command="{Binding ResumeDeploymentCommand}"
                        Visibility="{Binding CanResumeDeployment, Converter={StaticResource BooleanToVisibilityConverter}}"
                        Margin="0,0,8,0"
                        AutomationProperties.Name="Resume deployment"
                        AutomationProperties.HelpText="Continue the paused deployment"/>

                <!-- Cancel Button -->
                <Button Grid.Column="6"
                        Content="{loc:Loc Btn_Cancel}"
                        Style="{StaticResource MaterialDesignFlatSecondaryButton}"
                        Command="{Binding CancelDeploymentCommand}"
                        Visibility="{Binding IsDeploying, Converter={StaticResource BooleanToVisibilityConverter}}"
                        AutomationProperties.Name="Cancel deployment"
                        AutomationProperties.HelpText="Stop the deployment and cancel remaining installations"/>
            </Grid>
        </materialDesign:Card>

        <!-- Applications DataGrid -->
        <materialDesign:Card Grid.Row="5"
                              Padding="0"
                              materialDesign:ElevationAssist.Elevation="Dp2"
                              Visibility="{Binding CurrentProfile, Converter={StaticResource NullableToVisibilityConverter}}">
            <DataGrid ItemsSource="{Binding CurrentProfile.Applications}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      CanUserReorderColumns="False"
                      SelectionMode="Single"
                      SelectionUnit="FullRow"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      BorderThickness="0"
                      materialDesign:DataGridAssist.CellPadding="16 8"
                      materialDesign:DataGridAssist.ColumnHeaderPadding="16 8"
                      AutomationProperties.Name="Deployment applications list"
                      AutomationProperties.HelpText="List of applications in the selected profile. Use checkboxes to select applications for deployment.">
                <DataGrid.Columns>
                    <!-- Selection Checkbox -->
                    <DataGridTemplateColumn Width="60">
                        <DataGridTemplateColumn.Header>
                            <CheckBox IsChecked="{Binding DataContext.AllSelected, RelativeSource={RelativeSource AncestorType=DataGrid}, Mode=OneWay}"
                                      Style="{StaticResource MaterialDesignCheckBox}"/>
                        </DataGridTemplateColumn.Header>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type models:ApplicationModel}">
                                <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                          Style="{StaticResource MaterialDesignCheckBox}"
                                          IsEnabled="{Binding IsRequired, Converter={StaticResource InverseBoolConverter}}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Status Column - Localized Header -->
                    <DataGridTemplateColumn Width="100">
                        <DataGridTemplateColumn.Header>
                            <TextBlock Text="{loc:Loc Col_Status}"/>
                        </DataGridTemplateColumn.Header>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type models:ApplicationModel}">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="{Binding Status, Converter={StaticResource StatusToIconConverter}}"
                                                              Width="20"
                                                              Height="20"
                                                              Foreground="{Binding Status, Converter={StaticResource StatusToColorConverter}}"
                                                              ToolTip="{Binding StatusMessage}"/>
                                    <TextBlock Text="{Binding StatusMessage}"
                                               Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                               VerticalAlignment="Center"
                                               Margin="6,0,0,0"
                                               MaxWidth="100"
                                               TextTrimming="CharacterEllipsis"
                                               ToolTip="{Binding StatusMessage}"
                                               Visibility="{Binding StatusMessage, Converter={StaticResource NullableToVisibilityConverter}}"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Application Column - Localized Header -->
                    <DataGridTemplateColumn Width="*" MinWidth="200">
                        <DataGridTemplateColumn.Header>
                            <TextBlock Text="{loc:Loc Col_Application}"/>
                        </DataGridTemplateColumn.Header>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type models:ApplicationModel}">
                                <StackPanel Orientation="Vertical">
                                    <TextBlock Text="{Binding Name}"
                                               Style="{StaticResource MaterialDesignBody1TextBlock}"
                                               FontWeight="Medium"/>
                                    <TextBlock Text="{Binding Description}"
                                               Style="{StaticResource MaterialDesignBody2TextBlock}"
                                               Opacity="0.7"
                                               TextTrimming="CharacterEllipsis"
                                               ToolTip="{Binding Description}"
                                               MaxWidth="400"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Category Column - Localized Header -->
                    <DataGridTemplateColumn Width="120">
                        <DataGridTemplateColumn.Header>
                            <TextBlock Text="{loc:Loc Col_Category}"/>
                        </DataGridTemplateColumn.Header>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type models:ApplicationModel}">
                                <materialDesign:Chip Content="{Binding Category}"
                                                      IconBackground="{DynamicResource PrimaryHueLightBrush}"
                                                      IconForeground="{DynamicResource PrimaryHueLightForegroundBrush}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Priority Column - Localized Header -->
                    <DataGridTemplateColumn Width="80">
                        <DataGridTemplateColumn.Header>
                            <TextBlock Text="{loc:Loc Col_Priority}"/>
                        </DataGridTemplateColumn.Header>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type models:ApplicationModel}">
                                <TextBlock Text="{Binding Priority}"
                                           HorizontalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Required Column - Localized Header -->
                    <DataGridTemplateColumn Width="80">
                        <DataGridTemplateColumn.Header>
                            <TextBlock Text="{loc:Loc Col_Required}"/>
                        </DataGridTemplateColumn.Header>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type models:ApplicationModel}">
                                <materialDesign:PackIcon Kind="{Binding IsRequired, Converter={StaticResource BoolToRequiredIconConverter}}"
                                                          Width="20"
                                                          Height="20"
                                                          HorizontalAlignment="Center"
                                                          Foreground="{Binding IsRequired, Converter={StaticResource BoolToRequiredColorConverter}}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Logs Column -->
                    <DataGridTemplateColumn Width="70">
                        <DataGridTemplateColumn.Header>
                            <TextBlock Text="{loc:Loc Col_Logs}"/>
                        </DataGridTemplateColumn.Header>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type models:ApplicationModel}">
                                <Button Style="{StaticResource MaterialDesignIconButton}"
                                        Width="32" Height="32"
                                        ToolTip="{loc:Loc Btn_ViewLogs}"
                                        Command="{Binding DataContext.ViewLogsCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"
                                        Visibility="{Binding LogOutput, Converter={StaticResource NullableToVisibilityConverter}}">
                                    <materialDesign:PackIcon Kind="FileDocumentOutline" Width="18" Height="18"/>
                                </Button>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </materialDesign:Card>

        <!-- Error Message -->
        <TextBlock Grid.Row="5"
                   Text="{Binding ErrorMessage}"
                   Foreground="{DynamicResource MaterialDesignValidationErrorBrush}"
                   Style="{StaticResource MaterialDesignBody1TextBlock}"
                   Visibility="{Binding ErrorMessage, Converter={StaticResource NullableToVisibilityConverter}}"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"/>
    </Grid>
    </materialDesign:DialogHost>
</UserControl>
