<UserControl x:Class="Win11Forge.GUI.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:loc="clr-namespace:Win11Forge.GUI.Resources"
             xmlns:viewModels="clr-namespace:Win11Forge.GUI.ViewModels"
             xmlns:models="clr-namespace:Win11Forge.GUI.Models"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=viewModels:DashboardViewModel}"
             d:DesignHeight="800" d:DesignWidth="1000">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header with Title and Refresh -->
            <Grid Grid.Row="0" Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{loc:Loc Dashboard_Title}"
                           Style="{StaticResource MaterialDesignHeadline4TextBlock}"/>

                <Button Grid.Column="1"
                        Command="{Binding RefreshCommand}"
                        Style="{StaticResource MaterialDesignIconButton}"
                        ToolTip="{loc:Loc Dashboard_Refresh}">
                    <materialDesign:PackIcon Kind="Refresh" Width="24" Height="24"/>
                </Button>
            </Grid>

            <!-- Quick Stats Cards -->
            <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,16">
                <!-- Profiles Card -->
                <materialDesign:Card Padding="16" Margin="0,0,8,0"
                                      materialDesign:ElevationAssist.Elevation="Dp2">
                    <StackPanel>
                        <materialDesign:PackIcon Kind="FileDocumentMultiple"
                                                  Width="32" Height="32"
                                                  Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                        <TextBlock Text="{Binding ProfileCount}"
                                   Style="{StaticResource MaterialDesignHeadline4TextBlock}"
                                   Margin="0,8,0,0"/>
                        <TextBlock Text="{loc:Loc Dashboard_Stat_Profiles}"
                                   Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                   Opacity="0.7"/>
                    </StackPanel>
                </materialDesign:Card>

                <!-- Applications Card -->
                <materialDesign:Card Padding="16" Margin="4,0"
                                      materialDesign:ElevationAssist.Elevation="Dp2">
                    <StackPanel>
                        <materialDesign:PackIcon Kind="Apps"
                                                  Width="32" Height="32"
                                                  Foreground="{DynamicResource SecondaryHueMidBrush}"/>
                        <TextBlock Text="{Binding ApplicationCount}"
                                   Style="{StaticResource MaterialDesignHeadline4TextBlock}"
                                   Margin="0,8,0,0"/>
                        <TextBlock Text="{loc:Loc Dashboard_Stat_Apps}"
                                   Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                   Opacity="0.7"/>
                    </StackPanel>
                </materialDesign:Card>

                <!-- Deployments Card -->
                <materialDesign:Card Padding="16" Margin="4,0"
                                      materialDesign:ElevationAssist.Elevation="Dp2">
                    <StackPanel>
                        <materialDesign:PackIcon Kind="Rocket"
                                                  Width="32" Height="32"
                                                  Foreground="{DynamicResource PrimaryHueLightBrush}"/>
                        <TextBlock Text="{Binding TotalDeployments}"
                                   Style="{StaticResource MaterialDesignHeadline4TextBlock}"
                                   Margin="0,8,0,0"/>
                        <TextBlock Text="{loc:Loc Dashboard_Stat_Deployments}"
                                   Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                   Opacity="0.7"/>
                    </StackPanel>
                </materialDesign:Card>

                <!-- Version Card -->
                <materialDesign:Card Padding="16" Margin="8,0,0,0"
                                      materialDesign:ElevationAssist.Elevation="Dp2">
                    <StackPanel>
                        <materialDesign:PackIcon Kind="Information"
                                                  Width="32" Height="32"
                                                  Foreground="{DynamicResource MaterialDesignBody}"/>
                        <TextBlock Text="{Binding AppVersion}"
                                   Style="{StaticResource MaterialDesignHeadline5TextBlock}"
                                   Margin="0,8,0,0"/>
                        <TextBlock Text="{loc:Loc Dashboard_Stat_Version}"
                                   Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                   Opacity="0.7"/>
                    </StackPanel>
                </materialDesign:Card>
            </UniformGrid>

            <!-- Main Content Grid -->
            <Grid Grid.Row="2" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- System Info Card -->
                <materialDesign:Card Grid.Column="0"
                                      Padding="16"
                                      materialDesign:ElevationAssist.Elevation="Dp2">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                            <materialDesign:PackIcon Kind="MonitorDashboard"
                                                      Width="24" Height="24"
                                                      VerticalAlignment="Center"
                                                      Margin="0,0,8,0"/>
                            <TextBlock Text="{loc:Loc Dashboard_SystemInfo_Title}"
                                       Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                                       VerticalAlignment="Center"/>
                            <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                                         Value="0" IsIndeterminate="True"
                                         Width="16" Height="16"
                                         Margin="12,0,0,0"
                                         Visibility="{Binding IsLoadingSystemInfo, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        </StackPanel>

                        <!-- System Info Content -->
                        <StackPanel Grid.Row="1"
                                    Visibility="{Binding SystemInfo, Converter={StaticResource NullableToVisibilityConverter}}">
                            <!-- Hostname -->
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{loc:Loc Dashboard_Sys_Hostname}"
                                           Style="{StaticResource MaterialDesignBody2TextBlock}"
                                           Opacity="0.7"/>
                                <TextBlock Grid.Column="1" Text="{Binding SystemInfo.Hostname}"
                                           Style="{StaticResource MaterialDesignBody1TextBlock}"/>
                            </Grid>

                            <!-- OS -->
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{loc:Loc Dashboard_Sys_OS}"
                                           Style="{StaticResource MaterialDesignBody2TextBlock}"
                                           Opacity="0.7"/>
                                <TextBlock Grid.Column="1" Text="{Binding SystemInfo.WindowsVersion}"
                                           Style="{StaticResource MaterialDesignBody1TextBlock}"
                                           TextTrimming="CharacterEllipsis"/>
                            </Grid>

                            <!-- Build -->
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{loc:Loc Dashboard_Sys_Build}"
                                           Style="{StaticResource MaterialDesignBody2TextBlock}"
                                           Opacity="0.7"/>
                                <TextBlock Grid.Column="1" Text="{Binding SystemInfo.WindowsBuild}"
                                           Style="{StaticResource MaterialDesignBody1TextBlock}"/>
                            </Grid>

                            <!-- Admin Status -->
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{loc:Loc Dashboard_Sys_Admin}"
                                           Style="{StaticResource MaterialDesignBody2TextBlock}"
                                           Opacity="0.7"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="{Binding SystemInfo.IsAdministrator, Converter={StaticResource BoolToRequiredIconConverter}}"
                                                              Width="18" Height="18"
                                                              VerticalAlignment="Center"
                                                              Foreground="{Binding SystemInfo.IsAdministrator, Converter={StaticResource BoolToRequiredColorConverter}}"
                                                              Margin="0,0,4,0"/>
                                    <TextBlock Text="{Binding SystemInfo.IsAdministrator}"
                                               Style="{StaticResource MaterialDesignBody1TextBlock}"/>
                                </StackPanel>
                            </Grid>

                            <!-- Winget -->
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{loc:Loc Dashboard_Sys_Winget}"
                                           Style="{StaticResource MaterialDesignBody2TextBlock}"
                                           Opacity="0.7"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="{Binding SystemInfo.WingetAvailable, Converter={StaticResource BoolToRequiredIconConverter}}"
                                                              Width="18" Height="18"
                                                              VerticalAlignment="Center"
                                                              Foreground="{Binding SystemInfo.WingetAvailable, Converter={StaticResource BoolToRequiredColorConverter}}"
                                                              Margin="0,0,4,0"/>
                                    <TextBlock Text="{Binding SystemInfo.WingetVersion}"
                                               Style="{StaticResource MaterialDesignBody1TextBlock}"/>
                                </StackPanel>
                            </Grid>

                            <!-- Chocolatey -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{loc:Loc Dashboard_Sys_Chocolatey}"
                                           Style="{StaticResource MaterialDesignBody2TextBlock}"
                                           Opacity="0.7"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="{Binding SystemInfo.ChocolateyAvailable, Converter={StaticResource BoolToRequiredIconConverter}}"
                                                              Width="18" Height="18"
                                                              VerticalAlignment="Center"
                                                              Foreground="{Binding SystemInfo.ChocolateyAvailable, Converter={StaticResource BoolToRequiredColorConverter}}"
                                                              Margin="0,0,4,0"/>
                                    <TextBlock Text="{Binding SystemInfo.ChocolateyVersion}"
                                               Style="{StaticResource MaterialDesignBody1TextBlock}"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </materialDesign:Card>

                <!-- Recent Activity Card -->
                <materialDesign:Card Grid.Column="2"
                                      Padding="16"
                                      materialDesign:ElevationAssist.Elevation="Dp2">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                            <materialDesign:PackIcon Kind="History"
                                                      Width="24" Height="24"
                                                      VerticalAlignment="Center"
                                                      Margin="0,0,8,0"/>
                            <TextBlock Text="{loc:Loc Dashboard_RecentActivity}"
                                       Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- History List -->
                        <ItemsControl Grid.Row="1"
                                       ItemsSource="{Binding RecentDeployments}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:DeploymentHistoryEntry}">
                                    <Border BorderBrush="{DynamicResource MaterialDesignDivider}"
                                            BorderThickness="0,0,0,1"
                                            Padding="0,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Status Icon -->
                                            <materialDesign:PackIcon Grid.Column="0"
                                                                      Kind="{Binding Result, Converter={StaticResource StatusToIconConverter}}"
                                                                      Width="20" Height="20"
                                                                      Foreground="{Binding Result, Converter={StaticResource StatusToColorConverter}}"
                                                                      VerticalAlignment="Center"
                                                                      Margin="0,0,12,0"/>

                                            <!-- Profile Info -->
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="{Binding ProfileName}"
                                                           Style="{StaticResource MaterialDesignBody1TextBlock}"
                                                           FontWeight="Medium"/>
                                                <TextBlock Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                                           Opacity="0.7">
                                                    <Run Text="{Binding Summary}"/>
                                                    <Run Text=" - "/>
                                                    <Run Text="{Binding FormattedDuration}"/>
                                                </TextBlock>
                                            </StackPanel>

                                            <!-- Date -->
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding FormattedDate}"
                                                       Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                                       Opacity="0.5"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Empty State -->
                        <StackPanel Grid.Row="1"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Visibility="{Binding RecentDeployments.Count, Converter={StaticResource ZeroToVisibilityConverter}}">
                            <materialDesign:PackIcon Kind="History"
                                                      Width="48" Height="48"
                                                      Opacity="0.3"
                                                      HorizontalAlignment="Center"/>
                            <TextBlock Text="{loc:Loc Dashboard_NoActivity}"
                                       Style="{StaticResource MaterialDesignBody2TextBlock}"
                                       Opacity="0.5"
                                       HorizontalAlignment="Center"
                                       Margin="0,8,0,0"/>
                        </StackPanel>
                    </Grid>
                </materialDesign:Card>
            </Grid>

            <!-- Repository Path -->
            <materialDesign:Card Grid.Row="3"
                                  Padding="12"
                                  materialDesign:ElevationAssist.Elevation="Dp1">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="FolderOpen"
                                              Width="20" Height="20"
                                              VerticalAlignment="Center"
                                              Opacity="0.7"
                                              Margin="0,0,8,0"/>
                    <TextBlock Text="{loc:Loc Dashboard_Repository_Prefix}"
                               Style="{StaticResource MaterialDesignBody2TextBlock}"
                               VerticalAlignment="Center"
                               Opacity="0.7"
                               Margin="0,0,8,0"/>
                    <TextBlock Text="{Binding RepositoryPath}"
                               Style="{StaticResource MaterialDesignBody2TextBlock}"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"
                               ToolTip="{Binding RepositoryPath}"/>
                </StackPanel>
            </materialDesign:Card>
        </Grid>
    </ScrollViewer>
</UserControl>
