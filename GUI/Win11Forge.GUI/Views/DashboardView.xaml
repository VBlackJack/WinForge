<UserControl x:Class="Win11Forge.GUI.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:loc="clr-namespace:Win11Forge.GUI.Resources"
             xmlns:viewModels="clr-namespace:Win11Forge.GUI.ViewModels"
             xmlns:models="clr-namespace:Win11Forge.GUI.Models"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=viewModels:DashboardViewModel}"
             d:DesignHeight="800" d:DesignWidth="1000">

    <UserControl.Resources>
        <!-- Clickable Stats Card Style -->
        <Style x:Key="ClickableStatsCard" TargetType="Button" BasedOn="{StaticResource MaterialDesignFlatButton}">
            <Setter Property="Height" Value="Auto"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
            <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="8"/>
            <Setter Property="Background" Value="{DynamicResource MaterialDesignCardBackground}"/>
            <Setter Property="materialDesign:ElevationAssist.Elevation" Value="Dp1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource MaterialDesignSelection}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Quick Action Button Style -->
        <Style x:Key="QuickActionButtonStyle" TargetType="Button" BasedOn="{StaticResource ThemeAdaptiveOutlinedButton}">
            <Setter Property="Height" Value="Auto"/>
            <Setter Property="Padding" Value="24,16"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="8"/>
        </Style>

        <!-- Hero CTA Button Style -->
        <Style x:Key="HeroCtaButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
            <Setter Property="Height" Value="56"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="32,0"/>
            <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="8"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="32,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>   <!-- Hero Section -->
                <RowDefinition Height="Auto"/>   <!-- Stats Row -->
                <RowDefinition Height="Auto"/>   <!-- Main Content -->
                <RowDefinition Height="Auto"/>   <!-- History -->
                <RowDefinition Height="Auto"/>   <!-- Footer -->
            </Grid.RowDefinitions>

            <!-- HERO SECTION -->
            <materialDesign:Card Grid.Row="0"
                                  Margin="0,0,0,24"
                                  Padding="32"
                                  materialDesign:ElevationAssist.Elevation="Dp2">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Hero Content -->
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <!-- State: Checking -->
                        <StackPanel Visibility="{Binding IsChecking, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                                             IsIndeterminate="True"
                                             Width="32" Height="32"
                                             Margin="0,0,16,0"/>
                                <TextBlock Text="{Binding HeroTitle}"
                                           Style="{StaticResource MaterialDesignHeadline5TextBlock}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="{Binding HeroSubtitle}"
                                       Style="{StaticResource MaterialDesignBody1TextBlock}"
                                       Opacity="0.7"/>
                        </StackPanel>

                        <!-- State: NeedPrereqs -->
                        <StackPanel Visibility="{Binding NeedsPrerequisites, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <materialDesign:PackIcon Kind="AlertCircle"
                                                          Width="32" Height="32"
                                                          Foreground="{DynamicResource AccentOrangeTextBrush}"
                                                          Margin="0,0,16,0"
                                                          VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding HeroTitle}"
                                           Style="{StaticResource MaterialDesignHeadline5TextBlock}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="{Binding HeroSubtitle}"
                                       Style="{StaticResource MaterialDesignBody1TextBlock}"
                                       Opacity="0.7"
                                       Margin="0,0,0,16"/>
                            <Button Command="{Binding NavigateToPrerequisitesCommand}"
                                    Style="{StaticResource MaterialDesignRaisedButton}"
                                    Background="{DynamicResource AccentOrangeTextBrush}"
                                    Foreground="White"
                                    materialDesign:ButtonAssist.CornerRadius="8"
                                    Padding="24,12"
                                    HorizontalAlignment="Left">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Wrench"
                                                              Width="20" Height="20"
                                                              VerticalAlignment="Center"
                                                              Margin="0,0,8,0"/>
                                    <TextBlock Text="{loc:Loc Dashboard_Btn_FixPrereqs}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <!-- State: Ready -->
                        <StackPanel Visibility="{Binding IsReady, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <materialDesign:PackIcon Kind="CheckCircle"
                                                          Width="32" Height="32"
                                                          Foreground="{DynamicResource AccentGreenTextBrush}"
                                                          Margin="0,0,16,0"
                                                          VerticalAlignment="Center"
                                                          Visibility="{Binding HasUpdatesAvailable, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>
                                <materialDesign:PackIcon Kind="InformationOutline"
                                                          Width="32" Height="32"
                                                          Foreground="{DynamicResource PrimaryHueMidBrush}"
                                                          Margin="0,0,16,0"
                                                          VerticalAlignment="Center"
                                                          Visibility="{Binding HasUpdatesAvailable, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                <TextBlock Text="{Binding HeroTitle}"
                                           Style="{StaticResource MaterialDesignHeadline5TextBlock}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="{Binding HeroSubtitle}"
                                       Style="{StaticResource MaterialDesignBody1TextBlock}"
                                       Opacity="0.7"
                                       Margin="0,0,0,16"/>
                            <StackPanel Orientation="Horizontal">
                                <Button Command="{Binding StartDeploymentCommand}"
                                        Style="{StaticResource HeroCtaButton}"
                                        Margin="0,0,12,0">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="RocketLaunch"
                                                                  Width="24" Height="24"
                                                                  VerticalAlignment="Center"
                                                                  Margin="0,0,12,0"/>
                                        <TextBlock Text="{loc:Loc Dashboard_Btn_StartDeployment}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button Command="{Binding ViewUpdatesCommand}"
                                        Style="{StaticResource MaterialDesignOutlinedButton}"
                                        materialDesign:ButtonAssist.CornerRadius="8"
                                        Height="56"
                                        Padding="24,0"
                                        Visibility="{Binding HasUpdatesAvailable, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="Download"
                                                                  Width="20" Height="20"
                                                                  VerticalAlignment="Center"
                                                                  Margin="0,0,8,0"/>
                                        <TextBlock Text="{loc:Loc Dashboard_Btn_ViewUpdates}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>

                    <!-- Version Badge -->
                    <Border Grid.Column="1"
                            Background="{DynamicResource MaterialDesignCardBackground}"
                            BorderBrush="{DynamicResource MaterialDesignDivider}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="16,12"
                            VerticalAlignment="Top">
                        <StackPanel>
                            <TextBlock Text="Win11Forge"
                                       Style="{StaticResource MaterialDesignSubtitle2TextBlock}"
                                       Opacity="0.7"/>
                            <TextBlock Style="{StaticResource MaterialDesignHeadline6TextBlock}">
                                <Run Text="v"/>
                                <Run Text="{Binding AppVersion, Mode=OneWay}"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </Grid>
            </materialDesign:Card>

            <!-- STATS ROW -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,24">
                <!-- Profiles Stat (Clickable) -->
                <Button Command="{Binding NavigateToProfilesCommand}"
                        Style="{StaticResource ClickableStatsCard}"
                        ToolTip="{loc:Loc Dashboard_Stats_ProfilesHint}"
                        MinWidth="160">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{Binding ProfileCount}"
                                       Style="{StaticResource MaterialDesignHeadline4TextBlock}"
                                       Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                            <TextBlock Text="{loc:Loc Dashboard_Stats_Profiles}"
                                       Style="{StaticResource MaterialDesignBody2TextBlock}"
                                       Opacity="0.7"/>
                        </StackPanel>
                        <materialDesign:PackIcon Grid.Column="1"
                                                  Kind="ChevronRight"
                                                  Width="24" Height="24"
                                                  Opacity="0.5"
                                                  VerticalAlignment="Center"/>
                    </Grid>
                </Button>

                <!-- Apps Stat (Clickable) -->
                <Button Command="{Binding NavigateToAppsCommand}"
                        Style="{StaticResource ClickableStatsCard}"
                        ToolTip="{loc:Loc Dashboard_Stats_AppsHint}"
                        MinWidth="160">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{Binding AppCount}"
                                       Style="{StaticResource MaterialDesignHeadline4TextBlock}"
                                       Foreground="{DynamicResource SecondaryHueMidBrush}"/>
                            <TextBlock Text="{loc:Loc Dashboard_Stats_Apps}"
                                       Style="{StaticResource MaterialDesignBody2TextBlock}"
                                       Opacity="0.7"/>
                        </StackPanel>
                        <materialDesign:PackIcon Grid.Column="1"
                                                  Kind="ChevronRight"
                                                  Width="24" Height="24"
                                                  Opacity="0.5"
                                                  VerticalAlignment="Center"/>
                    </Grid>
                </Button>

                <!-- Updates Stat (Clickable) -->
                <Button Command="{Binding ViewUpdatesCommand}"
                        Style="{StaticResource ClickableStatsCard}"
                        ToolTip="{loc:Loc Dashboard_Stats_UpdatesHint}"
                        MinWidth="160"
                        Margin="0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{Binding UpdateCount}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource MaterialDesignHeadline4TextBlock}">
                                        <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBodyLight}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding UpdateCount, Converter={StaticResource NonZeroToBoolConverter}}" Value="True">
                                                <Setter Property="Foreground" Value="{DynamicResource AccentGreenTextBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Text="{loc:Loc Dashboard_Stats_Updates}"
                                       Style="{StaticResource MaterialDesignBody2TextBlock}"
                                       Opacity="0.7"/>
                        </StackPanel>
                        <materialDesign:PackIcon Grid.Column="1"
                                                  Kind="ChevronRight"
                                                  Width="24" Height="24"
                                                  Opacity="0.5"
                                                  VerticalAlignment="Center"/>
                    </Grid>
                </Button>
            </StackPanel>

            <!-- MAIN CONTENT -->
            <Grid Grid.Row="2" Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="320"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT: System Info -->
                <materialDesign:Card Grid.Column="0"
                                      Padding="24"
                                      materialDesign:ElevationAssist.Elevation="Dp1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- System Info Header -->
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
                            <materialDesign:PackIcon Kind="MonitorDashboard"
                                                      Width="24" Height="24"
                                                      VerticalAlignment="Center"
                                                      Foreground="{DynamicResource PrimaryHueMidBrush}"
                                                      Margin="0,0,12,0"/>
                            <TextBlock Text="{loc:Loc Dashboard_SystemInfo_Title}"
                                       Style="{StaticResource MaterialDesignHeadline6TextBlock}"/>
                        </StackPanel>

                        <!-- System Info Grid -->
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Hostname -->
                            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,16,16">
                                <TextBlock Text="{loc:Loc Dashboard_Sys_Hostname}"
                                           Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                           Opacity="0.6"/>
                                <TextBlock Text="{Binding Hostname}"
                                           Style="{StaticResource MaterialDesignBody1TextBlock}"/>
                            </StackPanel>

                            <!-- OS -->
                            <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,16">
                                <TextBlock Text="{loc:Loc Dashboard_Sys_OS}"
                                           Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                           Opacity="0.6"/>
                                <TextBlock Text="{Binding OSName}"
                                           Style="{StaticResource MaterialDesignBody1TextBlock}"/>
                            </StackPanel>

                            <!-- Build -->
                            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,16,16">
                                <TextBlock Text="{loc:Loc Dashboard_Sys_Build}"
                                           Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                           Opacity="0.6"/>
                                <TextBlock Text="{Binding OSBuild}"
                                           Style="{StaticResource MaterialDesignBody1TextBlock}"/>
                            </StackPanel>

                            <!-- Admin -->
                            <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,16">
                                <TextBlock Text="{loc:Loc Dashboard_Sys_Admin}"
                                           Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                           Opacity="0.6"/>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="{Binding IsAdmin, Converter={StaticResource BoolToInstalledIconConverter}}"
                                                              Width="16" Height="16"
                                                              Foreground="{Binding IsAdmin, Converter={StaticResource BoolToInstalledColorConverter}}"
                                                              VerticalAlignment="Center"
                                                              Margin="0,0,6,0"/>
                                    <TextBlock Text="{Binding AdminStatus}"
                                               Style="{StaticResource MaterialDesignBody1TextBlock}"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Winget -->
                            <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,16,16">
                                <TextBlock Text="{loc:Loc Dashboard_Sys_Winget}"
                                           Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                           Opacity="0.6"/>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="{Binding WingetInstalled, Converter={StaticResource BoolToInstalledIconConverter}}"
                                                              Width="16" Height="16"
                                                              Foreground="{Binding WingetInstalled, Converter={StaticResource BoolToInstalledColorConverter}}"
                                                              VerticalAlignment="Center"
                                                              Margin="0,0,6,0"/>
                                    <TextBlock Text="{Binding WingetVersion}"
                                               Style="{StaticResource MaterialDesignBody1TextBlock}"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Chocolatey -->
                            <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,0,0,16">
                                <TextBlock Text="{loc:Loc Dashboard_Sys_Chocolatey}"
                                           Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                           Opacity="0.6"/>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="{Binding ChocolateyInstalled, Converter={StaticResource BoolToInstalledIconConverter}}"
                                                              Width="16" Height="16"
                                                              Foreground="{Binding ChocolateyInstalled, Converter={StaticResource BoolToInstalledColorConverter}}"
                                                              VerticalAlignment="Center"
                                                              Margin="0,0,6,0"/>
                                    <TextBlock Text="{Binding ChocolateyVersion}"
                                               Style="{StaticResource MaterialDesignBody1TextBlock}"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- PowerShell -->
                            <StackPanel Grid.Row="3" Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Text="{loc:Loc Dashboard_Sys_PowerShell}"
                                           Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                           Opacity="0.6"/>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="{Binding PowerShellInstalled, Converter={StaticResource BoolToInstalledIconConverter}}"
                                                              Width="16" Height="16"
                                                              Foreground="{Binding PowerShellInstalled, Converter={StaticResource BoolToInstalledColorConverter}}"
                                                              VerticalAlignment="Center"
                                                              Margin="0,0,6,0"/>
                                    <TextBlock Text="{Binding PowerShellVersion}"
                                               Style="{StaticResource MaterialDesignBody1TextBlock}"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </materialDesign:Card>

                <!-- RIGHT: Quick Actions -->
                <StackPanel Grid.Column="2">
                    <!-- Updates Status Card -->
                    <materialDesign:Card Padding="20"
                                          Margin="0,0,0,16"
                                          materialDesign:ElevationAssist.Elevation="Dp1">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <materialDesign:PackIcon Kind="Update"
                                                          Width="24" Height="24"
                                                          VerticalAlignment="Center"
                                                          Foreground="{DynamicResource AccentGreenTextBrush}"
                                                          Margin="0,0,12,0"/>
                                <TextBlock Text="{loc:Loc Dashboard_Updates_Title}"
                                           Style="{StaticResource MaterialDesignHeadline6TextBlock}"/>
                            </StackPanel>

                            <!-- Scan Button -->
                            <Button Command="{Binding ScanUpdatesCommand}"
                                    Style="{StaticResource MaterialDesignRaisedButton}"
                                    materialDesign:ButtonAssist.CornerRadius="8"
                                    HorizontalAlignment="Stretch"
                                    IsEnabled="{Binding IsNotScanning}">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Magnify"
                                                              Width="18" Height="18"
                                                              VerticalAlignment="Center"
                                                              Margin="0,0,8,0"
                                                              Visibility="{Binding IsNotScanning, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                    <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                                                 IsIndeterminate="True"
                                                 Width="18" Height="18"
                                                 Margin="0,0,8,0"
                                                 Visibility="{Binding IsScanning, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                    <TextBlock Text="{Binding ScanButtonText}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- Last Scan Time -->
                            <TextBlock Text="{Binding LastScanDisplay}"
                                       Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                       HorizontalAlignment="Center"
                                       Opacity="0.5"
                                       Margin="0,8,0,0"/>
                        </StackPanel>
                    </materialDesign:Card>

                    <!-- Quick Navigation -->
                    <materialDesign:Card Padding="20"
                                          materialDesign:ElevationAssist.Elevation="Dp1">
                        <StackPanel>
                            <TextBlock Text="{loc:Loc Dashboard_QuickNav_Title}"
                                       Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                                       Margin="0,0,0,16"/>

                            <!-- Prerequisites Button -->
                            <Button Command="{Binding NavigateToPrerequisitesCommand}"
                                    Style="{StaticResource QuickActionButtonStyle}">
                                <Grid Width="240">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <materialDesign:PackIcon Grid.Column="0"
                                                              Kind="CheckboxMarkedCircleOutline"
                                                              Width="24" Height="24"
                                                              VerticalAlignment="Center"
                                                              Margin="0,0,12,0"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{loc:Loc Nav_Prerequisites}"
                                               VerticalAlignment="Center"/>
                                    <materialDesign:PackIcon Grid.Column="2"
                                                              Kind="ChevronRight"
                                                              Width="20" Height="20"
                                                              Opacity="0.5"
                                                              VerticalAlignment="Center"/>
                                </Grid>
                            </Button>

                            <!-- Applications Button -->
                            <Button Command="{Binding NavigateToAppsCommand}"
                                    Style="{StaticResource QuickActionButtonStyle}"
                                    Margin="0">
                                <Grid Width="240">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <materialDesign:PackIcon Grid.Column="0"
                                                              Kind="Apps"
                                                              Width="24" Height="24"
                                                              VerticalAlignment="Center"
                                                              Margin="0,0,12,0"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{loc:Loc Nav_Apps}"
                                               VerticalAlignment="Center"/>
                                    <materialDesign:PackIcon Grid.Column="2"
                                                              Kind="ChevronRight"
                                                              Width="20" Height="20"
                                                              Opacity="0.5"
                                                              VerticalAlignment="Center"/>
                                </Grid>
                            </Button>
                        </StackPanel>
                    </materialDesign:Card>
                </StackPanel>
            </Grid>

            <!-- HISTORY SECTION -->
            <materialDesign:Card Grid.Row="3"
                                  Padding="24"
                                  Margin="0,0,0,24"
                                  materialDesign:ElevationAssist.Elevation="Dp1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                        <materialDesign:PackIcon Kind="History"
                                                  Width="24" Height="24"
                                                  VerticalAlignment="Center"
                                                  Foreground="{DynamicResource PrimaryHueMidBrush}"
                                                  Margin="0,0,12,0"/>
                        <TextBlock Text="{loc:Loc Dashboard_History_Title}"
                                   Style="{StaticResource MaterialDesignHeadline6TextBlock}"/>
                    </StackPanel>

                    <!-- History List -->
                    <ItemsControl Grid.Row="1"
                                   ItemsSource="{Binding RecentDeployments}"
                                   Visibility="{Binding HasRecentDeployments, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:DeploymentHistoryEntry}">
                                <Border BorderBrush="{DynamicResource MaterialDesignDivider}"
                                        BorderThickness="0,0,0,1"
                                        Padding="0,12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Status Icon -->
                                        <materialDesign:PackIcon Grid.Column="0"
                                                                  Kind="{Binding Result, Converter={StaticResource StatusToIconConverter}}"
                                                                  Width="24" Height="24"
                                                                  Foreground="{Binding Result, Converter={StaticResource StatusToColorConverter}}"
                                                                  VerticalAlignment="Center"
                                                                  Margin="0,0,16,0"/>

                                        <!-- Profile Info -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding ProfileName}"
                                                       Style="{StaticResource MaterialDesignBody1TextBlock}"/>
                                            <TextBlock Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                                       Opacity="0.6">
                                                <Run Text="{Binding Summary, Mode=OneWay}"/>
                                                <Run Text=" - "/>
                                                <Run Text="{Binding FormattedDuration, Mode=OneWay}"/>
                                            </TextBlock>
                                        </StackPanel>

                                        <!-- Date -->
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding FormattedDate}"
                                                   Style="{StaticResource MaterialDesignBody2TextBlock}"
                                                   Opacity="0.6"
                                                   VerticalAlignment="Center"
                                                   Margin="16,0"/>

                                        <!-- Dry Run Badge -->
                                        <Border Grid.Column="3"
                                                Background="{DynamicResource SecondaryHueMidBrush}"
                                                CornerRadius="4"
                                                Padding="8,4"
                                                VerticalAlignment="Center"
                                                Visibility="{Binding IsDryRun, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <TextBlock Text="{loc:Loc Lbl_DryRun}"
                                                       Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                                       Foreground="Black"/>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Empty State -->
                    <StackPanel Grid.Row="1"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Margin="0,24"
                                Visibility="{Binding HasRecentDeployments, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                        <materialDesign:PackIcon Kind="ClipboardTextClockOutline"
                                                  Width="48" Height="48"
                                                  Opacity="0.3"
                                                  HorizontalAlignment="Center"
                                                  Margin="0,0,0,12"/>
                        <TextBlock Text="{loc:Loc Dashboard_History_Empty}"
                                   Style="{StaticResource MaterialDesignBody1TextBlock}"
                                   Opacity="0.5"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </materialDesign:Card>

            <!-- FOOTER -->
            <TextBlock Grid.Row="4"
                       HorizontalAlignment="Center"
                       Opacity="0.4"
                       Style="{StaticResource MaterialDesignCaptionTextBlock}">
                <Run Text="Win11Forge v"/>
                <Run Text="{Binding AppVersion, Mode=OneWay}"/>
            </TextBlock>
        </Grid>
    </ScrollViewer>
</UserControl>
