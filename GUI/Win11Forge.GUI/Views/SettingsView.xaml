<UserControl x:Class="Win11Forge.GUI.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:loc="clr-namespace:Win11Forge.GUI.Resources"
             xmlns:viewModels="clr-namespace:Win11Forge.GUI.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=viewModels:SettingsViewModel}"
             d:DesignHeight="600" d:DesignWidth="800">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0"
                   Text="{loc:Loc Settings_Title}"
                   FontSize="34" FontWeight="SemiBold"
                   Margin="0,0,0,24"/>

        <!-- Settings Content with Tabs -->
        <TabControl Grid.Row="1"
                    TabStripPlacement="Top">

            <!-- Appearance & Language Tab -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Color24" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="{loc:Loc Settings_Tab_Appearance}" FontSize="13" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="16">
                    <StackPanel>
                        <!-- Theme Section -->
                        <Border Padding="16" Margin="0,0,0,16" CornerRadius="8" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                    <ui:SymbolIcon Symbol="Color24" Width="24" Height="24" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    <TextBlock Text="{loc:Loc Settings_Section_Appearance}" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>

                                <!-- Theme Toggle -->
                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{loc:Loc Settings_Theme}" FontSize="14" FontWeight="Medium"/>
                                        <TextBlock Text="{loc:Loc Settings_Theme_Desc}" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <ui:SymbolIcon Symbol="WeatherSunny24" Width="20" Height="20" VerticalAlignment="Center" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,8,0"/>
                                        <ui:ToggleSwitch IsChecked="{Binding IsDarkTheme}"/>
                                        <ui:SymbolIcon Symbol="DarkTheme24" Width="20" Height="20" VerticalAlignment="Center" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="8,0,0,0"/>
                                    </StackPanel>
                                </Grid>

                                <!-- Reduced Motion -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{loc:Loc Settings_ReducedMotion}" FontSize="14" FontWeight="Medium"/>
                                        <TextBlock Text="{loc:Loc Settings_ReducedMotion_Desc}" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                    </StackPanel>

                                    <ui:ToggleSwitch Grid.Column="1"
                                                  IsChecked="{Binding ReducedMotion}"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Language Section -->
                        <Border Padding="16" Margin="0,0,0,16" CornerRadius="8" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                    <ui:SymbolIcon Symbol="Translate24" Width="24" Height="24" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    <TextBlock Text="{loc:Loc Settings_Section_Language}" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>

                                <!-- Language Selector -->
                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{loc:Loc Settings_Language}" FontSize="14" FontWeight="Medium"/>
                                        <TextBlock Text="{loc:Loc Settings_Language_Desc}" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <ComboBox ItemsSource="{Binding AvailableLanguages}"
                                                  SelectedItem="{Binding SelectedLanguage}"
                                                  DisplayMemberPath="DisplayName"
                                                  MinWidth="140" MaxWidth="200" Margin="0,0,12,0"/>
                                        <ui:Button Content="{loc:Loc Settings_Apply}"
                                                Command="{Binding ApplyLanguageCommand}"
                                                Appearance="Primary"/>
                                    </StackPanel>
                                </Grid>

                                <!-- Restart Warning -->
                                <Border Background="{DynamicResource ControlFillColorDefaultBrush}"
                                        CornerRadius="4" Padding="12"
                                        Visibility="{Binding RestartRequired, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                                            <ui:SymbolIcon Symbol="ErrorCircle24" Width="20" Height="20" VerticalAlignment="Center"
                                                                      Foreground="{DynamicResource SystemFillColorCriticalBrush}" Margin="0,0,8,0"/>
                                            <TextBlock Text="{loc:Loc Settings_RestartRequired}" FontSize="12" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <ui:Button Grid.Column="1"
                                                Command="{Binding RestartApplicationCommand}"
                                                Appearance="Primary"
                                                Margin="12,0,0,0"
                                                AutomationProperties.Name="Restart application now">
                                            <StackPanel Orientation="Horizontal">
                                                <ui:SymbolIcon Symbol="ArrowSync24" Width="16" Height="16" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                <TextBlock Text="{loc:Loc Settings_RestartNow}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </ui:Button>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Performance Tab -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Gauge24" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="{loc:Loc Settings_Tab_Performance}" FontSize="13" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="16">
                    <Border Padding="16" CornerRadius="8" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <ui:SymbolIcon Symbol="Gauge24" Width="24" Height="24" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <TextBlock Text="{loc:Loc Settings_Section_Performance}" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                <ui:SymbolIcon Symbol="QuestionCircle24" Width="18" Height="18" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                          VerticalAlignment="Center" Margin="8,0,0,0" ToolTip="{loc:Loc Help_Performance}"/>
                            </StackPanel>

                            <!-- Parallel Installs Setting -->
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{loc:Loc Settings_ParallelInstalls}" FontSize="14" FontWeight="Medium"/>
                                    <TextBlock Text="{loc:Loc Settings_ParallelInstalls_Desc}" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                </StackPanel>

                                <ComboBox Grid.Column="1"
                                          ItemsSource="{Binding ParallelInstallOptions}"
                                          SelectedItem="{Binding MaxParallelInstalls}"
                                          Width="80"/>
                            </Grid>

                            <!-- Parallel Scans Setting -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{loc:Loc Settings_ParallelScans}" FontSize="14" FontWeight="Medium"/>
                                    <TextBlock Text="{loc:Loc Settings_ParallelScans_Desc}" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                </StackPanel>

                                <ComboBox Grid.Column="1"
                                          ItemsSource="{Binding ParallelScanOptions}"
                                          SelectedItem="{Binding MaxParallelScans}"
                                          Width="80"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </ScrollViewer>
            </TabItem>

            <!-- Data Tab -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Database24" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="{loc:Loc Settings_Tab_Data}" FontSize="13" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="16">
                    <StackPanel>
                    <Border Padding="16" CornerRadius="8" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel>
                        <!-- Section Header -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <ui:SymbolIcon Symbol="Database24"
                                                      Width="24" Height="24"
                                                      VerticalAlignment="Center"
                                                      Margin="0,0,12,0"/>
                            <TextBlock Text="{loc:Loc Settings_Section_Data}"
                                       FontSize="20" FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Export/Import Settings -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{loc:Loc Settings_ExportImport}"
                                           FontSize="14"
                                           FontWeight="Medium"/>
                                <TextBlock Text="{loc:Loc Settings_ExportImport_Desc}"
                                           FontSize="12"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button Command="{Binding ExportSettingsCommand}"
                                        Style="{StaticResource ThemeAdaptiveOutlinedButton}"
                                        Margin="0,0,8,0">
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon Symbol="ArrowExportUp24" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock Text="{loc:Loc Settings_Export}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button Command="{Binding ImportSettingsCommand}"
                                        Style="{StaticResource ThemeAdaptiveOutlinedButton}">
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon Symbol="ArrowImport24" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock Text="{loc:Loc Settings_Import}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>

                        <!-- Reset to Defaults -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{loc:Loc Settings_ResetDefaults}"
                                           FontSize="14"
                                           FontWeight="Medium"/>
                                <TextBlock Text="{loc:Loc Settings_ResetDefaults_Desc}"
                                           FontSize="12"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>

                            <Button Grid.Column="1"
                                    Command="{Binding ResetToDefaultsCommand}"
                                    Style="{StaticResource ThemeAdaptiveOutlinedButton}">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="ArrowReset24" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="{loc:Loc Settings_ResetBtn}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Grid>

                        <!-- Clear History -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{loc:Loc Settings_ClearHistory}"
                                           FontSize="14"
                                           FontWeight="Medium"/>
                                <TextBlock Text="{loc:Loc Settings_ClearHistory_Desc}"
                                           FontSize="12"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>

                            <Button Grid.Column="1"
                                    Content="{loc:Loc Settings_ClearBtn}"
                                    Command="{Binding ClearHistoryCommand}"
                                    Style="{StaticResource DestructiveOutlinedButton}"/>
                        </Grid>

                        <!-- Open Log Folder -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{loc:Loc Settings_Btn_OpenLogs}"
                                           FontSize="14"
                                           FontWeight="Medium"/>
                                <TextBlock Text="{loc:Loc Settings_OpenLogs_Desc}"
                                           FontSize="12"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>

                            <Button Grid.Column="1"
                                    Command="{Binding OpenLogFolderCommand}"
                                    Style="{StaticResource ThemeAdaptiveOutlinedButton}">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="FolderOpen24" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="{loc:Loc Settings_Btn_OpenLogs}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </StackPanel>
                    </Border>

                    <!-- Error History Section -->
                    <Border Padding="16" Margin="0,16,0,0" CornerRadius="8" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
                        <Expander IsExpanded="{Binding HasErrors}">
                            <Expander.Header>
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="ErrorCircle24"
                                                              Width="24" Height="24"
                                                              VerticalAlignment="Center"
                                                              Margin="0,0,12,0"/>
                                    <TextBlock Text="{loc:Loc Settings_ErrorHistory}"
                                               FontSize="20" FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                    <Border Background="{DynamicResource ErrorBorderBrush}"
                                            CornerRadius="12"
                                            Padding="8,2"
                                            Margin="12,0,0,0"
                                            Visibility="{Binding HasErrors, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <TextBlock Text="{Binding ErrorCount}"
                                                   Foreground="{DynamicResource BadgePrimaryForegroundBrush}"
                                                   FontWeight="Bold"
                                                   FontSize="12"/>
                                    </Border>
                                </StackPanel>
                            </Expander.Header>
                            <StackPanel Margin="0,12,0,0">
                                <!-- Clear Errors Button -->
                                <Button Content="{loc:Loc Settings_ClearErrors}"
                                        Command="{Binding ClearErrorHistoryCommand}"
                                        Style="{StaticResource DestructiveOutlinedButton}"
                                        HorizontalAlignment="Right"
                                        Margin="0,0,0,12"
                                        Visibility="{Binding HasErrors, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                                <!-- Error List -->
                                <ItemsControl ItemsSource="{Binding RecentErrors}"
                                              MaxHeight="300">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}"
                                                    BorderThickness="0,0,0,1"
                                                    Padding="0,8">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <ui:SymbolIcon Symbol="ErrorCircle24"
                                                                              Grid.Column="0"
                                                                              Width="20" Height="20"
                                                                              Foreground="{DynamicResource ErrorBorderBrush}"
                                                                              VerticalAlignment="Top"
                                                                              Margin="0,2,12,0"/>

                                                    <StackPanel Grid.Column="1">
                                                        <TextBlock Text="{Binding Message}"
                                                                   FontSize="12"
                                                                   TextWrapping="Wrap"/>
                                                        <TextBlock Text="{Binding Source}"
                                                                   FontSize="12"
                                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                                   Visibility="{Binding Source, Converter={StaticResource NullableToVisibilityConverter}}"
                                                                   Margin="0,4,0,0"/>
                                                    </StackPanel>

                                                    <TextBlock Grid.Column="2"
                                                               Text="{Binding FormattedTimestamp}"
                                                               FontSize="12"
                                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                               VerticalAlignment="Top"
                                                               Margin="12,2,0,0"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- Empty State -->
                                <TextBlock Text="{loc:Loc Settings_NoErrors}"
                                           FontSize="12"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           HorizontalAlignment="Center"
                                           Margin="0,16"
                                           Visibility="{Binding HasErrors, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>
                            </StackPanel>
                        </Expander>
                    </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Scheduled Deployments Tab -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="CalendarClock24" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="{loc:Loc Settings_Tab_Scheduled}" FontSize="13" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="16">
                    <StackPanel>
                        <!-- Admin Required Warning -->
                        <Border Padding="16" Margin="0,0,0,16" CornerRadius="8" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                              Visibility="{Binding IsScheduledDeploymentsAvailable, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="ErrorCircle24" Width="24" Height="24"
                                                          Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                                                          VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <TextBlock Text="{loc:Loc ScheduledDeployment_AdminRequired}"
                                           FontSize="14"
                                           VerticalAlignment="Center"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <!-- Create New Scheduled Deployment -->
                        <Border Padding="16" Margin="0,0,0,16" CornerRadius="8" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                              IsEnabled="{Binding IsScheduledDeploymentsAvailable}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                    <ui:SymbolIcon Symbol="CalendarAdd24" Width="24" Height="24" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    <TextBlock Text="{loc:Loc ScheduledDeployment_CreateNew}"
                                               FontSize="20" FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                </StackPanel>

                                <!-- Profile Selection -->
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="2*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Text="{loc:Loc ScheduledDeployment_Profile}"
                                               FontSize="14"
                                               VerticalAlignment="Center"/>
                                    <ComboBox Grid.Column="1"
                                              ItemsSource="{Binding AvailableProfiles}"
                                              SelectedItem="{Binding NewScheduledProfile}"/>
                                </Grid>

                                <!-- Trigger Type -->
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="2*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Text="{loc:Loc ScheduledDeployment_TriggerType}"
                                               FontSize="14"
                                               VerticalAlignment="Center"/>
                                    <ComboBox Grid.Column="1"
                                              ItemsSource="{Binding AvailableTriggerTypes}"
                                              SelectedItem="{Binding NewScheduledTriggerType}"/>
                                </Grid>

                                <!-- Schedule Time -->
                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Text="{loc:Loc ScheduledDeployment_DateTime}"
                                               FontSize="14"
                                               VerticalAlignment="Center"/>
                                    <DatePicker Grid.Column="1"
                                                SelectedDate="{Binding NewScheduledTime}"
                                                Margin="0,0,8,0"/>
                                    <ui:TextBox Grid.Column="2"
                                                PlaceholderText="HH:mm"
                                                Text="{Binding NewScheduledTimeText, UpdateSourceTrigger=PropertyChanged}"/>
                                </Grid>

                                <!-- Create Button -->
                                <ui:Button Command="{Binding CreateScheduledDeploymentCommand}"
                                        Appearance="Primary"
                                        HorizontalAlignment="Right">
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon Symbol="CalendarAdd24" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBlock Text="{loc:Loc ScheduledDeployment_Create}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </ui:Button>
                            </StackPanel>
                        </Border>

                        <!-- Scheduled Deployments List -->
                        <Border Padding="16" CornerRadius="8" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                              IsEnabled="{Binding IsScheduledDeploymentsAvailable}">
                            <StackPanel>
                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon Symbol="CalendarMultiple24" Width="24" Height="24" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                        <TextBlock Text="{loc:Loc ScheduledDeployment_List}"
                                                   FontSize="20" FontWeight="SemiBold"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <ui:Button Grid.Column="1"
                                            Command="{Binding LoadScheduledDeploymentsCommand}"
                                            Appearance="Transparent"
                                            ToolTip="{loc:Loc ScheduledDeployment_Refresh}">
                                        <ui:SymbolIcon Symbol="ArrowSync24" Width="20" Height="20"/>
                                    </ui:Button>
                                </Grid>

                                <!-- Loading Indicator -->
                                <ProgressBar IsIndeterminate="True"
                                             Visibility="{Binding IsLoadingScheduledDeployments, Converter={StaticResource BooleanToVisibilityConverter}}"
                                             Margin="0,0,0,12"/>

                                <!-- Empty State -->
                                <TextBlock Text="{loc:Loc ScheduledDeployment_Empty}"
                                           FontSize="12"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           HorizontalAlignment="Center"
                                           Margin="0,16"
                                           Visibility="{Binding ScheduledDeployments.Count, Converter={StaticResource ZeroToVisibilityConverter}}"/>

                                <!-- Deployments DataGrid -->
                                <DataGrid ItemsSource="{Binding ScheduledDeployments}"
                                          SelectedItem="{Binding SelectedScheduledDeployment}"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          IsReadOnly="True"
                                          SelectionMode="Single"
                                          Visibility="{Binding ScheduledDeployments.Count, Converter={StaticResource NonZeroToVisibilityConverter}}"
                                          MaxHeight="300">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="{loc:Loc ScheduledDeployment_Col_Profile}"
                                                            Binding="{Binding ProfileName}"
                                                            Width="*"/>
                                        <DataGridTextColumn Header="{loc:Loc ScheduledDeployment_Col_Schedule}"
                                                            Binding="{Binding ScheduledTimeDisplay}"
                                                            Width="*"/>
                                        <DataGridTextColumn Header="{loc:Loc ScheduledDeployment_Col_Status}"
                                                            Binding="{Binding StatusDisplay}"
                                                            Width="Auto"/>
                                        <DataGridTextColumn Header="{loc:Loc ScheduledDeployment_Col_LastRun}"
                                                            Binding="{Binding LastRunResult}"
                                                            Width="Auto"/>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <!-- Action Buttons -->
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Right"
                                            Margin="0,16,0,0"
                                            Visibility="{Binding ScheduledDeployments.Count, Converter={StaticResource NonZeroToVisibilityConverter}}">
                                    <Button Command="{Binding RunScheduledDeploymentNowCommand}"
                                            Style="{StaticResource ThemeAdaptiveOutlinedButton}"
                                            Margin="0,0,8,0"
                                            IsEnabled="{Binding SelectedScheduledDeployment, Converter={StaticResource NullableToBooleanConverter}}">
                                        <StackPanel Orientation="Horizontal">
                                            <ui:SymbolIcon Symbol="Play24" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Text="{loc:Loc ScheduledDeployment_RunNow}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Command="{Binding RemoveScheduledDeploymentCommand}"
                                            Style="{StaticResource DestructiveOutlinedButton}"
                                            IsEnabled="{Binding SelectedScheduledDeployment, Converter={StaticResource NullableToBooleanConverter}}">
                                        <StackPanel Orientation="Horizontal">
                                            <ui:SymbolIcon Symbol="Delete24" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Text="{loc:Loc ScheduledDeployment_Remove}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- About Tab -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Info24" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="{loc:Loc Settings_Tab_About}" FontSize="13" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="16">
                    <StackPanel>
                        <Border Padding="16" CornerRadius="8" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- App Info (Left) -->
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="{loc:Loc App_Name}"
                                               FontSize="24" FontWeight="SemiBold"
                                               Margin="0,0,0,16"/>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- Version -->
                                        <TextBlock Grid.Row="0" Grid.Column="0"
                                                   Text="{loc:Loc About_Version}"
                                                   FontSize="14"
                                                   FontWeight="Medium"
                                                   Margin="0,0,24,8"/>
                                        <TextBlock Grid.Row="0" Grid.Column="1"
                                                   Text="{Binding AppVersion}"
                                                   FontSize="14"
                                                   Margin="0,0,0,8"/>

                                        <!-- Author -->
                                        <TextBlock Grid.Row="1" Grid.Column="0"
                                                   Text="{loc:Loc About_Author}"
                                                   FontSize="14"
                                                   FontWeight="Medium"
                                                   Margin="0,0,24,8"/>
                                        <TextBlock Grid.Row="1" Grid.Column="1"
                                                   Text="{loc:Loc About_AuthorName}"
                                                   FontSize="14"
                                                   Margin="0,0,0,8"/>

                                        <!-- License -->
                                        <TextBlock Grid.Row="2" Grid.Column="0"
                                                   Text="{loc:Loc About_License}"
                                                   FontSize="14"
                                                   FontWeight="Medium"
                                                   Margin="0,0,24,8"/>
                                        <TextBlock Grid.Row="2" Grid.Column="1"
                                                   Text="{loc:Loc About_LicenseValue}"
                                                   FontSize="14"
                                                   Margin="0,0,0,8"/>

                                        <!-- GitHub -->
                                        <TextBlock Grid.Row="3" Grid.Column="0"
                                                   Text="{loc:Loc About_Repository}"
                                                   FontSize="14"
                                                   FontWeight="Medium"
                                                   Margin="0,0,24,0"/>
                                        <Button Grid.Row="3" Grid.Column="1"
                                                Content="{loc:Loc About_RepoUrl}"
                                                Command="{Binding OpenGitHubCommand}"
                                                Style="{StaticResource ThemeAdaptiveOutlinedButton}"
                                                HorizontalAlignment="Left"
                                                Padding="0"
                                                Margin="0"/>
                                    </Grid>
                                </StackPanel>

                                <!-- Logo (Right) -->
                                <Image Grid.Column="1"
                                       Source="/icon_cropped.png"
                                       Width="120" Height="120"
                                       RenderOptions.BitmapScalingMode="HighQuality"
                                       VerticalAlignment="Center"
                                       Margin="24,0,0,0"/>
                            </Grid>
                        </Border>

                        <!-- Status Message -->
                        <Border Padding="12" Margin="0,16,0,0"
                                              CornerRadius="8" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                              Visibility="{Binding StatusMessage, Converter={StaticResource NullableToVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="CheckmarkCircle24"
                                                          Width="20" Height="20"
                                                          VerticalAlignment="Center"
                                                          Foreground="{DynamicResource SystemFillColorSuccessBrush}"
                                                          Margin="0,0,8,0"/>
                                <TextBlock Text="{Binding StatusMessage}"
                                           FontSize="12"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
