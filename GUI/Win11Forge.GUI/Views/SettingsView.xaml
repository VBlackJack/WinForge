<UserControl x:Class="Win11Forge.GUI.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:loc="clr-namespace:Win11Forge.GUI.Resources"
             xmlns:viewModels="clr-namespace:Win11Forge.GUI.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=viewModels:SettingsViewModel}"
             d:DesignHeight="600" d:DesignWidth="800">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0"
                   Text="{loc:Loc Settings_Title}"
                   Style="{StaticResource MaterialDesignHeadline4TextBlock}"
                   Margin="0,0,0,24"/>

        <!-- Settings Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Appearance Section -->
                <materialDesign:Card Padding="16"
                                      Margin="0,0,0,16"
                                      materialDesign:ElevationAssist.Elevation="Dp2">
                    <StackPanel>
                        <!-- Section Header -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <materialDesign:PackIcon Kind="Palette"
                                                      Width="24" Height="24"
                                                      VerticalAlignment="Center"
                                                      Margin="0,0,12,0"/>
                            <TextBlock Text="{loc:Loc Settings_Section_Appearance}"
                                       Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Theme Toggle -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{loc:Loc Settings_Theme}"
                                           Style="{StaticResource MaterialDesignBody1TextBlock}"
                                           FontWeight="Medium"/>
                                <TextBlock Text="{loc:Loc Settings_Theme_Desc}"
                                           Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                           Opacity="0.7"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="WeatherSunny"
                                                          Width="20" Height="20"
                                                          VerticalAlignment="Center"
                                                          Opacity="0.7"
                                                          Margin="0,0,8,0"/>
                                <ToggleButton IsChecked="{Binding IsDarkTheme}"
                                              Style="{StaticResource MaterialDesignSwitchToggleButton}"/>
                                <materialDesign:PackIcon Kind="WeatherNight"
                                                          Width="20" Height="20"
                                                          VerticalAlignment="Center"
                                                          Opacity="0.7"
                                                          Margin="8,0,0,0"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </materialDesign:Card>

                <!-- Language Section -->
                <materialDesign:Card Padding="16"
                                      Margin="0,0,0,16"
                                      materialDesign:ElevationAssist.Elevation="Dp2">
                    <StackPanel>
                        <!-- Section Header -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <materialDesign:PackIcon Kind="Translate"
                                                      Width="24" Height="24"
                                                      VerticalAlignment="Center"
                                                      Margin="0,0,12,0"/>
                            <TextBlock Text="{loc:Loc Settings_Section_Language}"
                                       Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Language Selector -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{loc:Loc Settings_Language}"
                                           Style="{StaticResource MaterialDesignBody1TextBlock}"
                                           FontWeight="Medium"/>
                                <TextBlock Text="{loc:Loc Settings_Language_Desc}"
                                           Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                           Opacity="0.7"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <ComboBox ItemsSource="{Binding AvailableLanguages}"
                                          SelectedItem="{Binding SelectedLanguage}"
                                          DisplayMemberPath="DisplayName"
                                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                          Width="160"
                                          Margin="0,0,12,0"/>
                                <Button Content="{loc:Loc Settings_Apply}"
                                        Command="{Binding ApplyLanguageCommand}"
                                        Style="{StaticResource MaterialDesignRaisedButton}"/>
                            </StackPanel>
                        </Grid>

                        <!-- Restart Warning -->
                        <Border Background="{DynamicResource MaterialDesignToolBarBackground}"
                                CornerRadius="4"
                                Padding="12"
                                Visibility="{Binding RestartRequired, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="AlertCircle"
                                                          Width="20" Height="20"
                                                          VerticalAlignment="Center"
                                                          Foreground="{DynamicResource MaterialDesignValidationErrorBrush}"
                                                          Margin="0,0,8,0"/>
                                <TextBlock Text="{loc:Loc Settings_RestartRequired}"
                                           Style="{StaticResource MaterialDesignBody2TextBlock}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </materialDesign:Card>

                <!-- Data Section -->
                <materialDesign:Card Padding="16"
                                      Margin="0,0,0,16"
                                      materialDesign:ElevationAssist.Elevation="Dp2">
                    <StackPanel>
                        <!-- Section Header -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <materialDesign:PackIcon Kind="Database"
                                                      Width="24" Height="24"
                                                      VerticalAlignment="Center"
                                                      Margin="0,0,12,0"/>
                            <TextBlock Text="{loc:Loc Settings_Section_Data}"
                                       Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Clear History -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{loc:Loc Settings_ClearHistory}"
                                           Style="{StaticResource MaterialDesignBody1TextBlock}"
                                           FontWeight="Medium"/>
                                <TextBlock Text="{loc:Loc Settings_ClearHistory_Desc}"
                                           Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                           Opacity="0.7"/>
                            </StackPanel>

                            <Button Grid.Column="1"
                                    Content="{loc:Loc Settings_ClearBtn}"
                                    Command="{Binding ClearHistoryCommand}"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Foreground="{DynamicResource MaterialDesignValidationErrorBrush}"/>
                        </Grid>

                        <!-- Open Log Folder -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{loc:Loc Settings_Btn_OpenLogs}"
                                           Style="{StaticResource MaterialDesignBody1TextBlock}"
                                           FontWeight="Medium"/>
                                <TextBlock Text="{loc:Loc Settings_OpenLogs_Desc}"
                                           Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                           Opacity="0.7"/>
                            </StackPanel>

                            <Button Grid.Column="1"
                                    Command="{Binding OpenLogFolderCommand}"
                                    Style="{StaticResource MaterialDesignOutlinedButton}">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="FolderOpen" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="{loc:Loc Settings_Btn_OpenLogs}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </StackPanel>
                </materialDesign:Card>

                <!-- About Section -->
                <materialDesign:Card Padding="16"
                                      Margin="0,0,0,16"
                                      materialDesign:ElevationAssist.Elevation="Dp2">
                    <StackPanel>
                        <!-- Section Header -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <materialDesign:PackIcon Kind="InformationOutline"
                                                      Width="24" Height="24"
                                                      VerticalAlignment="Center"
                                                      Margin="0,0,12,0"/>
                            <TextBlock Text="{loc:Loc Settings_Section_About}"
                                       Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- App Info -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Author -->
                            <TextBlock Grid.Row="0" Grid.Column="0"
                                       Text="{loc:Loc About_Author}"
                                       Style="{StaticResource MaterialDesignBody1TextBlock}"
                                       FontWeight="Medium"
                                       Margin="0,0,24,8"/>
                            <TextBlock Grid.Row="0" Grid.Column="1"
                                       Text="Julien Bombled"
                                       Style="{StaticResource MaterialDesignBody1TextBlock}"
                                       Margin="0,0,0,8"/>

                            <!-- Version -->
                            <TextBlock Grid.Row="1" Grid.Column="0"
                                       Text="{loc:Loc About_Version}"
                                       Style="{StaticResource MaterialDesignBody1TextBlock}"
                                       FontWeight="Medium"
                                       Margin="0,0,24,8"/>
                            <TextBlock Grid.Row="1" Grid.Column="1"
                                       Text="{Binding AppVersion}"
                                       Style="{StaticResource MaterialDesignBody1TextBlock}"
                                       Margin="0,0,0,8"/>

                            <!-- License -->
                            <TextBlock Grid.Row="2" Grid.Column="0"
                                       Text="{loc:Loc About_License}"
                                       Style="{StaticResource MaterialDesignBody1TextBlock}"
                                       FontWeight="Medium"
                                       Margin="0,0,24,8"/>
                            <TextBlock Grid.Row="2" Grid.Column="1"
                                       Text="Apache License 2.0"
                                       Style="{StaticResource MaterialDesignBody1TextBlock}"
                                       Margin="0,0,0,8"/>

                            <!-- GitHub -->
                            <TextBlock Grid.Row="3" Grid.Column="0"
                                       Text="{loc:Loc About_Repository}"
                                       Style="{StaticResource MaterialDesignBody1TextBlock}"
                                       FontWeight="Medium"
                                       Margin="0,0,24,0"/>
                            <Button Grid.Row="3" Grid.Column="1"
                                    Content="github.com/youen/Win11Forge"
                                    Command="{Binding OpenGitHubCommand}"
                                    Style="{StaticResource MaterialDesignFlatButton}"
                                    HorizontalAlignment="Left"
                                    Padding="0"
                                    Margin="0"/>
                        </Grid>
                    </StackPanel>
                </materialDesign:Card>

                <!-- Status Message -->
                <materialDesign:Card Padding="12"
                                      materialDesign:ElevationAssist.Elevation="Dp1"
                                      Visibility="{Binding StatusMessage, Converter={StaticResource NullableToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="CheckCircle"
                                                  Width="20" Height="20"
                                                  VerticalAlignment="Center"
                                                  Foreground="{DynamicResource PrimaryHueMidBrush}"
                                                  Margin="0,0,8,0"/>
                        <TextBlock Text="{Binding StatusMessage}"
                                   Style="{StaticResource MaterialDesignBody2TextBlock}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </materialDesign:Card>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
