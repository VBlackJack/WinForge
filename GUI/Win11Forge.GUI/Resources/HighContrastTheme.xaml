<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <!-- High Contrast Color Palette (WCAG AAA compliant - 7:1 minimum contrast) -->

    <!-- Primary Colors - High contrast yellow on black -->
    <SolidColorBrush x:Key="HighContrastPrimaryBrush" Color="#FFFF00"/>
    <SolidColorBrush x:Key="HighContrastPrimaryForegroundBrush" Color="#000000"/>

    <!-- Secondary Colors - High contrast cyan -->
    <SolidColorBrush x:Key="HighContrastSecondaryBrush" Color="#00FFFF"/>
    <SolidColorBrush x:Key="HighContrastSecondaryForegroundBrush" Color="#000000"/>

    <!-- Background Colors -->
    <SolidColorBrush x:Key="HighContrastBackgroundBrush" Color="#000000"/>
    <SolidColorBrush x:Key="HighContrastSurfaceBrush" Color="#1A1A1A"/>
    <SolidColorBrush x:Key="HighContrastCardBrush" Color="#262626"/>

    <!-- Text Colors -->
    <SolidColorBrush x:Key="HighContrastTextPrimaryBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="HighContrastTextSecondaryBrush" Color="#E0E0E0"/>
    <SolidColorBrush x:Key="HighContrastTextDisabledBrush" Color="#808080"/>

    <!-- Status Colors - High visibility -->
    <SolidColorBrush x:Key="HighContrastSuccessBrush" Color="#00FF00"/>
    <SolidColorBrush x:Key="HighContrastSuccessBackgroundBrush" Color="#003300"/>
    <SolidColorBrush x:Key="HighContrastErrorBrush" Color="#FF0000"/>
    <SolidColorBrush x:Key="HighContrastErrorBackgroundBrush" Color="#330000"/>
    <SolidColorBrush x:Key="HighContrastWarningBrush" Color="#FFFF00"/>
    <SolidColorBrush x:Key="HighContrastWarningBackgroundBrush" Color="#333300"/>
    <SolidColorBrush x:Key="HighContrastInfoBrush" Color="#00FFFF"/>
    <SolidColorBrush x:Key="HighContrastInfoBackgroundBrush" Color="#003333"/>

    <!-- Border Colors -->
    <SolidColorBrush x:Key="HighContrastBorderBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="HighContrastBorderLightBrush" Color="#666666"/>
    <SolidColorBrush x:Key="HighContrastFocusBorderBrush" Color="#FFFF00"/>

    <!-- Link Colors -->
    <SolidColorBrush x:Key="HighContrastLinkBrush" Color="#00FFFF"/>
    <SolidColorBrush x:Key="HighContrastLinkHoverBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="HighContrastLinkVisitedBrush" Color="#FF00FF"/>

    <!-- Selection Colors -->
    <SolidColorBrush x:Key="HighContrastSelectionBrush" Color="#FFFF00"/>
    <SolidColorBrush x:Key="HighContrastSelectionForegroundBrush" Color="#000000"/>

    <!-- High Contrast Focus Visual Style (extra thick border) -->
    <Style x:Key="HighContrastFocusVisual">
        <Setter Property="Control.Template">
            <Setter.Value>
                <ControlTemplate>
                    <Border BorderBrush="{DynamicResource HighContrastFocusBorderBrush}"
                            BorderThickness="3"
                            CornerRadius="2"
                            Margin="-3"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- High Contrast Button Style -->
    <Style x:Key="HighContrastButtonStyle" TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
        <Setter Property="Background" Value="{DynamicResource HighContrastPrimaryBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource HighContrastPrimaryForegroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource HighContrastBorderBrush}"/>
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="FocusVisualStyle" Value="{StaticResource HighContrastFocusVisual}"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource HighContrastSecondaryBrush}"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Background" Value="{DynamicResource HighContrastBorderLightBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource HighContrastTextDisabledBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- High Contrast Outlined Button Style -->
    <Style x:Key="HighContrastOutlinedButtonStyle" TargetType="Button" BasedOn="{StaticResource MaterialDesignOutlinedButton}">
        <Setter Property="Foreground" Value="{DynamicResource HighContrastPrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource HighContrastPrimaryBrush}"/>
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="FocusVisualStyle" Value="{StaticResource HighContrastFocusVisual}"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource HighContrastSurfaceBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- High Contrast TextBox Style -->
    <Style x:Key="HighContrastTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource MaterialDesignOutlinedTextBox}">
        <Setter Property="Background" Value="{DynamicResource HighContrastSurfaceBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource HighContrastTextPrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource HighContrastBorderBrush}"/>
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="CaretBrush" Value="{DynamicResource HighContrastPrimaryBrush}"/>
        <Setter Property="FocusVisualStyle" Value="{StaticResource HighContrastFocusVisual}"/>
    </Style>

    <!-- High Contrast CheckBox Style -->
    <Style x:Key="HighContrastCheckBoxStyle" TargetType="CheckBox" BasedOn="{StaticResource MaterialDesignCheckBox}">
        <Setter Property="Foreground" Value="{DynamicResource HighContrastTextPrimaryBrush}"/>
        <Setter Property="FocusVisualStyle" Value="{StaticResource HighContrastFocusVisual}"/>
        <Setter Property="FontWeight" Value="Medium"/>
    </Style>

    <!-- High Contrast ListBoxItem Style -->
    <Style x:Key="HighContrastListBoxItemStyle" TargetType="ListBoxItem" BasedOn="{StaticResource MaterialDesignNavigationPrimaryListBoxItem}">
        <Setter Property="Foreground" Value="{DynamicResource HighContrastTextPrimaryBrush}"/>
        <Setter Property="FocusVisualStyle" Value="{StaticResource HighContrastFocusVisual}"/>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{DynamicResource HighContrastSelectionBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource HighContrastSelectionForegroundBrush}"/>
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource HighContrastSurfaceBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- High Contrast Card Style -->
    <Style x:Key="HighContrastCardStyle" TargetType="materialDesign:Card" BasedOn="{StaticResource {x:Type materialDesign:Card}}">
        <Setter Property="Background" Value="{DynamicResource HighContrastCardBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource HighContrastTextPrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource HighContrastBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <!-- High Contrast Progress Bar Style -->
    <Style x:Key="HighContrastProgressBarStyle" TargetType="ProgressBar" BasedOn="{StaticResource MaterialDesignLinearProgressBar}">
        <Setter Property="Foreground" Value="{DynamicResource HighContrastPrimaryBrush}"/>
        <Setter Property="Background" Value="{DynamicResource HighContrastSurfaceBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource HighContrastBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <!-- High Contrast DataGrid Style -->
    <Style x:Key="HighContrastDataGridStyle" TargetType="DataGrid" BasedOn="{StaticResource {x:Type DataGrid}}">
        <Setter Property="Background" Value="{DynamicResource HighContrastBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource HighContrastTextPrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource HighContrastBorderBrush}"/>
        <Setter Property="GridLinesVisibility" Value="All"/>
        <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource HighContrastBorderLightBrush}"/>
        <Setter Property="VerticalGridLinesBrush" Value="{DynamicResource HighContrastBorderLightBrush}"/>
    </Style>

    <!-- High Contrast Severity Indicator Styles -->
    <Style x:Key="HighContrastSeverityCriticalStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource HighContrastErrorBackgroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource HighContrastErrorBrush}"/>
        <Setter Property="BorderThickness" Value="3"/>
    </Style>

    <Style x:Key="HighContrastSeverityWarningStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource HighContrastWarningBackgroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource HighContrastWarningBrush}"/>
        <Setter Property="BorderThickness" Value="2"/>
    </Style>

    <Style x:Key="HighContrastSeverityInfoStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource HighContrastInfoBackgroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource HighContrastInfoBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <Style x:Key="HighContrastSeveritySuccessStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource HighContrastSuccessBackgroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource HighContrastSuccessBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

</ResourceDictionary>
