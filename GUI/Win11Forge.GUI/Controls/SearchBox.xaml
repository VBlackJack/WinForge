<UserControl x:Class="Win11Forge.GUI.Controls.SearchBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:loc="clr-namespace:Win11Forge.GUI.Resources">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Search TextBox -->
        <TextBox x:Name="SearchTextBox"
                 Grid.Row="0"
                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                 materialDesign:HintAssist.Hint="{loc:Loc Apps_SearchHint}"
                 materialDesign:TextFieldAssist.HasClearButton="True"
                 materialDesign:TextFieldAssist.HasLeadingIcon="True"
                 materialDesign:TextFieldAssist.LeadingIcon="Magnify"
                 TextChanged="SearchTextBox_TextChanged"
                 KeyDown="SearchTextBox_KeyDown"
                 GotFocus="SearchTextBox_GotFocus"
                 LostFocus="SearchTextBox_LostFocus"
                 AutomationProperties.Name="Search applications"
                 AutomationProperties.HelpText="Type to filter applications. Use arrow keys to navigate suggestions."/>

        <!-- Suggestions Popup -->
        <Popup x:Name="SuggestionsPopup"
               Grid.Row="1"
               PlacementTarget="{Binding ElementName=SearchTextBox}"
               Placement="Bottom"
               StaysOpen="False"
               AllowsTransparency="True"
               PopupAnimation="Fade">
            <materialDesign:Card Width="{Binding ActualWidth, ElementName=SearchTextBox}"
                                  MaxHeight="250"
                                  Padding="0"
                                  materialDesign:ElevationAssist.Elevation="Dp4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Recent Searches Header -->
                    <Border Grid.Row="0"
                            Background="{DynamicResource MaterialDesignToolBarBackground}"
                            Padding="12,8"
                            Visibility="{Binding HasRecentSearches, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="History" Width="16" Height="16" Opacity="0.7" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="{loc:Loc Search_RecentSearches}"
                                       Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                       Opacity="0.7"/>
                        </StackPanel>
                    </Border>

                    <!-- Suggestions List -->
                    <ListBox x:Name="SuggestionsList"
                             Grid.Row="1"
                             MaxHeight="200"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             SelectionChanged="SuggestionsList_SelectionChanged"
                             Style="{StaticResource MaterialDesignListBox}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <materialDesign:PackIcon Grid.Column="0"
                                                              Kind="{Binding Icon}"
                                                              Width="18" Height="18"
                                                              Opacity="0.7"
                                                              VerticalAlignment="Center"
                                                              Margin="0,0,12,0"/>

                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Text}"
                                                   Style="{StaticResource MaterialDesignBody2TextBlock}"/>
                                        <TextBlock Text="{Binding Category}"
                                                   Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                                   Opacity="0.6"
                                                   Visibility="{Binding Category, Converter={StaticResource NullableToVisibilityConverter}}"/>
                                    </StackPanel>

                                    <TextBlock Grid.Column="2"
                                               Text="{Binding Shortcut}"
                                               Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                               Opacity="0.5"
                                               VerticalAlignment="Center"
                                               Visibility="{Binding Shortcut, Converter={StaticResource NullableToVisibilityConverter}}"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </materialDesign:Card>
        </Popup>
    </Grid>
</UserControl>
