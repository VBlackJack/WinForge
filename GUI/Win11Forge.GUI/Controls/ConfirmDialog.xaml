<UserControl x:Class="Win11Forge.GUI.Controls.ConfirmDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:loc="clr-namespace:Win11Forge.GUI.Resources"
             xmlns:helpers="clr-namespace:Win11Forge.GUI.Helpers"
             MinWidth="350" MaxWidth="500"
             AutomationProperties.Name="{loc:Loc A11y_Dialog_Confirm}"
             Loaded="UserControl_Loaded"
             FocusManager.FocusedElement="{Binding ElementName=CancelButton}"
             helpers:FocusTrapBehavior.IsEnabled="True"
             helpers:FocusTrapBehavior.InitialFocusElement="{Binding ElementName=CancelButton}"
             KeyDown="UserControl_KeyDown">
   <Border Padding="24">
       <Grid>
           <Grid.RowDefinitions>
               <RowDefinition Height="Auto"/>
               <RowDefinition Height="Auto"/>
               <RowDefinition Height="Auto"/>
           </Grid.RowDefinitions>

           <!-- Header with Icon -->
           <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
               <ui:SymbolIcon x:Name="DialogIcon"
                              Symbol="QuestionCircle24"
                              Width="32" Height="32"
                              Foreground="{DynamicResource PrimaryHueMidBrush}"
                              VerticalAlignment="Center"
                              Margin="0,0,12,0"/>
               <TextBlock x:Name="TitleText"
                          FontSize="20" FontWeight="SemiBold"
                          VerticalAlignment="Center"
                          Text="{loc:Loc Dialog_Confirm}"/>
           </StackPanel>

           <!-- Message -->
           <TextBlock Grid.Row="1"
                      x:Name="MessageText"
                      FontSize="14"
                      TextWrapping="Wrap"
                      Margin="0,0,0,24"/>

           <!-- Actions -->
           <StackPanel Grid.Row="2"
                       Orientation="Horizontal"
                       HorizontalAlignment="Right">
               <!-- Cancel Button -->
               <ui:Button x:Name="CancelButton"
                       Content="{loc:Loc Dialog_Cancel}"
                       Appearance="Transparent"
                       Click="CancelButton_Click"
                       Margin="0,0,12,0"
                       AutomationProperties.Name="{loc:Loc Dialog_Cancel}"
                       IsCancel="True"/>

               <!-- Confirm Button -->
               <ui:Button x:Name="ConfirmButton"
                       Content="{loc:Loc Dialog_Confirm}"
                       Appearance="Transparent"
                       Click="ConfirmButton_Click"
                       AutomationProperties.Name="{loc:Loc Dialog_Confirm}"
                       IsDefault="True"/>
           </StackPanel>
       </Grid>
   </Border>
</UserControl>
