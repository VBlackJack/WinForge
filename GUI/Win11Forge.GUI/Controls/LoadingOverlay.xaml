<UserControl x:Class="Win11Forge.GUI.Controls.LoadingOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:loc="clr-namespace:Win11Forge.GUI.Resources"
             xmlns:local="clr-namespace:Win11Forge.GUI.Controls"
             AutomationProperties.Name="{loc:Loc Common_Loading}"
             AutomationProperties.LiveSetting="Assertive"
             Visibility="Collapsed"
             IsHitTestVisible="True">
    <Grid Background="{DynamicResource DialogOverlayBackgroundBrush}">
        <!-- Semi-transparent background to block interaction -->

        <!-- Centered loading content -->
        <Border HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                CornerRadius="12"
                Padding="32"
                MinWidth="200">
            <StackPanel HorizontalAlignment="Center">
                <!-- Progress Indicator -->
                <Grid x:Name="ProgressContainer" Margin="0,0,0,16">
                    <!-- Indeterminate Progress -->
                    <ui:ProgressRing x:Name="IndeterminateProgress"
                                 IsIndeterminate="True"
                                 Width="48" Height="48"
                                 HorizontalAlignment="Center"/>

                    <!-- Determinate Progress (hidden by default) -->
                    <ProgressBar x:Name="DeterminateProgress"
                                 Width="200" Height="8"
                                 HorizontalAlignment="Center"
                                 Minimum="0" Maximum="100"
                                 Visibility="Collapsed"/>
                </Grid>

                <!-- Loading Message -->
                <TextBlock x:Name="MessageText"
                           FontSize="{StaticResource FontSizeBodyLarge}" FontWeight="Medium"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           MaxWidth="300"
                           AutomationProperties.LiveSetting="Assertive"/>

                <!-- Sub-message (e.g., "This may take a moment") -->
                <TextBlock x:Name="SubMessageText"
                           FontSize="{StaticResource FontSizeCaption}"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Margin="0,8,0,0"
                           Visibility="Collapsed"/>

                <!-- Progress Text (e.g., "3 of 10") -->
                <TextBlock x:Name="ProgressText"
                           FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           Margin="0,8,0,0"
                           Visibility="Collapsed"
                           AutomationProperties.LiveSetting="Polite"/>

                <!-- Cancel Button (optional) -->
                <ui:Button x:Name="CancelButton"
                        Content="{loc:Loc Dialog_Cancel}"
                        Style="{DynamicResource SecondaryButton}"
                        Margin="0,16,0,0"
                        Visibility="Collapsed"
                        Click="CancelButton_Click"
                        AutomationProperties.Name="{loc:Loc Btn_Cancel}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
