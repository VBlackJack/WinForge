<UserControl x:Class="Win11Forge.GUI.Controls.SkeletonLoader"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:loc="clr-namespace:Win11Forge.GUI.Resources"
             xmlns:local="clr-namespace:Win11Forge.GUI.Controls"
             AutomationProperties.Name="{loc:Loc Common_Loading}"
             AutomationProperties.HelpText="Content is being loaded, please wait"
             AutomationProperties.LiveSetting="Polite">
    <Border x:Name="CardBorder"
            Padding="16"
            CornerRadius="8"
            Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
        <Border.Style>
            <Style TargetType="Border">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding ShowAnimation, RelativeSource={RelativeSource AncestorType=local:SkeletonLoader}}" Value="True">
                        <DataTrigger.EnterActions>
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever">
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                     From="0.6" To="1.0" Duration="0:0:0.8"
                                                     AutoReverse="True"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </DataTrigger.EnterActions>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>

        <Grid>
            <!-- Card Type (Default) -->
            <StackPanel x:Name="CardContent" Visibility="Visible">
                <!-- Title Skeleton -->
                <Border Height="20"
                        Width="200"
                        CornerRadius="4"
                        Background="{DynamicResource SkeletonBaseBrush}"
                        HorizontalAlignment="Left"
                        Margin="0,0,0,12"/>

                <!-- Content Lines -->
                <Border Height="14"
                        CornerRadius="4"
                        Background="{DynamicResource SkeletonBaseBrush}"
                        Margin="0,0,0,8"/>
                <Border Height="14"
                        Width="280"
                        CornerRadius="4"
                        Background="{DynamicResource SkeletonBaseBrush}"
                        HorizontalAlignment="Left"
                        Margin="0,0,0,8"/>
                <Border Height="14"
                        Width="200"
                        CornerRadius="4"
                        Background="{DynamicResource SkeletonBaseBrush}"
                        HorizontalAlignment="Left"/>
            </StackPanel>

            <!-- List Item Type -->
            <Grid x:Name="ListItemContent" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Icon placeholder -->
                <Border Grid.Column="0"
                        Width="40" Height="40"
                        CornerRadius="4"
                        Background="{DynamicResource SkeletonBaseBrush}"
                        Margin="0,0,16,0"/>

                <!-- Text placeholders -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <Border Height="16"
                            Width="180"
                            CornerRadius="4"
                            Background="{DynamicResource SkeletonBaseBrush}"
                            HorizontalAlignment="Left"
                            Margin="0,0,0,8"/>
                    <Border Height="12"
                            Width="120"
                            CornerRadius="4"
                            Background="{DynamicResource SkeletonBaseBrush}"
                            HorizontalAlignment="Left"/>
                </StackPanel>
            </Grid>

            <!-- Table Row Type -->
            <Grid x:Name="TableRowContent" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="48"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="60"/>
                </Grid.ColumnDefinitions>

                <!-- Checkbox placeholder -->
                <Border Grid.Column="0"
                        Width="20" Height="20"
                        CornerRadius="4"
                        Background="{DynamicResource SkeletonBaseBrush}"
                        HorizontalAlignment="Center"/>

                <!-- Name placeholder -->
                <Border Grid.Column="1"
                        Height="16"
                        CornerRadius="4"
                        Background="{DynamicResource SkeletonBaseBrush}"
                        Margin="8,0"/>

                <!-- Category placeholder -->
                <Border Grid.Column="2"
                        Height="14"
                        CornerRadius="4"
                        Background="{DynamicResource SkeletonBaseBrush}"
                        Margin="4,0"/>

                <!-- Status placeholder -->
                <Border Grid.Column="3"
                        Height="24"
                        CornerRadius="12"
                        Background="{DynamicResource SkeletonBaseBrush}"
                        Margin="4,0"/>

                <!-- Action placeholder -->
                <Border Grid.Column="4"
                        Width="32" Height="32"
                        CornerRadius="16"
                        Background="{DynamicResource SkeletonBaseBrush}"
                        HorizontalAlignment="Center"/>
            </Grid>

            <!-- Stat Card Type -->
            <StackPanel x:Name="StatCardContent" Visibility="Collapsed" HorizontalAlignment="Center">
                <!-- Large number -->
                <Border Height="48"
                        Width="80"
                        CornerRadius="8"
                        Background="{DynamicResource SkeletonBaseBrush}"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,12"/>

                <!-- Label -->
                <Border Height="14"
                        Width="100"
                        CornerRadius="4"
                        Background="{DynamicResource SkeletonBaseBrush}"
                        HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Profile Type -->
            <StackPanel x:Name="ProfileContent" Visibility="Collapsed" Orientation="Horizontal">
                <!-- Avatar circle -->
                <Border Width="56" Height="56"
                        CornerRadius="28"
                        Background="{DynamicResource SkeletonBaseBrush}"
                        Margin="0,0,16,0"/>

                <!-- Name and details -->
                <StackPanel VerticalAlignment="Center">
                    <Border Height="18"
                            Width="150"
                            CornerRadius="4"
                            Background="{DynamicResource SkeletonBaseBrush}"
                            HorizontalAlignment="Left"
                            Margin="0,0,0,8"/>
                    <Border Height="12"
                            Width="100"
                            CornerRadius="4"
                            Background="{DynamicResource SkeletonBaseBrush}"
                            HorizontalAlignment="Left"/>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
