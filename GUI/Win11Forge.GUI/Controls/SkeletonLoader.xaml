<UserControl x:Class="Win11Forge.GUI.Controls.SkeletonLoader"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:loc="clr-namespace:Win11Forge.GUI.Resources"
             AutomationProperties.Name="{loc:Loc Common_Loading}"
             AutomationProperties.HelpText="Content is being loaded, please wait"
             AutomationProperties.LiveSetting="Polite">
    <materialDesign:Card Padding="16"
                          materialDesign:ElevationAssist.Elevation="Dp1">
        <materialDesign:Card.Triggers>
            <EventTrigger RoutedEvent="Loaded">
                <BeginStoryboard>
                    <Storyboard RepeatBehavior="Forever">
                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                         From="0.6" To="1.0" Duration="0:0:0.8"
                                         AutoReverse="True"/>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </materialDesign:Card.Triggers>
        <StackPanel>
            <!-- Title Skeleton -->
            <Border Height="20"
                    Width="200"
                    CornerRadius="4"
                    Background="{DynamicResource SkeletonBaseBrush}"
                    HorizontalAlignment="Left"
                    Margin="0,0,0,12"/>

            <!-- Content Lines -->
            <Border Height="14"
                    CornerRadius="4"
                    Background="{DynamicResource SkeletonBaseBrush}"
                    Margin="0,0,0,8"/>
            <Border Height="14"
                    Width="80%"
                    CornerRadius="4"
                    Background="{DynamicResource SkeletonBaseBrush}"
                    HorizontalAlignment="Left"
                    Margin="0,0,0,8"/>
            <Border Height="14"
                    Width="60%"
                    CornerRadius="4"
                    Background="{DynamicResource SkeletonBaseBrush}"
                    HorizontalAlignment="Left"/>
        </StackPanel>
    </materialDesign:Card>
</UserControl>
