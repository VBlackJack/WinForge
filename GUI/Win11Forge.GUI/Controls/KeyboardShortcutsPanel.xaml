<UserControl x:Class="Win11Forge.GUI.Controls.KeyboardShortcutsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:loc="clr-namespace:Win11Forge.GUI.Resources"
             MinWidth="350" MaxWidth="500">
    <Border Padding="24">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
                <ui:SymbolIcon Symbol="Keyboard24"
                               Width="28" Height="28"
                               VerticalAlignment="Center"
                               Margin="0,0,12,0"/>
                <TextBlock Text="{loc:Loc Help_KeyboardShortcuts}"
                           FontSize="20" FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Shortcuts List -->
            <ScrollViewer Grid.Row="1" MaxHeight="400" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- General Section -->
                    <TextBlock Text="{loc:Loc Help_Section_General}"
                               FontSize="14" FontWeight="Medium"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Margin="0,0,0,8"/>

                    <ItemsControl x:Name="GeneralShortcuts">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" MinWidth="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0"
                                            Background="{DynamicResource ControlFillColorDefaultBrush}"
                                            CornerRadius="4"
                                            Padding="8,4"
                                            HorizontalAlignment="Left">
                                        <TextBlock Text="{Binding Key}"
                                                   FontFamily="Consolas"
                                                   FontWeight="Medium"/>
                                    </Border>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Description}"
                                               FontSize="12"
                                               VerticalAlignment="Center"
                                               Margin="12,0,0,0"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Applications Section -->
                    <TextBlock Text="{loc:Loc Help_Section_AppManager}"
                               FontSize="14" FontWeight="Medium"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Margin="0,16,0,8"/>

                    <ItemsControl x:Name="AppManagerShortcuts">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" MinWidth="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0"
                                            Background="{DynamicResource ControlFillColorDefaultBrush}"
                                            CornerRadius="4"
                                            Padding="8,4"
                                            HorizontalAlignment="Left">
                                        <TextBlock Text="{Binding Key}"
                                                   FontFamily="Consolas"
                                                   FontWeight="Medium"/>
                                    </Border>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Description}"
                                               FontSize="12"
                                               VerticalAlignment="Center"
                                               Margin="12,0,0,0"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Navigation Section -->
                    <TextBlock Text="{loc:Loc Help_Section_Navigation}"
                               FontSize="14" FontWeight="Medium"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Margin="0,16,0,8"/>

                    <ItemsControl x:Name="NavigationShortcuts">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" MinWidth="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0"
                                            Background="{DynamicResource ControlFillColorDefaultBrush}"
                                            CornerRadius="4"
                                            Padding="8,4"
                                            HorizontalAlignment="Left">
                                        <TextBlock Text="{Binding Key}"
                                                   FontFamily="Consolas"
                                                   FontWeight="Medium"/>
                                    </Border>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Description}"
                                               FontSize="12"
                                               VerticalAlignment="Center"
                                               Margin="12,0,0,0"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Data Grid Section -->
                    <TextBlock Text="{loc:Loc Help_Section_DataGrid}"
                               FontSize="14" FontWeight="Medium"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Margin="0,16,0,8"/>

                    <ItemsControl x:Name="DataGridShortcuts">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" MinWidth="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0"
                                            Background="{DynamicResource ControlFillColorDefaultBrush}"
                                            CornerRadius="4"
                                            Padding="8,4"
                                            HorizontalAlignment="Left">
                                        <TextBlock Text="{Binding Key}"
                                                   FontFamily="Consolas"
                                                   FontWeight="Medium"/>
                                    </Border>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Description}"
                                               FontSize="12"
                                               VerticalAlignment="Center"
                                               Margin="12,0,0,0"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Hint for DataGrid -->
                    <Border Background="{DynamicResource ControlFillColorDefaultBrush}"
                            CornerRadius="4"
                            Padding="12"
                            Margin="0,16,0,0">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Info24"
                                           Width="18" Height="18"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           Margin="0,0,8,0"/>
                            <TextBlock Text="{loc:Loc Help_Shortcut_DataGrid}"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Close Button -->
            <ui:Button Grid.Row="2"
                       Content="{loc:Loc Dialog_Close}"
                       Appearance="Primary"
                       HorizontalAlignment="Right"
                       Margin="0,20,0,0"
                       Click="CloseButton_Click"
                       AutomationProperties.Name="{loc:Loc A11y_Shortcuts_Close}"/>
        </Grid>
    </Border>
</UserControl>
