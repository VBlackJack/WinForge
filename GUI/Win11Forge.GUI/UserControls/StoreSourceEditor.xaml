<UserControl x:Class="Win11Forge.GUI.UserControls.StoreSourceEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:loc="clr-namespace:Win11Forge.GUI.Resources"
             mc:Ignorable="d"
             d:DesignHeight="140" d:DesignWidth="500">

    <materialDesign:Card Padding="16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header with enable toggle -->
            <Grid Grid.Row="0" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Shopping"
                                              Width="24" Height="24"
                                              VerticalAlignment="Center"
                                              Margin="0,0,12,0"/>
                    <TextBlock Text="Microsoft Store"
                               Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <ToggleButton Grid.Column="2"
                              x:Name="EnableToggle"
                              Style="{StaticResource MaterialDesignSwitchToggleButton}"
                              IsChecked="{Binding IsSourceEnabled, RelativeSource={RelativeSource AncestorType=UserControl}}"
                              ToolTip="{loc:Loc SourceEditor_EnableDisable}"
                              AutomationProperties.Name="Enable Microsoft Store source"/>
            </Grid>

            <!-- Store App ID -->
            <Grid Grid.Row="1" Margin="0,0,0,12" IsEnabled="{Binding IsChecked, ElementName=EnableToggle}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0"
                         Text="{Binding StoreId, RelativeSource={RelativeSource AncestorType=UserControl}, UpdateSourceTrigger=PropertyChanged}"
                         materialDesign:HintAssist.Hint="{loc:Loc AppEditor_StoreAppId}"
                         materialDesign:HintAssist.IsFloating="True"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         MaxLength="12"
                         CharacterCasing="Upper"
                         AutomationProperties.Name="Microsoft Store app ID"/>

                <!-- Validation indicator -->
                <materialDesign:PackIcon Grid.Column="1"
                                          x:Name="ValidationIcon"
                                          Width="24" Height="24"
                                          VerticalAlignment="Center"
                                          Margin="8,0,0,0"
                                          Visibility="{Binding StoreId, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource NullableToVisibilityConverter}}"/>
            </Grid>

            <!-- Format hint -->
            <TextBlock Grid.Row="2"
                       Text="{loc:Loc SourceEditor_StoreIdHint}"
                       Style="{StaticResource MaterialDesignCaptionTextBlock}"
                       Foreground="{DynamicResource MaterialDesignBodyLight}"
                       IsEnabled="{Binding IsChecked, ElementName=EnableToggle}"
                       Margin="0,0,0,0"/>
        </Grid>
    </materialDesign:Card>
</UserControl>
