<UserControl x:Class="Win11Forge.GUI.UserControls.DetectionEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:loc="clr-namespace:Win11Forge.GUI.Resources"
             mc:Ignorable="d"
             d:DesignHeight="400" d:DesignWidth="500">

    <StackPanel>
        <!-- Description -->
        <TextBlock Text="{loc:Loc AppEditor_DetectionDescription}"
                   Style="{StaticResource MaterialDesignBody2TextBlock}"
                   Foreground="{DynamicResource MaterialDesignBodyLight}"
                   TextWrapping="Wrap"
                   Margin="0,0,0,16"/>

        <!-- Detection Method -->
        <ComboBox x:Name="MethodComboBox"
                  SelectedValue="{Binding Method, RelativeSource={RelativeSource AncestorType=UserControl}}"
                  SelectedValuePath="Tag"
                  materialDesign:HintAssist.Hint="{loc:Loc AppEditor_DetectionMethod}"
                  materialDesign:HintAssist.IsFloating="True"
                  Style="{StaticResource MaterialDesignOutlinedComboBox}"
                  Margin="0,0,0,16"
                  AutomationProperties.Name="Detection method">
            <ComboBoxItem Content="{loc:Loc Detection_Method_Registry}" Tag="Registry"/>
            <ComboBoxItem Content="{loc:Loc Detection_Method_File}" Tag="File"/>
            <ComboBoxItem Content="{loc:Loc Detection_Method_Command}" Tag="Command"/>
            <ComboBoxItem Content="{loc:Loc Detection_Method_WindowsFeature}" Tag="WindowsFeature"/>
            <ComboBoxItem Content="{loc:Loc Detection_Method_StoreApp}" Tag="StoreApp"/>
        </ComboBox>

        <!-- Registry Detection Panel -->
        <materialDesign:Card x:Name="RegistryPanel"
                              Padding="16"
                              Margin="0,0,0,16"
                              Visibility="Collapsed">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <materialDesign:PackIcon Kind="Key"
                                              Width="20" Height="20"
                                              VerticalAlignment="Center"
                                              Margin="0,0,8,0"/>
                    <TextBlock Text="{loc:Loc Detection_Registry_Title}"
                               Style="{StaticResource MaterialDesignSubtitle2TextBlock}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Registry Path -->
                <TextBox Text="{Binding Path, RelativeSource={RelativeSource AncestorType=UserControl}, UpdateSourceTrigger=PropertyChanged}"
                         materialDesign:HintAssist.Hint="{loc:Loc Detection_Registry_Path}"
                         materialDesign:HintAssist.IsFloating="True"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Margin="0,0,0,12"
                         AutomationProperties.Name="Registry path"/>

                <!-- Registry Value Name -->
                <TextBox Text="{Binding VersionKey, RelativeSource={RelativeSource AncestorType=UserControl}, UpdateSourceTrigger=PropertyChanged}"
                         materialDesign:HintAssist.Hint="{loc:Loc AppEditor_VersionKey}"
                         materialDesign:HintAssist.IsFloating="True"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Margin="0,0,0,12"
                         AutomationProperties.Name="Version registry value"/>

                <!-- Minimum Version -->
                <TextBox Text="{Binding MinVersion, RelativeSource={RelativeSource AncestorType=UserControl}, UpdateSourceTrigger=PropertyChanged}"
                         materialDesign:HintAssist.Hint="{loc:Loc AppEditor_MinVersion}"
                         materialDesign:HintAssist.IsFloating="True"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         AutomationProperties.Name="Minimum version"/>
            </StackPanel>
        </materialDesign:Card>

        <!-- File Detection Panel -->
        <materialDesign:Card x:Name="FilePanel"
                              Padding="16"
                              Margin="0,0,0,16"
                              Visibility="Collapsed">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <materialDesign:PackIcon Kind="File"
                                              Width="20" Height="20"
                                              VerticalAlignment="Center"
                                              Margin="0,0,8,0"/>
                    <TextBlock Text="{loc:Loc Detection_File_Title}"
                               Style="{StaticResource MaterialDesignSubtitle2TextBlock}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- File Path with Browse Button -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0"
                             Text="{Binding Path, RelativeSource={RelativeSource AncestorType=UserControl}, UpdateSourceTrigger=PropertyChanged}"
                             materialDesign:HintAssist.Hint="{loc:Loc Detection_File_Path}"
                             materialDesign:HintAssist.IsFloating="True"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             AutomationProperties.Name="File path"/>

                    <Button Grid.Column="1"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Content="{loc:Loc Detection_Browse}"
                            Command="{Binding BrowseCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            Margin="8,0,0,0"
                            VerticalAlignment="Stretch"
                            AutomationProperties.Name="Browse for file"/>
                </Grid>

                <!-- Minimum Version -->
                <TextBox Text="{Binding MinVersion, RelativeSource={RelativeSource AncestorType=UserControl}, UpdateSourceTrigger=PropertyChanged}"
                         materialDesign:HintAssist.Hint="{loc:Loc AppEditor_MinVersion}"
                         materialDesign:HintAssist.IsFloating="True"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         AutomationProperties.Name="Minimum version"/>
            </StackPanel>
        </materialDesign:Card>

        <!-- Command Detection Panel -->
        <materialDesign:Card x:Name="CommandPanel"
                              Padding="16"
                              Margin="0,0,0,16"
                              Visibility="Collapsed">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <materialDesign:PackIcon Kind="Application"
                                              Width="20" Height="20"
                                              VerticalAlignment="Center"
                                              Margin="0,0,8,0"/>
                    <TextBlock Text="{loc:Loc Detection_Command_Title}"
                               Style="{StaticResource MaterialDesignSubtitle2TextBlock}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Command -->
                <TextBox Text="{Binding Path, RelativeSource={RelativeSource AncestorType=UserControl}, UpdateSourceTrigger=PropertyChanged}"
                         materialDesign:HintAssist.Hint="{loc:Loc Detection_Command_Path}"
                         materialDesign:HintAssist.IsFloating="True"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         AutomationProperties.Name="Command to execute"/>

                <TextBlock Text="{loc:Loc Detection_Command_Hint}"
                           Style="{StaticResource MaterialDesignCaptionTextBlock}"
                           Foreground="{DynamicResource MaterialDesignBodyLight}"
                           Margin="0,4,0,0"/>
            </StackPanel>
        </materialDesign:Card>

        <!-- Windows Feature Panel -->
        <materialDesign:Card x:Name="WindowsFeaturePanel"
                              Padding="16"
                              Margin="0,0,0,16"
                              Visibility="Collapsed">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <materialDesign:PackIcon Kind="Cog"
                                              Width="20" Height="20"
                                              VerticalAlignment="Center"
                                              Margin="0,0,8,0"/>
                    <TextBlock Text="{loc:Loc Detection_WindowsFeature_Title}"
                               Style="{StaticResource MaterialDesignSubtitle2TextBlock}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Feature Name -->
                <TextBox Text="{Binding Path, RelativeSource={RelativeSource AncestorType=UserControl}, UpdateSourceTrigger=PropertyChanged}"
                         materialDesign:HintAssist.Hint="{loc:Loc Detection_WindowsFeature_Name}"
                         materialDesign:HintAssist.IsFloating="True"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         AutomationProperties.Name="Windows feature name"/>
            </StackPanel>
        </materialDesign:Card>

        <!-- Store App Panel -->
        <materialDesign:Card x:Name="StoreAppPanel"
                              Padding="16"
                              Margin="0,0,0,16"
                              Visibility="Collapsed">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <materialDesign:PackIcon Kind="Shopping"
                                              Width="20" Height="20"
                                              VerticalAlignment="Center"
                                              Margin="0,0,8,0"/>
                    <TextBlock Text="{loc:Loc Detection_StoreApp_Title}"
                               Style="{StaticResource MaterialDesignSubtitle2TextBlock}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Package Family Name -->
                <TextBox Text="{Binding Path, RelativeSource={RelativeSource AncestorType=UserControl}, UpdateSourceTrigger=PropertyChanged}"
                         materialDesign:HintAssist.Hint="{loc:Loc Detection_StoreApp_PackageName}"
                         materialDesign:HintAssist.IsFloating="True"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         AutomationProperties.Name="Package family name"/>
            </StackPanel>
        </materialDesign:Card>

        <!-- Test Detection Button and Result -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    Command="{Binding TestCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                    ToolTip="{loc:Loc Detection_TestTooltip}"
                    MinWidth="140"
                    AutomationProperties.Name="Test detection">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Play"
                                              Width="18" Height="18"
                                              VerticalAlignment="Center"
                                              Margin="0,0,8,0"
                                              Visibility="{Binding IsTesting, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>
                    <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                                 IsIndeterminate="True"
                                 Width="18" Height="18"
                                 Margin="0,0,8,0"
                                 Visibility="{Binding IsTesting, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    <TextBlock Text="{loc:Loc Detection_TestButton}" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <!-- Test Result -->
            <Border Grid.Column="1"
                    Margin="16,0,0,0"
                    Padding="12,8"
                    CornerRadius="4"
                    Visibility="{Binding TestResult, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource NullableToVisibilityConverter}}">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding TestSuccess, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                <Setter Property="Background" Value="#E8F5E9"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding TestSuccess, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="False">
                                <Setter Property="Background" Value="#FFEBEE"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon x:Name="TestResultIcon"
                                              Width="20" Height="20"
                                              VerticalAlignment="Center"
                                              Margin="0,0,8,0"/>
                    <StackPanel>
                        <TextBlock Text="{Binding TestResult, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                   FontWeight="Medium"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding DetectedVersion, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                   Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                   Visibility="{Binding DetectedVersion, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource NullableToVisibilityConverter}}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </StackPanel>
</UserControl>
