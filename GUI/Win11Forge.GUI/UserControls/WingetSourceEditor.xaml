<UserControl x:Class="Win11Forge.GUI.UserControls.WingetSourceEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:loc="clr-namespace:Win11Forge.GUI.Resources"
             mc:Ignorable="d"
             d:DesignHeight="200" d:DesignWidth="500">

    <Border CornerRadius="8" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" Padding="16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header with enable toggle -->
            <Grid Grid.Row="0" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="Box24"
                                   Width="24" Height="24"
                                   VerticalAlignment="Center"
                                   Margin="0,0,12,0"/>
                    <TextBlock Text="{loc:Loc Source_Winget}"
                               FontSize="16" FontWeight="Medium"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <ui:ToggleSwitch Grid.Column="2"
                                 x:Name="EnableToggle"
                                 IsChecked="{Binding IsSourceEnabled, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                 ToolTip="{loc:Loc SourceEditor_EnableDisable}"
                                 AutomationProperties.Name="{loc:Loc SourceEditor_EnableDisable}"/>
            </Grid>

            <!-- Package ID -->
            <ui:TextBox Grid.Row="1"
                     x:Name="PackageIdTextBox"
                     Text="{Binding PackageId, RelativeSource={RelativeSource AncestorType=UserControl}, UpdateSourceTrigger=PropertyChanged}"
                     PlaceholderText="{loc:Loc AppEditor_WingetPackageId}"
                     IsEnabled="{Binding IsChecked, ElementName=EnableToggle}"
                     Margin="0,0,0,12"
                     AutomationProperties.Name="{loc:Loc AppEditor_WingetPackageId}"/>

            <!-- Version and Source Row -->
            <Grid Grid.Row="2" Margin="0,0,0,12"
                  IsEnabled="{Binding IsChecked, ElementName=EnableToggle}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Version -->
                <ui:TextBox Grid.Column="0"
                         Text="{Binding Version, RelativeSource={RelativeSource AncestorType=UserControl}, UpdateSourceTrigger=PropertyChanged}"
                         PlaceholderText="{loc:Loc SourceEditor_Version}"
                         AutomationProperties.Name="{loc:Loc SourceEditor_Version}"/>

                <!-- Source Repository -->
                <ComboBox Grid.Column="2"
                          SelectedValue="{Binding SourceRepository, RelativeSource={RelativeSource AncestorType=UserControl}}"
                          SelectedValuePath="Tag"
                          AutomationProperties.Name="{loc:Loc SourceEditor_Repository}">
                    <ComboBoxItem Content="winget" Tag="winget"/>
                    <ComboBoxItem Content="msstore" Tag="msstore"/>
                </ComboBox>
            </Grid>

            <!-- Test Button and Status -->
            <Grid Grid.Row="3" IsEnabled="{Binding IsChecked, ElementName=EnableToggle}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <ui:Button Grid.Column="0"
                        Appearance="Transparent"
                        Command="{Binding TestCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                        ToolTip="{loc:Loc SourceEditor_TestTooltip}"
                        MinWidth="120"
                        AutomationProperties.Name="{loc:Loc SourceEditor_Test}">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Search24"
                                       Width="18" Height="18"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"
                                       Visibility="{Binding IsTesting, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>
                        <ProgressBar IsIndeterminate="True"
                                     Width="18" Height="18"
                                     Margin="0,0,8,0"
                                     Visibility="{Binding IsTesting, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        <TextBlock Text="{loc:Loc SourceEditor_Test}" VerticalAlignment="Center"/>
                    </StackPanel>
                </ui:Button>

                <!-- Test Result -->
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            Margin="16,0,0,0"
                            VerticalAlignment="Center"
                            Visibility="{Binding TestResult, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource NullableToVisibilityConverter}}">
                    <ui:SymbolIcon x:Name="TestResultIcon"
                                   Width="20" Height="20"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                    <TextBlock x:Name="TestResultText"
                               Text="{Binding TestResult, RelativeSource={RelativeSource AncestorType=UserControl}}"
                               VerticalAlignment="Center"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</UserControl>
