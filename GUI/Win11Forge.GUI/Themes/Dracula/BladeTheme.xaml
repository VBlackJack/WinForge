<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Dracula Blade Theme - https://draculatheme.com/contribute -->
    <Color x:Key="PrimaryColor">#1D1217</Color>
    <Color x:Key="SecondaryColor">#160E12</Color>
    <Color x:Key="SurfaceColor">#37212B</Color>
    <Color x:Key="AccentColor">#C798FF</Color>
    <Color x:Key="AccentHoverColor">#DEB3FF</Color>
    <Color x:Key="AccentPressedColor">#A87DE0</Color>
    <Color x:Key="TextPrimaryColor">#FFF1F4</Color>
    <Color x:Key="TextSecondaryColor">#CF9BAE</Color>
    <Color x:Key="TextDisabledColor">#AD6D82</Color>
    <Color x:Key="SuccessColor">#7AF6AE</Color>
    <Color x:Key="WarningColor">#FF9E63</Color>
    <Color x:Key="ErrorColor">#FF4D6D</Color>
    <Color x:Key="InfoColor">#6AE8FF</Color>
    <Color x:Key="BorderColor">#AD6D82</Color>
    <Color x:Key="HighlightColor">#4A2634</Color>
    <Color x:Key="SuccessTextColor">#7AF6AE</Color>
    <Color x:Key="WarningTextColor">#FF9E63</Color>
    <Color x:Key="ErrorTextColor">#FF4D6D</Color>
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SecondaryColor}"/>
    <SolidColorBrush x:Key="CardBrush" Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHoverColor}"/>
    <SolidColorBrush x:Key="AccentPressedBrush" Color="{StaticResource AccentPressedColor}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextTertiaryBrush" Color="#BD8498"/>
    <SolidColorBrush x:Key="TextDisabledBrush" Color="{StaticResource TextDisabledColor}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="HighlightBrush" Color="{StaticResource HighlightColor}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorColor}"/>
    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource InfoColor}"/>
    <SolidColorBrush x:Key="SuccessTextBrush" Color="{StaticResource SuccessTextColor}"/>
    <SolidColorBrush x:Key="WarningTextBrush" Color="{StaticResource WarningTextColor}"/>
    <SolidColorBrush x:Key="ErrorTextBrush" Color="{StaticResource ErrorTextColor}"/>
    <SolidColorBrush x:Key="BadgeTextBrush" Color="#10080C"/>
    <SolidColorBrush x:Key="TextOnAccentBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="FocusIndicatorBrush" Color="#6AE8FF"/>
    <SolidColorBrush x:Key="OverlayBackground" Color="#B3000000"/>

</ResourceDictionary>
