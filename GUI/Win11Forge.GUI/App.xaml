<Application x:Class="Win11Forge.GUI.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:Win11Forge.GUI.Resources">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <materialDesign:BundledTheme BaseTheme="Dark" PrimaryColor="DeepPurple" SecondaryColor="Lime" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign2.Defaults.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign3.Defaults.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Consolidated Color Resources for WCAG AA Contrast -->
            <SolidColorBrush x:Key="StatusPendingBrush" Color="#9E9E9E"/>
            <SolidColorBrush x:Key="StatusInstallingBrush" Color="#2196F3"/>
            <SolidColorBrush x:Key="StatusInstalledBrush" Color="#4CAF50"/>
            <SolidColorBrush x:Key="StatusFailedBrush" Color="#F44336"/>
            <SolidColorBrush x:Key="StatusSkippedBrush" Color="#FF9800"/>
            <SolidColorBrush x:Key="StatusAlreadyInstalledBrush" Color="#8BC34A"/>
            <SolidColorBrush x:Key="StatusUninstallingBrush" Color="#9C27B0"/>
            <SolidColorBrush x:Key="StatusUninstalledBrush" Color="#7986CB"/>

            <!-- Row Background Colors (semi-transparent) -->
            <SolidColorBrush x:Key="RowInstalledBackground" Color="#1E4CAF50"/>
            <SolidColorBrush x:Key="RowFailedBackground" Color="#1EF44336"/>
            <SolidColorBrush x:Key="RowInstallingBackground" Color="#1E2196F3"/>
            <SolidColorBrush x:Key="RowUninstalledBackground" Color="#1E7986CB"/>

            <!-- Accent Colors -->
            <SolidColorBrush x:Key="FavoriteActiveBrush" Color="#FFD700"/>
            <SolidColorBrush x:Key="FavoriteInactiveBrush" Color="#9E9E9E"/>
            <SolidColorBrush x:Key="RequiredBrush" Color="#FFC107"/>
            <SolidColorBrush x:Key="OptionalBrush" Color="#9E9E9E"/>

            <!-- High Contrast Text (WCAG AA compliant) -->
            <SolidColorBrush x:Key="HighContrastTextBrush" Color="#FFFFFF"/>
            <SolidColorBrush x:Key="MediumContrastTextBrush" Color="#E0E0E0"/>
            <SolidColorBrush x:Key="LowContrastTextBrush" Color="#BDBDBD"/>

            <!-- Error Display Colors (for error banners and validation) -->
            <SolidColorBrush x:Key="ErrorBackgroundBrush" Color="#FFEBEE"/>
            <SolidColorBrush x:Key="ErrorBorderBrush" Color="#EF5350"/>
            <SolidColorBrush x:Key="ErrorTextBrush" Color="#D32F2F"/>
            <SolidColorBrush x:Key="ErrorIconBrush" Color="#D32F2F"/>

            <!-- Validation Colors -->
            <SolidColorBrush x:Key="ValidationErrorBorderBrush" Color="#F44336"/>
            <SolidColorBrush x:Key="ValidationSuccessBorderBrush" Color="#4CAF50"/>

            <!-- Warning Display Colors (for dry run, caution banners) -->
            <SolidColorBrush x:Key="WarningBackgroundBrush" Color="#FFF3E0"/>
            <SolidColorBrush x:Key="WarningBorderBrush" Color="#FF9800"/>
            <SolidColorBrush x:Key="WarningTextBrush" Color="#E65100"/>
            <SolidColorBrush x:Key="WarningIconBrush" Color="#E65100"/>

            <!-- Skeleton Loader Colors -->
            <SolidColorBrush x:Key="SkeletonBaseBrush" Color="#2A2A2A"/>
            <SolidColorBrush x:Key="SkeletonHighlightBrush" Color="#3A3A3A"/>

            <!-- Validation TextBox Style (shows error when text is empty) -->
            <Style x:Key="MaterialDesignRequiredOutlinedTextBox" TargetType="TextBox" BasedOn="{StaticResource MaterialDesignOutlinedTextBox}">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding Text.Length, RelativeSource={RelativeSource Self}}" Value="0">
                        <Setter Property="BorderBrush" Value="{DynamicResource ValidationErrorBorderBrush}"/>
                        <Setter Property="materialDesign:TextFieldAssist.UnderlineBrush" Value="{DynamicResource ValidationErrorBorderBrush}"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <!-- Animation Durations -->
            <Duration x:Key="AnimationFast">0:0:0.15</Duration>
            <Duration x:Key="AnimationNormal">0:0:0.3</Duration>
            <Duration x:Key="AnimationSlow">0:0:0.5</Duration>

            <!-- Fade In Animation Style for Views -->
            <Style x:Key="FadeInStyle" TargetType="FrameworkElement">
                <Style.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 From="0" To="1" Duration="0:0:0.3">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <ThicknessAnimation Storyboard.TargetProperty="Margin"
                                                    From="0,20,0,0" To="0" Duration="0:0:0.3">
                                    <ThicknessAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </ThicknessAnimation.EasingFunction>
                                </ThicknessAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Style.Triggers>
            </Style>

            <!-- Card Hover Animation Style -->
            <Style x:Key="AnimatedCardStyle" TargetType="materialDesign:Card" BasedOn="{StaticResource {x:Type materialDesign:Card}}">
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Trigger.EnterActions>
                            <BeginStoryboard>
                                <Storyboard>
                                    <ThicknessAnimation Storyboard.TargetProperty="Margin"
                                                        To="-2,-2,-2,-2" Duration="0:0:0.15">
                                        <ThicknessAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut"/>
                                        </ThicknessAnimation.EasingFunction>
                                    </ThicknessAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </Trigger.EnterActions>
                        <Trigger.ExitActions>
                            <BeginStoryboard>
                                <Storyboard>
                                    <ThicknessAnimation Storyboard.TargetProperty="Margin"
                                                        To="0" Duration="0:0:0.15">
                                        <ThicknessAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut"/>
                                        </ThicknessAnimation.EasingFunction>
                                    </ThicknessAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </Trigger.ExitActions>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- Success Pulse Animation Storyboard -->
            <Storyboard x:Key="SuccessPulseAnimation">
                <ColorAnimation Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                To="#4CAF50" Duration="0:0:0.2" AutoReverse="True"/>
            </Storyboard>

            <!-- Error Shake Animation Storyboard -->
            <Storyboard x:Key="ErrorShakeAnimation">
                <ThicknessAnimation Storyboard.TargetProperty="Margin"
                                    From="0" To="5,0,-5,0" Duration="0:0:0.05"
                                    AutoReverse="True" RepeatBehavior="3x"/>
            </Storyboard>

            <!-- Converters -->
            <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
            <converters:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter"/>
            <converters:InverseBoolConverter x:Key="InverseBoolConverter"/>
            <converters:NullableToVisibilityConverter x:Key="NullableToVisibilityConverter"/>
            <converters:InverseNullableToVisibilityConverter x:Key="InverseNullableToVisibilityConverter"/>
            <converters:BoolToRequiredIconConverter x:Key="BoolToRequiredIconConverter"/>
            <converters:BoolToRequiredColorConverter x:Key="BoolToRequiredColorConverter"/>
            <converters:StatusToIconConverter x:Key="StatusToIconConverter"/>
            <converters:StatusToColorConverter x:Key="StatusToColorConverter"/>
            <converters:ZeroToVisibilityConverter x:Key="ZeroToVisibilityConverter"/>
            <converters:BoolToInstalledIconConverter x:Key="BoolToInstalledIconConverter"/>
            <converters:BoolToInstalledColorConverter x:Key="BoolToInstalledColorConverter"/>
            <converters:BoolToPauseIconConverter x:Key="BoolToPauseIconConverter"/>
            <converters:StatusFilterToStringConverter x:Key="StatusFilterToStringConverter"/>
            <converters:BoolToFavoriteIconConverter x:Key="BoolToFavoriteIconConverter"/>
            <converters:BoolToFavoriteColorConverter x:Key="BoolToFavoriteColorConverter"/>
            <converters:StatusToRowBackgroundConverter x:Key="StatusToRowBackgroundConverter"/>
            <converters:DeploymentResultToStringConverter x:Key="DeploymentResultToStringConverter"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
