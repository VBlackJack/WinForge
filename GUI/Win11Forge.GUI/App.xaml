<Application x:Class="Win11Forge.GUI.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:Win11Forge.GUI.Resources">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <materialDesign:BundledTheme BaseTheme="Dark" PrimaryColor="DeepPurple" SecondaryColor="Lime" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign2.Defaults.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign3.Defaults.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Consolidated Color Resources for WCAG AA Contrast -->
            <SolidColorBrush x:Key="StatusPendingBrush" Color="#9E9E9E"/>
            <SolidColorBrush x:Key="StatusInstallingBrush" Color="#2196F3"/>
            <SolidColorBrush x:Key="StatusInstalledBrush" Color="#4CAF50"/>
            <SolidColorBrush x:Key="StatusFailedBrush" Color="#F44336"/>
            <SolidColorBrush x:Key="StatusSkippedBrush" Color="#F57C00"/>
            <SolidColorBrush x:Key="StatusAlreadyInstalledBrush" Color="#8BC34A"/>
            <SolidColorBrush x:Key="StatusUninstallingBrush" Color="#9C27B0"/>
            <SolidColorBrush x:Key="StatusUninstalledBrush" Color="#7986CB"/>

            <!-- Row Background Colors (semi-transparent) -->
            <SolidColorBrush x:Key="RowInstalledBackground" Color="#1E4CAF50"/>
            <SolidColorBrush x:Key="RowFailedBackground" Color="#1EF44336"/>
            <SolidColorBrush x:Key="RowInstallingBackground" Color="#1E2196F3"/>
            <SolidColorBrush x:Key="RowUninstalledBackground" Color="#1E7986CB"/>
            <SolidColorBrush x:Key="RowUpdateAvailableBackground" Color="#28F57C00"/>

            <!-- Accent Colors -->
            <SolidColorBrush x:Key="FavoriteActiveBrush" Color="#FFD700"/>
            <SolidColorBrush x:Key="FavoriteInactiveBrush" Color="#9E9E9E"/>
            <SolidColorBrush x:Key="FavoriteTextBrush" Color="#FF8F00"/>
            <SolidColorBrush x:Key="RequiredBrush" Color="#FFC107"/>
            <SolidColorBrush x:Key="OptionalBrush" Color="#9E9E9E"/>
            <SolidColorBrush x:Key="AccentGreenTextBrush" Color="#2E7D32"/>
            <SolidColorBrush x:Key="AccentOrangeTextBrush" Color="#E65100"/>
            <SolidColorBrush x:Key="ManualInstallBadgeBrush" Color="#FF8A00"/>

            <!-- Secondary/Muted Icon Colors (use instead of Opacity for WCAG compliance) -->
            <SolidColorBrush x:Key="IconSecondaryBrush" Color="#9E9E9E"/>
            <SolidColorBrush x:Key="IconHintBrush" Color="#757575"/>
            <SolidColorBrush x:Key="IconDisabledBrush" Color="#616161"/>

            <!-- NOTE: For text colors, prefer using MaterialDesign theme brushes directly:
                 - MaterialDesignBody (primary text)
                 - MaterialDesignBodyLight (secondary text)
                 - MaterialDesignCheckBoxDisabled (disabled/hint text)
                 These custom brushes are kept for legacy compatibility only -->

            <!-- Error Display Colors (for error banners and validation) -->
            <!-- Using semi-transparent colors for theme compatibility -->
            <SolidColorBrush x:Key="ErrorBackgroundBrush" Color="#33F44336"/>
            <SolidColorBrush x:Key="ErrorBorderBrush" Color="#EF5350"/>
            <SolidColorBrush x:Key="ErrorTextBrush" Color="#EF5350"/>
            <SolidColorBrush x:Key="ErrorIconBrush" Color="#EF5350"/>

            <!-- Validation Colors -->
            <SolidColorBrush x:Key="ValidationErrorBorderBrush" Color="#F44336"/>
            <SolidColorBrush x:Key="ValidationSuccessBorderBrush" Color="#4CAF50"/>

            <!-- Warning Display Colors (for dry run, caution banners) -->
            <!-- Using semi-transparent colors for theme compatibility -->
            <SolidColorBrush x:Key="WarningBackgroundBrush" Color="#33F57C00"/>
            <SolidColorBrush x:Key="WarningBorderBrush" Color="#F57C00"/>
            <SolidColorBrush x:Key="WarningTextBrush" Color="#FFB74D"/>
            <SolidColorBrush x:Key="WarningIconBrush" Color="#FFB74D"/>

            <!-- Success Display Colors (for deployment complete, validation success) -->
            <SolidColorBrush x:Key="SuccessBackgroundBrush" Color="#334CAF50"/>
            <SolidColorBrush x:Key="SuccessBorderBrush" Color="#4CAF50"/>
            <SolidColorBrush x:Key="SuccessTextBrush" Color="#81C784"/>
            <SolidColorBrush x:Key="SuccessIconBrush" Color="#81C784"/>

            <!-- Skeleton Loader Colors (theme-aware with transparency) -->
            <SolidColorBrush x:Key="SkeletonBaseBrush" Color="#1AFFFFFF"/>
            <SolidColorBrush x:Key="SkeletonHighlightBrush" Color="#33FFFFFF"/>

            <!-- Light Theme Contrast Enhancement Colors -->
            <!-- These provide WCAG AA compliant contrast ratios for light backgrounds -->
            <SolidColorBrush x:Key="LightThemeTextPrimary" Color="#212121"/>
            <SolidColorBrush x:Key="LightThemeTextSecondary" Color="#424242"/>
            <SolidColorBrush x:Key="LightThemeTextHint" Color="#757575"/>
            <SolidColorBrush x:Key="LightThemeBorder" Color="#BDBDBD"/>
            <SolidColorBrush x:Key="LightThemeCardBackground" Color="#FFFFFF"/>
            <SolidColorBrush x:Key="LightThemeHoverBackground" Color="#0A000000"/>

            <!-- Status Colors optimized for light theme (darker for better contrast) -->
            <SolidColorBrush x:Key="StatusInstalledLightBrush" Color="#2E7D32"/>
            <SolidColorBrush x:Key="StatusFailedLightBrush" Color="#C62828"/>
            <SolidColorBrush x:Key="StatusInstallingLightBrush" Color="#1565C0"/>
            <SolidColorBrush x:Key="StatusSkippedLightBrush" Color="#E65100"/>
            <SolidColorBrush x:Key="StatusPendingLightBrush" Color="#616161"/>

            <!-- Focus Visual Style (WCAG compliant high-visibility focus indicator) -->
            <Style x:Key="HighVisibilityFocusVisual">
                <Setter Property="Control.Template">
                    <Setter.Value>
                        <ControlTemplate>
                            <Border BorderBrush="{DynamicResource SecondaryHueMidBrush}"
                                    BorderThickness="2"
                                    CornerRadius="4"
                                    Margin="-2"/>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Keyboard-focused Button Style with enhanced visibility -->
            <Style x:Key="KeyboardFocusableButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
                <Setter Property="FocusVisualStyle" Value="{StaticResource HighVisibilityFocusVisual}"/>
                <Setter Property="AutomationProperties.IsRequiredForForm" Value="False"/>
                <Style.Triggers>
                    <Trigger Property="IsKeyboardFocused" Value="True">
                        <Setter Property="materialDesign:ElevationAssist.Elevation" Value="Dp8"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- Keyboard-focused Icon Button Style -->
            <Style x:Key="KeyboardFocusableIconButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignIconButton}">
                <Setter Property="FocusVisualStyle" Value="{StaticResource HighVisibilityFocusVisual}"/>
                <Style.Triggers>
                    <Trigger Property="IsKeyboardFocused" Value="True">
                        <Setter Property="Background" Value="{DynamicResource MaterialDesign.Brush.Primary.Light}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- Keyboard-focused Card Style with outline on focus -->
            <Style x:Key="KeyboardFocusableCard" TargetType="materialDesign:Card" BasedOn="{StaticResource {x:Type materialDesign:Card}}">
                <Setter Property="Focusable" Value="True"/>
                <Setter Property="FocusVisualStyle" Value="{StaticResource HighVisibilityFocusVisual}"/>
                <Style.Triggers>
                    <Trigger Property="IsKeyboardFocused" Value="True">
                        <Setter Property="materialDesign:ElevationAssist.Elevation" Value="Dp8"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- Navigation ListBoxItem Style with visible focus and active indicator -->
            <Style x:Key="NavigationListBoxItemStyle" TargetType="ListBoxItem" BasedOn="{StaticResource MaterialDesignNavigationPrimaryListBoxItem}">
                <Setter Property="FocusVisualStyle" Value="{StaticResource HighVisibilityFocusVisual}"/>
                <Setter Property="MinHeight" Value="48"/>
                <Setter Property="Padding" Value="16,12"/>
                <Setter Property="BorderThickness" Value="4,0,0,0"/>
                <Setter Property="BorderBrush" Value="Transparent"/>
                <Style.Triggers>
                    <Trigger Property="IsSelected" Value="True">
                        <Setter Property="BorderBrush" Value="{DynamicResource PrimaryHueMidBrush}"/>
                        <Setter Property="Background" Value="{DynamicResource MaterialDesign.Brush.Primary.Light}"/>
                        <Setter Property="Foreground" Value="{DynamicResource PrimaryHueMidBrush}"/>
                    </Trigger>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{DynamicResource MaterialDesign.Brush.Primary.Light}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- Validation TextBox Style (shows error when text is empty) -->
            <Style x:Key="MaterialDesignRequiredOutlinedTextBox" TargetType="TextBox" BasedOn="{StaticResource MaterialDesignOutlinedTextBox}">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding Text.Length, RelativeSource={RelativeSource Self}}" Value="0">
                        <Setter Property="BorderBrush" Value="{DynamicResource ValidationErrorBorderBrush}"/>
                        <Setter Property="materialDesign:TextFieldAssist.UnderlineBrush" Value="{DynamicResource ValidationErrorBorderBrush}"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <!-- Spacing Constants (4px-based scale) -->
            <sys:Double x:Key="SpacingMicro">4</sys:Double>
            <sys:Double x:Key="SpacingSmall">8</sys:Double>
            <sys:Double x:Key="SpacingMedium">12</sys:Double>
            <sys:Double x:Key="SpacingNormal">16</sys:Double>
            <sys:Double x:Key="SpacingLarge">24</sys:Double>
            <sys:Double x:Key="SpacingXLarge">32</sys:Double>
            <Thickness x:Key="CardPadding">16</Thickness>
            <Thickness x:Key="SectionMargin">0,0,0,24</Thickness>
            <Thickness x:Key="PagePadding">32,24</Thickness>

            <!-- Standard Margin/Padding Thickness Resources -->
            <Thickness x:Key="MarginSmall">8</Thickness>
            <Thickness x:Key="MarginMedium">12</Thickness>
            <Thickness x:Key="MarginNormal">16</Thickness>
            <Thickness x:Key="MarginLarge">24</Thickness>
            <Thickness x:Key="MarginSmallRight">0,0,8,0</Thickness>
            <Thickness x:Key="MarginNormalRight">0,0,16,0</Thickness>
            <Thickness x:Key="MarginSmallBottom">0,0,0,8</Thickness>
            <Thickness x:Key="MarginNormalBottom">0,0,0,16</Thickness>
            <Thickness x:Key="MarginLargeBottom">0,0,0,24</Thickness>
            <Thickness x:Key="ContentPadding">24</Thickness>

            <!-- Animation Durations (set to 0 by App.xaml.cs when reduced motion enabled) -->
            <Duration x:Key="AnimationFast">0:0:0.15</Duration>
            <Duration x:Key="AnimationNormal">0:0:0.3</Duration>
            <Duration x:Key="AnimationSlow">0:0:0.5</Duration>
            <Duration x:Key="AnimationNone">0:0:0</Duration>

            <!-- Fade In Animation Style for Views (respects reduced motion via App.xaml.cs) -->
            <Style x:Key="FadeInStyle" TargetType="FrameworkElement">
                <Style.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 From="0" To="1" Duration="{StaticResource AnimationNormal}">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <ThicknessAnimation Storyboard.TargetProperty="Margin"
                                                    From="0,20,0,0" To="0" Duration="{StaticResource AnimationNormal}">
                                    <ThicknessAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </ThicknessAnimation.EasingFunction>
                                </ThicknessAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Style.Triggers>
            </Style>

            <!-- No Animation Style (for reduced motion or instant display) -->
            <Style x:Key="NoAnimationStyle" TargetType="FrameworkElement">
                <Setter Property="Opacity" Value="1"/>
            </Style>

            <!-- Card Hover Animation Style (uses AnimationFast resource) -->
            <Style x:Key="AnimatedCardStyle" TargetType="materialDesign:Card" BasedOn="{StaticResource {x:Type materialDesign:Card}}">
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Trigger.EnterActions>
                            <BeginStoryboard>
                                <Storyboard>
                                    <ThicknessAnimation Storyboard.TargetProperty="Margin"
                                                        To="-2,-2,-2,-2" Duration="{StaticResource AnimationFast}">
                                        <ThicknessAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut"/>
                                        </ThicknessAnimation.EasingFunction>
                                    </ThicknessAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </Trigger.EnterActions>
                        <Trigger.ExitActions>
                            <BeginStoryboard>
                                <Storyboard>
                                    <ThicknessAnimation Storyboard.TargetProperty="Margin"
                                                        To="0" Duration="{StaticResource AnimationFast}">
                                        <ThicknessAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut"/>
                                        </ThicknessAnimation.EasingFunction>
                                    </ThicknessAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </Trigger.ExitActions>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- Static Card Style (no animation, for reduced motion) -->
            <Style x:Key="StaticCardStyle" TargetType="materialDesign:Card" BasedOn="{StaticResource {x:Type materialDesign:Card}}"/>

            <!-- Success Pulse Animation Storyboard (duration controlled by AnimationFast resource) -->
            <Storyboard x:Key="SuccessPulseAnimation">
                <ColorAnimation Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                To="#4CAF50" Duration="{StaticResource AnimationFast}" AutoReverse="True"/>
            </Storyboard>

            <!-- Error Shake Animation Storyboard (subtle feedback, short duration) -->
            <Storyboard x:Key="ErrorShakeAnimation">
                <ThicknessAnimation Storyboard.TargetProperty="Margin"
                                    From="0" To="5,0,-5,0" Duration="0:0:0.05"
                                    AutoReverse="True" RepeatBehavior="3x"/>
            </Storyboard>

            <!-- No-Op Storyboard for reduced motion (instant state change) -->
            <Storyboard x:Key="NoAnimationStoryboard"/>

            <!-- Theme-Adaptive Accent Brush -->
            <!-- Updated dynamically: Secondary (lime) in dark theme, Primary (purple) in light theme -->
            <SolidColorBrush x:Key="ThemeAdaptiveAccentBrush" Color="#CDDC39"/>

            <!-- Theme-Adaptive Outlined Button Style -->
            <!-- Uses ThemeAdaptiveAccentBrush which changes with theme -->
            <Style x:Key="ThemeAdaptiveOutlinedButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignOutlinedButton}">
                <Setter Property="BorderBrush" Value="{DynamicResource ThemeAdaptiveAccentBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource ThemeAdaptiveAccentBrush}"/>
            </Style>

            <!-- Destructive Action Outlined Button Style -->
            <!-- For dangerous actions like delete, clear, remove -->
            <Style x:Key="DestructiveOutlinedButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignOutlinedButton}">
                <Setter Property="BorderBrush" Value="{DynamicResource MaterialDesignValidationErrorBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource MaterialDesignValidationErrorBrush}"/>
            </Style>

            <!-- Hover Transition Styles (smooth micro-interactions) -->

            <!-- Icon Button with Hover Scale Effect -->
            <Style x:Key="HoverScaleIconButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignIconButton}">
                <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                <Setter Property="RenderTransform">
                    <Setter.Value>
                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Trigger.EnterActions>
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                     To="1.1" Duration="{StaticResource AnimationFast}">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                     To="1.1" Duration="{StaticResource AnimationFast}">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </Trigger.EnterActions>
                        <Trigger.ExitActions>
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                     To="1" Duration="{StaticResource AnimationFast}">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                     To="1" Duration="{StaticResource AnimationFast}">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </Trigger.ExitActions>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- Outlined Button with Hover Background Fade -->
            <Style x:Key="HoverFadeOutlinedButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignOutlinedButton}">
                <Setter Property="Background" Value="Transparent"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Trigger.EnterActions>
                            <BeginStoryboard>
                                <Storyboard>
                                    <ColorAnimation Storyboard.TargetProperty="(Button.Background).(SolidColorBrush.Color)"
                                                    To="#1AFFFFFF" Duration="{StaticResource AnimationFast}">
                                        <ColorAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut"/>
                                        </ColorAnimation.EasingFunction>
                                    </ColorAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </Trigger.EnterActions>
                        <Trigger.ExitActions>
                            <BeginStoryboard>
                                <Storyboard>
                                    <ColorAnimation Storyboard.TargetProperty="(Button.Background).(SolidColorBrush.Color)"
                                                    To="Transparent" Duration="{StaticResource AnimationFast}">
                                        <ColorAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut"/>
                                        </ColorAnimation.EasingFunction>
                                    </ColorAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </Trigger.ExitActions>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- Interactive Badge/Chip with Hover Effect -->
            <Style x:Key="HoverBadgeStyle" TargetType="Border">
                <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                <Setter Property="RenderTransform">
                    <Setter.Value>
                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Trigger.EnterActions>
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                     To="1.05" Duration="{StaticResource AnimationFast}">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                     To="1.05" Duration="{StaticResource AnimationFast}">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </Trigger.EnterActions>
                        <Trigger.ExitActions>
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                     To="1" Duration="{StaticResource AnimationFast}">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                     To="1" Duration="{StaticResource AnimationFast}">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </Trigger.ExitActions>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- Touch-Optimized Styles (WCAG 2.5.5 - minimum 44x44px touch targets) -->

            <!-- Touch-friendly Icon Button (min 44x44 hit area) -->
            <Style x:Key="TouchFriendlyIconButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignIconButton}">
                <Setter Property="MinWidth" Value="44"/>
                <Setter Property="MinHeight" Value="44"/>
                <Setter Property="Padding" Value="10"/>
            </Style>

            <!-- Touch-friendly Button with larger hit area -->
            <Style x:Key="TouchFriendlyButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
                <Setter Property="MinHeight" Value="44"/>
                <Setter Property="Padding" Value="16,10"/>
            </Style>

            <!-- Touch-friendly Outlined Button -->
            <Style x:Key="TouchFriendlyOutlinedButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignOutlinedButton}">
                <Setter Property="MinHeight" Value="44"/>
                <Setter Property="Padding" Value="16,10"/>
            </Style>

            <!-- Touch-friendly Checkbox with larger hit area -->
            <Style x:Key="TouchFriendlyCheckBox" TargetType="CheckBox" BasedOn="{StaticResource MaterialDesignCheckBox}">
                <Setter Property="MinHeight" Value="44"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="Padding" Value="8,10"/>
            </Style>

            <!-- Touch-friendly List Item -->
            <Style x:Key="TouchFriendlyListBoxItem" TargetType="ListBoxItem" BasedOn="{StaticResource MaterialDesignNavigationPrimaryListBoxItem}">
                <Setter Property="MinHeight" Value="48"/>
                <Setter Property="Padding" Value="16,12"/>
                <Setter Property="FocusVisualStyle" Value="{StaticResource HighVisibilityFocusVisual}"/>
            </Style>

            <!-- Touch-friendly ComboBox -->
            <Style x:Key="TouchFriendlyComboBox" TargetType="ComboBox" BasedOn="{StaticResource MaterialDesignOutlinedComboBox}">
                <Setter Property="MinHeight" Value="44"/>
            </Style>

            <!-- Touch-friendly TextBox -->
            <Style x:Key="TouchFriendlyTextBox" TargetType="TextBox" BasedOn="{StaticResource MaterialDesignOutlinedTextBox}">
                <Setter Property="MinHeight" Value="44"/>
            </Style>

            <!-- Enhanced DataGrid Row Style with visible hover effect -->
            <Style x:Key="EnhancedDataGridRowStyle" TargetType="DataGridRow" BasedOn="{StaticResource MaterialDesignDataGridRow}">
                <Setter Property="Background" Value="Transparent"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{DynamicResource MaterialDesign.Brush.Primary.Light}"/>
                    </Trigger>
                    <Trigger Property="IsSelected" Value="True">
                        <Setter Property="Background" Value="{DynamicResource MaterialDesign.Brush.Primary}"/>
                        <Setter Property="Foreground" Value="{DynamicResource MaterialDesign.Brush.Primary.Foreground}"/>
                    </Trigger>
                    <MultiTrigger>
                        <MultiTrigger.Conditions>
                            <Condition Property="IsSelected" Value="True"/>
                            <Condition Property="IsMouseOver" Value="True"/>
                        </MultiTrigger.Conditions>
                        <Setter Property="Background" Value="{DynamicResource MaterialDesign.Brush.Primary.Dark}"/>
                    </MultiTrigger>
                </Style.Triggers>
            </Style>

            <!-- DataGrid Cell Style with improved focus visibility -->
            <Style x:Key="EnhancedDataGridCellStyle" TargetType="DataGridCell" BasedOn="{StaticResource MaterialDesignDataGridCell}">
                <Setter Property="FocusVisualStyle" Value="{StaticResource HighVisibilityFocusVisual}"/>
                <Style.Triggers>
                    <Trigger Property="IsKeyboardFocused" Value="True">
                        <Setter Property="BorderBrush" Value="{DynamicResource SecondaryHueMidBrush}"/>
                        <Setter Property="BorderThickness" Value="2"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- Micro-animation Styles for Enhanced UX Feedback -->

            <!-- Favorite Button Style with bounce animation -->
            <Style x:Key="AnimatedFavoriteButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignIconButton}">
                <Setter Property="Width" Value="44"/>
                <Setter Property="Height" Value="44"/>
                <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                <Setter Property="RenderTransform">
                    <Setter.Value>
                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <EventTrigger RoutedEvent="Button.Click">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)">
                                    <EasingDoubleKeyFrame KeyTime="0:0:0.0" Value="1"/>
                                    <EasingDoubleKeyFrame KeyTime="0:0:0.1" Value="1.3">
                                        <EasingDoubleKeyFrame.EasingFunction>
                                            <CubicEase EasingMode="EaseOut"/>
                                        </EasingDoubleKeyFrame.EasingFunction>
                                    </EasingDoubleKeyFrame>
                                    <EasingDoubleKeyFrame KeyTime="0:0:0.25" Value="1">
                                        <EasingDoubleKeyFrame.EasingFunction>
                                            <ElasticEase EasingMode="EaseOut" Oscillations="1" Springiness="5"/>
                                        </EasingDoubleKeyFrame.EasingFunction>
                                    </EasingDoubleKeyFrame>
                                </DoubleAnimationUsingKeyFrames>
                                <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)">
                                    <EasingDoubleKeyFrame KeyTime="0:0:0.0" Value="1"/>
                                    <EasingDoubleKeyFrame KeyTime="0:0:0.1" Value="1.3">
                                        <EasingDoubleKeyFrame.EasingFunction>
                                            <CubicEase EasingMode="EaseOut"/>
                                        </EasingDoubleKeyFrame.EasingFunction>
                                    </EasingDoubleKeyFrame>
                                    <EasingDoubleKeyFrame KeyTime="0:0:0.25" Value="1">
                                        <EasingDoubleKeyFrame.EasingFunction>
                                            <ElasticEase EasingMode="EaseOut" Oscillations="1" Springiness="5"/>
                                        </EasingDoubleKeyFrame.EasingFunction>
                                    </EasingDoubleKeyFrame>
                                </DoubleAnimationUsingKeyFrames>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Style.Triggers>
            </Style>

            <!-- Selection Checkbox Style with scale animation -->
            <Style x:Key="AnimatedSelectionCheckBox" TargetType="CheckBox" BasedOn="{StaticResource MaterialDesignCheckBox}">
                <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                <Setter Property="RenderTransform">
                    <Setter.Value>
                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <EventTrigger RoutedEvent="CheckBox.Checked">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)">
                                    <EasingDoubleKeyFrame KeyTime="0:0:0.0" Value="1"/>
                                    <EasingDoubleKeyFrame KeyTime="0:0:0.08" Value="1.15">
                                        <EasingDoubleKeyFrame.EasingFunction>
                                            <CubicEase EasingMode="EaseOut"/>
                                        </EasingDoubleKeyFrame.EasingFunction>
                                    </EasingDoubleKeyFrame>
                                    <EasingDoubleKeyFrame KeyTime="0:0:0.2" Value="1">
                                        <EasingDoubleKeyFrame.EasingFunction>
                                            <CubicEase EasingMode="EaseOut"/>
                                        </EasingDoubleKeyFrame.EasingFunction>
                                    </EasingDoubleKeyFrame>
                                </DoubleAnimationUsingKeyFrames>
                                <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)">
                                    <EasingDoubleKeyFrame KeyTime="0:0:0.0" Value="1"/>
                                    <EasingDoubleKeyFrame KeyTime="0:0:0.08" Value="1.15">
                                        <EasingDoubleKeyFrame.EasingFunction>
                                            <CubicEase EasingMode="EaseOut"/>
                                        </EasingDoubleKeyFrame.EasingFunction>
                                    </EasingDoubleKeyFrame>
                                    <EasingDoubleKeyFrame KeyTime="0:0:0.2" Value="1">
                                        <EasingDoubleKeyFrame.EasingFunction>
                                            <CubicEase EasingMode="EaseOut"/>
                                        </EasingDoubleKeyFrame.EasingFunction>
                                    </EasingDoubleKeyFrame>
                                </DoubleAnimationUsingKeyFrames>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Style.Triggers>
            </Style>

