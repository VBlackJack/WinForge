<Application x:Class="Win11Forge.GUI.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:converters="clr-namespace:Win11Forge.GUI.Resources"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             ShutdownMode="OnMainWindowClose">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemesDictionary Theme="Dark" />
                <ui:ControlsDictionary />
                <ResourceDictionary Source="Resources/FluentThemeBridge.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Brush resources defined in FluentThemeBridge.xaml (merged above).
                 App.xaml.cs swaps theme-adaptive brushes at runtime via ApplyThemeResources(). -->

            <!-- Light Theme Contrast Enhancement Colors (unique to App.xaml) -->
            <SolidColorBrush x:Key="LightThemeTextPrimary" Color="#212121"/>
            <SolidColorBrush x:Key="LightThemeTextSecondary" Color="#424242"/>
            <SolidColorBrush x:Key="LightThemeTextHint" Color="#757575"/>
            <SolidColorBrush x:Key="LightThemeBorder" Color="#BDBDBD"/>
            <SolidColorBrush x:Key="LightThemeCardBackground" Color="#FFFFFF"/>
            <SolidColorBrush x:Key="LightThemeHoverBackground" Color="#0A000000"/>

            <!-- Focus Visual Style (WCAG compliant high-visibility focus indicator) -->
            <Style x:Key="HighVisibilityFocusVisual">
                <Setter Property="Control.Template">
                    <Setter.Value>
                        <ControlTemplate>
                            <Border BorderBrush="{DynamicResource FocusIndicatorBrush}"
                                    BorderThickness="2"
                                    CornerRadius="4"
                                    Margin="-2"/>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Implicit focus visuals for vanilla WPF focusable controls.
                 WPF resolves implicit styles by concrete DefaultStyleKey, so each
                 focusable TargetType needs its own style. -->
            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                <Setter Property="FocusVisualStyle" Value="{StaticResource HighVisibilityFocusVisual}"/>
            </Style>

            <Style TargetType="CheckBox" BasedOn="{StaticResource {x:Type CheckBox}}">
                <Setter Property="FocusVisualStyle" Value="{StaticResource HighVisibilityFocusVisual}"/>
            </Style>

            <Style TargetType="RadioButton" BasedOn="{StaticResource {x:Type RadioButton}}">
                <Setter Property="FocusVisualStyle" Value="{StaticResource HighVisibilityFocusVisual}"/>
            </Style>

            <Style TargetType="ToggleButton" BasedOn="{StaticResource {x:Type ToggleButton}}">
                <Setter Property="FocusVisualStyle" Value="{StaticResource HighVisibilityFocusVisual}"/>
            </Style>

            <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                <Setter Property="FocusVisualStyle" Value="{StaticResource HighVisibilityFocusVisual}"/>
            </Style>

            <!-- Forked WPF-UI 4.3 DefaultUiButtonStyle template, verbatim except for the
                 IsEnabled=False trigger. Upstream forces ContentBorder.Background to
                 ButtonBackgroundDisabled via DynamicResource that doesn't honor any user-scope
                 override (App.Resources direct, UserControl/Button/StackPanel.Resources — all
                 tested fail to propagate). Our IsEnabled=False trigger only lowers
                 ContentBorder.Opacity, so the theme-aware Background TemplateBinding stays
                 visible (Transparent for Transparent appearance, accent for Primary, etc.) and
                 the button greys out cleanly without white Fluent blocks.
                 The full template preserves Icon DP support (ControlIcon ContentPresenter),
                 RecognizesAccessKey, PressedForeground, the inset border for fidelity, and all
                 upstream Appearance triggers (Info / Success / Caution / Dark / Light) for
                 forward compatibility — our Dracula Style.Triggers below override Primary /
                 Secondary / Danger / Transparent, which are the appearances actually used in
                 this app.
                 Source: https://github.com/lepoco/wpfui/blob/4.3.0/src/Wpf.Ui/Controls/Button/Button.xaml -->
            <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                <Setter Property="FocusVisualStyle" Value="{StaticResource HighVisibilityFocusVisual}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ui:Button">
                            <Border
                                x:Name="ContentBorder"
                                Width="{TemplateBinding Width}"
                                Height="{TemplateBinding Height}"
                                MinWidth="{TemplateBinding MinWidth}"
                                MinHeight="{TemplateBinding MinHeight}"
                                HorizontalAlignment="{TemplateBinding HorizontalAlignment}"
                                VerticalAlignment="{TemplateBinding VerticalAlignment}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="0"
                                CornerRadius="{TemplateBinding CornerRadius}">
                                <Border
                                    x:Name="InsetBorder"
                                    Padding="{TemplateBinding Padding}"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch"
                                    BorderBrush="{Binding ElementName=ContentBorder, Path=BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="{TemplateBinding CornerRadius}">
                                    <Grid HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <ContentPresenter
                                            x:Name="ControlIcon"
                                            Grid.Column="0"
                                            Margin="{StaticResource ButtonIconMargin}"
                                            VerticalAlignment="Center"
                                            Content="{TemplateBinding Icon}"
                                            Focusable="False"
                                            TextElement.FontSize="{TemplateBinding FontSize}"
                                            TextElement.Foreground="{TemplateBinding Foreground}"/>
                                        <ContentPresenter
                                            x:Name="ContentPresenter"
                                            Grid.Column="1"
                                            VerticalAlignment="Center"
                                            Content="{TemplateBinding Content}"
                                            ContentTemplate="{TemplateBinding ContentTemplate}"
                                            RecognizesAccessKey="True"
                                            TextElement.Foreground="{TemplateBinding Foreground}"/>
                                    </Grid>
                                </Border>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="Appearance" Value="Transparent">
                                    <Setter Property="Background" Value="Transparent"/>
                                </Trigger>
                                <Trigger Property="Appearance" Value="Primary">
                                    <Setter Property="Background" Value="{DynamicResource AccentButtonBackground}"/>
                                    <Setter Property="MouseOverBackground" Value="{DynamicResource AccentButtonBackgroundPointerOver}"/>
                                    <Setter Property="PressedBackground" Value="{DynamicResource AccentButtonBackgroundPressed}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource AccentButtonForeground}"/>
                                    <Setter Property="PressedForeground" Value="{DynamicResource AccentButtonForegroundPointerOver}"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentControlElevationBorderBrush}"/>
                                    <Setter Property="MouseOverBorderBrush" Value="{DynamicResource AccentControlElevationBorderBrush}"/>
                                    <Setter Property="PressedBorderBrush" Value="{DynamicResource ControlFillColorTransparentBrush}"/>
                                </Trigger>
                                <Trigger Property="Appearance" Value="Secondary">
                                    <Setter TargetName="InsetBorder" Property="BorderThickness" Value="0"/>
                                    <Setter TargetName="ContentBorder" Property="BorderThickness" Value="{Binding BorderThickness, RelativeSource={RelativeSource TemplatedParent}}"/>
                                </Trigger>
                                <Trigger Property="Appearance" Value="Dark">
                                    <Setter Property="Background">
                                        <Setter.Value>
                                            <SolidColorBrush Color="{DynamicResource ControlStrongFillColorDark}"/>
                                        </Setter.Value>
                                    </Setter>
                                    <Setter Property="MouseOverBackground">
                                        <Setter.Value>
                                            <SolidColorBrush Color="#62000000"/>
                                        </Setter.Value>
                                    </Setter>
                                    <Setter Property="PressedBackground">
                                        <Setter.Value>
                                            <SolidColorBrush Color="#52000000"/>
                                        </Setter.Value>
                                    </Setter>
                                    <Setter Property="PressedBorderBrush" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="{DynamicResource TextFillColorLightPrimaryBrush}"/>
                                    <Setter Property="PressedForeground" Value="{DynamicResource TextFillColorLightSecondaryBrush}"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentControlElevationBorderBrush}"/>
                                    <Setter Property="MouseOverBorderBrush" Value="{DynamicResource AccentControlElevationBorderBrush}"/>
                                </Trigger>
                                <Trigger Property="Appearance" Value="Light">
                                    <Setter Property="Background">
                                        <Setter.Value>
                                            <SolidColorBrush Color="{DynamicResource ControlStrongFillColorLight}"/>
                                        </Setter.Value>
                                    </Setter>
                                    <Setter Property="MouseOverBackground">
                                        <Setter.Value>
                                            <SolidColorBrush Color="#D3FFFFFF"/>
                                        </Setter.Value>
                                    </Setter>
                                    <Setter Property="PressedBackground">
                                        <Setter.Value>
                                            <SolidColorBrush Color="#F3FFFFFF"/>
                                        </Setter.Value>
                                    </Setter>
                                    <Setter Property="Foreground" Value="{DynamicResource TextFillColorDarkPrimaryBrush}"/>
                                    <Setter Property="PressedForeground" Value="{DynamicResource TextFillColorDarkSecondaryBrush}"/>
                                </Trigger>
                                <Trigger Property="Appearance" Value="Info">
                                    <Setter Property="Background">
                                        <Setter.Value>
                                            <SolidColorBrush Color="{DynamicResource PaletteLightBlueColor}"/>
                                        </Setter.Value>
                                    </Setter>
                                    <Setter Property="MouseOverBackground">
                                        <Setter.Value>
                                            <SolidColorBrush Opacity="0.9" Color="{DynamicResource PaletteLightBlueColor}"/>
                                        </Setter.Value>
                                    </Setter>
                                    <Setter Property="PressedBackground">
                                        <Setter.Value>
                                            <SolidColorBrush Opacity="0.7" Color="{DynamicResource PaletteLightBlueColor}"/>
                                        </Setter.Value>
                                    </Setter>
                                    <Setter Property="Foreground" Value="{DynamicResource TextFillColorLightPrimaryBrush}"/>
                                    <Setter Property="PressedBorderBrush" Value="Transparent"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentControlElevationBorderBrush}"/>
                                    <Setter Property="MouseOverBorderBrush" Value="{DynamicResource AccentControlElevationBorderBrush}"/>
                                </Trigger>
                                <Trigger Property="Appearance" Value="Danger">
                                    <Setter Property="Background">
                                        <Setter.Value>
                                            <SolidColorBrush Color="{DynamicResource PaletteRedColor}"/>
                                        </Setter.Value>
                                    </Setter>
                                    <Setter Property="MouseOverBackground">
                                        <Setter.Value>
                                            <SolidColorBrush Opacity="0.9" Color="{DynamicResource PaletteRedColor}"/>
                                        </Setter.Value>
                                    </Setter>
                                    <Setter Property="PressedBackground">
                                        <Setter.Value>
                                            <SolidColorBrush Opacity="0.7" Color="{DynamicResource PaletteRedColor}"/>
                                        </Setter.Value>
                                    </Setter>
                                    <Setter Property="PressedBorderBrush" Value="Transparent"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentControlElevationBorderBrush}"/>
                                    <Setter Property="MouseOverBorderBrush" Value="{DynamicResource AccentControlElevationBorderBrush}"/>
                                </Trigger>
                                <Trigger Property="Appearance" Value="Success">
                                    <Setter Property="Background">
                                        <Setter.Value>
                                            <SolidColorBrush Color="{DynamicResource PaletteGreenColor}"/>
                                        </Setter.Value>
                                    </Setter>
                                    <Setter Property="MouseOverBackground">
                                        <Setter.Value>
                                            <SolidColorBrush Opacity="0.9" Color="{DynamicResource PaletteGreenColor}"/>
                                        </Setter.Value>
                                    </Setter>
                                    <Setter Property="PressedBackground">
                                        <Setter.Value>
                                            <SolidColorBrush Opacity="0.7" Color="{DynamicResource PaletteGreenColor}"/>
                                        </Setter.Value>
                                    </Setter>
                                    <Setter Property="PressedBorderBrush" Value="Transparent"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentControlElevationBorderBrush}"/>
                                    <Setter Property="MouseOverBorderBrush" Value="{DynamicResource AccentControlElevationBorderBrush}"/>
                                </Trigger>
                                <Trigger Property="Appearance" Value="Caution">
                                    <Setter Property="Background">
                                        <Setter.Value>
                                            <SolidColorBrush Color="{DynamicResource PaletteOrangeColor}"/>
                                        </Setter.Value>
                                    </Setter>
                                    <Setter Property="MouseOverBackground">
                                        <Setter.Value>
                                            <SolidColorBrush Opacity="0.9" Color="{DynamicResource PaletteOrangeColor}"/>
                                        </Setter.Value>
                                    </Setter>
                                    <Setter Property="PressedBackground">
                                        <Setter.Value>
                                            <SolidColorBrush Opacity="0.7" Color="{DynamicResource PaletteOrangeColor}"/>
                                        </Setter.Value>
                                    </Setter>
                                    <Setter Property="PressedBorderBrush" Value="Transparent"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentControlElevationBorderBrush}"/>
                                    <Setter Property="MouseOverBorderBrush" Value="{DynamicResource AccentControlElevationBorderBrush}"/>
                                </Trigger>
                                <MultiTrigger>
                                    <MultiTrigger.Conditions>
                                        <Condition Property="IsMouseOver" Value="True"/>
                                        <Condition Property="IsPressed" Value="False"/>
                                    </MultiTrigger.Conditions>
                                    <Setter TargetName="ContentBorder" Property="Background" Value="{Binding MouseOverBackground, RelativeSource={RelativeSource TemplatedParent}}"/>
                                    <Setter TargetName="ContentBorder" Property="BorderBrush" Value="{Binding MouseOverBorderBrush, RelativeSource={RelativeSource TemplatedParent}}"/>
                                </MultiTrigger>
                                <MultiTrigger>
                                    <MultiTrigger.Conditions>
                                        <Condition Property="IsMouseOver" Value="True"/>
                                        <Condition Property="IsPressed" Value="True"/>
                                    </MultiTrigger.Conditions>
                                    <Setter TargetName="ContentBorder" Property="Background" Value="{Binding PressedBackground, RelativeSource={RelativeSource TemplatedParent}}"/>
                                    <Setter TargetName="ContentBorder" Property="BorderBrush" Value="{Binding PressedBorderBrush, RelativeSource={RelativeSource TemplatedParent}}"/>
                                    <Setter Property="Foreground" Value="{Binding PressedForeground, RelativeSource={RelativeSource TemplatedParent}}"/>
                                </MultiTrigger>
                                <Trigger Property="Content" Value="{x:Null}">
                                    <Setter TargetName="ControlIcon" Property="Margin" Value="0"/>
                                </Trigger>
                                <Trigger Property="Content" Value="">
                                    <Setter TargetName="ControlIcon" Property="Margin" Value="0"/>
                                </Trigger>
                                <Trigger Property="Icon" Value="{x:Null}">
                                    <Setter TargetName="ControlIcon" Property="Margin" Value="0"/>
                                    <Setter TargetName="ControlIcon" Property="Visibility" Value="Collapsed"/>
                                </Trigger>
                                <!-- ONLY DEVIATION FROM UPSTREAM: target ContentBorder.Opacity per Codex review,
                                     don't repaint ContentBorder.Background to a brush that fails our user-scope override. -->
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="ContentBorder" Property="Opacity" Value="0.45"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="Appearance" Value="Primary">
                        <Setter Property="Background" Value="{DynamicResource ThemeAdaptiveAccentBrush}"/>
                        <Setter Property="BorderBrush" Value="{DynamicResource ThemeAdaptiveAccentBrush}"/>
                        <Setter Property="Foreground" Value="{DynamicResource BadgeTextBrush}"/>
                        <Setter Property="MouseOverBackground" Value="{DynamicResource AccentHoverBrush}"/>
                        <Setter Property="MouseOverBorderBrush" Value="{DynamicResource AccentHoverBrush}"/>
                        <Setter Property="PressedBackground" Value="{DynamicResource AccentPressedBrush}"/>
                        <Setter Property="PressedBorderBrush" Value="{DynamicResource AccentPressedBrush}"/>
                    </Trigger>
                    <Trigger Property="Appearance" Value="Secondary">
                        <Setter Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}"/>
                        <Setter Property="BorderBrush" Value="{DynamicResource ThemeAdaptiveAccentBrush}"/>
                        <Setter Property="Foreground" Value="{DynamicResource ThemeAdaptiveAccentBrush}"/>
                        <!-- Hover bg uses SurfaceBrush (very dark) to maintain WCAG AA contrast (~5.6:1)
                             with ThemeAdaptiveAccentBrush foreground. HighlightBrush (#4A4E66) is too
                             close to the purple text in luminance and fails contrast (~2.25:1). -->
                        <Setter Property="MouseOverBackground" Value="{DynamicResource SurfaceBrush}"/>
                        <Setter Property="MouseOverBorderBrush" Value="{DynamicResource AccentHoverBrush}"/>
                        <Setter Property="PressedBackground" Value="{DynamicResource SurfaceBrush}"/>
                        <Setter Property="PressedBorderBrush" Value="{DynamicResource AccentPressedBrush}"/>
                    </Trigger>
                    <Trigger Property="Appearance" Value="Danger">
                        <Setter Property="Background" Value="{DynamicResource ErrorBrush}"/>
                        <Setter Property="BorderBrush" Value="{DynamicResource ErrorBrush}"/>
                        <Setter Property="Foreground" Value="{DynamicResource BadgeTextBrush}"/>
                        <Setter Property="MouseOverBackground" Value="{DynamicResource ErrorBrush}"/>
                        <Setter Property="MouseOverBorderBrush" Value="{DynamicResource ErrorBrush}"/>
                        <Setter Property="PressedBackground" Value="{DynamicResource ErrorBrush}"/>
                        <Setter Property="PressedBorderBrush" Value="{DynamicResource ErrorBrush}"/>
                    </Trigger>
                    <Trigger Property="Appearance" Value="Transparent">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderBrush" Value="Transparent"/>
                        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
                        <!-- Hover bg uses SurfaceBrush (very dark) for ~6:1 contrast with light text,
                             clears the WCAG AA threshold. HighlightBrush was too close to text luminance. -->
                        <Setter Property="MouseOverBackground" Value="{DynamicResource SurfaceBrush}"/>
                        <Setter Property="MouseOverBorderBrush" Value="Transparent"/>
                        <Setter Property="PressedBackground" Value="{DynamicResource SurfaceBrush}"/>
                        <Setter Property="PressedBorderBrush" Value="Transparent"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- Keyboard-focused Button Style with enhanced visibility -->
            <Style x:Key="KeyboardFocusableButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                <Setter Property="FocusVisualStyle" Value="{StaticResource HighVisibilityFocusVisual}"/>
                <Setter Property="AutomationProperties.IsRequiredForForm" Value="False"/>
            </Style>

            <!-- Keyboard-focused Icon Button Style -->
            <Style x:Key="KeyboardFocusableIconButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                <Setter Property="FocusVisualStyle" Value="{StaticResource HighVisibilityFocusVisual}"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Style.Triggers>
                    <Trigger Property="IsKeyboardFocused" Value="True">
                        <Setter Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- Keyboard-focused Card Style with outline on focus -->
            <Style x:Key="KeyboardFocusableCard" TargetType="Border">
                <Setter Property="Focusable" Value="True"/>
                <Setter Property="FocusVisualStyle" Value="{StaticResource HighVisibilityFocusVisual}"/>
            </Style>

            <!-- Validation TextBox Style (shows error when text is empty) -->
            <Style x:Key="RequiredTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                <Setter Property="FocusVisualStyle" Value="{StaticResource HighVisibilityFocusVisual}"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding Text.Length, RelativeSource={RelativeSource Self}}" Value="0">
                        <Setter Property="BorderBrush" Value="{DynamicResource ValidationErrorBorderBrush}"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <!-- Spacing Constants (4px-based scale) -->
            <sys:Double x:Key="SpacingMicro">4</sys:Double>
            <sys:Double x:Key="SpacingSmall">8</sys:Double>
            <sys:Double x:Key="SpacingMedium">12</sys:Double>
            <sys:Double x:Key="SpacingNormal">16</sys:Double>
            <sys:Double x:Key="SpacingLarge">24</sys:Double>
            <sys:Double x:Key="SpacingXLarge">32</sys:Double>
            <Thickness x:Key="CardPadding">16</Thickness>
            <Thickness x:Key="SectionMargin">0,0,0,24</Thickness>
            <Thickness x:Key="PagePadding">32,24</Thickness>
            <CornerRadius x:Key="CardCornerRadius">8</CornerRadius>

            <!-- Standard Margin/Padding Thickness Resources -->
            <Thickness x:Key="MarginSmall">8</Thickness>
            <Thickness x:Key="MarginMedium">12</Thickness>
            <Thickness x:Key="MarginNormal">16</Thickness>
            <Thickness x:Key="MarginLarge">24</Thickness>
            <Thickness x:Key="MarginSmallRight">0,0,8,0</Thickness>
            <Thickness x:Key="MarginNormalRight">0,0,16,0</Thickness>
            <Thickness x:Key="MarginSmallBottom">0,0,0,8</Thickness>
            <Thickness x:Key="MarginNormalBottom">0,0,0,16</Thickness>
            <Thickness x:Key="MarginLargeBottom">0,0,0,24</Thickness>
            <Thickness x:Key="ContentPadding">24</Thickness>

            <!-- Button design tokens (single source of truth for button metrics) -->
            <CornerRadius x:Key="ButtonCornerRadius">4</CornerRadius>
            <CornerRadius x:Key="ButtonCornerRadiusLarge">8</CornerRadius>

            <sys:Double x:Key="ButtonMinHeightCompact">32</sys:Double>
            <sys:Double x:Key="ButtonMinHeightStandard">40</sys:Double>
            <sys:Double x:Key="ButtonMinHeightTouch">44</sys:Double>
            <sys:Double x:Key="ButtonMinHeightHero">56</sys:Double>

            <Thickness x:Key="ButtonPaddingCompact">12,6</Thickness>
            <Thickness x:Key="ButtonPaddingStandard">16,10</Thickness>
            <Thickness x:Key="ButtonPaddingLarge">24,14</Thickness>
            <Thickness x:Key="ButtonPaddingHero">32,0</Thickness>
            <Thickness x:Key="ButtonPaddingIcon">10</Thickness>

            <sys:Double x:Key="ButtonFontSizeStandard">14</sys:Double>
            <sys:Double x:Key="ButtonFontSizeHero">16</sys:Double>
            <FontWeight x:Key="ButtonFontWeightStandard">SemiBold</FontWeight>
            <sys:Double x:Key="ButtonIconSizeStandard">18</sys:Double>
            <sys:Double x:Key="ButtonIconSizeLarge">20</sys:Double>
            <Thickness x:Key="ButtonIconMarginStandard">0,0,8,0</Thickness>
            <Thickness x:Key="ButtonIconMarginCompact">0,0,6,0</Thickness>

            <!-- Shared page and card surfaces -->
            <Style x:Key="PageRootGridStyle" TargetType="Grid">
                <Setter Property="Margin" Value="{StaticResource PagePadding}"/>
            </Style>

            <Style x:Key="CardBorderStyle" TargetType="Border">
                <Setter Property="Padding" Value="{StaticResource CardPadding}"/>
                <Setter Property="CornerRadius" Value="{StaticResource CardCornerRadius}"/>
                <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorDefaultBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource ControlElevationBorderBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
            </Style>

            <Style x:Key="SectionCardStyle" TargetType="Border" BasedOn="{StaticResource CardBorderStyle}">
                <Setter Property="Margin" Value="{StaticResource MarginNormalBottom}"/>
            </Style>

            <!-- Page header typography tokens -->
            <Style x:Key="PageTitleTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="28"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
            </Style>

            <Style x:Key="PageSubtitleTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}"/>
                <Setter Property="Margin" Value="0,8,0,0"/>
            </Style>

            <!-- Reinforced TabItem indicator for accessibility and visual hierarchy. -->
            <Style x:Key="ReinforcedTabItemStyle" TargetType="TabItem" BasedOn="{StaticResource {x:Type TabItem}}">
                <Setter Property="Padding" Value="16,8"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
                <Setter Property="BorderThickness" Value="0,0,0,3"/>
                <Setter Property="BorderBrush" Value="Transparent"/>
                <Setter Property="FocusVisualStyle" Value="{StaticResource HighVisibilityFocusVisual}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type TabItem}">
                            <Border x:Name="TabRoot"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    Padding="{TemplateBinding Padding}"
                                    SnapsToDevicePixels="True">
                                <ContentPresenter ContentSource="Header"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  RecognizesAccessKey="True"
                                                  TextElement.Foreground="{TemplateBinding Foreground}"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Foreground" Value="{DynamicResource TextFillColorDisabledBrush}"/>
                                    <Setter TargetName="TabRoot" Property="Opacity" Value="0.55"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{DynamicResource SubtleFillColorTertiaryBrush}"/>
                    </Trigger>
                    <Trigger Property="IsKeyboardFocused" Value="True">
                        <Setter Property="Background" Value="{DynamicResource SubtleFillColorTertiaryBrush}"/>
                        <Setter Property="BorderBrush" Value="{DynamicResource FocusIndicatorBrush}"/>
                    </Trigger>
                    <Trigger Property="IsSelected" Value="True">
                        <Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColorPrimaryBrush}"/>
                        <Setter Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}"/>
                        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style TargetType="{x:Type TabItem}" BasedOn="{StaticResource ReinforcedTabItemStyle}"/>

            <!-- Animation Durations (set to 0 by App.xaml.cs when reduced motion enabled) -->
            <Duration x:Key="AnimationFast">0:0:0.15</Duration>
            <Duration x:Key="AnimationNormal">0:0:0.3</Duration>
            <Duration x:Key="AnimationSlow">0:0:0.5</Duration>
            <Duration x:Key="AnimationMicro">0:0:0.05</Duration>
            <Duration x:Key="AnimationNone">0:0:0</Duration>

            <!-- Kept as a compatibility style key; global XAML motion is disabled for reduced-motion safety. -->
            <Style x:Key="FadeInStyle" TargetType="FrameworkElement"/>

            <!-- No Animation Style (for reduced motion or instant display) -->
            <Style x:Key="NoAnimationStyle" TargetType="FrameworkElement">
                <Setter Property="Opacity" Value="1"/>
            </Style>

            <Style x:Key="AnimatedCardStyle" TargetType="Border"/>

            <!-- Static Card Style (no animation, for reduced motion) -->
            <Style x:Key="StaticCardStyle" TargetType="Border"/>

            <!--
                ThemeAdaptiveOutlinedButton / DestructiveOutlinedButton / HoverFadeOutlinedButton
                have been relocated below the canonical taxonomy (BasedOn requires lexical order).
            -->

            <!--
                HoverScaleIconButton targets vanilla Button (legacy); IconButton targets ui:Button (canonical).
                Kept as a separate style with the original metrics so it doesn't break vanilla-Button usages.
                DEPRECATED: prefer IconButton (ui:Button) for new code.
            -->
            <Style x:Key="HoverScaleIconButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                <Setter Property="FocusVisualStyle" Value="{StaticResource HighVisibilityFocusVisual}"/>
                <Setter Property="MinWidth" Value="{StaticResource ButtonMinHeightTouch}"/>
                <Setter Property="MinHeight" Value="{StaticResource ButtonMinHeightTouch}"/>
                <Setter Property="Padding" Value="{StaticResource ButtonPaddingIcon}"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                <Setter Property="RenderTransform">
                    <Setter.Value>
                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Interactive Badge/Chip with Hover Effect -->
            <Style x:Key="HoverBadgeStyle" TargetType="Border">
                <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                <Setter Property="RenderTransform">
                    <Setter.Value>
                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Shared source badge taxonomy -->
            <Style x:Key="SourceBadgeStyle" TargetType="Border">
                <Setter Property="CornerRadius" Value="4"/>
                <Setter Property="Padding" Value="6,2"/>
                <Setter Property="Margin" Value="0,0,4,0"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>

            <Style x:Key="SourceBadgeTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>

            <Style x:Key="SourceWingetBadgeStyle" TargetType="Border" BasedOn="{StaticResource SourceBadgeStyle}">
                <Setter Property="Background" Value="{DynamicResource SourceWingetBadgeBackgroundBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource SourceWingetBadgeBorderBrush}"/>
                <Setter Property="TextElement.Foreground" Value="{DynamicResource SourceWingetBadgeForegroundBrush}"/>
            </Style>

            <Style x:Key="SourceChocolateyBadgeStyle" TargetType="Border" BasedOn="{StaticResource SourceBadgeStyle}">
                <Setter Property="Background" Value="{DynamicResource SourceChocolateyBadgeBackgroundBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource SourceChocolateyBadgeBorderBrush}"/>
                <Setter Property="TextElement.Foreground" Value="{DynamicResource SourceChocolateyBadgeForegroundBrush}"/>
            </Style>

            <Style x:Key="SourceStoreBadgeStyle" TargetType="Border" BasedOn="{StaticResource SourceBadgeStyle}">
                <Setter Property="Background" Value="{DynamicResource SourceStoreBadgeBackgroundBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource SourceStoreBadgeBorderBrush}"/>
                <Setter Property="TextElement.Foreground" Value="{DynamicResource SourceStoreBadgeForegroundBrush}"/>
            </Style>

            <Style x:Key="SourceDirectBadgeStyle" TargetType="Border" BasedOn="{StaticResource SourceBadgeStyle}">
                <Setter Property="Background" Value="{DynamicResource SourceDirectBadgeBackgroundBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource SourceDirectBadgeBorderBrush}"/>
                <Setter Property="TextElement.Foreground" Value="{DynamicResource SourceDirectBadgeForegroundBrush}"/>
            </Style>

            <!-- Touch-Optimized Styles (WCAG 2.5.5 - minimum 44x44px touch targets) -->

            <!--
                Touch-friendly button variants (DEPRECATED).
                Tokenized to share metrics with the canonical taxonomy below.
                For new code use IconButton / PrimaryButton / OutlinedButton directly.
            -->
            <Style x:Key="TouchFriendlyIconButton" TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                <Setter Property="FocusVisualStyle" Value="{StaticResource HighVisibilityFocusVisual}"/>
                <Setter Property="MinWidth" Value="{StaticResource ButtonMinHeightTouch}"/>
                <Setter Property="MinHeight" Value="{StaticResource ButtonMinHeightTouch}"/>
                <Setter Property="Padding" Value="{StaticResource ButtonPaddingIcon}"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
            </Style>

            <Style x:Key="TouchFriendlyButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                <Setter Property="FocusVisualStyle" Value="{StaticResource HighVisibilityFocusVisual}"/>
                <Setter Property="MinHeight" Value="{StaticResource ButtonMinHeightTouch}"/>
                <Setter Property="Padding" Value="{StaticResource ButtonPaddingStandard}"/>
            </Style>

            <Style x:Key="TouchFriendlyOutlinedButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                <Setter Property="FocusVisualStyle" Value="{StaticResource HighVisibilityFocusVisual}"/>
                <Setter Property="MinHeight" Value="{StaticResource ButtonMinHeightTouch}"/>
                <Setter Property="Padding" Value="{StaticResource ButtonPaddingStandard}"/>
                <Setter Property="Background" Value="Transparent"/>
            </Style>

            <!-- Touch-friendly Checkbox with larger hit area -->
            <Style x:Key="TouchFriendlyCheckBox" TargetType="CheckBox" BasedOn="{StaticResource {x:Type CheckBox}}">
                <Setter Property="FocusVisualStyle" Value="{StaticResource HighVisibilityFocusVisual}"/>
                <Setter Property="MinHeight" Value="{StaticResource ButtonMinHeightTouch}"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="Padding" Value="8,10"/>
            </Style>

            <!-- Touch-friendly List Item -->
            <Style x:Key="TouchFriendlyListBoxItem" TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                <Setter Property="MinHeight" Value="48"/>
                <Setter Property="Padding" Value="16,12"/>
                <Setter Property="FocusVisualStyle" Value="{StaticResource HighVisibilityFocusVisual}"/>
            </Style>

            <!-- ====================================================== -->
            <!-- Canonical Button Taxonomy                              -->
            <!-- All button visual metrics resolve through these styles -->
            <!-- and the ButtonXxx tokens above. No view should set     -->
            <!-- Background, Padding, Height, FontSize, FontWeight      -->
            <!-- inline on a button.                                    -->
            <!-- ====================================================== -->

            <!-- Hero Primary Button: single page-level CTA (e.g. Start Deployment) -->
            <Style x:Key="HeroPrimaryButton" TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                <Setter Property="FocusVisualStyle" Value="{StaticResource HighVisibilityFocusVisual}"/>
                <Setter Property="Appearance" Value="Primary"/>
                <Setter Property="MinHeight" Value="{StaticResource ButtonMinHeightHero}"/>
                <Setter Property="Padding" Value="{StaticResource ButtonPaddingHero}"/>
                <Setter Property="FontSize" Value="{StaticResource ButtonFontSizeHero}"/>
                <Setter Property="FontWeight" Value="{StaticResource ButtonFontWeightStandard}"/>
                <Setter Property="CornerRadius" Value="{StaticResource ButtonCornerRadiusLarge}"/>
            </Style>

            <!-- Primary Button: standard primary action (inherits WPF-UI default MinHeight ~32px) -->
            <Style x:Key="PrimaryButton" TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                <Setter Property="FocusVisualStyle" Value="{StaticResource HighVisibilityFocusVisual}"/>
                <Setter Property="Appearance" Value="Primary"/>
                <Setter Property="MinHeight" Value="{StaticResource ButtonMinHeightStandard}"/>
                <Setter Property="Background" Value="{DynamicResource ThemeAdaptiveAccentBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource ThemeAdaptiveAccentBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource BadgeTextBrush}"/>
                <Setter Property="Padding" Value="{StaticResource ButtonPaddingStandard}"/>
                <Setter Property="FontSize" Value="{StaticResource ButtonFontSizeStandard}"/>
                <Setter Property="CornerRadius" Value="{StaticResource ButtonCornerRadius}"/>
            </Style>

            <!-- Secondary Button: standard secondary action -->
            <Style x:Key="SecondaryButton" TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                <Setter Property="FocusVisualStyle" Value="{StaticResource HighVisibilityFocusVisual}"/>
                <Setter Property="Appearance" Value="Secondary"/>
                <Setter Property="MinHeight" Value="{StaticResource ButtonMinHeightStandard}"/>
                <Setter Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource ThemeAdaptiveAccentBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource ThemeAdaptiveAccentBrush}"/>
                <Setter Property="Padding" Value="{StaticResource ButtonPaddingStandard}"/>
                <Setter Property="FontSize" Value="{StaticResource ButtonFontSizeStandard}"/>
                <Setter Property="CornerRadius" Value="{StaticResource ButtonCornerRadius}"/>
            </Style>

            <!-- Compact action buttons for dense toolbars and selection helpers. -->
            <Style x:Key="CompactPrimaryButton" TargetType="ui:Button" BasedOn="{StaticResource PrimaryButton}">
                <Setter Property="MinHeight" Value="{StaticResource ButtonMinHeightCompact}"/>
                <Setter Property="Padding" Value="{StaticResource ButtonPaddingCompact}"/>
            </Style>

            <Style x:Key="CompactSecondaryButton" TargetType="ui:Button" BasedOn="{StaticResource SecondaryButton}">
                <Setter Property="MinHeight" Value="{StaticResource ButtonMinHeightCompact}"/>
                <Setter Property="Padding" Value="{StaticResource ButtonPaddingCompact}"/>
            </Style>

            <Style x:Key="CompactTransparentButton" TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                <Setter Property="FocusVisualStyle" Value="{StaticResource HighVisibilityFocusVisual}"/>
                <Setter Property="Appearance" Value="Transparent"/>
                <Setter Property="MinHeight" Value="{StaticResource ButtonMinHeightCompact}"/>
                <Setter Property="Padding" Value="{StaticResource ButtonPaddingCompact}"/>
                <Setter Property="FontSize" Value="{StaticResource ButtonFontSizeStandard}"/>
                <Setter Property="CornerRadius" Value="{StaticResource ButtonCornerRadius}"/>
            </Style>

            <Style x:Key="CompactSecondaryDropDownButton" TargetType="ui:DropDownButton" BasedOn="{StaticResource {x:Type ui:DropDownButton}}">
                <Setter Property="FocusVisualStyle" Value="{StaticResource HighVisibilityFocusVisual}"/>
                <Setter Property="Appearance" Value="Secondary"/>
                <Setter Property="MinHeight" Value="{StaticResource ButtonMinHeightCompact}"/>
                <Setter Property="Padding" Value="{StaticResource ButtonPaddingCompact}"/>
                <Setter Property="FontSize" Value="{StaticResource ButtonFontSizeStandard}"/>
            </Style>

            <!-- Outlined Button: theme-tinted outlined action -->
            <Style x:Key="OutlinedButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                <Setter Property="FocusVisualStyle" Value="{StaticResource HighVisibilityFocusVisual}"/>
                <Setter Property="MinHeight" Value="{StaticResource ButtonMinHeightStandard}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource ThemeAdaptiveAccentBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource ThemeAdaptiveAccentBrush}"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Padding" Value="{StaticResource ButtonPaddingStandard}"/>
                <Setter Property="FontSize" Value="{StaticResource ButtonFontSizeStandard}"/>
            </Style>

            <!-- Warning Primary Button: orange/amber CTA (e.g. Fix Prerequisites callout) -->
            <Style x:Key="WarningPrimaryButton" TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                <Setter Property="FocusVisualStyle" Value="{StaticResource HighVisibilityFocusVisual}"/>
                <Setter Property="Appearance" Value="Primary"/>
                <Setter Property="Background" Value="{DynamicResource AccentOrangeTextBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource BadgePrimaryForegroundBrush}"/>
                <Setter Property="MinHeight" Value="{StaticResource ButtonMinHeightTouch}"/>
                <Setter Property="Padding" Value="{StaticResource ButtonPaddingLarge}"/>
                <Setter Property="FontSize" Value="{StaticResource ButtonFontSizeStandard}"/>
                <Setter Property="FontWeight" Value="{StaticResource ButtonFontWeightStandard}"/>
                <Setter Property="CornerRadius" Value="{StaticResource ButtonCornerRadius}"/>
            </Style>

            <!-- Destructive Button: outlined red, for delete-with-confirmation -->
            <Style x:Key="DestructiveButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                <Setter Property="FocusVisualStyle" Value="{StaticResource HighVisibilityFocusVisual}"/>
                <Setter Property="MinHeight" Value="{StaticResource ButtonMinHeightStandard}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource ValidationErrorBorderBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource ValidationErrorBorderBrush}"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Padding" Value="{StaticResource ButtonPaddingStandard}"/>
                <Setter Property="FontSize" Value="{StaticResource ButtonFontSizeStandard}"/>
            </Style>

            <!-- Destructive Solid Button: solid red, for immediate destructive actions -->
            <Style x:Key="DestructiveSolidButton" TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                <Setter Property="FocusVisualStyle" Value="{StaticResource HighVisibilityFocusVisual}"/>
                <Setter Property="Appearance" Value="Danger"/>
                <Setter Property="MinHeight" Value="{StaticResource ButtonMinHeightStandard}"/>
                <Setter Property="Background" Value="{DynamicResource ErrorBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource ErrorBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource BadgeTextBrush}"/>
                <Setter Property="Padding" Value="{StaticResource ButtonPaddingStandard}"/>
                <Setter Property="FontSize" Value="{StaticResource ButtonFontSizeStandard}"/>
                <Setter Property="FontWeight" Value="{StaticResource ButtonFontWeightStandard}"/>
                <Setter Property="CornerRadius" Value="{StaticResource ButtonCornerRadius}"/>
            </Style>

            <!-- Icon Button: toolbar icon, transparent, 44x44 touch target -->
            <Style x:Key="IconButton" TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                <Setter Property="FocusVisualStyle" Value="{StaticResource HighVisibilityFocusVisual}"/>
                <Setter Property="Appearance" Value="Transparent"/>
                <Setter Property="MinWidth" Value="{StaticResource ButtonMinHeightTouch}"/>
                <Setter Property="MinHeight" Value="{StaticResource ButtonMinHeightTouch}"/>
                <Setter Property="Padding" Value="{StaticResource ButtonPaddingIcon}"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="CornerRadius" Value="{StaticResource ButtonCornerRadius}"/>
                <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                <Setter Property="RenderTransform">
                    <Setter.Value>
                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Stats Card Button: clickable card surface (Dashboard stats tiles) -->
            <Style x:Key="StatsCardButton" TargetType="Button">
                <Setter Property="Padding" Value="{StaticResource CardPadding}"/>
                <Setter Property="Margin" Value="{StaticResource MarginNormalRight}"/>
                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorDefaultBrush}"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="FocusVisualStyle" Value="{StaticResource HighVisibilityFocusVisual}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="{StaticResource ButtonCornerRadiusLarge}"
                                    Padding="{TemplateBinding Padding}"
                                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                    BorderThickness="1">
                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- Quick Action Button: tile launcher (Dashboard quick actions) -->
            <Style x:Key="QuickActionButton" TargetType="ui:Button" BasedOn="{StaticResource SecondaryButton}">
                <Setter Property="Padding" Value="{StaticResource ButtonPaddingLarge}"/>
                <Setter Property="Margin" Value="{StaticResource MarginNormalBottom}"/>
                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                <Setter Property="BorderBrush" Value="{DynamicResource ThemeAdaptiveAccentBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource ThemeAdaptiveAccentBrush}"/>
            </Style>

            <!-- Favorite Icon Button: animated favorite toggle (variant of IconButton) -->
            <Style x:Key="FavoriteIconButton" TargetType="ui:Button" BasedOn="{StaticResource IconButton}">
                <Setter Property="Width" Value="{StaticResource ButtonMinHeightTouch}"/>
                <Setter Property="Height" Value="{StaticResource ButtonMinHeightTouch}"/>
            </Style>

            <!-- ====================================================== -->
            <!-- Legacy button style aliases (DEPRECATED)               -->
            <!-- Kept for one release so existing view references keep  -->
            <!-- working while migrating to the canonical names above.  -->
            <!-- All inherit canonical tokens through BasedOn.          -->
            <!-- ====================================================== -->
            <Style x:Key="ThemeAdaptiveOutlinedButton" TargetType="Button" BasedOn="{StaticResource OutlinedButton}"/>
            <Style x:Key="DestructiveOutlinedButton"   TargetType="Button" BasedOn="{StaticResource DestructiveButton}"/>
            <Style x:Key="HoverFadeOutlinedButton"     TargetType="Button" BasedOn="{StaticResource OutlinedButton}"/>

            <Style x:Key="ThemeAwareComboBoxToggleButton" TargetType="ToggleButton">
                <Setter Property="Focusable" Value="False"/>
                <Setter Property="ClickMode" Value="Press"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ToggleButton">
                            <Border x:Name="ToggleBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="4"
                                    SnapsToDevicePixels="True">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition/>
                                        <ColumnDefinition Width="32"/>
                                    </Grid.ColumnDefinitions>
                                    <Path Grid.Column="1"
                                          Data="M 0 0 L 4 4 L 8 0 Z"
                                          Width="8"
                                          Height="4"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Fill="{DynamicResource TextFillColorSecondaryBrush}"/>
                                </Grid>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="ToggleBorder" Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}"/>
                                </Trigger>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="{DynamicResource FocusIndicatorBrush}"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="ToggleBorder" Property="Opacity" Value="0.55"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="ThemeAwareComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
                <Setter Property="FocusVisualStyle" Value="{StaticResource HighVisibilityFocusVisual}"/>
                <Setter Property="SnapsToDevicePixels" Value="True"/>
                <Setter Property="MinHeight" Value="36"/>
                <Setter Property="Padding" Value="10,0,34,0"/>
                <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ComboBox">
                            <Grid>
                                <ToggleButton x:Name="ToggleButton"
                                              Style="{StaticResource ThemeAwareComboBoxToggleButton}"
                                              Background="{TemplateBinding Background}"
                                              BorderBrush="{TemplateBinding BorderBrush}"
                                              BorderThickness="{TemplateBinding BorderThickness}"
                                              IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"/>
                                <ContentPresenter x:Name="ContentSite"
                                                  Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                  ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                                  ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                                  IsHitTestVisible="False"
                                                  Margin="{TemplateBinding Padding}"
                                                  HorizontalAlignment="Left"
                                                  VerticalAlignment="Center"
                                                  TextElement.Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                <Popup x:Name="PART_Popup"
                                       AllowsTransparency="True"
                                       Focusable="False"
                                       IsOpen="{TemplateBinding IsDropDownOpen}"
                                       Placement="Bottom"
                                       PopupAnimation="Fade">
                                    <Grid MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                          MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                        <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                                BorderThickness="1"
                                                CornerRadius="4"/>
                                        <ScrollViewer Margin="1"
                                                      SnapsToDevicePixels="True"
                                                      KeyboardNavigation.DirectionalNavigation="Contained">
                                            <ItemsPresenter/>
                                        </ScrollViewer>
                                    </Grid>
                                </Popup>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                    <Setter TargetName="ToggleButton" Property="BorderBrush" Value="{DynamicResource FocusIndicatorBrush}"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.55"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Touch-friendly ComboBox -->
            <Style x:Key="TouchFriendlyComboBox" TargetType="ComboBox" BasedOn="{StaticResource ThemeAwareComboBoxStyle}">
                <Setter Property="FocusVisualStyle" Value="{StaticResource HighVisibilityFocusVisual}"/>
                <Setter Property="MinHeight" Value="44"/>
            </Style>

            <!-- Touch-friendly TextBox -->
            <Style x:Key="TouchFriendlyTextBox" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                <Setter Property="FocusVisualStyle" Value="{StaticResource HighVisibilityFocusVisual}"/>
                <Setter Property="MinHeight" Value="44"/>
                <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}"/>
                <Setter Property="CaretBrush" Value="{DynamicResource ThemeAdaptiveAccentBrush}"/>
            </Style>

            <!-- Theme-aware dense controls -->
            <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                <Setter Property="FocusVisualStyle" Value="{StaticResource HighVisibilityFocusVisual}"/>
                <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}"/>
                <Setter Property="CaretBrush" Value="{DynamicResource ThemeAdaptiveAccentBrush}"/>
                <Setter Property="SelectionBrush" Value="{DynamicResource SystemAccentColorPrimaryBrush}"/>
            </Style>

            <!-- Enhanced DataGrid Row Style with visible hover effect -->
            <Style x:Key="EnhancedDataGridRowStyle" TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource SubtleDataGridLineBrush}"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}"/>
                    </Trigger>
                    <Trigger Property="IsSelected" Value="True">
                        <Setter Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}"/>
                        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
                    </Trigger>
                    <MultiTrigger>
                        <MultiTrigger.Conditions>
                            <Condition Property="IsSelected" Value="True"/>
                            <Condition Property="IsMouseOver" Value="True"/>
                        </MultiTrigger.Conditions>
                        <Setter Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}"/>
                    </MultiTrigger>
                </Style.Triggers>
            </Style>

            <!-- DataGrid Cell Style with improved focus visibility -->
            <Style x:Key="EnhancedDataGridCellStyle" TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
                <Setter Property="FocusVisualStyle" Value="{StaticResource HighVisibilityFocusVisual}"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource SubtleDataGridLineBrush}"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="Padding" Value="8,4"/>
                <Style.Triggers>
                    <Trigger Property="IsSelected" Value="True">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
                    </Trigger>
                    <Trigger Property="IsKeyboardFocused" Value="True">
                        <Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColorSecondaryBrush}"/>
                        <Setter Property="BorderThickness" Value="2"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style TargetType="DataGrid" BasedOn="{StaticResource {x:Type DataGrid}}">
                <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorDefaultBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource SubtleDataGridLineBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="GridLinesVisibility" Value="Horizontal"/>
                <Setter Property="RowBackground" Value="Transparent"/>
                <Setter Property="AlternatingRowBackground" Value="{DynamicResource ControlFillColorDefaultBrush}"/>
                <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource SubtleDataGridLineBrush}"/>
                <Setter Property="VerticalGridLinesBrush" Value="Transparent"/>
                <Setter Property="CellStyle" Value="{StaticResource EnhancedDataGridCellStyle}"/>
            </Style>

            <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorDefaultBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource SubtleDataGridLineBrush}"/>
                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="MinHeight" Value="40"/>
                <Setter Property="Padding" Value="12,8"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="HorizontalContentAlignment" Value="Left"/>
            </Style>

            <!-- Micro-animation Styles for Enhanced UX Feedback -->

            <!-- Favorite Button Style with bounce animation (vanilla Button variant) -->
            <Style x:Key="AnimatedFavoriteButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                <Setter Property="FocusVisualStyle" Value="{StaticResource HighVisibilityFocusVisual}"/>
                <Setter Property="Width" Value="{StaticResource ButtonMinHeightTouch}"/>
                <Setter Property="Height" Value="{StaticResource ButtonMinHeightTouch}"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                <Setter Property="RenderTransform">
                    <Setter.Value>
                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Selection Checkbox Style with scale animation -->
            <Style x:Key="AnimatedSelectionCheckBox" TargetType="CheckBox" BasedOn="{StaticResource {x:Type CheckBox}}">
                <Setter Property="FocusVisualStyle" Value="{StaticResource HighVisibilityFocusVisual}"/>
                <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                <Setter Property="RenderTransform">
                    <Setter.Value>
                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style TargetType="ComboBox" BasedOn="{StaticResource ThemeAwareComboBoxStyle}">
                <Setter Property="FocusVisualStyle" Value="{StaticResource HighVisibilityFocusVisual}"/>
            </Style>

            <Style TargetType="ComboBoxItem">
                <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}"/>
                <Setter Property="FocusVisualStyle" Value="{StaticResource HighVisibilityFocusVisual}"/>
                <Setter Property="Padding" Value="10,6"/>
                <Setter Property="MinHeight" Value="32"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}"/>
                    </Trigger>
                    <Trigger Property="IsSelected" Value="True">
                        <Setter Property="Background" Value="{DynamicResource SystemAccentColorPrimaryBrush}"/>
                        <Setter Property="Foreground" Value="{DynamicResource TextOnAccentFillColorPrimaryBrush}"/>
                    </Trigger>
                    <Trigger Property="IsEnabled" Value="False">
                        <Setter Property="Opacity" Value="0.55"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style TargetType="ContextMenu">
                <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorDefaultBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
            </Style>

            <Style TargetType="MenuItem">
                <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorDefaultBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
                <Setter Property="Padding" Value="10,6"/>
                <Setter Property="MinHeight" Value="34"/>
                <Setter Property="FocusVisualStyle" Value="{StaticResource HighVisibilityFocusVisual}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="MenuItem">
                            <Border x:Name="MenuItemRoot"
                                    Background="{TemplateBinding Background}"
                                    SnapsToDevicePixels="True">
                                <Grid MinHeight="{TemplateBinding MinHeight}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="30"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <!-- Checkmark glyph for IsCheckable items (visible only when IsChecked) -->
                                    <Path x:Name="CheckGlyph"
                                          Grid.Column="0"
                                          Width="14" Height="14"
                                          Stretch="Uniform"
                                          Data="M0,4 L4,8 L11,1"
                                          Stroke="{DynamicResource ThemeAdaptiveAccentBrush}"
                                          StrokeThickness="2"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Visibility="Collapsed"/>
                                    <ContentPresenter x:Name="IconPresenter"
                                                      Grid.Column="0"
                                                      ContentSource="Icon"
                                                      Width="18"
                                                      Height="18"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      TextElement.Foreground="{TemplateBinding Foreground}"/>
                                    <ContentPresenter Grid.Column="1"
                                                      ContentSource="Header"
                                                      Margin="{TemplateBinding Padding}"
                                                      RecognizesAccessKey="True"
                                                      VerticalAlignment="Center"
                                                      TextElement.Foreground="{TemplateBinding Foreground}"/>
                                </Grid>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="Icon" Value="{x:Null}">
                                    <Setter TargetName="IconPresenter" Property="Visibility" Value="Hidden"/>
                                </Trigger>
                                <!-- IsCheckable items: hide icon column, show CheckGlyph when checked -->
                                <Trigger Property="IsCheckable" Value="True">
                                    <Setter TargetName="IconPresenter" Property="Visibility" Value="Collapsed"/>
                                </Trigger>
                                <MultiTrigger>
                                    <MultiTrigger.Conditions>
                                        <Condition Property="IsCheckable" Value="True"/>
                                        <Condition Property="IsChecked" Value="True"/>
                                    </MultiTrigger.Conditions>
                                    <Setter TargetName="CheckGlyph" Property="Visibility" Value="Visible"/>
                                </MultiTrigger>
                                <Trigger Property="IsHighlighted" Value="True">
                                    <Setter TargetName="MenuItemRoot" Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="MenuItemRoot" Property="Opacity" Value="0.55"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style TargetType="Separator">
                <Setter Property="Background" Value="{DynamicResource DividerStrokeColorDefaultBrush}"/>
            </Style>

            <!-- Converters -->
            <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
            <converters:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter"/>
            <converters:InverseBoolConverter x:Key="InverseBoolConverter"/>
            <converters:NullableToVisibilityConverter x:Key="NullableToVisibilityConverter"/>
            <converters:InverseNullableToVisibilityConverter x:Key="InverseNullableToVisibilityConverter"/>
            <converters:SourceStringToVisibilityConverter x:Key="SourceStringToVisibilityConverter"/>
            <converters:BoolToRequiredIconConverter x:Key="BoolToRequiredIconConverter"/>
            <converters:BoolToRequiredColorConverter x:Key="BoolToRequiredColorConverter"/>
            <converters:StatusToIconConverter x:Key="StatusToIconConverter"/>
            <converters:StatusToColorConverter x:Key="StatusToColorConverter"/>
            <converters:ZeroToVisibilityConverter x:Key="ZeroToVisibilityConverter"/>
            <converters:AndZeroToVisibilityConverter x:Key="AndZeroToVisibilityConverter"/>
            <converters:BoolToInstalledIconConverter x:Key="BoolToInstalledIconConverter"/>
            <converters:BoolToInstalledColorConverter x:Key="BoolToInstalledColorConverter"/>
            <converters:BoolToPauseIconConverter x:Key="BoolToPauseIconConverter"/>
            <converters:StatusFilterToStringConverter x:Key="StatusFilterToStringConverter"/>
            <converters:BoolToFavoriteIconConverter x:Key="BoolToFavoriteIconConverter"/>
            <converters:BoolToFavoriteColorConverter x:Key="BoolToFavoriteColorConverter"/>
            <converters:StatusToRowBackgroundConverter x:Key="StatusToRowBackgroundConverter"/>
            <converters:DeploymentResultToStringConverter x:Key="DeploymentResultToStringConverter"/>
            <converters:NonZeroToVisibilityConverter x:Key="NonZeroToVisibilityConverter"/>
            <converters:NonZeroToBoolConverter x:Key="NonZeroToBoolConverter"/>
            <converters:BooleanToCheckIconConverter x:Key="BooleanToCheckIconConverter"/>
            <converters:BooleanToPhaseColorConverter x:Key="BooleanToPhaseColorConverter"/>
            <converters:BooleanToPhaseOpacityConverter x:Key="BooleanToPhaseOpacityConverter"/>
            <converters:ResxKeyConverter x:Key="ResxKeyConverter"/>
            <converters:NullableToBooleanConverter x:Key="NullableToBooleanConverter"/>
            <converters:BoolToAddEditIconConverter x:Key="BoolToAddEditIconConverter"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
