{
  "_meta": {
    "description": "Plugin system configuration for Win11Forge",
    "version": "3.6.8",
    "author": "Julien Bombled",
    "lastUpdated": "2026-01-19"
  },
  "enabled": true,
  "autoLoad": true,
  "allowedHooks": [
    "pre-install",
    "post-install",
    "pre-uninstall",
    "post-uninstall",
    "pre-deployment",
    "post-deployment",
    "on-error"
  ],
  "disabledPlugins": [
    "_template"
  ],
  "pluginTimeout": 30,
  "sandboxing": {
    "enabled": true,
    "notes": "Plugin sandboxing enabled with AST validation and job isolation (v3.7.2)"
  },
  "trustedPublishers": [],
  "pluginRegistry": {
    "enabled": false,
    "url": null,
    "notes": "Online plugin registry is planned for future versions"
  }
}
