      "protonvpn.com",
      "roboform.com",
      "nordvpn.com",
      "wireguard.com",
      "openvpn.net",
      "filezilla-project.org",
      "winscp.net",
      "putty.org",
      "chiark.greenend.org.uk",
      "qbittorrent.org",
      "crystalidea.com",
      "voidtools.com",
      "autohotkey.com",
