      "creality.com"
    ]
  },
  "directDownloads": {
    "description": "Pre-configured direct download URLs for applications not available via package managers",
    "applications": {
      "Discord": {
        "url": "https://discord.com/api/downloads/distributions/app/installers/latest?channel=stable&platform=win&arch=x64",
        "silentArgs": "-s",
        "notes": "Always downloads latest stable version"
      },
      "Steam": {
        "url": "https://cdn.akamai.steamstatic.com/client/installer/SteamSetup.exe",
        "silentArgs": "/S",
        "sha256": "SKIP_VALIDATION",
        "notes": "SHA256 skipped - Steam installer auto-updates frequently. Download is from trusted Valve CDN (akamai.steamstatic.com) over HTTPS."
      },
      "BattleNet": {
        "url": "https://downloader.battle.net/download/getInstallerForGame?os=win&gameProgram=BATTLENET_APP&version=Live",
        "silentArgs": "--lang=enUS --installpath=\"%ProgramFiles(x86)%\\Battle.net\"",
        "notes": "Blizzard Battle.net launcher - uses %ProgramFiles(x86)% for portability"
      },
      "VLC": {
        "url": "https://get.videolan.org/vlc/last/win64/",
        "pattern": "vlc-*-win64.exe",
        "silentArgs": "/S",
        "notes": "VideoLAN VLC media player - URL points to directory, pattern matches latest"
      },
      "Firefox": {
        "url": "https://download.mozilla.org/?product=firefox-latest&os=win64&lang=en-US",
        "silentArgs": "-ms",
        "notes": "Always downloads latest stable Firefox"
      },
      "Chrome": {
        "url": "https://dl.google.com/chrome/install/GoogleChromeStandaloneEnterprise64.msi",
        "silentArgs": "/quiet /norestart",
        "notes": "Google Chrome enterprise MSI installer (standalone 64-bit)"
      },
      "Roboform": {
        "url": "https://www.roboform.com/dist/RoboForm-Setup.exe",
        "silentArgs": "/VERYSILENT /NORESTART",
        "notes": "Roboform password manager installer"
      }
    }
  },
  "packageManagers": {
    "winget": {
      "source": "winget",
      "repositoryUrl": "https://github.com/microsoft/winget-pkgs",
      "searchUrl": "https://winget.run/"
    },
    "chocolatey": {
      "source": "chocolatey",
      "repositoryUrl": "https://community.chocolatey.org/packages",
      "searchUrl": "https://community.chocolatey.org/packages"
    },
    "microsoftStore": {
      "source": "msstore",
      "notes": "Use winget with --source msstore for Store apps"
    }
  },
  "apiEndpoints": {
    "description": "External API base URLs used by the framework",
    "gitHubApi": {
      "baseUrl": "https://api.github.com",
      "description": "GitHub REST API for release checks and update downloads",
      "notes": "Used by UpdateManager for release queries"
    }
  },
  "cache": {
    "description": "Cache settings for package manager operations",
    "winget": {
      "listTTLMinutes": 30,
      "searchTTLMinutes": 60,
      "maxEntries": 500,
      "enabled": true,
      "persistToDisk": true
    }
  }
}
