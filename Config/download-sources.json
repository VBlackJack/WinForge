      "discordapp.com",
      "steampowered.com",
      "steamstatic.com",
      "battle.net",
      "blizzard.com",
      "videolan.org",
      "mozilla.org",
      "mozilla.net",
      "google.com",
      "dl.google.com",
      "sourceforge.net",
      "sf.net",
      "7-zip.org",
      "rarlab.com",
      "notepad-plus-plus.org",
      "sublimetext.com",
      "jetbrains.com",
      "visualstudio.com",
      "visualstudio.microsoft.com",
      "code.visualstudio.com",
      "python.org",
      "nodejs.org",
      "adoptium.net",
      "oracle.com",
      "docker.com",
      "git-scm.com",
      "tortoisegit.org",
      "tortoisesvn.net",
      "gimp.org",
      "inkscape.org",
      "libreoffice.org",
      "documentfoundation.org",
      "getpaint.net",
      "faststone.org",
      "irfanview.com",
      "spotify.com",
