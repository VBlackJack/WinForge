{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "Description": "Configuration for applications to disable from Windows startup",
  "Version": "1.0.0",
  "LastUpdated": "2025-10-06",
  "DisabledApplications": [
    {
      "Name": "Epic Games Launcher",
      "Reason": "Disabled via Startup Manager",
      "Enabled": true
    },
    {
      "Name": "Battle.net",
      "Reason": "Disabled via Startup Manager",
      "Enabled": true
    },
    {
      "Name": "Discord",
      "Reason": "Disabled via Startup Manager",
      "Enabled": true
    },
    {
      "Name": "Steam",
      "Reason": "Disabled via Startup Manager",
