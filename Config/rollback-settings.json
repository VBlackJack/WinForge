{
  "_meta": {
    "description": "Rollback system configuration for Win11Forge",
    "version": "3.6.8",
    "author": "Julien Bombled",
    "lastUpdated": "2026-01-19"
  },
  "autoRollbackEnabled": true,
  "autoRollbackThreshold": 3,
  "requireConfirmation": true,
  "confirmationTimeoutSeconds": 30,
  "criticalFailurePatterns": [
    "\\bsystem32\\b",
    "\\bregistry\\s+corruption\\b",
    "\\bboot\\s*(failure|error|corrupt)\\b",
    "\\bdriver\\s*(failure|error|missing|corrupt)\\b",
    "\\bkernel\\s*(panic|error|fault)\\b",
    "\\baccess\\s+denied\\b.*\\bsystem\\b",
    "\\bpermission\\s+denied\\b.*\\bwindows\\b",
    "\\bbsod\\b",
    "\\bblue\\s+screen\\b"
  ],
  "rollbackMethods": {
    "supported": [
      "Winget",
      "Chocolatey",
      "Choco",
      "StoreApp",
      "MsStore"
    ],
    "unsupported": [
      "DirectDownload",
      "Custom",
      "WindowsFeature",
      "WindowsCapability",
      "Manual"
    ]
  },
  "reporting": {
    "autoExportOnFailure": false,
    "reportDirectory": "%LOCALAPPDATA%\\Win11Forge\\Reports",
    "defaultFormat": "Json"
  }
}
