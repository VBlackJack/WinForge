Logs/
*.log

# Cache files
.url_cache.json
*.cache

# .NET SDK home (NuGet, temp packages)
.dotnet-home-audit/
.dotnet-cli/

# Local throwaway launch helper
launch-win11forge.ps1

# Windows shortcuts
*.lnk

# Temporary files
*.tmp
*.temp
~$*

# PowerShell temp files
*.ps1~
*.psm1~

# Test output
Test-*-Output.txt
*-TestResults.xml
Tests/Results/TestResults_*.NUnitXml
Tests/Results/TestResults_*.JUnitXml
TestResults/
**/TestResults/
Tests/Results/Coverage_*.xml

# Generated dashboard data
Assets/Dashboard/telemetry-data.json

# Archive (old versions, root-level only)
/Archive/

# User-specific profiles (keep templates)
Profiles/Custom*.json
Profiles/*-Backup*.json

# IDE
.vscode/
.idea/
*.code-workspace

# Windows
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# macOS
.DS_Store
.AppleDouble
.LSOverride

