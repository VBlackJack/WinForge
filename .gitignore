# Win11Forge - Git Ignore

# Claude Code (local settings)
.claude/

# Distribution builds
Dist/

# Logs
Logs/
*.log

# Cache files
.url_cache.json
*.cache

# Windows shortcuts
*.lnk

# Temporary files
*.tmp
*.temp
~$*

# PowerShell temp files
*.ps1~
*.psm1~

# Test output
Test-*-Output.txt
*-TestResults.xml
Tests/Results/TestResults_*.NUnitXml
Tests/Results/TestResults_*.JUnitXml

# Generated dashboard data
Assets/Dashboard/telemetry-data.json

# Archive (old versions)
Archive/

# User-specific profiles (keep templates)
Profiles/Custom*.json
Profiles/*-Backup*.json

# IDE
.vscode/
.idea/
*.code-workspace

# Windows
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Downloaded installers (temp)
*.exe
*.msi

# Credentials (if any)
*.credentials
*.secrets
*apikey*

# .NET build output
bin/
obj/
*.dll
*.pdb

# Backups
Backups/

# Release builds
Release/

# Audit reports (generated, not source)
AUDIT-REPORT*.md

# Reports output
Reports/

# Audit process snapshots
Tools/AuditReports/*.json

# Claude Code project instructions
CLAUDE.md
