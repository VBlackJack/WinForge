root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{json,yml,yaml,xaml,csproj,props,resx}]
indent_size = 2

[*.{bat,cmd}]
end_of_line = crlf

[*.md]
trim_trailing_whitespace = false

[*.cs]
# Project standard: explicit types, file-scoped namespaces, and using directives
# outside namespaces are build-gated through EnforceCodeStyleInBuild plus
# TreatWarningsAsErrors. Keep matching dotnet_diagnostic severities explicit.
csharp_style_var_for_built_in_types = false:warning
csharp_style_var_when_type_is_apparent = false:warning
csharp_style_var_elsewhere = false:warning
csharp_style_namespace_declarations = file_scoped:warning
dotnet_sort_system_directives_first = true
csharp_using_directive_placement = outside_namespace:warning
dotnet_diagnostic.IDE0008.severity = warning
dotnet_diagnostic.IDE0065.severity = warning
dotnet_diagnostic.IDE0161.severity = warning
